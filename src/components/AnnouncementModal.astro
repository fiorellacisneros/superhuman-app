---
import { renderMarkdown } from '../lib/markdown';
import type { AnnouncementRecord, AnnouncementButton } from '../lib/announcements';

interface Props {
  announcements: AnnouncementRecord[];
}

const { announcements } = Astro.props;

const primaryActionClass =
  'inline-flex shrink-0 items-center justify-center gap-2 rounded-full border-0 bg-neutral-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-neutral-800 active:scale-[0.98]';

function renderPanels(list: AnnouncementRecord[]) {
  return list.map((a) => {
    const bodyHtml =
      a.content_mode === 'text' && a.body_text?.trim() ? renderMarkdown(a.body_text) : '';
    const bullets =
      a.content_mode === 'bullets'
        ? a.body_items.map((it) => ({
            icon: it.icon,
            html: renderMarkdown(it.text),
          }))
        : [];
    const btn = a.buttons[0];
    return { a, bodyHtml, bullets, btn };
  });
}

const panels = renderPanels(announcements);
---

{
  panels.length > 0 && (
    <div
      id="announcement-modal-root"
      class="fixed inset-0 z-[190] hidden flex-col"
      aria-hidden="true"
    >
      <button
        type="button"
        id="announcement-modal-backdrop"
        class="absolute inset-0 bg-black/55 backdrop-blur-[2px] transition-opacity"
        aria-label="Cerrar aviso"
      />
      <div class="relative flex min-h-0 flex-1 items-center justify-center p-4 sm:p-6">
        <div
          class="announcement-modal-inner relative w-full max-w-[420px] overflow-hidden rounded-[28px] bg-white shadow-[0_24px_80px_rgba(0,0,0,0.22)] ring-1 ring-black/5"
          role="dialog"
          aria-modal="true"
          aria-labelledby="ann-modal-live-title"
        >
          <button
            type="button"
            class="ann-modal-dismiss-x absolute right-3 top-3 z-20 flex h-9 w-9 items-center justify-center rounded-full text-neutral-400 transition hover:bg-neutral-100 hover:text-neutral-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-900"
            aria-label="Cerrar"
          >
            <i class="bi bi-x-lg text-lg leading-none" aria-hidden="true" />
          </button>

          {panels.map(({ a, bodyHtml, bullets, btn }, idx) => (
            <div
              class:list={['ann-modal-panel px-0 pb-0 pt-0', { hidden: idx > 0 }]}
              data-ann-panel={a.id}
              data-dismiss-behavior={a.dismiss_behavior}
              data-ann-modal-panel
            >
              <div class="relative min-h-[148px] overflow-hidden rounded-t-[28px] bg-gradient-to-b from-neutral-100 via-neutral-100/95 to-neutral-200/70 px-8 pb-6 pt-10">
                <div class="pointer-events-none absolute inset-0 opacity-[0.07]" aria-hidden="true">
                  <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-neutral-900" />
                  <div class="absolute -bottom-10 left-4 h-24 w-24 rounded-full bg-neutral-900" />
                </div>
                {a.image_url?.trim() ? (
                  <div class="relative flex justify-center">
                    <img
                      src={a.image_url.trim()}
                      alt=""
                      class="max-h-36 w-auto max-w-[220px] object-contain drop-shadow-md"
                      width="220"
                      height="160"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ) : (
                  <div class="relative flex justify-center text-neutral-400">
                    <span
                      class="flex h-20 w-20 items-center justify-center rounded-2xl bg-white/80 shadow-sm ring-1 ring-neutral-200/80"
                      aria-hidden="true"
                    >
                      <i class="bi bi-megaphone text-3xl text-neutral-500" />
                    </span>
                  </div>
                )}
              </div>

              <div class="px-6 pb-6 pt-1 sm:px-8">
                {a.badge_text?.trim() && (
                  <p class="mb-3 text-center">
                    <span class="inline-flex rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-700">
                      {a.badge_text.trim()}
                    </span>
                  </p>
                )}
                {(a.title?.trim() || a.subtitle?.trim()) && (
                  <div class="space-y-2 text-center">
                    {a.title?.trim() && (
                      <h2
                        id={idx === 0 ? 'ann-modal-live-title' : undefined}
                        class="font-manrope text-xl font-bold leading-snug tracking-tight text-neutral-950 sm:text-2xl"
                      >
                        {a.title.trim()}
                      </h2>
                    )}
                    {a.subtitle?.trim() && (
                      <p class="text-sm leading-relaxed text-neutral-500 sm:text-base">{a.subtitle.trim()}</p>
                    )}
                  </div>
                )}

                {a.content_mode === 'text' && bodyHtml && (
                  <div
                    class="ann-modal-body mt-5 text-left text-sm leading-relaxed text-neutral-600 [&_a]:font-medium [&_a]:text-[#012EDC] [&_a]:underline [&_strong]:text-neutral-900 [&_ul]:mt-2 [&_ul]:list-disc [&_ul]:pl-5"
                    set:html={bodyHtml}
                  />
                )}

                {a.content_mode === 'bullets' && bullets.length > 0 && (
                  <div class="mt-5 space-y-3 text-left">
                    <p class="text-center text-xs font-semibold uppercase tracking-wide text-neutral-400">
                      {a.body_section_label?.trim() || 'Cómo funciona'}
                    </p>
                    <ul class="space-y-2.5">
                      {bullets.map((row) => (
                        <li class="flex gap-3 rounded-2xl bg-neutral-50 px-3 py-3 ring-1 ring-neutral-100/80">
                          <span
                            class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-white"
                            aria-hidden="true"
                          >
                            <i class={`bi ${row.icon} text-sm`} />
                          </span>
                          <div
                            class="min-w-0 flex-1 text-sm leading-relaxed text-neutral-600 [&_a]:font-medium [&_a]:text-[#012EDC] [&_a]:underline [&_strong]:text-neutral-900"
                            set:html={row.html}
                          />
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class="mt-8 flex flex-col-reverse gap-3 border-t border-neutral-100 pt-5 sm:flex-row sm:items-center sm:justify-between">
                  <button
                    type="button"
                    class="ann-modal-dismiss-secondary w-full rounded-full bg-neutral-100 px-5 py-2.5 text-center text-sm font-semibold text-neutral-900 transition hover:bg-neutral-200 sm:w-auto"
                  >
                    Ahora no
                  </button>
                  <div class="flex w-full flex-1 justify-end sm:w-auto">
                    {btn ? (
                      btn.type === 'link' ? (
                        <a
                          href={btn.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class:list={['ann-modal-primary-action w-full justify-center sm:w-auto', primaryActionClass]}
                        >
                          <i class="bi bi-stars text-base opacity-90" aria-hidden="true" />
                          {btn.label}
                        </a>
                      ) : (
                        <button
                          type="button"
                          class:list={[
                            'ann-modal-primary-action announcement-copy-btn w-full justify-center sm:w-auto',
                            primaryActionClass,
                          ]}
                          data-announcement-copy={btn.url}
                        >
                          <i class="bi bi-stars text-base opacity-90" aria-hidden="true" />
                          <span class="announcement-copy-label">{btn.label}</span>
                        </button>
                      )
                    ) : (
                      <button
                        type="button"
                        class:list={['ann-modal-dismiss-primary w-full justify-center sm:w-auto', primaryActionClass]}
                      >
                        <i class="bi bi-stars text-base opacity-90" aria-hidden="true" />
                        Entendido
                      </button>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}

<script is:inline>
  (function () {
    var root = document.getElementById('announcement-modal-root');
    if (!root) return;

    var PERM = 'superhuman_ann_dismiss_';
    var SESS = 'superhuman_ann_sess_dismiss_';

    function isDismissed(id, mode) {
      try {
        if (mode === 'remember_dismissal') return localStorage.getItem(PERM + id) === '1';
        return sessionStorage.getItem(SESS + id) === '1';
      } catch (e) {
        return false;
      }
    }

    function markDismissed(id, mode) {
      try {
        if (mode === 'remember_dismissal') localStorage.setItem(PERM + id, '1');
        else sessionStorage.setItem(SESS + id, '1');
      } catch (e) {}
    }

    function allPanels() {
      return Array.prototype.slice.call(root.querySelectorAll('[data-ann-modal-panel]'));
    }

    function hideAll() {
      allPanels().forEach(function (p) {
        p.classList.add('hidden');
      });
    }

    function syncBodyScrollAnn() {
      var open = !root.classList.contains('hidden');
      if (open) document.body.style.overflow = 'hidden';
      else {
        var badge = document.getElementById('badge-guide-modal');
        var points = document.getElementById('points-breakdown-modal');
        var other =
          (badge && !badge.classList.contains('hidden')) || (points && !points.classList.contains('hidden'));
        if (!other) document.body.style.overflow = '';
      }
    }

    function showModal() {
      root.classList.remove('hidden');
      root.classList.add('flex');
      root.setAttribute('aria-hidden', 'false');
      syncBodyScrollAnn();
    }

    function hideModal() {
      root.classList.add('hidden');
      root.classList.remove('flex');
      root.setAttribute('aria-hidden', 'true');
      syncBodyScrollAnn();
    }

    function showNext() {
      var panels = allPanels();
      for (var i = 0; i < panels.length; i++) {
        var p = panels[i];
        var id = p.getAttribute('data-ann-panel');
        var mode = p.getAttribute('data-dismiss-behavior') || 'always_show';
        if (!id || isDismissed(id, mode)) continue;
        hideAll();
        p.classList.remove('hidden');
        panels.forEach(function (el) {
          el.querySelectorAll('h2').forEach(function (h) {
            if (h.id === 'ann-modal-live-title') h.removeAttribute('id');
          });
        });
        var title = p.querySelector('h2');
        if (title) title.id = 'ann-modal-live-title';
        showModal();
        return;
      }
      hideAll();
      hideModal();
    }

    function dismissVisible() {
      var visible = root.querySelector('[data-ann-modal-panel]:not(.hidden)');
      if (!visible) return;
      var id = visible.getAttribute('data-ann-panel');
      var mode = visible.getAttribute('data-dismiss-behavior') || 'always_show';
      if (id) markDismissed(id, mode);
      showNext();
    }

    document.addEventListener('DOMContentLoaded', function () {
      showNext();
    });

    document.getElementById('announcement-modal-backdrop')?.addEventListener('click', function () {
      dismissVisible();
    });

    root.querySelector('.ann-modal-dismiss-x')?.addEventListener('click', function () {
      dismissVisible();
    });

    root.querySelectorAll('.ann-modal-dismiss-secondary').forEach(function (b) {
      b.addEventListener('click', function () {
        dismissVisible();
      });
    });

    root.querySelectorAll('.ann-modal-dismiss-primary').forEach(function (b) {
      b.addEventListener('click', function () {
        dismissVisible();
      });
    });

    root.querySelectorAll('a.ann-modal-primary-action').forEach(function (a) {
      a.addEventListener('click', function () {
        dismissVisible();
      });
    });
  })();
</script>
