---
interface Props {
  label: string;
  detail?: string;
  pts: number;
}
const { label, detail, pts } = Astro.props;
---

<li class="flex items-start justify-between gap-3 text-sm">
  <div class="min-w-0 flex-1">
    <span class="text-muted">{label}</span>
    {detail && <p class="mt-0.5 text-xs text-muted/85">{detail}</p>}
  </div>
  <span class="shrink-0 font-medium text-lime">+{pts}</span>
</li>
