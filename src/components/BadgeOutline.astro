  </div>
  {variant === 'earned' && count != null && count > 1 && (
    <span
      class="absolute -right-0.5 -top-0.5 z-40 flex h-5 min-w-5 items-center justify-center rounded-full bg-gray px-1 text-[11px] font-semibold text-white"
