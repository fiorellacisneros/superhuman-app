---
/**
 * Contorno punteado para insignias. El slot (icono) va centrado dentro.
 * variant: 'earned' = amarillo, 'unearned' = gris claro, 'locked' = gris oscuro sin icono
 */
interface Props {
  variant: 'earned' | 'unearned' | 'locked';
  count?: number; // veces obtenida (solo se muestra si > 1)
  id?: string; // para clipPath único cuando hay varias instancias
  class?: string;
}

const { variant, count, id: idProp, class: className = '' } = Astro.props;
const clipId = idProp ? `clip0_${idProp.replace(/[^a-z0-9-]/gi, '_')}` : `clip0_badge_${Math.random().toString(36).slice(2)}`;

// SVG contorno punteado: activo = blue 012EDC, desactivado = 404040
const outlineColor = variant === 'earned' ? '#012EDC' : variant === 'unearned' ? '#404040' : '#404040';
// Fondo del círculo (detrás del icono): activo = amarillo FFBE00, desactivado = 262626
const bgColor = variant === 'earned' ? '#FFBE00' : '#262626';
---

<!-- Fondo 64px (44 + 10+10): el bg engloba todo; 10px de padding entre el borde del bg y el SVG -->
<div class={`relative inline-flex h-16 w-16 shrink-0 items-center justify-center rounded-full ${className}`} style={`background-color: ${variant === 'locked' ? 'transparent' : bgColor}`}>
  <!-- Área interior: SVG + icono, 10px hacia dentro del fondo; tamaño fijo para centrado correcto -->
  <div class="absolute inset-[10px] size-[44px] overflow-hidden">
  <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" class="absolute left-0 top-0 z-10 h-[44px] w-[44px] shrink-0 pointer-events-none" aria-hidden="true">
