  </svg>
  {variant !== 'locked' && (
  <div class="absolute left-1/2 top-1/2 z-20 flex h-6 w-6 shrink-0 -translate-x-1/2 -translate-y-1/2 items-center justify-center [&_svg]:h-5 [&_svg]:w-5">
    <slot />
