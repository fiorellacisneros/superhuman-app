---
interface Props {
  icon: string;
  class?: string;
}

const { icon, class: className = '' } = Astro.props as Props;
---

{icon === 'first_submission' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M7 9V5a2 2 0 012-2h10a2 2 0 012 2v14a2 2 0 01-2 2H9a2 2 0 01-2-2v-4" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 12H3m0 0l3-3m-3 3l3 3" />
  </svg>
)}
{icon === 'on_time' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="8" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l2.5 1.5" />
  </svg>
)}
{icon === 'early_bird' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z" />
  </svg>
)}
{icon === 'streak_3' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M13.5 2.5c.2 2.2-.8 3.6-2.2 5-1.5 1.5-2.8 3-2.8 5.1A5.5 5.5 0 0014 18a5 5 0 004.9-5c0-2.8-1.8-5-5.4-10.5zM7 15a4.5 4.5 0 104.5 4.5A4.5 4.5 0 007 15z" />
  </svg>
)}
{icon === 'attendance_streak_3' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
    <rect x="3" y="5" width="18" height="16" rx="2" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 3v4m8-4v4M7 12l3 3 6-6" />
  </svg>
)}
{icon === 'first_attendance' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s6-5.6 6-10a6 6 0 10-12 0c0 4.4 6 10 6 10z" />
    <circle cx="12" cy="11" r="2.5" />
  </svg>
)}
{icon === 'module_complete' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M14 3l7 7-3 3-7-7V3zM2 22l7-2 9-9-5-5-9 9-2 7z" />
  </svg>
)}
{icon === 'night_owl' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M14.5 2.2A9.8 9.8 0 1021.8 14a8 8 0 01-7.3-11.8z" />
  </svg>
)}
{icon === 'course_complete' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M12 2l2.8 5.7 6.2.9-4.5 4.4 1.1 6.2L12 16.3 6.4 19.2l1.1-6.2L3 8.6l6.2-.9L12 2z" />
  </svg>
)}
{icon === 'manual' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M12 2l2.8 5.7 6.2.9-4.5 4.4 1.1 6.2L12 16.3 6.4 19.2l1.1-6.2L3 8.6l6.2-.9L12 2z" />
  </svg>
)}
