---
import '../styles/global.css';
import { getSupabaseServiceRoleClient } from '../lib/supabase';
import { avatarImagePath } from '../lib/avatars';
import { SignOutButton } from '@clerk/astro/components';
import DeleteConfirmModal from '../components/DeleteConfirmModal.astro';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase
  .from('users')
  .select('display_name, avatar_id')
  .eq('id', userId)
  .maybeSingle();

const displayName = userRow?.display_name ?? 'Admin';
const avatarId = userRow?.avatar_id ?? null;
const avatarSrc = avatarImagePath(avatarId);
const initialLetter = (displayName || 'A').charAt(0).toUpperCase();

const currentPath = Astro.url.pathname;
const adminNav = [
  { label: 'Dashboard', href: '/dashboard', icon: 'bi-grid-1x2-fill' },
  { label: 'Cursos', href: '/admin/courses', icon: 'bi-journal-richtext' },
  { label: 'Retos', href: '/admin/challenges', icon: 'bi-lightning-charge-fill', showActiveCount: true },
  { label: 'Asistencia', href: '/admin/attendance', icon: 'bi-calendar2-check-fill' },
  { label: 'Kahoot', href: '/admin/kahoot', icon: 'bi-trophy-fill' },
  { label: 'Alumnos', href: '/admin/students', icon: 'bi-people-fill' },
  { label: 'Submissions', href: '/admin/submissions', icon: 'bi-inbox-fill' },
] as const;
const { count: activeChallengesCount } = await supabase
  .from('challenges')
  .select('*', { count: 'exact', head: true })
  .eq('is_active', true);
const activeRetosCount = activeChallengesCount ?? 0;

function isActive(href: string): boolean {
  if (href === '/dashboard') return currentPath === '/dashboard';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<html lang="es" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <slot name="head" />
    <title>Superhuman School — Admin</title>
  </head>
  <body class="min-h-screen bg-background text-white antialiased">
    <div class="min-h-screen">
      <header class="border-b border-transparent bg-surface px-4 py-4 sm:px-6">
        <div class="relative mx-auto flex max-w-5xl items-center justify-between gap-3">
          <a href="/dashboard" class="shrink-0">
            <img src="/logo.png" alt="Superhuman School" class="h-5 w-auto" />
          </a>

          <div class="hidden min-w-0 flex-1 overflow-x-auto md:flex md:flex-none md:overflow-visible">
            <nav class="flex w-max items-center gap-1 rounded-xl border border-transparent/80 bg-surface-2/40 p-1 sm:w-auto" aria-label="Admin">
              {adminNav.map((item) => {
                const active = isActive(item.href);
                return (
                  <a
                    href={item.href}
                    class={`group relative inline-flex shrink-0 items-center gap-1.5 rounded-lg px-2.5 py-2 text-xs font-medium transition-all sm:gap-2 sm:px-3.5 sm:text-sm ${
                      active
                        ? 'bg-surface text-white shadow-[inset_0_0_0_1px_rgba(163,230,53,0.25)]'
                        : 'text-muted hover:bg-surface-2/80 hover:text-white'
                    }`}
                  >
                    <i
                      class={`bi ${item.icon} text-[13px] leading-none transition-colors ${
                        active ? 'text-lime' : 'text-muted group-hover:text-white/90'
                      }`}
                      aria-hidden="true"
                    />
                    {item.label}
                    {item.showActiveCount && activeRetosCount > 0 && (
                      <span class="inline-flex min-w-5 items-center justify-center rounded-full bg-lime/20 px-1.5 py-0.5 text-[10px] font-semibold text-lime">
                        {activeRetosCount}
                      </span>
                    )}
                    <span
                      class={`absolute bottom-0 left-2 right-2 h-0.5 origin-center rounded-full transition-all duration-200 ${
                        active
                          ? 'bg-lime opacity-100 scale-x-100'
                          : 'bg-white/35 opacity-0 scale-x-75 group-hover:opacity-100 group-hover:scale-x-100'
                      }`}
                      aria-hidden="true"
                    />
                  </a>
                );
              })}
            </nav>
          </div>

          <div class="flex shrink-0 items-center gap-2">
            <div class="relative" id="user-menu">
            <button
              type="button"
              id="user-menu-button"
              aria-expanded="false"
              aria-haspopup="true"
              class="flex cursor-pointer items-center gap-2 rounded-lg border border-transparent py-1.5 pl-1 pr-2 transition hover:border-transparent hover:bg-surface-2"
            >
              {avatarSrc ? (
                <img
                  src={avatarSrc}
                  alt=""
                  class="h-8 w-8 shrink-0 rounded-full object-cover ring-1 ring-border"
                  width="32"
                  height="32"
                />
              ) : (
                <div
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-lime text-sm font-semibold text-background ring-1 ring-border"
                  aria-hidden="true"
                >
                  {initialLetter}
                </div>
              )}
              <span class="hidden max-w-[120px] truncate text-sm text-white sm:inline">{displayName}</span>
              <svg id="chevron-icon" class="h-4 w-4 shrink-0 text-muted transition-transform duration-200 ease-out" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M7 10l5 5 5-5z" />
              </svg>
            </button>
            <div
              id="user-menu-dropdown"
              class="pointer-events-none absolute right-0 top-full z-50 mt-1 min-w-[180px] rounded-xl border border-transparent bg-surface-2 py-1 shadow-lg opacity-0 transition-[opacity,transform] duration-200 ease-out"
              style="transform: translateY(-8px);"
              role="menu"
              aria-hidden="true"
            >
              <div class="flex items-center gap-2 border-b border-transparent px-4 py-2 text-xs font-medium text-lime/90" role="none">
                <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 16L3 5l5.5 2.5L12 4l3.5 3.5L21 5l-2 11H5z" />
                </svg>
                Admin
              </div>
              <a
                href="/profile"
                class="mx-1 block rounded-lg px-3 py-2.5 text-sm text-white transition hover:bg-surface hover:text-lime"
                role="menuitem"
              >
                Ver perfil
              </a>
              <div class="mt-1 border-t border-transparent pt-1">
                <SignOutButton
                  redirectUrl="/"
                  class="mx-1 w-[calc(100%-0.5rem)] rounded-lg px-3 py-2.5 text-left text-sm text-muted transition hover:bg-surface hover:text-lime"
                  role="menuitem"
                >
                  Cerrar sesión
                </SignOutButton>
              </div>
            </div>
          </div>
        </div>
      </header>

      <div
        id="user-menu-backdrop"
        class="fixed inset-0 z-[38] hidden cursor-default bg-black/50"
        aria-hidden="true"
      ></div>

      <main id="admin-layout-main" class="mx-auto max-w-5xl px-4 pb-36 pt-8 sm:px-6 md:pb-8">
        <slot />
      </main>
    </div>
    <nav
      class="pointer-events-none fixed inset-x-0 z-[100] md:hidden overflow-visible"
      style="bottom: calc(env(safe-area-inset-bottom) + 0.5rem);"
      aria-label="Navegación inferior admin"
    >
      <div class="mx-auto w-fit max-w-[min(92vw,360px)] overflow-visible">
        <div class="pointer-events-auto flex overflow-visible rounded-full border border-transparent/80 bg-surface/95 px-2 py-3 shadow-[0_8px_24px_rgba(0,0,0,0.4)] backdrop-blur">
          <div class="flex min-w-max items-end justify-center gap-1">
        {adminNav.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              aria-label={item.label}
              title={item.label}
              class={`group relative flex min-w-[3rem] shrink-0 flex-col items-center justify-center gap-0.5 py-1 transition ${
                active ? 'text-lime' : 'text-muted hover:text-white'
              }`}
            >
              {active && (
                <span
                  class="pointer-events-none absolute -top-3 z-0 h-8 w-[4.2rem] rounded-b-[999px] bg-background shadow-[inset_0_-7px_12px_rgba(0,0,0,0.34)]"
                  aria-hidden="true"
                />
              )}
              {active ? (
                <span class="relative z-10 -mt-7 inline-flex h-12 w-12 items-center justify-center rounded-full border border-lime/70 bg-lime ring-[3px] ring-background shadow-[0_14px_26px_rgba(198,241,53,0.30),0_8px_20px_rgba(0,0,0,0.35),inset_0_1px_0_rgba(255,255,255,0.26)]">
                  <i class={`bi ${item.icon} text-[17px] leading-none text-background`} aria-hidden="true" />
                </span>
              ) : (
                <i class={`bi ${item.icon} text-[17px] leading-none text-muted group-hover:text-white/90`} aria-hidden="true" />
              )}
              <span class={`max-w-full truncate text-[10px] font-medium leading-tight ${active ? 'text-lime' : 'text-muted group-hover:text-white/90'}`}>
                {item.label}
              </span>
              {item.showActiveCount && activeRetosCount > 0 && (
                <span class="absolute -right-0.5 top-0 inline-flex min-w-4 items-center justify-center rounded-full bg-lime/20 px-1 py-0.5 text-[9px] font-semibold text-lime">
                  {activeRetosCount}
                </span>
              )}
            </a>
          );
        })}
          </div>
        </div>
      </div>
    </nav>
    <div id="toast-root" class="pointer-events-none fixed right-4 top-4 z-[120] flex w-[min(92vw,360px)] flex-col gap-2"></div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const menu = document.getElementById('user-menu');
        const button = document.getElementById('user-menu-button');
        const dropdown = document.getElementById('user-menu-dropdown');
        const chevron = document.getElementById('chevron-icon');
        const backdrop = document.getElementById('user-menu-backdrop');
        if (!menu || !button || !dropdown || !chevron) return;
        function open() {
          dropdown.classList.remove('pointer-events-none', 'opacity-0');
          dropdown.style.transform = 'translateY(0)';
          dropdown.setAttribute('aria-hidden', 'false');
          chevron.classList.add('rotate-180');
          button.setAttribute('aria-expanded', 'true');
          if (backdrop) backdrop.classList.remove('hidden');
        }
        function close() {
          dropdown.classList.add('pointer-events-none', 'opacity-0');
          dropdown.style.transform = 'translateY(-8px)';
          dropdown.setAttribute('aria-hidden', 'true');
          chevron.classList.remove('rotate-180');
          button.setAttribute('aria-expanded', 'false');
          if (backdrop) backdrop.classList.add('hidden');
        }
        function isOpen() {
          return button.getAttribute('aria-expanded') === 'true';
        }
        close();
        button.addEventListener('click', (e) => {
          e.stopPropagation();
          if (isOpen()) close();
          else open();
        });
        backdrop?.addEventListener('click', () => {
          if (isOpen()) close();
        });
        document.addEventListener('click', (e) => {
          if (!isOpen()) return;
          const t = e.target;
          if (!(t instanceof Node)) return;
          if (menu.contains(t)) return;
          if (backdrop && (t === backdrop || backdrop.contains(t))) return;
          requestAnimationFrame(close);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen()) {
            e.preventDefault();
            close();
          }
        });
        document.getElementById('admin-layout-main')?.addEventListener(
          'scroll',
          () => {
            if (isOpen()) close();
          },
          { passive: true },
        );
      });

      document.addEventListener('DOMContentLoaded', () => {
        const toastRoot = document.getElementById('toast-root');
        if (!toastRoot) return;
        const params = new URLSearchParams(window.location.search);
        const message = params.get('toast');
        const type = params.get('toast_type') || 'success';
        if (!message) return;

        const styles = {
          success: 'border-lime/40 bg-surface text-white',
          error: 'border-red-500/40 bg-surface text-white',
          info: 'border-amber-400/40 bg-surface text-white',
        };
        const icons = {
          success: 'bi-check-circle-fill text-lime',
          error: 'bi-x-circle-fill text-red-400',
          info: 'bi-info-circle-fill text-amber-300',
        };
        const toastType = type === 'error' || type === 'info' ? type : 'success';

        const item = document.createElement('div');
        item.className = `pointer-events-auto rounded-xl border px-3 py-2.5 shadow-[0_12px_30px_rgba(0,0,0,0.35)] backdrop-blur transition ${styles[toastType]}`;
        item.style.opacity = '0';
        item.style.transform = 'translateY(-6px)';
        const row = document.createElement('div');
        row.className = 'flex items-start gap-2.5';
        const icon = document.createElement('i');
        icon.className = `bi ${icons[toastType]} mt-0.5 text-sm`;
        icon.setAttribute('aria-hidden', 'true');
        const text = document.createElement('p');
        text.className = 'text-sm leading-5';
        text.textContent = message;
        row.appendChild(icon);
        row.appendChild(text);
        item.appendChild(row);
        toastRoot.appendChild(item);

        requestAnimationFrame(() => {
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        });

        setTimeout(() => {
          item.style.opacity = '0';
          item.style.transform = 'translateY(-6px)';
          setTimeout(() => item.remove(), 220);
        }, 3600);

        params.delete('toast');
        params.delete('toast_type');
        const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}${window.location.hash || ''}`;
        window.history.replaceState({}, '', nextUrl);
      });

      document.addEventListener('DOMContentLoaded', () => {
        const selects = Array.from(document.querySelectorAll('.custom-select'));
        if (!selects.length) return;
        let openSelect = null;
        const closeSelect = (el) => {
          const trigger = el?.querySelector('.custom-select-trigger');
          const panel = el?.querySelector('.custom-select-panel');
          const icon = trigger?.querySelector('svg');
          if (!trigger || !panel || !icon) return;
          panel.classList.add('hidden');
          trigger.setAttribute('aria-expanded', 'false');
          icon.classList.remove('rotate-180');
          panel.style.position = '';
          panel.style.left = '';
          panel.style.top = '';
          panel.style.minWidth = '';
          panel.style.width = '';
          panel.style.maxHeight = '';
          panel.style.overflowY = '';
          panel.style.zIndex = '';
          panel.style.right = '';
        };
        const openCurrentSelect = (el) => {
          if (openSelect && openSelect !== el) closeSelect(openSelect);
          const trigger = el.querySelector('.custom-select-trigger');
          const panel = el.querySelector('.custom-select-panel');
          const icon = trigger?.querySelector('svg');
          if (!trigger || !panel || !icon) return;
          panel.classList.remove('hidden');
          trigger.setAttribute('aria-expanded', 'true');
          icon.classList.add('rotate-180');
          const tr = trigger.getBoundingClientRect();
          const margin = 8;
          const maxPanelH = 256;
          const spaceBelow = window.innerHeight - tr.bottom - margin;
          const spaceAbove = tr.top - margin;
          let top = tr.bottom + 4;
          let maxH = Math.min(maxPanelH, spaceBelow - 4);
          if (maxH < 100 && spaceAbove > spaceBelow) {
            maxH = Math.min(maxPanelH, spaceAbove - 4);
            top = Math.max(margin, tr.top - 4 - maxH);
          }
          const left = Math.max(margin, Math.min(tr.left, window.innerWidth - tr.width - margin));
          panel.style.position = 'fixed';
          panel.style.left = `${left}px`;
          panel.style.width = `${tr.width}px`;
          panel.style.top = `${top}px`;
          panel.style.maxHeight = `${Math.max(100, maxH)}px`;
          panel.style.overflowY = 'auto';
          panel.style.zIndex = '85';
          panel.style.right = 'auto';
          openSelect = el;
        };
        for (const select of selects) {
          const form = select.closest('#create-challenge-form');
          if (form?.classList.contains('hidden')) continue;
          const trigger = select.querySelector('.custom-select-trigger');
          const panel = select.querySelector('.custom-select-panel');
          const hidden = select.querySelector('input[type="hidden"]');
          const label = select.querySelector('.custom-select-label');
          const options = Array.from(select.querySelectorAll('.custom-select-option'));
          if (!trigger || !panel || !hidden || !label || !options.length) continue;
          select.setAttribute('data-custom-select-initialized', 'true');
          const updateVisual = (value) => {
            for (const option of options) {
              const optionValue = option.dataset.value ?? '';
              const check = option.querySelector('span');
              const isSelected = optionValue === value;
              option.classList.toggle('bg-lime/10', isSelected);
              option.classList.toggle('text-lime', isSelected);
              option.classList.toggle('text-white', !isSelected);
              if (check) {
                check.classList.toggle('border-lime', isSelected);
                check.classList.toggle('bg-lime', isSelected);
                check.classList.toggle('text-background', isSelected);
                check.classList.toggle('border-transparent', !isSelected);
                check.classList.toggle('bg-surface-2', !isSelected);
                check.classList.toggle('text-transparent', !isSelected);
              }
            }
          };
          trigger.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (openSelect === select) {
              closeSelect(select);
              openSelect = null;
              return;
            }
            openCurrentSelect(select);
          });
          for (const option of options) {
            option.addEventListener('click', (e) => {
              e.preventDefault();
              const nextValue = option.dataset.value ?? '';
              const nextLabel = option.dataset.label ?? '';
              hidden.value = nextValue;
              label.textContent = nextLabel;
              updateVisual(nextValue);
              closeSelect(select);
              openSelect = null;
              select.dispatchEvent(new CustomEvent('custom-select-change', { detail: { name: hidden.name, value: nextValue }, bubbles: true }));
            });
          }
          updateVisual(hidden.value);
        }
        document.addEventListener('click', (e) => {
          if (!openSelect) return;
          const target = e.target;
          if (!(target instanceof Node) || openSelect.contains(target)) return;
          requestAnimationFrame(() => {
            closeSelect(openSelect);
            openSelect = null;
          });
        });
        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape' || !openSelect) return;
          closeSelect(openSelect);
          openSelect = null;
        });
        document.addEventListener('custom-select-reinit', (e) => {
          const container = e.detail?.container;
          if (!container) return;
          const toInit = Array.from(container.querySelectorAll('.custom-select')).filter((s) => !s.hasAttribute('data-custom-select-initialized'));
          for (const select of toInit) {
            const trigger = select.querySelector('.custom-select-trigger');
            const panel = select.querySelector('.custom-select-panel');
            const hidden = select.querySelector('input[type="hidden"]');
            const label = select.querySelector('.custom-select-label');
            const options = Array.from(select.querySelectorAll('.custom-select-option'));
            if (!trigger || !panel || !hidden || !label || !options.length) continue;
            select.setAttribute('data-custom-select-initialized', 'true');
            const updateVisual = (value) => {
              for (const option of options) {
                const optionValue = option.dataset.value ?? '';
                const check = option.querySelector('span');
                const isSelected = optionValue === value;
                option.classList.toggle('bg-lime/10', isSelected);
                option.classList.toggle('text-lime', isSelected);
                option.classList.toggle('text-white', !isSelected);
                if (check) {
                  check.classList.toggle('border-lime', isSelected);
                  check.classList.toggle('bg-lime', isSelected);
                  check.classList.toggle('text-background', isSelected);
                  check.classList.toggle('border-transparent', !isSelected);
                  check.classList.toggle('bg-surface-2', !isSelected);
                  check.classList.toggle('text-transparent', !isSelected);
                }
              }
            };
            trigger.addEventListener('click', (ev) => {
              ev.preventDefault();
              ev.stopPropagation();
              if (openSelect === select) {
                closeSelect(select);
                openSelect = null;
                return;
              }
              openCurrentSelect(select);
            });
            for (const option of options) {
              option.addEventListener('click', (ev) => {
                ev.preventDefault();
                const nextValue = option.dataset.value ?? '';
                const nextLabel = option.dataset.label ?? '';
                hidden.value = nextValue;
                label.textContent = nextLabel;
                updateVisual(nextValue);
                closeSelect(select);
                openSelect = null;
                select.dispatchEvent(new CustomEvent('custom-select-change', { detail: { name: hidden.name, value: nextValue }, bubbles: true }));
              });
            }
            updateVisual(hidden.value);
          }
        });
      });

      document.addEventListener('click', (e) => {
        const target = e.target.closest('[data-clerk-unstyled-id]');
        if (!target) return;
        e.preventDefault();
        e.stopPropagation();
        requestAnimationFrame(() => {
          const doSignOut = () => {
            if (window.Clerk && typeof window.Clerk.signOut === 'function') {
              window.Clerk.signOut({ redirectUrl: '/' });
              return true;
            }
            return false;
          };
          if (!doSignOut()) {
            const interval = setInterval(() => {
              if (doSignOut()) clearInterval(interval);
            }, 100);
            setTimeout(() => clearInterval(interval), 5000);
          }
        });
      }, true);
    </script>
    <DeleteConfirmModal />
  </body>
</html>
