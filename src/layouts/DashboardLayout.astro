          <svg class="h-7 w-7 shrink-0" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path
              d="M128 10C193.17 10 246 62.8304 246 128C246 193.17 193.17 246 128 246C62.8304 246 10 193.17 10 128C10 62.8304 62.8304 10 128 10ZM90.5576 69C90.5475 69.0045 90.5366 69.0091 90.5264 69.0137C83.6225 69.1555 77.3443 70.4113 71.6973 72.7832C66.0618 75.1015 61.5025 78.487 58.0283 82.9395L57.3477 83.8447C53.8401 88.7038 52.0939 94.6384 52.0938 101.632C52.0938 106.256 52.8384 110.217 54.3379 113.499C55.8306 116.714 57.7624 119.435 60.1367 121.654L60.1416 121.659C62.558 123.817 65.2077 125.582 68.0879 126.951H68.0928C70.9595 128.261 73.7786 129.337 76.5459 130.177L104.783 138.718C106.809 139.34 108.657 140.092 110.323 140.971L110.823 141.221C111.948 141.805 112.942 142.474 113.808 143.221C114.771 144.307 115.704 145.379 116.599 146.412C116.898 146.905 117.164 147.423 117.395 147.968L117.396 147.975C118.092 149.501 118.443 151.264 118.443 153.27C118.443 156.74 117.452 159.75 115.473 162.309L115.064 162.813C112.854 165.437 109.908 167.476 106.222 168.925L105.525 169.18C102.024 170.408 98.2065 171.023 94.0732 171.023C86.9825 171.023 80.7864 169.13 75.4795 165.353C70.1804 161.528 66.6948 156.204 65.0254 149.367L64.9678 149.127L64.7207 149.163L48.0371 151.751L47.7656 151.792L47.8115 152.062C49.0428 159.258 51.7138 165.494 55.8252 170.756C59.9858 175.962 65.2525 179.985 71.6162 182.822L71.6191 182.825C78.0342 185.61 85.2146 187 93.1533 187C98.8393 187 104.249 186.265 109.376 184.795C114.505 183.324 119.029 181.142 122.935 178.248C126.035 175.939 128.615 173.206 130.676 170.056V187H149.488V137.737C149.488 133.441 150.461 129.883 152.303 126.972C154.328 123.938 156.88 121.665 159.963 120.125L160.014 120.103C163.135 118.452 166.485 117.626 170.083 117.626C173.681 117.626 177.032 118.452 180.152 120.103L180.178 120.114C183.358 121.749 185.902 124.106 187.82 127.209L187.836 127.234C189.695 130.153 190.678 133.719 190.678 138.042V187H209.484V137.89C209.484 130.625 207.985 124.159 204.909 118.554L204.907 118.551L204.317 117.52C201.296 112.437 197.2 108.429 192.045 105.549C