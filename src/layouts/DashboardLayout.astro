              fill="#F7F7F7"
            />
          </svg>
        </a>
        <span class="mx-0.5 h-6 w-px shrink-0 bg-white/15" aria-hidden="true" />
        <div class="flex items-center gap-0.5">
          {navLinks.slice(0, 4).map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                class={`relative flex h-9 w-9 shrink-0 items-center justify-center rounded-full transition ${
                  active ? 'bg-white/15 text-white' : 'text-muted hover:bg-white/10 hover:text-white'
                }`}
                aria-current={active ? 'page' : undefined}
                aria-label={item.label}
                title={item.label}
              >
                <i class={`bi ${item.icon} text-[16px] leading-none`} aria-hidden="true" />
                {item.showActiveCount && activeRetosCount > 0 && (
                  <span class="absolute -right-0.5 -top-0.5 flex h-3.5 min-w-[0.875rem] items-center justify-center rounded-full bg-lime/90 px-0.5 text-[8px] font-bold leading-none text-background">
                    {activeRetosCount > 9 ? '9+' : activeRetosCount}
                  </span>
                )}
              </a>
            );
          })}
        </div>
        <span class="mx-0.5 h-6 w-px shrink-0 bg-white/15" aria-hidden="true" />
        <button
          type="button"
          id="mobile-nav-open"
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-white transition hover:bg-white/10"
          aria-expanded="false"
          aria-controls="mobile-nav-overlay"
          aria-label="Abrir menú completo"
        >
          <span class="mobile-nav-lines" aria-hidden="true">
            <span class="mobile-nav-line"></span>
            <span class="mobile-nav-line"></span>
            <span class="mobile-nav-line"></span>
          </span>
        </button>
      </nav>
    </div>

    <div id="mobile-nav-overlay" class="fixed inset-0 z-[110] md:hidden" aria-hidden="true">
      <div
        id="mobile-nav-backdrop"
        class="absolute inset-0 cursor-pointer bg-black/55 backdrop-blur-[3px]"
        aria-hidden="true"
      />
      <div
        id="mobile-nav-panel"
        class="absolute left-3 right-3 flex max-h-[min(78vh,calc(100dvh-7.5rem))] flex-col overflow-hidden rounded-2xl border border-white/12 bg-[#141414] shadow-[0_20px_60px_rgba(0,0,0,0.55)] md:hidden"
        style={`bottom: calc(58px + env(safe-area-inset-bottom, 0px) + 10px);`}
        role="dialog"
        aria-modal="true"
        aria-labelledby="mobile-nav-overlay-title"
      >
        <div class="shrink-0 border-b border-white/10 px-4 py-3">
          <h2 id="mobile-nav-overlay-title" class="font-work-sans text-base font-semibold tracking-tight text-white">
            Menú
          </h2>
        </div>
        <div class="min-h-0 flex-1 overflow-y-auto overscroll-contain pt-2">
          {
            mobileNavSections.map((section, si) => (
              <div class={si > 0 ? 'mt-1 border-t border-white/10 pt-2' : ''}>
                <p
                  class={`px-5 pb-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted ${si === 0 ? 'pt-3' : 'pt-4'}`}
                >
                  {section.title}
                </p>
                <nav class="px-2 pb-2" aria-label={section.title}>
                  {section.items.map((item) => {
                    const active = isActive(item.href);
                    return (
                      <a
                        href={item.href}
                        class={`flex min-h-[3rem] items-center gap-4 rounded-xl px-3 py-2 font-work-sans text-[15px] leading-snug transition ${
                          active ? 'bg-white/10 text-white' : 'text-white/90 hover:bg-white/[0.06]'
                        }`}
                      >
                        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-white/[0.06] text-white/80">
                          <i class={`bi ${item.icon} text-lg leading-none`} aria-hidden="true" />
                        </span>
                        <span class="min-w-0 flex-1 font-medium">{item.label}</span>
                        {item.showActiveCount && activeRetosCount > 0 && (
                          <span class="shrink-0 rounded-full bg-lime/20 px-2 py-0.5 text-center text-[11px] font-semibold text-lime">
                            {activeRetosCount}
                          </span>
                        )}
