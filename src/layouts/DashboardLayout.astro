    </div>

    <div id="toast-root" class="pointer-events-none fixed right-4 top-4 z-[120] flex w-[min(92vw,400px)] flex-col gap-2"></div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const openBtn = document.getElementById('mobile-nav-open');
        const overlay = document.getElementById('mobile-nav-overlay');
        const backdrop = document.getElementById('mobile-nav-backdrop');
        const panel = document.getElementById('mobile-nav-panel');
        if (!openBtn || !overlay || !backdrop || !panel) return;

        const syncDockToggle = (open) => {
          openBtn.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú completo');
        };

        const openNav = () => {
          overlay.classList.add('mobile-nav-open');
          overlay.setAttribute('aria-hidden', 'false');
          openBtn.setAttribute('aria-expanded', 'true');
          syncDockToggle(true);
          document.body.style.overflow = 'hidden';
        };
        const closeNav = () => {
          overlay.classList.remove('mobile-nav-open');
          overlay.setAttribute('aria-hidden', 'true');
          openBtn.setAttribute('aria-expanded', 'false');
          syncDockToggle(false);
          document.body.style.overflow = '';
        };

        openBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (openBtn.getAttribute('aria-expanded') === 'true') closeNav();
          else openNav();
        });
        backdrop.addEventListener('click', () => closeNav());
        panel.querySelectorAll('a[href]').forEach((a) => {
          a.addEventListener('click', () => closeNav());
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && openBtn.getAttribute('aria-expanded') === 'true') {
            e.preventDefault();
            closeNav();
          }
        });
        document.querySelector('#main-content-panel main')?.addEventListener(
          'scroll',
          () => {
            if (openBtn.getAttribute('aria-expanded') === 'true') closeNav();
          },
          { passive: true },
        );
      });

      document.addEventListener('DOMContentLoaded', () => {
        const STORAGE_KEY = 'sidebarCollapsed';
        const body = document.getElementById('body-el');
        const sidebar = document.getElementById('sidebar');
        const spacer = document.getElementById('sidebar-spacer');
        const toggleBtn = document.getElementById('sidebar-toggle');

        if (body && sidebar && spacer && toggleBtn) {
          const collapsed = localStorage.getItem(STORAGE_KEY) === 'true';
          if (collapsed) body.classList.add('sidebar-collapsed');

          toggleBtn.addEventListener('click', () => {
            const isCollapsed = body.classList.toggle('sidebar-collapsed');
            localStorage.setItem(STORAGE_KEY, String(isCollapsed));
            toggleBtn.setAttribute('aria-label', isCollapsed ? 'Expandir menú' : 'Contraer menú');
            toggleBtn.setAttribute('title', isCollapsed ? 'Expandir menú' : 'Contraer menú');
          });
        }
      });

      document.addEventListener('DOMContentLoaded', () => {
        const menu = document.getElementById('user-menu');
        const button = document.getElementById('user-menu-button');
        const dropdown = document.getElementById('user-menu-dropdown');
        const chevron = document.getElementById('chevron-icon');
        const backdrop = document.getElementById('user-menu-backdrop');

        if (!menu || !button || !dropdown || !chevron) return;

        function open() {
          dropdown.classList.remove('pointer-events-none', 'opacity-0');
          dropdown.style.transform = 'translateY(0)';
          dropdown.setAttribute('aria-hidden', 'false');
          chevron.classList.add('rotate-180');
          button.setAttribute('aria-expanded', 'true');
          if (backdrop) backdrop.classList.remove('hidden');
        }

        function close() {
          dropdown.classList.add('pointer-events-none', 'opacity-0');
          dropdown.style.transform = 'translateY(-8px)';
          dropdown.setAttribute('aria-hidden', 'true');
          chevron.classList.remove('rotate-180');
          button.setAttribute('aria-expanded', 'false');
          if (backdrop) backdrop.classList.add('hidden');
        }

        function isOpen() {
          return button.getAttribute('aria-expanded') === 'true';
        }

        close();

        button.addEventListener('click', (e) => {
          e.stopPropagation();
          if (isOpen()) close();
          else open();
        });

        backdrop?.addEventListener('click', () => {
          if (isOpen()) close();
        });

        document.addEventListener(
          'click',
          (e) => {
            if (!isOpen()) return;
            const t = e.target;
            if (!(t instanceof Node)) return;
            if (menu.contains(t)) return;
            if (backdrop && (t === backdrop || backdrop.contains(t))) return;
            requestAnimationFrame(close);
          },
          { passive: true },
        );

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen()) {
            e.preventDefault();
            close();
          }
        });

        document.querySelector('#main-content-panel main')?.addEventListener(
          'scroll',
          () => {
            if (isOpen()) close();
          },
          { passive: true },
        );
      });

      document.addEventListener('DOMContentLoaded', () => {
        const toastRoot = document.getElementById('toast-root');
        if (!toastRoot) return;
        const params = new URLSearchParams(window.location.search);
        const message = params.get('toast');
        const type = params.get('toast_type') || 'success';
        if (!message) return;

        const titles = { success: 'Listo', error: 'Error', info: 'Aviso' };
        const icons = {
          success: 'bi-check-lg',
          error: 'bi-exclamation-triangle-fill',
          info: 'bi-info-lg',
        };
        const toastType = type === 'error' || type === 'info' ? type : 'success';

        const item = document.createElement('div');
        item.className = `ds-toast ds-toast--${toastType} pointer-events-auto transition-[opacity,transform] duration-200 ease-out`;
        item.setAttribute('role', 'status');
        item.setAttribute('aria-live', 'polite');
        item.style.opacity = '0';
        item.style.transform = 'translateY(-6px)';

        let hideTimer = null;
        const dismiss = () => {
          if (hideTimer !== null) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }
          item.style.opacity = '0';
          item.style.transform = 'translateY(-6px)';
          setTimeout(() => item.remove(), 220);
        };

        const shine = document.createElement('div');
        shine.className = 'ds-toast-shine';
        shine.setAttribute('aria-hidden', 'true');

        const row = document.createElement('div');
        row.className = 'relative z-[1] flex items-center gap-3 px-3.5 py-3';

        const iconWrap = document.createElement('div');
        iconWrap.className = `ds-toast-icon ds-toast-icon--${toastType}`;
        const icon = document.createElement('i');
        icon.className = `bi ${icons[toastType]}`;
        icon.setAttribute('aria-hidden', 'true');
        iconWrap.appendChild(icon);

        const body = document.createElement('div');
        body.className = 'min-w-0 flex-1';
        const titleEl = document.createElement('p');
        titleEl.className = 'ds-toast-title';
        titleEl.textContent = titles[toastType];
        const descEl = document.createElement('p');
        descEl.className = 'ds-toast-desc';
        descEl.textContent = message;
        body.appendChild(titleEl);
        body.appendChild(descEl);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ds-toast-action';
        btn.textContent = toastType === 'error' ? 'Cerrar' : 'Entendido';
        btn.setAttribute('aria-label', 'Cerrar notificación');
        btn.addEventListener('click', dismiss);

        row.appendChild(iconWrap);
        row.appendChild(body);
        row.appendChild(btn);
        item.appendChild(shine);
        item.appendChild(row);
        toastRoot.appendChild(item);

        requestAnimationFrame(() => {
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        });

        hideTimer = window.setTimeout(dismiss, 3600);

        params.delete('toast');
        params.delete('toast_type');
        const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}${window.location.hash || ''}`;
        window.history.replaceState({}, '', nextUrl);
      });

      document.addEventListener('DOMContentLoaded', () => {
        /** INP: defer heavy custom-select setup so first paint/input stays responsive. */
        const scheduleAfterPaint = (fn) => {
          if (typeof requestIdleCallback !== 'undefined') {
            requestIdleCallback(fn, { timeout: 900 });
          } else {
            setTimeout(fn, 0);
          }
        };

        scheduleAfterPaint(() => {
        const mainPanel = document.getElementById('main-content-panel');
        const selects = Array.from(
          (mainPanel ?? document.body).querySelectorAll('.custom-select'),
        );
        if (!selects.length) return;
        let openSelect = null;
        const closeSelect = (el) => {
          const trigger = el?.querySelector('.custom-select-trigger');
          const panel = el?.querySelector('.custom-select-panel');
          const icon = trigger?.querySelector('svg');
          if (!trigger || !panel || !icon) return;
          panel.classList.add('hidden');
          trigger.setAttribute('aria-expanded', 'false');
          icon.classList.remove('rotate-180');
          panel.style.position = '';
          panel.style.left = '';
          panel.style.top = '';
          panel.style.minWidth = '';
          panel.style.width = '';
          panel.style.maxHeight = '';
          panel.style.overflowY = '';
          panel.style.zIndex = '';
          panel.style.right = '';
          panel.style.display = '';
          panel.style.visibility = '';
        };
        const openCurrentSelect = (el) => {
          if (openSelect && openSelect !== el) closeSelect(openSelect);
          const trigger = el.querySelector('.custom-select-trigger');
          const panel = el.querySelector('.custom-select-panel');
          const icon = trigger?.querySelector('svg');
          if (!trigger || !panel || !icon) return;
          panel.classList.remove('hidden');
          trigger.setAttribute('aria-expanded', 'true');
          icon.classList.add('rotate-180');
          const tr = trigger.getBoundingClientRect();
          const margin = 8;
          const maxPanelH = 256;
          const pickerPanel = el.closest('.course-picker-panel');
          if (pickerPanel) {
            panel.style.position = 'fixed';
            panel.style.left = `${tr.right - panel.offsetWidth}px`;
            panel.style.top = `${tr.bottom + 4}px`;
            panel.style.minWidth = `${tr.width}px`;
            panel.style.right = 'auto';
            panel.style.width = '';
            panel.style.maxHeight = `${Math.min(maxPanelH, window.innerHeight - tr.bottom - margin)}px`;
            panel.style.overflowY = 'auto';
            panel.style.zIndex = '85';
          } else {
            // Anclar al trigger con las clases CSS (absolute bajo .custom-select). Evita
            // position:fixed + getBoundingClientRect que desalinea el menú en formularios anchos / scroll.
            const spaceBelow = window.innerHeight - tr.bottom - margin;
            const maxH = Math.min(maxPanelH, Math.max(100, spaceBelow - 4));
            panel.style.position = '';
            panel.style.left = '';
            panel.style.top = '';
            panel.style.width = '';
            panel.style.right = '';
            panel.style.minWidth = '';
            panel.style.maxHeight = `${maxH}px`;
            panel.style.overflowY = 'auto';
            panel.style.zIndex = '85';
          }
          openSelect = el;
        };
        for (const select of selects) {
          const form = select.closest('#create-course-form, #create-challenge-form');
          if (form?.classList.contains('hidden')) continue;
          const trigger = select.querySelector('.custom-select-trigger');
          const panel = select.querySelector('.custom-select-panel');
          const hidden = select.querySelector('input[type="hidden"]');
          const label = select.querySelector('.custom-select-label');
          const options = Array.from(select.querySelectorAll('.custom-select-option'));
          if (!trigger || !panel || !hidden || !label || !options.length) continue;
          if (select.hasAttribute('data-custom-select-initialized')) continue;
          select.setAttribute('data-custom-select-initialized', 'true');
          const updateVisual = (value) => {
            for (const option of options) {
              const optionValue = option.dataset.value ?? '';
              const check = option.querySelector('span');
              const isSelected = optionValue === value;
              option.classList.toggle('bg-lime/10', isSelected);
              option.classList.toggle('text-lime', isSelected);
              option.classList.toggle('text-white', !isSelected);
              if (check) {
                check.classList.toggle('border-lime', isSelected);
                check.classList.toggle('bg-lime', isSelected);
                check.classList.toggle('text-background', isSelected);
                check.classList.toggle('border-transparent', !isSelected);
                check.classList.toggle('bg-surface-2', !isSelected);
                check.classList.toggle('text-transparent', !isSelected);
              }
            }
          };
          trigger.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (openSelect === select) {
              closeSelect(select);
              openSelect = null;
              return;
            }
            openCurrentSelect(select);
          });
          for (const option of options) {
            option.addEventListener('click', (e) => {
              e.preventDefault();
              const nextValue = option.dataset.value ?? '';
              const nextLabel = option.dataset.label ?? '';
              hidden.value = nextValue;
              label.textContent = nextLabel;
              updateVisual(nextValue);
              closeSelect(select);
              openSelect = null;
              const name = select.getAttribute('data-name');
              if (name) {
                select.dispatchEvent(new CustomEvent('custom-select-change', { detail: { name, value: nextValue }, bubbles: true }));
              }
            });
          }
          updateVisual(hidden.value);
        }
        document.addEventListener(
          'click',
          (e) => {
            if (!openSelect) return;
            const target = e.target;
            if (!(target instanceof Node) || openSelect.contains(target)) return;
            requestAnimationFrame(() => {
              closeSelect(openSelect);
              openSelect = null;
            });
          },
          { capture: true, passive: true },
        );
        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape' || !openSelect) return;
          closeSelect(openSelect);
          openSelect = null;
        });
        const closeSelectOnMainScroll = () => {
          if (!openSelect) return;
          requestAnimationFrame(() => {
            closeSelect(openSelect);
            openSelect = null;
          });
        };
        document.querySelector('#main-content-panel main')?.addEventListener('scroll', closeSelectOnMainScroll, {
          passive: true,
        });
        document.addEventListener('custom-select-reinit', (e) => {
          const container = e.detail?.container;
          if (!container) return;
          const toInit = Array.from(container.querySelectorAll('.custom-select')).filter(
            (s) => !s.hasAttribute('data-custom-select-initialized'),
          );
          for (const select of toInit) {
            const trigger = select.querySelector('.custom-select-trigger');
            const panel = select.querySelector('.custom-select-panel');
            const hidden = select.querySelector('input[type="hidden"]');
            const label = select.querySelector('.custom-select-label');
            const options = Array.from(select.querySelectorAll('.custom-select-option'));
            if (!trigger || !panel || !hidden || !label || !options.length) continue;
            select.setAttribute('data-custom-select-initialized', 'true');
            const updateVisual = (value) => {
              for (const option of options) {
                const optionValue = option.dataset.value ?? '';
                const check = option.querySelector('span');
                const isSelected = optionValue === value;
                option.classList.toggle('bg-lime/10', isSelected);
                option.classList.toggle('text-lime', isSelected);
                option.classList.toggle('text-white', !isSelected);
                if (check) {
                  check.classList.toggle('border-lime', isSelected);
                  check.classList.toggle('bg-lime', isSelected);
                  check.classList.toggle('text-background', isSelected);
                  check.classList.toggle('border-transparent', !isSelected);
                  check.classList.toggle('bg-surface-2', !isSelected);
                  check.classList.toggle('text-transparent', !isSelected);
                }
              }
            };
            trigger.addEventListener('click', (ev) => {
              ev.preventDefault();
              ev.stopPropagation();
              if (openSelect === select) { closeSelect(select); openSelect = null; return; }
              openCurrentSelect(select);
            });
            for (const option of options) {
              option.addEventListener('click', (ev) => {
                ev.preventDefault();
                const nextValue = option.dataset.value ?? '';
                const nextLabel = option.dataset.label ?? '';
                hidden.value = nextValue;
                label.textContent = nextLabel;
                updateVisual(nextValue);
                closeSelect(select);
                openSelect = null;
                const name = select.getAttribute('data-name');
                if (name) select.dispatchEvent(new CustomEvent('custom-select-change', { detail: { name, value: nextValue }, bubbles: true }));
              });
            }
            updateVisual(hidden.value);
          }
        });
        });
      });

      // Fallback: ensure Cerrar sesión works if Clerk script loads after the SignOutButton script
      document.addEventListener(
        'click',
        (e) => {
          const node = e.target;
          const el = node instanceof Element ? node : node?.parentElement;
          if (!el) return;
          const target = el.closest('[data-clerk-unstyled-id]');
          if (!target) return;
          e.preventDefault();
          e.stopPropagation();
          requestAnimationFrame(() => {
            const doSignOut = () => {
              if (window.Clerk && typeof window.Clerk.signOut === 'function') {
                window.Clerk.signOut({ redirectUrl: '/' });
                return true;
              }
              return false;
            };
            if (!doSignOut()) {
              const interval = setInterval(() => {
                if (doSignOut()) clearInterval(interval);
              }, 100);
              setTimeout(() => clearInterval(interval), 5000);
            }
          });
        },
        true,
      );
    </script>
    <DeleteConfirmModal />
  </body>
</html>

