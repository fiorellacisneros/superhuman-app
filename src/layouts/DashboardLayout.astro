            ))
          }

          <div class="mt-1 border-t border-white/10 pt-2">
            <p class="px-5 pb-2 pt-4 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Cuenta</p>
            <nav class="px-2 pb-4" aria-label="Cuenta">
              <a
                href="/profile"
                class={`flex min-h-[3rem] items-center gap-4 rounded-xl px-3 py-2 font-work-sans text-[15px] leading-snug transition ${
                  isActive('/profile') ? 'bg-white/10 text-white' : 'text-white/90 hover:bg-white/[0.06]'
                }`}
              >
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-white/[0.06] text-white/80">
                  <i class="bi bi-person-circle text-lg leading-none" aria-hidden="true" />
                </span>
                <span class="min-w-0 flex-1 font-medium">Mi perfil</span>
              </a>
              <SignOutButton
                redirectUrl="/"
                class="mt-0.5 flex min-h-[3rem] w-full items-center gap-4 rounded-xl border-0 bg-transparent px-3 py-2 text-left font-work-sans text-[15px] font-medium leading-snug text-white/90 transition hover:bg-white/[0.06] hover:text-white"
              >
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-white/[0.06] text-white/80">
                  <i class="bi bi-box-arrow-right text-lg leading-none" aria-hidden="true" />
                </span>
                <span class="min-w-0 flex-1">Cerrar sesión</span>
              </SignOutButton>
