---
import '../styles/global.css';
import { getSupabaseServiceRoleClient } from '../lib/supabase';
import { avatarImagePath } from '../lib/avatars';
import { SignOutButton } from '@clerk/astro/components';
import DeleteConfirmModal from '../components/DeleteConfirmModal.astro';
import { getPreviewContext } from '../lib/preview';

interface Props {
  role?: 'admin' | 'student' | null;
}

const { role: roleProp } = Astro.props;
const { preview, previewAs } = getPreviewContext(Astro);
const { isAuthenticated, userId, redirectToSignIn, sessionClaims } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase
  .from('users')
  .select('display_name, avatar_id, role, email')
  .eq('id', userId)
  .maybeSingle();

let userEmail: string | null = userRow?.email ?? null;
if (!userEmail) {
  try {
    const currentUser = await (Astro.locals as any).currentUser?.();
    if (currentUser?.emailAddresses?.[0]?.emailAddress) {
      userEmail = String(currentUser.emailAddresses[0].emailAddress);
    }
  } catch {
    // ignore
  }
}
if (!userEmail && sessionClaims) {
  const claims = sessionClaims as Record<string, unknown>;
  userEmail = (claims.primary_email ?? claims.email ?? (claims as any).email_address) as string | null;
  if (!userEmail && Array.isArray((claims as any)?.email_addresses)?.[0]) {
    userEmail = String((claims as any).email_addresses[0].email_address ?? '') || null;
  }
}

const displayName = userRow?.display_name ?? 'Estudiante';
const avatarId = userRow?.avatar_id ?? null;
const avatarSrc = avatarImagePath(avatarId);
const initialLetter = (displayName || 'E').charAt(0).toUpperCase();
const role = roleProp ?? (userRow?.role as 'admin' | 'student' | null) ?? 'student';

const currentPath = Astro.url.pathname;

const studentNavLive = [
  { label: 'Dashboard', href: '/dashboard', icon: 'bi-grid-1x2-fill' },
  { label: 'Mis cursos', href: '/courses', icon: 'bi-journal-richtext' },
  { label: 'Sesiones 1:1', href: '/sesiones-1-1', icon: 'bi-calendar-check-fill' },
  { label: 'Retos', href: '/challenges', icon: 'bi-lightning-charge-fill', showActiveCount: true },
  { label: 'Ranking', href: '/leaderboard', icon: 'bi-trophy-fill' },
  { label: 'Insignias', href: '/badges', icon: 'bi-award' },
  { label: 'Certificados', href: '/certificados', icon: 'bi-patch-check' },
  { label: 'superHumans', href: '/superhumans', icon: 'bi-stars' },
  { label: 'Mi perfil', href: '/profile', icon: 'bi-person-circle' },
] as const;

const studentNavOnDemand = [
  { label: 'Dashboard', href: '/dashboard', icon: 'bi-grid-1x2-fill' },
  { label: 'Mis cursos', href: '/courses', icon: 'bi-journal-richtext' },
  { label: 'Sesión grupal', href: '/sesion-grupal', icon: 'bi-calendar-check-fill' },
  { label: 'Retos', href: '/challenges', icon: 'bi-lightning-charge-fill', showActiveCount: true },
  { label: 'Certificados', href: '/certificados', icon: 'bi-patch-check' },
  { label: 'superHumans', href: '/superhumans', icon: 'bi-stars' },
  { label: 'Mi perfil', href: '/profile', icon: 'bi-person-circle' },
] as const;

const adminNav = [
  { label: 'Dashboard', href: '/dashboard', icon: 'bi-grid-1x2-fill' },
  { label: 'Cursos', href: '/admin/courses', icon: 'bi-journal-richtext' },
  { label: 'Retos', href: '/admin/challenges', icon: 'bi-lightning-charge-fill', showActiveCount: true },
  { label: 'Alumnos', href: '/admin/students', icon: 'bi-people-fill' },
  { label: 'Sesiones 1:1', href: '/sesiones-1-1', icon: 'bi-calendar-check-fill' },
  { label: 'Asistencia', href: '/admin/attendance', icon: 'bi-calendar2-check-fill' },
  { label: 'Kahoot', href: '/admin/kahoot', icon: 'bi-trophy-fill' },
  { label: 'Submissions', href: '/admin/submissions', icon: 'bi-inbox-fill' },
  { label: 'Avisos', href: '/admin/avisos', icon: 'bi-megaphone-fill' },
  { label: 'Certificados', href: '/certificados', icon: 'bi-patch-check' },
  { label: 'SuperHumans', href: '/superhumans', icon: 'bi-stars' },
] as const;

type NavLinkItem = {
  label: string;
  href: string;
  icon: string;
  showActiveCount?: boolean;
};

function navSectionsFromSpec(
  links: readonly NavLinkItem[],
  spec: { title: string; hrefs: string[] }[],
): { title: string; items: NavLinkItem[] }[] {
  const byHref = new Map(links.map((l) => [l.href, l]));
  return spec
    .map((s) => ({
      title: s.title,
      items: s.hrefs.map((h) => byHref.get(h)).filter((x): x is NavLinkItem => Boolean(x)),
    }))
    .filter((sec) => sec.items.length > 0);
}

const adminMobileMenuSpec = [
  { title: 'Panel', hrefs: ['/dashboard', '/admin/courses'] },
  {
    title: 'Gestión',
    hrefs: ['/admin/challenges', '/sesiones-1-1', '/admin/attendance', '/admin/kahoot', '/admin/students', '/admin/submissions', '/admin/avisos', '/certificados'],
  },
  { title: 'Comunidad', hrefs: ['/superhumans'] },
] as const;

const studentLiveMobileSpec = [
  { title: 'Tu espacio', hrefs: ['/dashboard', '/courses'] },
  { title: 'Aprende', hrefs: ['/sesiones-1-1', '/challenges', '/leaderboard', '/badges', '/certificados'] },
  { title: 'Comunidad', hrefs: ['/superhumans'] },
] as const;

const studentOnDemandMobileSpec = [
  { title: 'Tu espacio', hrefs: ['/dashboard', '/courses'] },
  { title: 'Aprende', hrefs: ['/sesion-grupal', '/challenges', '/certificados'] },
  { title: 'Comunidad', hrefs: ['/superhumans'] },
] as const;

let hasOnlyOnDemand = false;
let navLinks = role === 'admin' ? adminNav : studentNavLive;
let activeRetosCount = 0;
if (preview) {
  hasOnlyOnDemand = previewAs === 'on_demand';
  navLinks = hasOnlyOnDemand ? studentNavOnDemand : studentNavLive;
  const { count: activeChallengesCount } = await supabase
    .from('challenges')
    .select('*', { count: 'exact', head: true })
    .eq('is_active', true);
  activeRetosCount = activeChallengesCount ?? 0;
} else if (role === 'admin') {
  const { count: activeChallengesCount } = await supabase
    .from('challenges')
    .select('*', { count: 'exact', head: true })
    .eq('is_active', true);
  activeRetosCount = activeChallengesCount ?? 0;
} else {
  // For students: solo retos activos de cursos en los que está inscrito, pendientes de entregar.
  const { data: enrollmentRows } = await supabase.from('enrollments').select('course_id, access_type').eq('user_id', userId);
  hasOnlyOnDemand = (enrollmentRows ?? []).length > 0 && (enrollmentRows ?? []).every((r) => (r.access_type as string) === 'on_demand');
  navLinks = hasOnlyOnDemand ? studentNavOnDemand : studentNavLive;
  const enrolledCourseIds = (enrollmentRows ?? []).map((r) => r.course_id);
  const onDemandCourseIds = new Set(
    (enrollmentRows ?? []).filter((r) => (r.access_type as string) === 'on_demand').map((r) => r.course_id as string),
  );

  const { data: challengeRows } = await supabase
    .from('challenges')
    .select('id, course_id, available_for_on_demand')
    .eq('is_active', true);

  const relevantIds = (challengeRows ?? [])
    .filter((c) => {
      if (!c.course_id) return true;
      if (!enrolledCourseIds.includes(c.course_id)) return false;
      if (onDemandCourseIds.has(c.course_id)) {
        return (c.available_for_on_demand as boolean) === true;
      }
      return true;
    })
    .map((c) => c.id as string);

  if (relevantIds.length > 0) {
    const { data: submittedRows } = await supabase
      .from('submissions')
      .select('challenge_id')
      .eq('user_id', userId)
      .in('challenge_id', relevantIds);
    const submittedSet = new Set((submittedRows ?? []).map((s) => s.challenge_id as string));
    activeRetosCount = relevantIds.filter((id) => !submittedSet.has(id)).length;
  }
}

let mobileNavSections: { title: string; items: NavLinkItem[] }[] = [];
if (role === 'admin') {
  mobileNavSections = navSectionsFromSpec([...adminNav], [...adminMobileMenuSpec]);
} else if (hasOnlyOnDemand) {
  mobileNavSections = navSectionsFromSpec([...navLinks], [...studentOnDemandMobileSpec]);
} else {
  mobileNavSections = navSectionsFromSpec([...navLinks], [...studentLiveMobileSpec]);
}

function isActive(href: string): boolean {
  if (href === '/dashboard') return currentPath === '/dashboard';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<html lang="es" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <slot name="head" />
    <title>Superhuman School — Dashboard</title>
    <style is:global>
      body.sidebar-collapsed #sidebar { width: 72px; }
      body.sidebar-collapsed #sidebar-spacer { width: 72px !important; }
      body.sidebar-collapsed .sidebar-label { display: none; }
      body.sidebar-collapsed .sidebar-greeting { display: none; }
      body.sidebar-collapsed .sidebar-badge { display: none; }
      body.sidebar-collapsed .sidebar-toggle .sidebar-chevron { transform: rotate(180deg); }
      body.sidebar-collapsed .sidebar .nav-link { justify-content: center; padding-left: 0.75rem; padding-right: 0.75rem; }
      body.sidebar-collapsed .sidebar-logo { justify-content: center; }
      /* Más aire cuando la sidebar está colapsada */
      body.sidebar-collapsed .sidebar-logo-wrap { padding-bottom: 1.5rem; padding-left: 1rem; padding-right: 1rem; }
      body.sidebar-collapsed .sidebar-nav { padding-top: 1.25rem; padding-left: 1rem; padding-right: 1rem; }
      body.sidebar-collapsed .sidebar-nav > * + * { margin-top: 1rem; }
      .sidebar-logo .logo-small { display: none; }
      .sidebar-logo .logo-large { display: block; }
      body.sidebar-collapsed .sidebar-logo .logo-small { display: block; height: 2.5rem; width: 2.5rem; min-width: 2.5rem; }
      body.sidebar-collapsed .sidebar-logo .logo-large { display: none; }
      /* Panel de contenido fijo: hueco para que se vea el border-radius superior izquierdo */
      #main-content-panel {
        left: 0;
        top: 87px;
        border-top-left-radius: 30px;
        margin-left: 0;
      }
      @media (max-width: 767px) {
        /* Sin navbar móvil: el contenido llega al borde superior (safe area vía padding en main si hace falta) */
        #main-content-panel {
          top: 0;
          border-top-left-radius: 20px;
        }
      }
      @media (min-width: 768px) {
        #main-content-panel { left: 272px; margin-left: 0; } /* 260px sidebar + 12px gap */
        body.sidebar-collapsed #main-content-panel { left: 84px; } /* 72px sidebar + 12px gap */
      }
      /* Menú móvil: panel flotante (no pantalla completa) */
      #mobile-nav-overlay {
        pointer-events: none;
      }
      #mobile-nav-overlay.mobile-nav-open {
        pointer-events: auto;
      }
      #mobile-nav-backdrop {
        opacity: 0;
        transition: opacity 0.22s ease-out;
      }
      #mobile-nav-overlay.mobile-nav-open #mobile-nav-backdrop {
        opacity: 1;
      }
      #mobile-nav-panel {
        transform: translateY(calc(100% + 20px));
        opacity: 0;
        transition:
          transform 0.34s cubic-bezier(0.32, 0.72, 0, 1),
          opacity 0.22s ease-out;
      }
      #mobile-nav-overlay.mobile-nav-open #mobile-nav-panel {
        transform: translateY(0);
        opacity: 1;
      }
      /* Hamburguesa → X (microinteracción) */
      .mobile-nav-lines {
        position: relative;
        display: block;
        width: 1.125rem;
        height: 0.875rem;
      }
      .mobile-nav-lines .mobile-nav-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        border-radius: 1px;
        background: currentColor;
        transition:
          transform 0.32s cubic-bezier(0.32, 0.72, 0, 1),
          opacity 0.2s ease,
          top 0.32s cubic-bezier(0.32, 0.72, 0, 1),
          bottom 0.32s cubic-bezier(0.32, 0.72, 0, 1);
      }
      .mobile-nav-lines .mobile-nav-line:nth-child(1) {
        top: 0;
      }
      .mobile-nav-lines .mobile-nav-line:nth-child(2) {
        top: 6px;
      }
      .mobile-nav-lines .mobile-nav-line:nth-child(3) {
        bottom: 0;
      }
      #mobile-nav-open[aria-expanded='true'] .mobile-nav-lines .mobile-nav-line:nth-child(1) {
        top: 6px;
        transform: rotate(45deg);
      }
      #mobile-nav-open[aria-expanded='true'] .mobile-nav-lines .mobile-nav-line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
      }
      #mobile-nav-open[aria-expanded='true'] .mobile-nav-lines .mobile-nav-line:nth-child(3) {
        bottom: auto;
        top: 6px;
        transform: rotate(-45deg);
      }
      @media (prefers-reduced-motion: reduce) {
        .mobile-nav-lines .mobile-nav-line {
          transition-duration: 0.01ms;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-background text-white antialiased" id="body-el">
    <div class="flex min-h-screen flex-col md:flex-row">
      <!-- Sidebar: fija, solo desktop, colapsable (solo iconos) -->
      <aside
        id="sidebar"
        class="sidebar fixed left-0 top-0 z-30 hidden h-screen w-[260px] flex-col bg-background transition-[width] duration-200 ease-out md:flex"
        aria-label="Navegación principal"
      >
        <div class="flex h-full flex-col">
          <!-- Logo (espaciado Figma: 24px izq, 36px arriba); el toggle está en el header -->
          <div class="sidebar-logo-wrap flex shrink-0 items-center pl-6 pr-3 pt-9 pb-0">
            <a href="/dashboard" class="sidebar-logo flex min-w-0 shrink items-center gap-2 overflow-hidden" title="Superhuman School">
              <svg class="logo-small h-5 w-auto shrink-0" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M128 10C193.17 10 246 62.8304 246 128C246 193.17 193.17 246 128 246C62.8304 246 10 193.17 10 128C10 62.8304 62.8304 10 128 10ZM90.5576 69C90.5475 69.0045 90.5366 69.0091 90.5264 69.0137C83.6225 69.1555 77.3443 70.4113 71.6973 72.7832C66.0618 75.1015 61.5025 78.487 58.0283 82.9395L57.3477 83.8447C53.8401 88.7038 52.0939 94.6384 52.0938 101.632C52.0938 106.256 52.8384 110.217 54.3379 113.499C55.8306 116.714 57.7624 119.435 60.1367 121.654L60.1416 121.659C62.558 123.817 65.2077 125.582 68.0879 126.951H68.0928C70.9595 128.261 73.7786 129.337 76.5459 130.177L104.783 138.718C106.809 139.34 108.657 140.092 110.323 140.971L110.823 141.221C111.948 141.805 112.942 142.474 113.808 143.221C114.771 144.307 115.704 145.379 116.599 146.412C116.898 146.905 117.164 147.423 117.395 147.968L117.396 147.975C118.092 149.501 118.443 151.264 118.443 153.27C118.443 156.74 117.452 159.75 115.473 162.309L115.064 162.813C112.854 165.437 109.908 167.476 106.222 168.925L105.525 169.18C102.024 170.408 98.2065 171.023 94.0732 171.023C86.9825 171.023 80.7864 169.13 75.4795 165.353C70.1804 161.528 66.6948 156.204 65.0254 149.367L64.9678 149.127L64.7207 149.163L48.0371 151.751L47.7656 151.792L47.8115 152.062C49.0428 159.258 51.7138 165.494 55.8252 170.756C59.9858 175.962 65.2525 179.985 71.6162 182.822L71.6191 182.825C78.0342 185.61 85.2146 187 93.1533 187C98.8393 187 104.249 186.265 109.376 184.795C114.505 183.324 119.029 181.142 122.935 178.248C126.035 175.939 128.615 173.206 130.676 170.056V187H149.488V137.737C149.488 133.441 150.461 129.883 152.303 126.972C154.328 123.938 156.88 121.665 159.963 120.125L160.014 120.103C163.135 118.452 166.485 117.626 170.083 117.626C173.681 117.626 177.032 118.452 180.152 120.103L180.178 120.114C183.358 121.749 185.902 124.106 187.82 127.209L187.836 127.234C189.695 130.153 190.678 133.719 190.678 138.042V187H209.484V137.89C209.484 130.625 207.985 124.159 204.909 118.554L204.907 118.551L204.317 117.52C201.296 112.437 197.2 108.429 192.045 105.549C186.535 102.358 180.099 100.813 172.835 100.812C167.615 100.813 162.562 101.844 157.684 103.898L157.663 103.907C154.656 105.205 151.926 106.949 149.479 109.12V69H133.903L112.977 100.86L140.117 116.2L125.644 152.78L124.776 119.74L83.1631 109.12L98.4756 69H90.5576ZM112.086 183.645C111.18 183.965 110.252 184.264 109.303 184.536L108.413 184.779C108.709 184.7 109.005 184.619 109.299 184.535C110.249 184.263 111.179 183.966 112.086 183.645ZM130.676 169.56C128.596 172.831 125.962 175.657 122.771 178.032L122.036 178.562C121.705 178.796 121.367 179.021 121.027 179.244C121.62 178.855 122.201 178.451 122.768 178.031C125.959 175.655 128.595 172.829 130.676 169.557V169.56ZM96.2949 171.23C95.5636 171.271 94.8212 171.293 94.0693 171.293C93.6519 171.293 93.2365 171.285 92.8252 171.272L94.0732 171.292C94.8238 171.292 95.5648 171.271 96.2949 171.23ZM64.7627 149.432C66.4464 156.326 69.9657 161.708 75.3223 165.573L76.3223 166.254C75.9853 166.034 75.6503 165.807 75.3203 165.572C69.9636 161.707 66.4425 156.327 64.7588 149.432H64.7627ZM71.7998 73.0322C71.6627 73.0886 71.5254 73.1464 71.3896 73.2041C71.5265 73.146 71.6646 73.0871 71.8027 73.0303C71.943 72.9713 72.0855 72.914 72.2266 72.8564C72.0844 72.9144 71.9412 72.9728 71.7998 73.0322Z" fill="#F7F7F7"/>
              </svg>
              <img src="/logo.png" alt="Superhuman School" class="logo-large h-auto max-h-12 w-auto shrink-0 object-contain" width="120" height="48" />
            </a>
          </div>
          <!-- Saludo (75px bajo logo; 87px bajo saludo hasta el menú) -->
          <div class="sidebar-greeting shrink-0 overflow-hidden px-5 pt-[75px] pb-[87px] transition-opacity duration-200">
            <p class="font-work-sans text-2xl font-normal text-[#CCCCCC]">Hola,</p>
            <p class="mt-1 font-manrope text-[40px] font-semibold leading-[1.309] text-white">{displayName}</p>
          </div>
          <nav class="sidebar-nav flex-1 space-y-2 overflow-x-hidden px-3 py-2" aria-label="Principal">
            {navLinks.map((item) => {
              const active = isActive(item.href);
              return (
                <a
                  href={item.href}
                  class={`nav-link group flex items-center justify-center gap-3 rounded-[40px] px-3 py-2.5 font-work-sans text-base font-normal transition md:justify-start ${
                    active
                      ? 'bg-white text-background'
                      : 'text-white hover:bg-white/10'
                  }`}
                  title={item.label}
                >
                  <i
                    class={`bi ${item.icon} shrink-0 text-[15px] leading-none ${
                      active ? 'text-background' : 'text-white group-hover:text-white'
                    }`}
                    aria-hidden="true"
                  />
                  <span class="sidebar-label min-w-0 truncate whitespace-nowrap">{item.label}</span>
                  {item.showActiveCount && activeRetosCount > 0 && (
                    <span class={`sidebar-badge ml-auto inline-flex min-w-5 shrink-0 items-center justify-center rounded-full px-1.5 py-0.5 text-[10px] font-semibold ${active ? 'bg-background/15 text-background' : 'bg-lime/20 text-lime'}`}>
                      {activeRetosCount}
                    </span>
                  )}
                </a>
              );
            })}
          </nav>
        </div>
      </aside>
      <!-- Espaciador para contenido (ancho de la sidebar) -->
      <div id="sidebar-spacer" class="hidden shrink-0 transition-[width] duration-200 ease-out md:block md:w-[260px]" aria-hidden="true" data-width="260"></div>

      <!-- Área principal: header (negro) + bloque de contenido (gris 1A1A1A, radio solo esquina superior izquierda) -->
      <div class="flex min-w-0 flex-1 flex-col">
        <header class="sticky top-0 z-40 hidden shrink-0 bg-background py-2.5 pl-3 pr-3 md:flex md:pl-0 md:pr-6 md:py-4">
          <div class="flex w-full items-center justify-between gap-2">
            <button
              type="button"
              id="sidebar-toggle"
              class="sidebar-toggle hidden h-9 w-9 shrink-0 items-center justify-center rounded-lg text-white/70 transition hover:bg-white/10 hover:text-white md:flex"
              aria-label="Contraer menú"
              title="Contraer menú"
            >
              <svg class="h-5 w-5 shrink-0 transition-transform duration-200 sidebar-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="1" />
                <path d="M9 4v16" />
              </svg>
            </button>
            <div class="flex flex-1 items-center justify-end">
            <div class="relative" id="user-menu">
            <button
              type="button"
              id="user-menu-button"
              aria-expanded="false"
              aria-haspopup="true"
              class="flex cursor-pointer items-center gap-2 rounded-lg px-2 py-1 transition hover:bg-surface-2"
            >
              {avatarSrc ? (
                <img
                  src={avatarSrc}
                  alt=""
                  class="h-10 w-10 shrink-0 rounded-full object-cover"
                  width="40"
                  height="40"
                />
              ) : (
                <div
                  class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(217,217,217)] text-sm font-semibold text-background"
                  aria-hidden="true"
                >
                  {initialLetter}
                </div>
              )}
              <div class="hidden min-w-0 max-w-[180px] flex flex-col items-start text-left sm:flex">
                <span class="block truncate font-work-sans text-base font-semibold text-white">{displayName}</span>
                {userEmail && <span class="block truncate font-work-sans text-[14px] font-normal text-white/80">{userEmail}</span>}
              </div>
              <svg id="chevron-icon" class="h-[10px] w-4 shrink-0 stroke-white transition-transform duration-200 ease-out" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M0.353516 0.353516L8.35352 8.35352L15.3535 0.353516" stroke="white" stroke-width="1" />
              </svg>
            </button>
            <div
              id="user-menu-dropdown"
              class="pointer-events-none absolute right-0 top-full z-50 mt-1 min-w-[180px] rounded-xl bg-surface-2 py-1 shadow-lg opacity-0 transition-[opacity,transform] duration-200 ease-out"
              style="transform: translateY(-8px);"
              role="menu"
              aria-hidden="true"
            >
              {role === 'admin' && (
                <div class="flex items-center gap-2 px-4 py-2 text-xs font-medium text-lime/90" role="none">
