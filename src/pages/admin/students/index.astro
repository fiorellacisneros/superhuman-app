---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';
import { createClerkClient } from '@clerk/backend';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { data: studentRows } = await supabase
  .from('users')
  .select('id, email, display_name, avatar_id')
  .eq('role', 'student')
  .order('created_at', { ascending: false });

const pointsByUser = new Map<string, number>();
if (studentRows?.length) {
  const { data: pointsRows } = await supabase
    .from('user_course_points')
    .select('user_id, points')
    .in('user_id', studentRows.map((u) => u.id));
  for (const row of pointsRows ?? []) {
    const uid = row.user_id as string;
    pointsByUser.set(uid, (pointsByUser.get(uid) ?? 0) + (row.points ?? 0));
  }
}

const clerkEmailByUserId = new Map<string, string>();
const secretKey = import.meta.env.CLERK_SECRET_KEY ?? process.env.CLERK_SECRET_KEY;
if (secretKey) {
  try {
    const clerk = createClerkClient({ secretKey });
    for (const u of studentRows ?? []) {
      if (u.email) continue;
      try {
        const cu = await clerk.users.getUser(u.id);
        const primary = cu.emailAddresses.find((e) => e.id === cu.primaryEmailAddressId)?.emailAddress;
        const fallback = cu.emailAddresses[0]?.emailAddress;
        const email = primary ?? fallback ?? null;
        if (email) {
          clerkEmailByUserId.set(u.id, email);
          await supabase.from('users').update({ email }).eq('id', u.id);
        }
      } catch {
        // ignore per-user Clerk fetch errors
      }
    }
  } catch {
    // ignore Clerk client init issues
  }
}

type StudentWithMeta = {
  id: string;
  display_name: string;
  email: string | null;
  avatar_id: string | null;
  points: number;
  badgesCount: number;
  courseNames: string;
  enrolledCourseIds: string[];
  accessTypeByCourse: Record<string, 'live' | 'on_demand'>;
};

const students: StudentWithMeta[] = [];
const allCourses: { id: string; title: string }[] = [];

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
allCourses.push(...((coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }))));

for (const u of studentRows ?? []) {
  const { count: badgesCount } = await supabase
    .from('user_badges')
    .select('*', { count: 'exact', head: true })
    .eq('user_id', u.id);
  const { data: enrolls } = await supabase
    .from('enrollments')
    .select('course_id, access_type, courses(title)')
    .eq('user_id', u.id);
  const names = (enrolls ?? [])
    .map((e) => (e.courses as { title: string | null } | null)?.title ?? '')
    .filter(Boolean);
  const enrolledCourseIds = (enrolls ?? [])
    .map((e) => e.course_id as string)
    .filter(Boolean);
  const accessTypeByCourse: Record<string, 'live' | 'on_demand'> = {};
  for (const e of enrolls ?? []) {
    const cid = e.course_id as string;
    accessTypeByCourse[cid] = (e.access_type as string) === 'on_demand' ? 'on_demand' : 'live';
  }
  students.push({
    id: u.id,
    display_name: u.display_name ?? 'Estudiante',
    email: u.email ?? clerkEmailByUserId.get(u.id) ?? null,
    avatar_id: u.avatar_id ?? null,
    points: pointsByUser.get(u.id) ?? 0,
    badgesCount: badgesCount ?? 0,
    courseNames: names.join(', ') || '—',
    enrolledCourseIds,
    accessTypeByCourse,
  });
}
---

<DashboardLayout>
  <section class="max-w-5xl space-y-8 xl:max-w-6xl">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Alumnos</h1>
      <p class="mt-1 text-sm text-muted">Inscribir estudiantes en cursos y ver progreso.</p>
    </header>

    {students.length > 0 ? (
      <div class="relative overflow-visible rounded-xl border border-transparent bg-surface shadow-[0_8px_30px_rgba(0,0,0,0.18)]">
        <div class="-mx-2 overflow-x-auto overflow-y-visible px-2 sm:mx-0 sm:px-0">
        <table class="w-full min-w-[760px] text-left text-sm">
          <thead>
            <tr class="border-b border-transparent bg-surface-2/40 text-muted">
              <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Estudiante</th>
              <th class="px-4 pb-3 pt-3 text-center text-[11px] font-semibold uppercase tracking-[0.14em]">Puntos</th>
              <th class="px-4 pb-3 pt-3 text-center text-[11px] font-semibold uppercase tracking-[0.14em]">Insignias</th>
              <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Cursos</th>
              <th class="px-4 pb-3 pt-3 text-right text-[11px] font-semibold uppercase tracking-[0.14em]">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {students.map((s) => (
              <tr class="border-b border-transparent/60 transition-colors hover:bg-surface-2/30 last:border-0">
                <td class="px-4 py-4">
                  <div class="flex items-center gap-3">
                    <div class="h-9 w-9 shrink-0 overflow-hidden rounded-full border border-transparent bg-surface-2">
                      {avatarImagePath(s.avatar_id) ? (
                        <img
                          src={avatarImagePath(s.avatar_id)!}
                          alt=""
                          class="h-full w-full object-cover"
                          width="36"
                          height="36"
                        />
                      ) : (
                        <span class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted">
                          {(s.display_name || 'E').charAt(0).toUpperCase()}
                        </span>
                      )}
                    </div>
                    <div>
                      <p class="font-medium text-white">{s.display_name}</p>
                      <p class="text-xs text-muted">{s.email ?? '—'}</p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-4 text-center">
                  <span class="inline-flex min-w-10 items-center justify-center rounded-full bg-lime/10 px-2.5 py-1 text-xs font-semibold text-lime">
                    {s.points}
                  </span>
                </td>
                <td class="px-4 py-4 text-center">
                  <span class="inline-flex min-w-10 items-center justify-center rounded-full bg-surface-2 px-2.5 py-1 text-xs font-semibold text-white">
                    {s.badgesCount}
                  </span>
                </td>
                <td class="max-w-[260px] px-4 py-4 text-muted" title={s.courseNames}>
                  <p class="line-clamp-2 text-sm">{s.courseNames}</p>
                </td>
                <td class="relative z-20 px-4 py-4 text-right">
                  <div class="flex flex-wrap items-center justify-end gap-2">
                    <div class="relative z-30">
                      <button
                        type="button"
                        class="course-picker-trigger inline-flex h-8 cursor-pointer items-center gap-2 rounded-lg border border-transparent bg-surface-2 px-3 text-xs font-medium text-white transition hover:border-lime/50"
                        data-user-id={s.id}
                        aria-expanded="false"
                      >
                        Asignar cursos
                        <span class="rounded-full bg-lime/15 px-1.5 py-0.5 text-[10px] font-semibold text-lime">{s.enrolledCourseIds.length}</span>
                        <svg class="h-3.5 w-3.5 text-muted transition" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 9l6 6 6-6" />
                        </svg>
                      </button>
                      <form
                        method="post"
                        action="/api/admin/enrollments"
                        class="course-picker-panel fixed z-[9999] hidden w-[240px] rounded-xl border border-transparent bg-surface p-3 shadow-2xl"
                        data-user-id={s.id}
                      >
                        <input type="hidden" name="action" value="sync" />
                        <input type="hidden" name="user_id" value={s.id} />
                        <input type="hidden" name="redirect_to" value="/admin/students" />
                        <p class="mb-2 text-left text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Cursos</p>
                        <div class="max-h-52 space-y-1 overflow-y-auto pr-1">
                          {allCourses.map((c) => (
                            <div class="flex items-center gap-2 rounded-md px-2 py-1.5 text-left text-xs">
                              <label class="group/option flex min-w-0 flex-1 cursor-pointer items-center gap-2 transition hover:bg-surface-2">
                                <input
                                  type="checkbox"
                                  name="course_ids"
                                  value={c.id}
                                  checked={s.enrolledCourseIds.includes(c.id)}
                                  class="peer sr-only"
                                />
                                <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border border-transparent bg-surface-2 text-transparent transition peer-checked:border-lime peer-checked:bg-lime peer-checked:text-white peer-checked:shadow-[0_0_0_1px_var(--color-lime)] group-hover/option:border-lime/60">
                                  <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                                </span>
                                <span class="min-w-0 flex-1 truncate">{c.title}</span>
                              </label>
                              <div class="relative w-[100px] shrink-0">
                                <select
                                  name={`access_type_${c.id}`}
                                  class="w-full cursor-pointer appearance-none rounded border border-transparent bg-surface-2 py-1 pl-1.5 pr-6 text-[11px] text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                                  title="Live u On-demand"
                                >
                                  <option value="live" selected={s.accessTypeByCourse[c.id] !== 'on_demand'}>Live</option>
                                  <option value="on_demand" selected={s.accessTypeByCourse[c.id] === 'on_demand'}>On-demand</option>
                                </select>
                                <svg class="pointer-events-none absolute right-1 top-1/2 h-3 w-3 -translate-y-1/2 text-muted" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                                </svg>
                              </div>
                            </div>
                          ))}
                        </div>
                        <button type="submit" class="btn btn-secondary mt-3 w-full text-xs">
                          Guardar cursos
                        </button>
                      </form>
                    </div>
                    <a href={`/admin/students/${s.id}`} class="btn btn-ghost h-8 text-xs">
                      Ver progreso
                    </a>
                    <form
                      method="post"
                      action="/api/admin/students/delete"
                      class="inline"
                      id={`delete-form-${s.id}`}
                    >
                      <input type="hidden" name="user_id" value={s.id} />
                      <input type="hidden" name="redirect_to" value="/admin/students" />
                      <button
                        type="button"
                        data-delete-confirm
                        data-confirm-label={s.display_name}
                        data-delete-form-id={`delete-form-${s.id}`}
                        class="btn btn-danger btn-icon h-8 w-8"
                        title="Eliminar estudiante"
                        aria-label="Eliminar"
                      >
                        <i class="bi bi-trash" aria-hidden="true"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-transparent bg-background p-8 text-center">
        <p class="text-sm font-medium text-white">Aún no hay estudiantes inscritos.</p>
        <p class="mt-1 text-sm text-muted">Los usuarios con rol estudiante aparecerán aquí.</p>
      </div>
    )}
  </section>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const triggers = Array.from(document.querySelectorAll('.course-picker-trigger'));
      const panels = Array.from(document.querySelectorAll('.course-picker-panel'));
      if (!triggers.length || !panels.length) return;

      let currentPanel = null;
      let currentTrigger = null;

      function closeCurrent() {
        if (currentPanel) currentPanel.classList.add('hidden');
        if (currentTrigger) {
          currentTrigger.setAttribute('aria-expanded', 'false');
          const icon = currentTrigger.querySelector('svg');
          icon?.classList.remove('rotate-180');
        }
        currentPanel = null;
        currentTrigger = null;
      }

      function openPanel(trigger, panel) {
        closeCurrent();
        if (panel.parentElement !== document.body) {
          document.body.appendChild(panel);
        }
        panel.classList.remove('hidden');

        const rect = trigger.getBoundingClientRect();
        const panelRect = panel.getBoundingClientRect();
        const margin = 10;
        const gap = 8;

        let left = rect.right - panelRect.width;
        left = Math.max(margin, Math.min(left, window.innerWidth - panelRect.width - margin));

        let top;
        const spaceBelow = window.innerHeight - rect.bottom - margin;
        const spaceAbove = rect.top - margin;
        if (spaceBelow >= panelRect.height + gap) {
          top = rect.bottom + gap;
        } else if (spaceAbove >= panelRect.height + gap) {
          top = rect.top - panelRect.height - gap;
        } else {
          top = spaceBelow >= spaceAbove ? rect.bottom + gap : rect.top - panelRect.height - gap;
          top = Math.max(margin, Math.min(top, window.innerHeight - panelRect.height - margin));
        }

        panel.style.left = `${left}px`;
        panel.style.top = `${top}px`;

        trigger.setAttribute('aria-expanded', 'true');
        const icon = trigger.querySelector('svg');
        icon?.classList.add('rotate-180');

        currentPanel = panel;
        currentTrigger = trigger;
      }

      for (const trigger of triggers) {
        const userId = trigger.dataset.userId;
        const panel = panels.find((p) => p.dataset.userId === userId);
        if (!panel) continue;

        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const isOpen = currentPanel === panel && !panel.classList.contains('hidden');
          if (isOpen) closeCurrent();
          else openPanel(trigger, panel);
        });
      }

      document.addEventListener('click', (e) => {
        if (!currentPanel || !currentTrigger) return;
        const target = e.target;
        if (!(target instanceof Node)) return;
        if (currentPanel.contains(target) || currentTrigger.contains(target)) return;
        closeCurrent();
      });

      window.addEventListener('resize', closeCurrent);
      window.addEventListener('scroll', closeCurrent, true);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeCurrent();
      });

    });
  </script>
</DashboardLayout>
