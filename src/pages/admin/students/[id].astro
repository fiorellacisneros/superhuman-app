---
import '../../../styles/global.css';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';
import { createClerkClient } from '@clerk/backend';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: adminRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((adminRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id: studentId } = Astro.params as { id: string };
if (!studentId) {
  return Astro.redirect('/admin/students');
}

const { data: student } = await supabase
  .from('users')
  .select('id, display_name, email, avatar_id, points, created_at, role')
  .eq('id', studentId)
  .maybeSingle();

if (!student || student.role !== 'student') {
  return Astro.redirect('/admin/students');
}

let studentEmail = student.email ?? null;
if (!studentEmail) {
  const secretKey = import.meta.env.CLERK_SECRET_KEY ?? process.env.CLERK_SECRET_KEY;
  if (secretKey) {
    try {
      const clerk = createClerkClient({ secretKey });
      const cu = await clerk.users.getUser(student.id);
      const primary = cu.emailAddresses.find((e) => e.id === cu.primaryEmailAddressId)?.emailAddress;
      const fallback = cu.emailAddresses[0]?.emailAddress;
      studentEmail = primary ?? fallback ?? null;
      if (studentEmail && !student.email) {
        await supabase.from('users').update({ email: studentEmail }).eq('id', student.id);
      }
    } catch {
      // ignore Clerk fetch errors
    }
  }
}

const { count: badgesCount } = await supabase
  .from('user_badges')
  .select('*', { count: 'exact', head: true })
  .eq('user_id', studentId);

const { count: coursesCount } = await supabase
  .from('enrollments')
  .select('*', { count: 'exact', head: true })
  .eq('user_id', studentId);

const { count: approvedSubmissionsCount } = await supabase
  .from('submissions')
  .select('*', { count: 'exact', head: true })
  .eq('user_id', studentId)
  .eq('approved', true);

const { data: enrollmentsRows } = await supabase
  .from('enrollments')
  .select('course_id, enrolled_at, access_type, courses(id, slug, title)')
  .eq('user_id', studentId)
  .order('enrolled_at', { ascending: false });

const enrolledCourses = (enrollmentsRows ?? []).map((e) => {
  const c = e.courses as { id: string; slug: string | null; title: string | null } | null;
  return {
    id: c?.id ?? e.course_id,
    slug: typeof c?.slug === 'string' && c.slug.trim() ? c.slug.trim() : (c?.id ?? e.course_id),
    title: c?.title ?? 'Curso',
    enrolledAt: e.enrolled_at as string | null,
    accessType: (e.access_type as string) === 'on_demand' ? 'on_demand' : 'live',
  };
});

const { data: userBadgeRows } = await supabase
  .from('user_badges')
  .select('earned_at, badges(name, description, condition_type)')
  .eq('user_id', studentId)
  .order('earned_at', { ascending: false });

const iconMap: Record<string, string> = {
  first_submission: 'bi-box-arrow-in-down',
  on_time: 'bi-clock-fill',
  early_bird: 'bi-lightning-fill',
  streak_3: 'bi-fire',
  attendance_streak_3: 'bi-calendar-check-fill',
  first_attendance: 'bi-geo-alt-fill',
  module_complete: 'bi-hammer',
  night_owl: 'bi-moon-fill',
  course_complete: 'bi-trophy-fill',
  manual: 'bi-star-fill',
};

const badges = (userBadgeRows ?? []).map((r) => {
  const b = r.badges as { name: string | null; description: string | null; condition_type: string | null } | null;
  return {
    name: b?.name ?? 'Insignia',
    description: b?.description ?? null,
    conditionType: b?.condition_type ?? null,
    earnedAt: r.earned_at as string | null,
  };
});

const { data: submissionsRows } = await supabase
  .from('submissions')
  .select('id, link, submitted_at, reviewed, approved, challenges(title, points_reward)')
  .eq('user_id', studentId)
  .order('submitted_at', { ascending: false })
  .limit(8);

const submissions = (submissionsRows ?? []).map((s) => {
  const c = s.challenges as { title: string | null; points_reward: number | null } | null;
  return {
    id: s.id,
    link: s.link ?? '',
    submittedAt: s.submitted_at as string,
    reviewed: Boolean(s.reviewed),
    approved: Boolean(s.approved),
    challengeTitle: c?.title ?? 'Desafío',
    pointsReward: c?.points_reward ?? 0,
  };
});

const { data: attendanceRows } = await supabase
  .from('attendance')
  .select('confirmed_at, lessons(title, courses(title))')
  .eq('user_id', studentId)
  .order('confirmed_at', { ascending: false })
  .limit(6);

const attendance = (attendanceRows ?? []).map((a) => {
  const lesson = a.lessons as { title: string | null; courses: { title: string | null } | null } | null;
  return {
    lessonTitle: lesson?.title ?? 'Clase',
    courseTitle: lesson?.courses?.title ?? 'Curso',
    confirmedAt: a.confirmed_at as string | null,
  };
});

function formatDate(iso: string | null): string {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleDateString('es', { day: '2-digit', month: 'short', year: 'numeric' });
  } catch {
    return iso;
  }
}
---

<AdminLayout>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/admin/students" class="hover:text-white">Alumnos</a>
      <span class="mx-1">/</span>
      <span class="text-white">{student.display_name ?? 'Estudiante'}</span>
    </nav>

    <header class="rounded-xl border border-border bg-surface p-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <div class="h-14 w-14 overflow-hidden rounded-full border border-border bg-surface-2">
            {avatarImagePath(student.avatar_id) ? (
              <img src={avatarImagePath(student.avatar_id)!} alt="" class="h-full w-full object-cover" width="56" height="56" />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-sm font-semibold text-muted">
                {(student.display_name ?? 'E').charAt(0).toUpperCase()}
              </div>
            )}
          </div>
          <div>
            <h1 class="text-xl font-semibold text-white">{student.display_name ?? 'Estudiante'}</h1>
            <p class="text-sm text-muted">{studentEmail ?? 'Sin email'}</p>
          </div>
        </div>
        <p class="text-xs text-muted">Miembro desde {formatDate(student.created_at as string | null)}</p>
      </div>
    </header>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Puntos</p>
        <p class="mt-1 text-2xl font-semibold text-lime">{student.points ?? 0}</p>
      </div>
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Insignias</p>
        <p class="mt-1 text-2xl font-semibold text-white">{badgesCount ?? 0}</p>
      </div>
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Cursos</p>
        <p class="mt-1 text-2xl font-semibold text-white">{coursesCount ?? 0}</p>
      </div>
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Entregas aprobadas</p>
        <p class="mt-1 text-2xl font-semibold text-white">{approvedSubmissionsCount ?? 0}</p>
      </div>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      <section class="rounded-xl border border-border bg-surface p-5">
        <h2 class="text-sm font-semibold text-white">Cursos inscritos</h2>
        {enrolledCourses.length > 0 ? (
          <ul class="mt-3 space-y-2">
            {enrolledCourses.map((c) => (
              <li class="rounded-lg border border-border bg-surface-2/60 px-3 py-2">
                <div class="flex items-center justify-between gap-2">
                  <a href={`/courses/${c.slug}`} class="truncate text-sm font-medium text-white hover:text-lime">
                    {c.title}
                  </a>
                  <div class="flex shrink-0 items-center gap-2">
                    <span class={`rounded px-1.5 py-0.5 text-[10px] font-medium ${c.accessType === 'on_demand' ? 'bg-amber-500/15 text-amber-400' : 'bg-lime/15 text-lime'}`}>
                      {c.accessType === 'on_demand' ? 'On-demand' : 'Live'}
                    </span>
                    <span class="text-[11px] text-muted">{formatDate(c.enrolledAt)}</span>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-3 text-sm text-muted">Sin cursos asignados todavía.</p>
        )}
      </section>

      <section class="rounded-xl border border-border bg-surface p-5">
        <h2 class="text-sm font-semibold text-white">Insignias ganadas</h2>
        {badges.length > 0 ? (
          <ul class="mt-3 space-y-2">
            {badges.map((b) => (
              <li class="flex items-start gap-3 rounded-lg border border-border bg-surface-2/60 px-3 py-2">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-lime/15 text-lime ring-1 ring-lime/40">
                  <i class={`bi ${iconMap[b.conditionType ?? ''] ?? 'bi-star-fill'} text-sm`} aria-hidden="true" />
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium text-white">{b.name}</p>
                  {b.description && <p class="text-xs text-muted">{b.description}</p>}
                </div>
                <span class="shrink-0 text-[11px] text-muted">{formatDate(b.earnedAt)}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-3 text-sm text-muted">Aún no tiene insignias.</p>
        )}
      </section>
    </div>

    <section class="rounded-xl border border-border bg-surface p-5">
      <h2 class="text-sm font-semibold text-white">Entregas recientes</h2>
      {submissions.length > 0 ? (
        <div class="-mx-2 mt-3 overflow-x-auto rounded-xl border border-border bg-surface-2/20 px-2 sm:mx-0 sm:px-0">
          <table class="w-full min-w-[620px] text-left text-sm">
            <thead>
              <tr class="border-b border-border bg-surface-2/40 text-muted">
                <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Desafío</th>
                <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Fecha</th>
                <th class="px-4 pb-3 pt-3 text-center text-[11px] font-semibold uppercase tracking-[0.14em]">Estado</th>
                <th class="px-4 pb-3 pt-3 text-center text-[11px] font-semibold uppercase tracking-[0.14em]">Pts</th>
                <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Link</th>
              </tr>
            </thead>
            <tbody>
              {submissions.map((s) => (
                <tr class="border-b border-border/60 transition-colors hover:bg-surface-2/30 last:border-0">
                  <td class="px-4 py-3 text-white">{s.challengeTitle}</td>
                  <td class="px-4 py-3 text-muted">{formatDate(s.submittedAt)}</td>
                  <td class="px-4 py-3 text-center">
                    {s.reviewed ? (
                      <span class={`inline-flex rounded-full px-2.5 py-1 text-[11px] font-medium ${s.approved ? 'bg-lime/15 text-lime' : 'bg-red-500/15 text-red-300'}`}>
                        {s.approved ? 'Aprobada' : 'Rechazada'}
                      </span>
                    ) : (
                      <span class="inline-flex rounded-full bg-surface-2 px-2.5 py-1 text-[11px] font-medium text-muted">Pendiente</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-center text-white">{s.pointsReward}</td>
                  <td class="px-4 py-3">
                    <a href={s.link} target="_blank" rel="noopener noreferrer" class="text-lime hover:underline">
                      Ver
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="mt-3 text-sm text-muted">No hay entregas registradas.</p>
      )}
    </section>

    <section class="rounded-xl border border-border bg-surface p-5">
      <h2 class="text-sm font-semibold text-white">Asistencias recientes</h2>
      {attendance.length > 0 ? (
        <ul class="mt-3 space-y-2">
          {attendance.map((a) => (
            <li class="flex items-center justify-between gap-2 rounded-lg border border-border bg-surface-2/60 px-3 py-2">
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-white">{a.lessonTitle}</p>
                <p class="truncate text-xs text-muted">{a.courseTitle}</p>
              </div>
              <span class="shrink-0 text-[11px] text-muted">{formatDate(a.confirmedAt)}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-3 text-sm text-muted">No hay asistencias registradas.</p>
      )}
    </section>
  </section>
</AdminLayout>
