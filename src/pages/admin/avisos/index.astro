---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import AnnouncementFormFields from '../../../components/AnnouncementFormFields.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { formatDateTime } from '../../../lib/format-date';
import { formatVisibilitySummary, resolveVisibilityConditionsFromRow } from '../../../lib/announcements';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

type Row = {
  id: string;
  is_active: boolean;
  sort_order: number;
  title: string | null;
  audience: string;
  course_id: string | null;
  starts_at: string | null;
  ends_at: string | null;
  created_at: string;
  min_points?: number | null;
  require_enrolled_course_id?: string | null;
};

let rows: Row[] = [];
const annRes = await supabase
  .from('announcements')
  .select('*')
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

if (!annRes.error && annRes.data) {
  rows = annRes.data as Row[];
} else if (annRes.error && !/does not exist|relation/i.test(String(annRes.error.message))) {
  console.error('[admin/avisos]', annRes.error);
}

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id as string, title: (c.title as string) ?? 'Curso' }));
const courseTitleById = new Map(courses.map((c) => [c.id, c.title]));

function fmt(iso: string | null): string {
  if (!iso) return '—';
  return formatDateTime(iso, 'America/Lima');
}

const announcementListItems = rows.map((r) => {
  const courseTitle = r.course_id ? (courseTitleById.get(r.course_id) ?? null) : null;
  const vis = resolveVisibilityConditionsFromRow(r as unknown as Record<string, unknown>);
  const visLine = formatVisibilitySummary(vis, courseTitleById);
  return { r, courseTitle, vis, visLine };
});
---

<DashboardLayout>
  <Fragment slot="head">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js" defer></script>
  </Fragment>
  <section class="max-w-5xl space-y-8 xl:max-w-6xl">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Avisos</h1>
      <p class="mt-1 text-sm text-muted">
        Tarjetas informativas en el dashboard del estudiante: texto o lista, imagen y botones; audiencia, fechas, puntos mínimos o curso de inscripción obligatorio.
      </p>
    </header>

    {annRes.error && /does not exist|relation/i.test(String(annRes.error.message)) && (
      <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
        Falta la tabla en Supabase. Ejecuta el SQL en{' '}
        <code class="rounded bg-black/30 px-1.5 py-0.5 text-xs">docs/announcements-migration.sql</code>
        y crea el bucket público <code class="rounded bg-black/30 px-1.5 py-0.5 text-xs">announcement-images</code> si quieres subir imágenes. Para condiciones (puntos / curso) ejecuta también{' '}
        <code class="rounded bg-black/30 px-1.5 py-0.5 text-xs">docs/announcements-conditions-migration.sql</code>.
      </div>
    )}

    <div class="rounded-xl border border-transparent bg-surface">
      <button
        type="button"
        id="toggle-create-ann"
        aria-expanded="false"
        aria-controls="create-ann-form"
        class="flex w-full items-center justify-between px-5 py-4 text-left text-sm font-medium text-white transition hover:bg-surface-2/60"
      >
        <span>Crear aviso</span>
        <svg
          id="toggle-create-ann-icon"
          class="h-5 w-5 shrink-0 text-muted transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id="create-ann-form" class="hidden border-t border-transparent px-5 pb-6 pt-5" role="region">
        <form method="post" action="/api/admin/announcements" enctype="multipart/form-data" class="space-y-8">
          <AnnouncementFormFields
            mode="create"
            redirectTo="/admin/avisos"
            courses={courses}
            initial={null}
            formSuffix="create"
          />
          <button type="submit" class="btn btn-primary w-full sm:w-auto">Publicar aviso</button>
        </form>
      </div>
    </div>

    <div class="space-y-3">
      <h2 class="text-sm font-semibold text-white">Publicados</h2>
      {rows.length === 0 ? (
        <p class="rounded-xl border border-dashed border-white/15 bg-surface-2/30 px-4 py-8 text-center text-sm text-muted">
          Aún no hay avisos. Crea uno con el formulario de arriba.
        </p>
      ) : (
        <ul class="space-y-3">
          {announcementListItems.map(({ r, courseTitle, vis, visLine }) => (
              <li class="rounded-xl border border-transparent bg-surface p-4 sm:flex sm:items-start sm:justify-between sm:gap-4">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span
                      class={`inline-flex rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide ${
                        r.is_active ? 'bg-lime/20 text-lime' : 'bg-white/10 text-muted'
                      }`}
                    >
                      {r.is_active ? 'Activo' : 'Pausado'}
                    </span>
                    <span class="text-[10px] text-muted">Orden {r.sort_order}</span>
                  </div>
                  <p class="mt-2 font-medium text-white">{r.title?.trim() || 'Sin título'}</p>
                  <p class="mt-1 text-xs text-muted">
                    {r.audience === 'course'
                      ? `Curso: ${courseTitle ?? r.course_id ?? '—'}`
                      : 'Todos los estudiantes'}
                    {visLine && (
                      <>
                        {' · '}
                        <span class="text-lime/90" title="Condiciones de visibilidad">
                          {vis.match === 'any' ? '(cualquiera) ' : '(todas) '}
                          {visLine}
                        </span>
                      </>
                    )}
                  </p>
                  <p class="mt-0.5 text-[10px] text-muted/80">
                    Desde {fmt(r.starts_at)} · Hasta {fmt(r.ends_at)}
                  </p>
                </div>
                <div class="mt-3 flex shrink-0 flex-wrap gap-2 sm:mt-0">
                  <a
                    href={`/admin/avisos/${r.id}/edit`}
                    class="inline-flex items-center justify-center rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-xs font-medium text-white transition hover:border-lime/40"
                  >
                    Editar
                  </a>
                  <form method="post" action="/api/admin/announcements" class="inline">
                    <input type="hidden" name="redirect_to" value="/admin/avisos" />
                    <input type="hidden" name="action" value="toggle" />
                    <input type="hidden" name="announcement_id" value={r.id} />
                    <button
                      type="submit"
                      class="inline-flex items-center justify-center rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-xs font-medium text-muted transition hover:text-white"
                    >
                      {r.is_active ? 'Pausar' : 'Activar'}
                    </button>
                  </form>
                  <form method="post" action="/api/admin/announcements" class="inline" data-confirm-delete>
                    <input type="hidden" name="redirect_to" value="/admin/avisos" />
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="announcement_id" value={r.id} />
                    <button
                      type="submit"
                      class="inline-flex items-center justify-center rounded-lg border border-red-500/30 px-3 py-2 text-xs font-medium text-red-300 transition hover:bg-red-500/10"
                    >
                      Eliminar
                    </button>
                  </form>
                </div>
              </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</DashboardLayout>

<script is:inline>
  (function () {
    function init() {
      var toggle = document.getElementById('toggle-create-ann');
      var form = document.getElementById('create-ann-form');
      var icon = document.getElementById('toggle-create-ann-icon');
      if (toggle && form && icon) {
        toggle.addEventListener('click', function () {
          var open = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!open));
          form.classList.toggle('hidden', open);
          icon.classList.toggle('rotate-180', !open);
          if (!open) {
            requestAnimationFrame(function () {
              document.dispatchEvent(new CustomEvent('custom-select-reinit', { detail: { container: form } }));
              document.dispatchEvent(new CustomEvent('ann-form-shown', { detail: { suffix: 'create' } }));
            });
          }
        });
      }
      document.querySelectorAll('form[data-confirm-delete]').forEach(function (f) {
        f.addEventListener('submit', function (e) {
          if (!confirm('¿Eliminar este aviso? No se puede deshacer.')) e.preventDefault();
        });
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
<script is:inline>
  (function () {
    var fpOpts = { enableTime: true, dateFormat: 'Y-m-d H:i', locale: 'es', time_24hr: true, allowInput: false };
    function initFp(suffix) {
      if (typeof window.flatpickr !== 'function') return;
      var s = document.getElementById('ann-starts-' + suffix);
      var e = document.getElementById('ann-ends-' + suffix);
      if (s && !s.dataset.flatpickrInit) {
        window.flatpickr(s, fpOpts);
        s.dataset.flatpickrInit = '1';
      }
      if (e && !e.dataset.flatpickrInit) {
        window.flatpickr(e, fpOpts);
        e.dataset.flatpickrInit = '1';
      }
    }
    document.addEventListener('ann-form-shown', function (ev) {
      var d = ev.detail || {};
      if (d.suffix) initFp(d.suffix);
    });
    function boot() {
      initFp('create');
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
</script>
