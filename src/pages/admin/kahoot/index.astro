---
import '../../../styles/global.css';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const selectedCourseId = Astro.url.searchParams.get('course') ?? '';
const selectedLessonId = Astro.url.searchParams.get('lesson') ?? '';

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));

const { data: lessonRows } = await supabase
  .from('lessons')
  .select('id, title, scheduled_at, order, course_id, courses(title)')
  .order('scheduled_at', { ascending: true, nullsFirst: false });

const allLessons = (lessonRows ?? []).map((l) => {
  const course = l.courses as { title: string | null } | null;
  return {
    id: l.id,
    title: l.title ?? 'Clase',
    scheduledAt: (l.scheduled_at as string | null) ?? null,
    order: (l.order as number | null) ?? 0,
    courseId: l.course_id as string,
    courseTitle: course?.title ?? 'Curso',
  };
});

const lessons = selectedCourseId ? allLessons.filter((l) => l.courseId === selectedCourseId) : [];
const selectedCourse = courses.find((c) => c.id === selectedCourseId) ?? null;
const selectedLesson = allLessons.find((l) => l.id === selectedLessonId) ?? null;

let students: { id: string; name: string; avatarId: string | null }[] = [];
let alreadyRegistered = false;
if (selectedLesson) {
  const { data: enrollmentRows } = await supabase
    .from('enrollments')
    .select('user_id, access_type, users(id, display_name, avatar_id, role)')
    .eq('course_id', selectedLesson.courseId);

  const { data: kahootRows } = await supabase
    .from('kahoot_results')
    .select('id')
    .eq('lesson_id', selectedLesson.id)
    .limit(1);
  alreadyRegistered = (kahootRows ?? []).length > 0;

  students = (enrollmentRows ?? [])
    .filter((row) => (row.access_type as string) !== 'on_demand')
    .map((row) => {
      const u = row.users as { id: string; display_name: string | null; avatar_id: string | null; role: string | null } | null;
      if (!u?.id || u.role !== 'student') return null;
      return {
        id: u.id,
        name: u.display_name ?? 'Estudiante',
        avatarId: u.avatar_id ?? null,
      };
    })
    .filter((s): s is { id: string; name: string; avatarId: string | null } => Boolean(s))
    .sort((a, b) => a.name.localeCompare(b.name));
}

function formatDateTime(iso: string | null): string {
  if (!iso) return 'Sin fecha';
  try {
    return new Date(iso).toLocaleString('es', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  } catch {
    return iso;
  }
}
---

<AdminLayout>
  <section class="space-y-6">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Kahoot</h1>
      <p class="mt-1 text-sm text-muted">
        Registra resultados de Kahoot por clase. Asigna podio (1º-5º) y participación.
      </p>
    </header>

    <div class="rounded-xl border border-border bg-surface p-5">
      <form method="get" action="/admin/kahoot" class="flex flex-wrap items-end gap-3">
        <div class="min-w-[240px]">
          <label for="course-select" class="block text-xs font-medium text-muted">Curso</label>
          <div class="custom-select custom-select--single relative mt-1" data-name="course">
            <input type="hidden" id="course-select" name="course" value={selectedCourseId} />
            <button
              type="button"
              class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-border bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span class="custom-select-label truncate">{selectedCourse?.title ?? '— Elige un curso —'}</span>
              <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
              </svg>
            </button>
            <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-border bg-surface p-2 shadow-2xl" role="listbox">
              <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!selectedCourseId ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Elige un curso —">
                <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!selectedCourseId ? 'border-lime bg-lime text-background' : 'border-border bg-surface-2 text-transparent'}`}>
                  <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                </span>
                <span class="truncate">— Elige un curso —</span>
              </button>
              {courses.map((c) => {
                const isSelected = selectedCourseId === c.id;
                return (
                  <button
                    type="button"
                    class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                    data-value={c.id}
                    data-label={c.title}
                  >
                    <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-border bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">{c.title}</span>
                  </button>
                );
              })}
            </div>
          </div>
        </div>
        <button type="submit" class="rounded-lg border border-lime bg-lime/15 px-4 py-2 text-sm font-medium text-lime transition hover:bg-lime/25">
          Cargar clases
        </button>
      </form>

      {selectedCourseId && (
        <form method="get" action="/admin/kahoot" class="mt-4 flex flex-wrap items-end gap-3">
          <input type="hidden" name="course" value={selectedCourseId} />
          <div class="min-w-[280px]">
            <label for="lesson-select" class="block text-xs font-medium text-muted">Clase</label>
            <div class="custom-select custom-select--single relative mt-1" data-name="lesson">
              <input type="hidden" id="lesson-select" name="lesson" value={selectedLessonId} />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-border bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
                aria-haspopup="listbox"
              >
                <span class="custom-select-label truncate">
                  {selectedLesson ? `${selectedLesson.title} · ${formatDateTime(selectedLesson.scheduledAt)}` : '— Elige una clase —'}
                </span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-border bg-surface p-2 shadow-2xl" role="listbox">
                <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!selectedLessonId ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Elige una clase —">
                  <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!selectedLessonId ? 'border-lime bg-lime text-background' : 'border-border bg-surface-2 text-transparent'}`}>
                    <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                  </span>
                  <span class="truncate">— Elige una clase —</span>
                </button>
                {lessons.map((l) => {
                  const optionLabel = `${l.title} · ${formatDateTime(l.scheduledAt)}`;
                  const isSelected = selectedLessonId === l.id;
                  return (
                    <button
                      type="button"
                      class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                      data-value={l.id}
                      data-label={optionLabel}
                    >
                      <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-border bg-surface-2 text-transparent'}`}>
                        <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                      </span>
                      <span class="truncate">{optionLabel}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          </div>
          <button type="submit" class="rounded-lg border border-border bg-surface-2 px-4 py-2 text-sm font-medium text-white transition hover:border-lime/50 hover:bg-surface-2/80">
            Cargar alumnos
          </button>
        </form>
      )}

      {selectedCourseId && lessons.length === 0 && (
        <p class="mt-4 text-sm text-muted">No hay clases en este curso.</p>
      )}
    </div>

    {selectedLesson && students.length > 0 ? (
      <div class="rounded-xl border border-border bg-surface p-5">
        <div class="mb-4">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{selectedLesson.courseTitle}</p>
          <h2 class="mt-1 text-lg font-semibold text-white">{selectedLesson.title}</h2>
          <p class="text-xs text-muted">{formatDateTime(selectedLesson.scheduledAt)}</p>
        </div>

        {alreadyRegistered ? (
          <div class="rounded-lg border border-lime/40 bg-lime/10 p-4">
            <p class="text-sm font-medium text-lime">Ya registraste Kahoot para esta clase. Los puntos ya fueron asignados.</p>
          </div>
        ) : (
          <form method="post" action="/api/admin/kahoot" class="space-y-6">
            <input type="hidden" name="lesson_id" value={selectedLesson.id} />
            <input type="hidden" name="redirect_to" value={`/admin/kahoot?course=${selectedLesson.courseId}&lesson=${selectedLesson.id}`} />

            <div class="grid gap-6 lg:grid-cols-3">
              <div class="space-y-4 lg:col-span-2">
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
                  {[1, 2, 3, 4, 5].map((pos) => (
                    <div>
                      <label for={`position_${pos}`} class="block text-xs font-medium text-muted">{pos}º lugar</label>
                      <select
                        id={`position_${pos}`}
                        name={`position_${pos}`}
                        class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2.5 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                      >
                        <option value="">—</option>
                        {students.map((s) => (
                          <option value={s.id}>{s.name}</option>
                        ))}
                      </select>
                    </div>
                  ))}
                </div>

                <p class="text-xs text-muted">Referencia: cruza los nombres de Kahoot con la lista de abajo.</p>

                <div class="rounded-lg border border-border bg-surface-2/40 p-3">
              <p class="mb-2 text-xs font-medium text-muted">Participaron (5 pts cada uno) — marca solo a quienes jugaron</p>
              <div class="flex flex-wrap gap-2">
                {students.map((s) => (
                  <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-border bg-surface-2/60 px-2.5 py-1.5 transition hover:border-lime/50 has-[:checked]:border-lime/50 has-[:checked]:bg-lime/10">
                    <input type="checkbox" name="participant_ids" value={s.id} class="peer sr-only" />
                    <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border border-border bg-surface text-transparent transition peer-checked:border-lime peer-checked:bg-lime peer-checked:text-background">
                      <i class="bi bi-check-lg text-[10px] leading-none" aria-hidden="true" />
                    </span>
                    {avatarImagePath(s.avatarId) ? (
                      <img src={avatarImagePath(s.avatarId)!} alt="" class="h-5 w-5 shrink-0 rounded-full object-cover" width="20" height="20" />
                    ) : (
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-surface text-[9px] font-semibold text-muted">{s.name.charAt(0).toUpperCase()}</span>
                    )}
                    <span class="text-xs text-white">{s.name}</span>
                  </label>
                ))}
              </div>
                </div>

                <div class="flex flex-wrap items-center gap-4">
                  <button type="submit" class="rounded-lg border border-lime bg-lime px-5 py-2.5 text-sm font-semibold text-background transition hover:bg-lime/90">
                    Guardar y asignar puntos
                  </button>
                </div>
              </div>

              <aside class="w-full lg:max-w-[280px]">
                <div class="rounded-xl border border-border bg-surface p-4">
                  <h2 class="text-xs font-semibold text-white">Leyenda</h2>
                  <p class="mt-0.5 text-[10px] text-muted">Puntos por posición.</p>
                  <ul class="mt-3 space-y-2">
                    {[
                      [1, 50],
                      [2, 40],
                      [3, 30],
                      [4, 20],
                      [5, 15],
                    ].map(([pos, pts]) => (
                      <li class="flex items-center justify-between rounded-lg border border-border bg-surface-2/60 px-3 py-2">
                        <span class="text-xs text-muted">{pos}º</span>
                        <span class="text-xs font-semibold text-lime">{pts} pts</span>
                      </li>
                    ))}
                    <li class="flex items-center justify-between rounded-lg border border-border bg-surface-2/60 px-3 py-2">
                      <span class="text-xs text-muted">Participación</span>
                      <span class="text-xs font-semibold text-white">5 pts</span>
                    </li>
                  </ul>
                </div>
              </aside>
            </div>
          </form>
        )}
      </div>
    ) : selectedCourseId ? (
      <div class="rounded-xl border border-dashed border-border bg-surface-2/60 p-6 text-sm text-muted">
        Elige una clase y haz clic en Cargar alumnos para registrar Kahoot.
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-border bg-surface-2/60 p-6 text-sm text-muted">
        Elige un curso y haz clic en Cargar clases para ver la lista de clases.
      </div>
    )}
  </section>
</AdminLayout>
