---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const selectedCourseId = Astro.url.searchParams.get('course') ?? '';
const selectedLessonId = Astro.url.searchParams.get('lesson') ?? '';

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));

const { data: lessonRows } = await supabase
  .from('lessons')
  .select('id, title, scheduled_at, order, course_id, courses(title)')
  .order('scheduled_at', { ascending: true, nullsFirst: false });

const allLessons = (lessonRows ?? []).map((l) => {
  const course = l.courses as { title: string | null } | null;
  return {
    id: l.id,
    title: l.title ?? 'Clase',
    scheduledAt: (l.scheduled_at as string | null) ?? null,
    order: (l.order as number | null) ?? 0,
    courseId: l.course_id as string,
    courseTitle: course?.title ?? 'Curso',
  };
});

const lessons = selectedCourseId ? allLessons.filter((l) => l.courseId === selectedCourseId) : [];
const selectedCourse = courses.find((c) => c.id === selectedCourseId) ?? null;
const selectedLesson = allLessons.find((l) => l.id === selectedLessonId) ?? null;

let students: { id: string; name: string; avatarId: string | null }[] = [];
let alreadyRegistered = false;
if (selectedLesson) {
  const { data: enrollmentRows } = await supabase
    .from('enrollments')
    .select('user_id, access_type, users(id, display_name, avatar_id, role)')
    .eq('course_id', selectedLesson.courseId);

  const { data: kahootRows } = await supabase
    .from('kahoot_results')
    .select('id')
    .eq('lesson_id', selectedLesson.id)
    .limit(1);
  alreadyRegistered = (kahootRows ?? []).length > 0;

  students = (enrollmentRows ?? [])
    .filter((row) => (row.access_type as string) !== 'on_demand')
    .map((row) => {
      const u = row.users as { id: string; display_name: string | null; avatar_id: string | null; role: string | null } | null;
      if (!u?.id || u.role !== 'student') return null;
      return {
        id: u.id,
        name: u.display_name ?? 'Estudiante',
        avatarId: u.avatar_id ?? null,
      };
    })
    .filter((s): s is { id: string; name: string; avatarId: string | null } => Boolean(s))
    .sort((a, b) => a.name.localeCompare(b.name));
}

function formatDateTime(iso: string | null): string {
  if (!iso) return 'Sin fecha';
  try {
    return new Date(iso).toLocaleString('es', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  } catch {
    return iso;
  }
}
---

<DashboardLayout>
  <section class="space-y-6">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Kahoot</h1>
      <p class="mt-1 text-sm text-muted">
        Registra resultados de Kahoot por clase. Asigna podio (1º-5º) y participación.
      </p>
    </header>

    <div class="rounded-xl border border-transparent bg-surface p-5">
      <form method="get" action="/admin/kahoot" class="flex flex-wrap items-end gap-3">
        <div class="min-w-[240px]">
          <label for="course-select" class="block text-xs font-medium text-muted">Curso</label>
          <div class="custom-select custom-select--single relative mt-1" data-name="course">
            <input type="hidden" id="course-select" name="course" value={selectedCourseId} />
            <button
              type="button"
              class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span class="custom-select-label truncate">{selectedCourse?.title ?? '— Elige un curso —'}</span>
              <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
              </svg>
            </button>
            <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
              <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!selectedCourseId ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Elige un curso —">
                <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!selectedCourseId ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                  <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                </span>
                <span class="truncate">— Elige un curso —</span>
              </button>
              {courses.map((c) => {
                const isSelected = selectedCourseId === c.id;
                return (
                  <button
                    type="button"
                    class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                    data-value={c.id}
                    data-label={c.title}
                  >
                    <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">{c.title}</span>
                  </button>
                );
              })}
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-secondary">Cargar clases</button>
      </form>

      {selectedCourseId && (
        <form method="get" action="/admin/kahoot" class="mt-4 flex flex-wrap items-end gap-3">
          <input type="hidden" name="course" value={selectedCourseId} />
          <div class="min-w-[280px]">
            <label for="lesson-select" class="block text-xs font-medium text-muted">Clase</label>
            <div class="custom-select custom-select--single relative mt-1" data-name="lesson">
              <input type="hidden" id="lesson-select" name="lesson" value={selectedLessonId} />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
                aria-haspopup="listbox"
              >
                <span class="custom-select-label truncate">
                  {selectedLesson ? `${selectedLesson.title} · ${formatDateTime(selectedLesson.scheduledAt)}` : '— Elige una clase —'}
                </span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
                <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!selectedLessonId ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Elige una clase —">
                  <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!selectedLessonId ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                    <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                  </span>
                  <span class="truncate">— Elige una clase —</span>
                </button>
                {lessons.map((l) => {
                  const optionLabel = `${l.title} · ${formatDateTime(l.scheduledAt)}`;
                  const isSelected = selectedLessonId === l.id;
                  return (
                    <button
                      type="button"
                      class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                      data-value={l.id}
                      data-label={optionLabel}
                    >
                      <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                        <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                      </span>
                      <span class="truncate">{optionLabel}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn-secondary">Cargar alumnos</button>
        </form>
      )}

      {selectedCourseId && lessons.length === 0 && (
        <p class="mt-4 text-sm text-muted">No hay clases en este curso.</p>
      )}
    </div>

    {selectedLesson && students.length > 0 ? (
      <div class="rounded-xl border border-transparent bg-surface p-5">
        <div class="mb-4">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{selectedLesson.courseTitle}</p>
          <h2 class="mt-1 text-lg font-semibold text-white">{selectedLesson.title}</h2>
          <p class="text-xs text-muted">{formatDateTime(selectedLesson.scheduledAt)}</p>
        </div>

        {alreadyRegistered ? (
          <div class="rounded-lg border border-lime/40 bg-lime/10 p-4">
            <p class="text-sm font-medium text-lime">Ya registraste Kahoot para esta clase. Los puntos ya fueron asignados.</p>
          </div>
        ) : (
          <form id="kahoot-form" method="post" action="/api/admin/kahoot" class="space-y-6">
            <input type="hidden" name="lesson_id" value={selectedLesson.id} />
            <input type="hidden" name="redirect_to" value={`/admin/kahoot?course=${selectedLesson.courseId}&lesson=${selectedLesson.id}`} />

            <div class="grid gap-6 lg:grid-cols-3">
              <div class="space-y-4 lg:col-span-2">
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
                  {[1, 2, 3, 4, 5].map((pos) => (
                    <div>
                      <label for={`position_${pos}`} class="block text-xs font-medium text-muted">{pos}º lugar</label>
                      <div class="custom-select custom-select--single relative mt-1" data-name={`position_${pos}`}>
                        <input type="hidden" id={`position_${pos}`} name={`position_${pos}`} value="" />
                        <button
                          type="button"
                          class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                          aria-expanded="false"
                          aria-haspopup="listbox"
                        >
                          <span class="custom-select-label truncate">—</span>
                          <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                          </svg>
                        </button>
                        <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
                          <button type="button" class="custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md bg-lime/10 px-2.5 py-2 text-left text-sm text-lime transition hover:bg-surface-2" data-value="" data-label="—">
                            <span class="flex h-4 w-4 items-center justify-center rounded-[4px] border border-lime bg-lime text-background">
                              <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                            </span>
                            <span class="truncate">—</span>
                          </button>
                          {students.map((s) => (
                            <button
                              type="button"
                              class="position-student-option custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm text-white transition hover:bg-surface-2"
                              data-value={s.id}
                              data-label={s.name}
                            >
                              <span class="flex h-4 w-4 items-center justify-center rounded-[4px] border border-transparent bg-surface-2 text-transparent">
                                <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                              </span>
                              <span class="truncate">{s.name}</span>
                            </button>
                          ))}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>

                <p class="text-xs text-muted">Referencia: cruza los nombres de Kahoot con la lista de abajo.</p>

                <div class="rounded-lg border border-transparent bg-surface-2/40 p-3">
              <p class="mb-2 text-xs font-medium text-muted">Participaron (5 pts cada uno) — marca a quienes jugaron; no aplica a los que ya tienen puntos por puesto</p>
              <div id="kahoot-participants" class="flex flex-wrap gap-2">
                {students.map((s) => (
                  <label class="kahoot-participant flex cursor-pointer items-center gap-2 rounded-lg border border-transparent bg-surface-2/60 px-2.5 py-1.5 transition hover:border-lime/50 has-[:checked]:border-lime/50 has-[:checked]:bg-lime/10" data-user-id={s.id}>
                    <input type="checkbox" name="participant_ids" value={s.id} class="peer sr-only" />
                    <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border border-transparent bg-surface text-transparent transition peer-checked:border-lime peer-checked:bg-lime peer-checked:text-background">
                      <i class="bi bi-check-lg text-[10px] leading-none" aria-hidden="true" />
                    </span>
                    {avatarImagePath(s.avatarId) ? (
                      <img src={avatarImagePath(s.avatarId)!} alt="" class="h-5 w-5 shrink-0 rounded-full object-cover" width="20" height="20" />
                    ) : (
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-surface text-[9px] font-semibold text-muted">{s.name.charAt(0).toUpperCase()}</span>
                    )}
                    <span class="text-xs text-white">{s.name}</span>
                  </label>
                ))}
              </div>
                </div>

                <div class="flex flex-wrap items-center gap-4">
                  <button type="submit" class="btn btn-primary">
                    Guardar y asignar puntos
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  </button>
                </div>
              </div>

              <aside class="w-full lg:max-w-[280px]">
                <div class="rounded-xl border border-transparent bg-surface p-4">
                  <h2 class="text-xs font-semibold text-white">Leyenda</h2>
                  <p class="mt-0.5 text-[10px] text-muted">Puntos por posición.</p>
                  <ul class="mt-3 space-y-2">
                    {[
                      [1, 50],
                      [2, 40],
                      [3, 30],
                      [4, 20],
                      [5, 15],
                    ].map(([pos, pts]) => (
                      <li class="flex items-center justify-between rounded-lg border border-transparent bg-surface-2/60 px-3 py-2">
                        <span class="text-xs text-muted">{pos}º</span>
                        <span class="text-xs font-semibold text-lime">{pts} pts</span>
                      </li>
                    ))}
                    <li class="flex items-center justify-between rounded-lg border border-transparent bg-surface-2/60 px-3 py-2">
                      <span class="text-xs text-muted">Participación</span>
                      <span class="text-xs font-semibold text-white">5 pts</span>
                    </li>
                  </ul>
                </div>
              </aside>
            </div>
          </form>
        )}
      </div>
    ) : selectedCourseId ? (
      <div class="rounded-xl border border-dashed border-transparent bg-surface-2/60 p-6 text-sm text-muted">
        Elige una clase y haz clic en Cargar alumnos para registrar Kahoot.
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-transparent bg-surface-2/60 p-6 text-sm text-muted">
        Elige un curso y haz clic en Cargar clases para ver la lista de clases.
      </div>
    )}
  </section>
</DashboardLayout>

<script>
  (function () {
    const form = document.getElementById('kahoot-form');
    if (!form) return;

    function getPositionValues() {
      const vals = {};
      for (let i = 1; i <= 5; i++) {
        const input = form.querySelector(`input[name="position_${i}"]`);
        vals[i] = input?.value ?? '';
      }
      return vals;
    }

    function getPositionIds() {
      const vals = getPositionValues();
      const ids = new Set();
      for (let i = 1; i <= 5; i++) {
        if (vals[i]) ids.add(vals[i]);
      }
      return ids;
    }

    function resetPositionSelect(pos) {
      const wrapper = form.querySelector(`.custom-select[data-name="position_${pos}"]`);
      if (!wrapper) return;
      const hidden = wrapper.querySelector('input[type="hidden"]');
      const label = wrapper.querySelector('.custom-select-label');
      const options = Array.from(wrapper.querySelectorAll('.custom-select-option'));
      if (!hidden || !label) return;
      hidden.value = '';
      label.textContent = '—';
      options.forEach((opt) => {
        const v = opt.dataset.value ?? '';
        const isSelected = v === '';
        opt.classList.toggle('bg-lime/10', isSelected);
        opt.classList.toggle('text-lime', isSelected);
        opt.classList.toggle('text-white', !isSelected);
        const check = opt.querySelector('span');
        if (check) {
          check.classList.toggle('border-lime', isSelected);
          check.classList.toggle('bg-lime', isSelected);
          check.classList.toggle('text-background', isSelected);
          check.classList.toggle('border-transparent', !isSelected);
          check.classList.toggle('bg-surface-2', !isSelected);
          check.classList.toggle('text-transparent', !isSelected);
        }
      });
    }

    function syncPositionOptions() {
      const vals = getPositionValues();
      const byId = {};
      for (let i = 1; i <= 5; i++) {
        if (vals[i]) byId[vals[i]] = (byId[vals[i]] || []).concat(i);
      }
      for (const [id, positions] of Object.entries(byId)) {
        if (positions.length > 1) {
          for (let k = 1; k < positions.length; k++) resetPositionSelect(positions[k]);
        }
      }
      const vals2 = getPositionValues();
      for (let i = 1; i <= 5; i++) {
        const wrapper = form.querySelector(`.custom-select[data-name="position_${i}"]`);
        if (!wrapper) continue;
        const otherIds = new Set();
        for (let j = 1; j <= 5; j++) {
          if (j !== i && vals2[j]) otherIds.add(vals2[j]);
        }
        wrapper.querySelectorAll('.position-student-option').forEach((opt) => {
          const vid = opt.dataset.value ?? '';
          if (otherIds.has(vid)) {
            opt.classList.add('hidden');
            opt.style.pointerEvents = 'none';
          } else {
            opt.classList.remove('hidden');
            opt.style.pointerEvents = '';
          }
        });
      }
    }

    function syncParticipants() {
      const positionIds = getPositionIds();
      form.querySelectorAll('.kahoot-participant').forEach((label) => {
        const userId = label.dataset.userId;
        const checkbox = label.querySelector('input[name="participant_ids"]');
        if (!userId || !checkbox) return;
        if (positionIds.has(userId)) {
          label.classList.add('hidden');
          checkbox.checked = false;
        } else {
          label.classList.remove('hidden');
        }
      });
    }

    function syncAll() {
      syncPositionOptions();
      syncParticipants();
    }

    document.addEventListener('custom-select-change', (e) => {
      if (!e.detail?.name?.startsWith('position_')) return;
      if (!e.target?.closest('#kahoot-form')) return;
      syncAll();
    });

    syncAll();
  })();
</script>
