---
import '../../../styles/global.css';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id: submissionId } = Astro.params as { id: string };
if (!submissionId) {
  return Astro.redirect('/admin/submissions');
}

const { data: sub } = await supabase
  .from('submissions')
  .select('id, link, submitted_at, reviewed, approved, feedback, user_id, challenge_id, users(display_name, avatar_id), challenges(title)')
  .eq('id', submissionId)
  .maybeSingle();

if (!sub) {
  return Astro.redirect('/admin/submissions');
}

const user = sub.users as { display_name: string | null; avatar_id: string | null } | null;
const challenge = sub.challenges as { title: string | null } | null;
const displayName = user?.display_name ?? 'Estudiante';
const challengeTitle = challenge?.title ?? 'Reto';
const link = (sub.link as string) ?? '';
const feedback = (sub.feedback as string | null) ?? '';
const reviewed = sub.reviewed ?? false;
const approved = sub.approved ?? false;

function formatDate(iso: string | null) {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleString('es', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}

const redirectTo = Astro.url.searchParams.get('from') === 'dashboard' ? '/dashboard' : '/admin/submissions';
---

<AdminLayout>
  <section class="space-y-6">
    <header class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <a href={redirectTo} class="text-sm font-medium text-muted hover:text-lime">← Volver</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight text-white">Revisar entrega</h1>
        <p class="mt-1 text-sm text-muted">{challengeTitle} · {displayName}</p>
      </div>
    </header>

    {reviewed ? (
      <div class="rounded-xl border border-border bg-surface p-6">
        <p class="text-sm text-muted">Esta entrega ya fue revisada.</p>
        <p class="mt-2 text-sm font-medium text-white">
          Estado: {approved ? (
            <span class="text-lime">Aprobada</span>
          ) : (
            <span class="text-red-400">Rechazada</span>
          )}
        </p>
        {feedback && (
          <div class="mt-4 rounded-lg border border-border bg-surface-2/60 p-4">
            <p class="text-xs font-medium text-muted">Feedback enviado</p>
            <p class="mt-1 whitespace-pre-wrap text-sm text-white">{feedback}</p>
          </div>
        )}
        <a href={redirectTo} class="mt-4 inline-block text-sm font-medium text-lime hover:underline">Volver</a>
      </div>
    ) : (
      <form method="post" action="/api/admin/submissions" class="space-y-6">
        <input type="hidden" name="submission_id" value={sub.id} />
        <input type="hidden" name="action" value="approve" />
        <input type="hidden" name="redirect_to" value={redirectTo} />

        <div class="rounded-xl border border-border bg-surface p-5">
          <h2 class="text-sm font-semibold text-white">Información</h2>
          <div class="mt-3 flex items-center gap-3">
            <div class="h-10 w-10 shrink-0 overflow-hidden rounded-full border border-border bg-surface-2">
              {avatarImagePath(user?.avatar_id ?? null) ? (
                <img src={avatarImagePath(user?.avatar_id ?? null)!} alt="" class="h-full w-full object-cover" width="40" height="40" />
              ) : (
                <span class="flex h-full w-full items-center justify-center text-sm font-semibold text-muted">{displayName.charAt(0).toUpperCase()}</span>
              )}
            </div>
            <div>
              <p class="font-medium text-white">{displayName}</p>
              <p class="text-xs text-muted">{challengeTitle} · {formatDate(sub.submitted_at as string)}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-border bg-surface p-5">
          <h2 class="text-sm font-semibold text-white">Archivo / enlace</h2>
          <p class="mt-1 text-xs text-muted">Abre el enlace para revisar la entrega antes de aprobar.</p>
          {link ? (
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-flex items-center gap-2 rounded-lg border border-lime/50 bg-lime/10 px-4 py-2.5 text-sm font-medium text-lime transition hover:bg-lime/20"
            >
              <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
              Ver entrega
            </a>
          ) : (
            <p class="mt-3 text-sm text-muted">No hay enlace.</p>
          )}
        </div>

        <div class="rounded-xl border border-border bg-surface p-5">
          <label for="feedback" class="block text-sm font-semibold text-white">Feedback (opcional)</label>
          <p class="mt-0.5 text-xs text-muted">Comentarios para el estudiante. Se enviará junto con la aprobación.</p>
          <textarea
            id="feedback"
            name="feedback"
            rows={4}
            class="mt-3 w-full rounded-lg border border-border bg-surface-2 px-3 py-2.5 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            placeholder="Ej: Buen trabajo con el layout. Considera mejorar el contraste en el CTA."
          ></textarea>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <button
            type="submit"
            class="rounded-lg border border-lime bg-lime px-5 py-2.5 text-sm font-semibold text-background transition hover:bg-lime/90"
          >
            Aprobar entrega
          </button>
          <a href={redirectTo} class="text-sm font-medium text-muted hover:text-white">Cancelar</a>
        </div>
      </form>
    )}
  </section>
</AdminLayout>
