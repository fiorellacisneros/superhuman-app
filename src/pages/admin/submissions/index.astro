---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const challengeFilter = Astro.url.searchParams.get('challenge') ?? '';
const tab = Astro.url.searchParams.get('tab') ?? 'all';

const { data: challengesRows } = await supabase
  .from('challenges')
  .select('id, title')
  .order('title');
const challenges = (challengesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));
const selectedChallenge = challenges.find((c) => c.id === challengeFilter) ?? null;
const selectedChallengeLabel = selectedChallenge?.title ?? '— Todos los retos —';

const { data: rows } = await supabase
  .from('submissions')
  .select('id, link, submitted_at, reviewed, approved, user_id, challenge_id, users(display_name, avatar_id), challenges(title)')
  .order('submitted_at', { ascending: false });

let list = (rows ?? []).map((r) => ({
  id: r.id,
  link: (r.link as string) ?? '',
  submitted_at: r.submitted_at as string,
  reviewed: r.reviewed ?? false,
  approved: r.approved ?? false,
  user_id: r.user_id as string,
  challenge_id: r.challenge_id as string,
  display_name: (r.users as { display_name: string | null } | null)?.display_name ?? 'Estudiante',
  avatar_id: (r.users as { avatar_id: string | null } | null)?.avatar_id ?? null,
  challenge_title: (r.challenges as { title: string | null } | null)?.title ?? 'Reto',
}));

// Keep only the latest submission per student+challenge.
const latestByStudentChallenge = new Map<string, (typeof list)[number]>();
for (const row of list) {
  const key = `${row.user_id}::${row.challenge_id}`;
  const current = latestByStudentChallenge.get(key);
  if (!current) {
    latestByStudentChallenge.set(key, row);
    continue;
  }
  const currentTs = new Date(current.submitted_at).getTime();
  const nextTs = new Date(row.submitted_at).getTime();
  if ((Number.isFinite(nextTs) ? nextTs : 0) > (Number.isFinite(currentTs) ? currentTs : 0)) {
    latestByStudentChallenge.set(key, row);
  }
}
list = Array.from(latestByStudentChallenge.values()).sort((a, b) => {
  const aTs = new Date(a.submitted_at).getTime();
  const bTs = new Date(b.submitted_at).getTime();
  return (Number.isFinite(bTs) ? bTs : 0) - (Number.isFinite(aTs) ? aTs : 0);
});

if (challengeFilter) {
  list = list.filter((s) => s.challenge_id === challengeFilter);
}
if (tab === 'pending') list = list.filter((s) => !s.reviewed);
if (tab === 'approved') list = list.filter((s) => s.reviewed && s.approved);
if (tab === 'rejected') list = list.filter((s) => s.reviewed && !s.approved);

const currentUrl = new URL(Astro.url);
function tabUrl(t: string) {
  const u = new URL(currentUrl);
  u.searchParams.set('tab', t);
  if (challengeFilter) u.searchParams.set('challenge', challengeFilter);
  return u.pathname + u.search;
}

function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleString('es', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}
---

<DashboardLayout>
  <section class="space-y-6">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Submissions</h1>
      <p class="mt-1 text-sm text-muted">Revisar y aprobar entregas de estudiantes.</p>
    </header>

    <form method="get" action="/admin/submissions" class="mb-4 flex flex-wrap items-end gap-3 rounded-xl border border-transparent bg-surface p-4">
      <div class="min-w-[260px] flex-1">
        <label for="challenge-filter" class="block text-xs font-medium text-muted">Filtrar por reto</label>
        <div class="custom-select custom-select--single relative mt-1" data-name="challenge">
          <input type="hidden" id="challenge-filter" name="challenge" value={challengeFilter} />
          <button
            type="button"
            class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            aria-expanded="false"
          >
            <span class="custom-select-label truncate">{selectedChallengeLabel}</span>
            <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
            </svg>
          </button>
          <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl">
            <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!challengeFilter ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Todos los retos —">
              <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!challengeFilter ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
              </span>
              <span class="truncate">— Todos los retos —</span>
            </button>
            {challenges.map((c) => {
              const isSelected = challengeFilter === c.id;
              return (
                <button
                  type="button"
                  class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                  data-value={c.id}
                  data-label={c.title}
                >
                  <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                    <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                  </span>
                  <span class="truncate">{c.title}</span>
                </button>
              );
            })}
          </div>
        </div>
      </div>
      <input type="hidden" name="tab" value={tab} />
<button type="submit" class="btn btn-secondary">
          Filtrar
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
      </button>
    </form>

    <div class="flex flex-wrap gap-2 border-b border-transparent pb-2">
      <a href={tabUrl('all')} class={`rounded-lg px-3 py-1.5 text-sm font-medium transition ${tab === 'all' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Todos</a>
      <a href={tabUrl('pending')} class={`rounded-lg px-3 py-1.5 text-sm font-medium transition ${tab === 'pending' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Pendientes</a>
      <a href={tabUrl('approved')} class={`rounded-lg px-3 py-1.5 text-sm font-medium transition ${tab === 'approved' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Aprobados</a>
      <a href={tabUrl('rejected')} class={`rounded-lg px-3 py-1.5 text-sm font-medium transition ${tab === 'rejected' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Rechazados</a>
    </div>

    {list.length > 0 ? (
      <div class="-mx-2 overflow-x-auto rounded-xl border border-transparent bg-surface px-2 shadow-[0_8px_30px_rgba(0,0,0,0.18)] sm:mx-0 sm:px-0">
        <table class="w-full min-w-[760px] text-left text-sm">
          <thead>
            <tr class="border-b border-transparent bg-surface-2/40 text-muted">
              <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Estudiante</th>
              <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Reto</th>
              <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Enlace</th>
              <th class="px-4 pb-3 pt-3 text-[11px] font-semibold uppercase tracking-[0.14em]">Fecha</th>
              <th class="px-4 pb-3 pt-3 text-center text-[11px] font-semibold uppercase tracking-[0.14em]">Estado</th>
              <th class="px-4 pb-3 pt-3 text-right text-[11px] font-semibold uppercase tracking-[0.14em]">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {list.map((s) => (
              <tr class="border-b border-transparent/60 transition-colors hover:bg-surface-2/30 last:border-0">
                <td class="px-4 py-4">
                  <div class="flex items-center gap-2">
                    <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full border border-transparent bg-surface-2">
                      {avatarImagePath(s.avatar_id) ? (
                        <img src={avatarImagePath(s.avatar_id)!} alt="" class="h-full w-full object-cover" width="32" height="32" />
                      ) : (
                        <span class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted">{(s.display_name || 'E').charAt(0).toUpperCase()}</span>
                      )}
                    </div>
                    <span class="font-medium text-white">{s.display_name}</span>
                  </div>
                </td>
                <td class="px-4 py-4 text-white">{s.challenge_title}</td>
                <td class="max-w-[220px] truncate px-4 py-4">
                  {s.link ? (
                    <a href={s.link} target="_blank" rel="noopener noreferrer" class="text-lime hover:underline truncate block">{s.link}</a>
                  ) : (
                    <span class="text-muted">—</span>
                  )}
                </td>
                <td class="px-4 py-4 text-muted">{formatDate(s.submitted_at)}</td>
                <td class="px-4 py-4 text-center">
                  {!s.reviewed ? (
                    <span class="inline-flex rounded-full bg-amber-500/20 px-2.5 py-1 text-xs font-medium text-amber-400">Pendiente</span>
                  ) : s.approved ? (
                    <span class="inline-flex rounded-full bg-lime/20 px-2.5 py-1 text-xs font-medium text-lime">Aprobado</span>
                  ) : (
                    <span class="inline-flex rounded-full bg-red-500/20 px-2.5 py-1 text-xs font-medium text-red-400">Rechazado</span>
                  )}
                </td>
                <td class="px-4 py-4 text-right">
                  {!s.reviewed ? (
                    <a
                      href={`/admin/submissions/${s.id}`}
                      class="btn btn-primary"
                    >
                      Revisar
                      <i class="bi bi-eye h-4 w-4" aria-hidden="true"></i>
                    </a>
                  ) : (
                    <span class="text-muted">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-transparent bg-surface-2/60 p-8 text-center">
        <p class="text-sm text-muted">
          {tab === 'all' && !challengeFilter && 'No hay submissions.'}
          {tab === 'all' && challengeFilter && 'No hay submissions para este reto.'}
          {tab === 'pending' && 'No hay entregas pendientes.'}
          {tab === 'approved' && 'No hay entregas aprobadas.'}
          {tab === 'rejected' && 'No hay entregas rechazadas.'}
        </p>
      </div>
    )}
  </section>
</DashboardLayout>
