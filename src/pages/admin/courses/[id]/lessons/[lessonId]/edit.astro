---
import '../../../../../../styles/global.css';
import AdminLayout from '../../../../../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../../../../lib/supabase';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id: courseId, lessonId } = Astro.params as { id: string; lessonId: string };
if (!courseId || !lessonId) {
  return Astro.redirect('/admin/courses');
}

const { data: course } = await supabase
  .from('courses')
  .select('id, slug, title')
  .eq('id', courseId)
  .maybeSingle();

if (!course) {
  return Astro.redirect('/admin/courses');
}

const detailedLesson = await supabase
  .from('lessons')
  .select('*')
  .eq('id', lessonId)
  .eq('course_id', courseId)
  .maybeSingle();

const raw = detailedLesson.data as Record<string, unknown> | null;
const lesson =
  raw
    ? {
        id: String(raw.id ?? ''),
        course_id: String(raw.course_id ?? ''),
        title: typeof raw.title === 'string' ? raw.title : null,
        notes: typeof raw.notes === 'string' ? raw.notes : null,
        zoom_link: typeof raw.zoom_link === 'string' ? raw.zoom_link : null,
        recording_url: typeof raw.recording_url === 'string' ? raw.recording_url : null,
        ppt_url: typeof raw.ppt_url === 'string' ? raw.ppt_url : null,
        resources_url: typeof raw.resources_url === 'string' ? raw.resources_url : null,
        resources: raw.resources,
        scheduled_at: typeof raw.scheduled_at === 'string' ? raw.scheduled_at : null,
        order: typeof raw.order === 'number' ? raw.order : 0,
      }
    : null;
const lessonError = detailedLesson.error;

if (lessonError || !lesson) {
  return Astro.redirect(`/admin/courses/${courseId}/edit`);
}

const resources = Array.isArray(lesson.resources)
  ? (lesson.resources as { label?: string; url?: string; type?: string }[]).map((r) => ({
      label: typeof r?.label === 'string' ? r.label : '',
      url: typeof r?.url === 'string' ? r.url : '',
      type: r?.type === 'shared' ? 'shared' : 'class',
    }))
  : [];
const resourceInputs = Array.from({ length: 5 }, (_, i) => resources[i] ?? { label: '', url: '', type: 'class' as const });

function toDateTimeLocal(value: string | null): string {
  if (!value) return '';
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return '';
  const pad = (n: number) => String(n).padStart(2, '0');
  const yyyy = d.getFullYear();
  const mm = pad(d.getMonth() + 1);
  const dd = pad(d.getDate());
  const hh = pad(d.getHours());
  const min = pad(d.getMinutes());
  return `${yyyy}-${mm}-${dd}T${hh}:${min}`;
}
---

<AdminLayout>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/admin/courses" class="hover:text-white">Cursos</a>
      <span class="mx-1">/</span>
      <a href={`/admin/courses/${courseId}/edit`} class="hover:text-white">{course.title}</a>
      <span class="mx-1">/</span>
      <span class="text-white">Editar clase</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Editar clase</h1>
      <p class="mt-1 text-sm text-muted">Curso: {course.title}</p>
    </header>

    <form method="post" action="/api/admin/lessons" class="space-y-5 rounded-xl border border-border bg-surface p-5">
      <input type="hidden" name="action" value="update" />
      <input type="hidden" name="course_id" value={courseId} />
      <input type="hidden" name="lesson_id" value={lessonId} />
      <input type="hidden" name="redirect_to" value={`/admin/courses/${courseId}/lessons/${lessonId}/edit`} />

      <div>
        <label for="lesson-title" class="block text-xs font-medium text-muted">Título</label>
        <input
          id="lesson-title"
          type="text"
          name="title"
          required
          value={lesson.title ?? ''}
          class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="Ej: Sesión 1 — Introducción"
        />
      </div>

      <div>
        <label for="lesson-notes" class="block text-xs font-medium text-muted">Notas / descripción</label>
        <textarea
          id="lesson-notes"
          name="notes"
          rows={4}
          class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="Descripción o notas para la clase"
        >{lesson.notes ?? ''}</textarea>
      </div>

      <div>
        <label for="lesson-zoom-link" class="block text-xs font-medium text-muted">Enlace Zoom (clase en vivo)</label>
        <input
          id="lesson-zoom-link"
          type="url"
          name="zoom_link"
          value={lesson.zoom_link ?? ''}
          class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="https://zoom.us/j/..."
        />
        <p class="mt-1 text-[11px] text-muted">Link para unirse a la clase en vivo. Se muestra antes de la clase.</p>
      </div>

      <div>
        <label for="lesson-recording" class="block text-xs font-medium text-muted">Grabación (después de la clase)</label>
        <input
          id="lesson-recording"
          type="url"
          name="recording_url"
          value={lesson.recording_url ?? ''}
          class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="https://..."
        />
        <p class="mt-1 text-[11px] text-muted">Link de la grabación. Puedes agregarlo después de que termine la clase.</p>
      </div>

      <div>
        <label for="lesson-ppt" class="block text-xs font-medium text-muted">Presentación (Google Slides / Drive)</label>
        <input
          id="lesson-ppt"
          type="url"
          name="ppt_url"
          value={lesson.ppt_url ?? ''}
          class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="https://..."
        />
      </div>

      <div>
        <label for="lesson-resources-url" class="block text-xs font-medium text-muted">Recursos de clase (carpeta / PDF principal)</label>
        <input
          id="lesson-resources-url"
          type="url"
          name="resources_url"
          value={lesson.resources_url ?? ''}
          class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="https://drive.google.com/..."
        />
        <p class="mt-1 text-[11px] text-muted">Carpeta Drive, PDF o material oficial de la clase.</p>
      </div>

      <div>
        <p class="mb-2 text-xs font-medium text-muted">Recursos adicionales (hasta 5)</p>
        <p class="mb-2 text-[11px] text-muted">Indica si es recurso de clase o link compartido durante la sesión.</p>
        <div class="space-y-3">
          {resourceInputs.map((r, i) => (
            <div class="flex flex-wrap gap-2 items-center">
              <input
                type="text"
                name={`resource_label_${i}`}
                value={r.label}
                placeholder="Etiqueta"
                class="w-28 rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              />
              <input
                type="url"
                name={`resource_url_${i}`}
                value={r.url}
                placeholder="URL"
                class="min-w-0 flex-1 rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              />
              <div class="custom-select custom-select--single relative w-[180px]" data-name={`resource_type_${i}`}>
                <input type="hidden" name={`resource_type_${i}`} value={r.type} />
                <button
                  type="button"
                  class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-border bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                  aria-expanded="false"
                  aria-haspopup="listbox"
                >
                  <span class="custom-select-label truncate">{r.type === 'shared' ? 'Link compartido' : 'Recurso de clase'}</span>
                  <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                  </svg>
                </button>
                <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden min-w-full overflow-hidden rounded-xl border border-border bg-surface p-2 shadow-2xl" role="listbox">
                  <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${r.type === 'class' ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="class" data-label="Recurso de clase">
                    <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${r.type === 'class' ? 'border-lime bg-lime text-background' : 'border-border bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">Recurso de clase</span>
                  </button>
                  <button type="button" class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${r.type === 'shared' ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="shared" data-label="Link compartido">
                    <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${r.type === 'shared' ? 'border-lime bg-lime text-background' : 'border-border bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">Link compartido</span>
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="lesson-scheduled" class="block text-xs font-medium text-muted">Programada (fecha y hora)</label>
          <div class="relative mt-1.5">
            <input
              id="lesson-scheduled"
              type="text"
              name="scheduled_at"
              value={toDateTimeLocal(lesson.scheduled_at)}
              readonly
              class="w-full cursor-pointer rounded-lg border border-border bg-surface-2 py-2.5 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="Elegir fecha y hora"
              autocomplete="off"
            />
            <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
          </div>
        </div>
        <div>
          <label for="lesson-order" class="block text-xs font-medium text-muted">Orden</label>
          <input
            id="lesson-order"
            type="number"
            name="order"
            value={lesson.order ?? 0}
            min="0"
            class="mt-1.5 w-full rounded-lg border border-border bg-surface-2 px-3 py-2.5 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          />
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <button
          type="submit"
          class="rounded-lg border border-lime bg-lime px-4 py-2 text-sm font-medium text-background transition hover:bg-lime/90"
        >
          Guardar clase
        </button>
        <a
          href={`/admin/courses/${courseId}/edit`}
          class="rounded-lg border border-border bg-surface-2 px-4 py-2 text-sm font-medium text-white transition hover:bg-surface-2/80"
        >
          Volver al curso
        </a>
      </div>
    </form>
  </section>
</AdminLayout>

<script>
  import flatpickr from 'flatpickr';
  import { Spanish } from 'flatpickr/dist/l10n/es.js';

  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('lesson-scheduled');
    if (el) {
      flatpickr(el, {
        enableTime: true,
        dateFormat: 'Y-m-d H:i',
        locale: Spanish,
        time_24hr: true,
        allowInput: false,
      });
    }
  });
</script>
