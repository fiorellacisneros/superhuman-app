---
import '../../../../styles/global.css';
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../../lib/supabase';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const role = (userRow?.role as string)?.toLowerCase?.() ?? '';
if (role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id: courseId } = Astro.params as { id: string };
if (!courseId) {
  return Astro.redirect('/admin/courses');
}

const [{ data: course }, { data: modulesData }] = await Promise.all([
  supabase.from('courses').select('id, title, description, cover_image, zoom_link, ends_at, calendly_link_1to1').eq('id', courseId).maybeSingle(),
  supabase.from('course_modules').select('id, title, order').eq('course_id', courseId).order('order', { ascending: true }),
]);
const modules = (modulesData ?? []) as { id: string; title: string; order: number }[];

if (!course) {
  return Astro.redirect('/admin/courses');
}
---
<script>
  import flatpickr from 'flatpickr';
  import { Spanish } from 'flatpickr/dist/l10n/es.js';
  const init = () => {
    const el = document.getElementById('edit-ends-at');
    if (el) {
      flatpickr(el, {
        dateFormat: 'Y-m-d',
        locale: Spanish,
        allowInput: false,
      });
    }
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<DashboardLayout role="admin">
  <section class="max-w-5xl space-y-6 xl:max-w-6xl">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <a href="/admin/courses" class="hover:text-white">Cursos</a>
      <span class="mx-1">/</span>
      <span class="text-white">{course.title}</span>
      <span class="mx-1">/</span>
      <span class="text-white">Editar</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Editar curso</h1>
      <p class="mt-1 text-sm text-muted">{course.title}</p>
    </header>

    <form method="post" action="/api/admin/courses" class="max-w-xl space-y-4 rounded-xl border border-transparent bg-surface p-5">
      <input type="hidden" name="action" value="update" />
      <input type="hidden" name="course_id" value={courseId} />
      <input type="hidden" name="redirect_to" value="/admin/courses" />

      <div>
        <label for="edit-title" class="block text-xs font-medium text-muted">Título</label>
        <input
          id="edit-title"
          type="text"
          name="title"
          required
          value={course.title ?? ''}
          class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
        />
      </div>
      <div>
        <label for="edit-description" class="block text-xs font-medium text-muted">Descripción</label>
        <textarea
          id="edit-description"
          name="description"
          rows={3}
          class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
        >{course.description ?? ''}</textarea>
      </div>
      <div>
        <label for="edit-cover" class="block text-xs font-medium text-muted">Imagen de portada</label>
        <input
          id="edit-cover"
          type="text"
          name="cover_image"
          value={course.cover_image ?? ''}
          class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="URL de la imagen (sube en Webflow y pega el enlace)"
        />
      </div>
      <div>
        <label for="edit-zoom-link" class="block text-xs font-medium text-muted">Enlace Zoom (por defecto del curso)</label>
        <input
          id="edit-zoom-link"
          type="url"
          name="zoom_link"
          value={course.zoom_link ?? ''}
          class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="https://zoom.us/j/..."
        />
        <p class="mt-1 text-[11px] text-muted">Se aplica a todas las clases del curso. Puedes sobrescribirlo en cada clase si hace falta.</p>
      </div>
      <div>
        <label for="edit-ends-at" class="block text-xs font-medium text-muted">Fecha fin del curso</label>
        <div class="relative mt-1">
          <input
            id="edit-ends-at"
            type="text"
            name="ends_at"
            value={course.ends_at ? new Date(course.ends_at).toISOString().slice(0, 10) : ''}
            readonly
            autocomplete="off"
            class="w-full cursor-pointer rounded-lg border border-transparent bg-surface-2 py-2.5 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            placeholder="Elegir fecha"
          />
          <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
        </div>
        <p class="mt-1 text-[11px] text-muted">Después de esta fecha los alumnos no podrán agendar sesiones 1:1.</p>
      </div>
      <div>
        <label for="edit-calendly-1to1" class="block text-xs font-medium text-muted">Link Calendly (sesiones 1:1)</label>
        <input
          id="edit-calendly-1to1"
          type="url"
          name="calendly_link_1to1"
          value={course.calendly_link_1to1 ?? ''}
          class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          placeholder="https://calendly.com/tu-usuario/1to1"
        />
        <p class="mt-1 text-[11px] text-muted">Cuando un alumno reserve en Calendly, regístralo manualmente en la página Sesiones 1:1 para que cuente en su cuota.</p>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="btn btn-primary">
          Guardar cambios
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
        <a href="/admin/courses" class="btn btn-ghost">Cancelar</a>
      </div>
    </form>

    <div class="max-w-xl space-y-4 rounded-xl border border-transparent bg-surface p-5">
      <h2 class="text-sm font-semibold text-white">Módulos del curso</h2>
      <p class="text-xs text-muted">Crea módulos (ej. Intro, Maquetado) para agrupar las clases. Luego asigna cada clase a un módulo al crearla o editarla.</p>
      {modules.length > 0 ? (
        <ul class="space-y-2">
          {modules.map((mod, i) => (
            <li class="flex items-center gap-2 rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white">
              <span class="text-muted">{i + 1}.</span>
              <span>{mod.title}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-muted">Aún no hay módulos. Agrega uno abajo.</p>
      )}
      <form method="post" action="/api/admin/course-modules" class="flex flex-wrap items-end gap-3">
        <input type="hidden" name="action" value="create" />
        <input type="hidden" name="course_id" value={courseId} />
        <input type="hidden" name="redirect_to" value={`/admin/courses/${courseId}/edit`} />
        <div>
          <label for="module-title" class="block text-xs font-medium text-muted">Nombre del módulo</label>
          <input
            id="module-title"
            type="text"
            name="title"
            required
            placeholder="Ej: Intro, Maquetado"
            class="mt-1 w-48 rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          />
        </div>
        <div>
          <label for="module-order" class="block text-xs font-medium text-muted">Orden</label>
          <input
            id="module-order"
            type="number"
            name="order"
            value={modules.length}
            min={0}
            class="mt-1 w-20 rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          />
        </div>
        <button type="submit" class="btn btn-primary">
          Agregar módulo
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
        </button>
      </form>
    </div>
  </section>
</DashboardLayout>
