---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return new Response(null, { status: 302, headers: { Location: '/dashboard' } });
}

const { data: coursesRows } = await supabase
  .from('courses')
  .select('id, slug, title, description, cover_image')
  .order('created_at', { ascending: false });

const courses: { id: string; slug: string; title: string; description: string | null; cover_image: string | null; lessonsCount: number; enrolledCount: number }[] = [];

for (const c of coursesRows ?? []) {
  const { count: lessonsCount } = await supabase
    .from('lessons')
    .select('*', { count: 'exact', head: true })
    .eq('course_id', c.id);
  const { count: enrolledCount } = await supabase
    .from('enrollments')
    .select('*', { count: 'exact', head: true })
    .eq('course_id', c.id);
  courses.push({
    id: c.id,
    slug: typeof c.slug === 'string' && c.slug.trim() ? c.slug.trim() : c.id,
    title: c.title ?? 'Sin título',
    description: c.description ?? null,
    cover_image: c.cover_image ?? null,
    lessonsCount: lessonsCount ?? 0,
    enrolledCount: enrolledCount ?? 0,
  });
}
---

<DashboardLayout>
  <section class="space-y-8">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Cursos</h1>
      <p class="mt-1 text-sm text-muted">Crear y editar cursos y sus clases.</p>
    </header>

    <div class="rounded-xl border border-transparent bg-surface">
      <button
        type="button"
        id="toggle-create-course"
        aria-expanded="false"
        aria-controls="create-course-form"
        class="flex w-full items-center justify-between px-5 py-4 text-left text-sm font-medium text-white transition hover:bg-surface-2/60"
      >
        <span>Crear nuevo curso</span>
        <svg id="toggle-create-icon" class="h-5 w-5 shrink-0 text-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id="create-course-form" class="hidden border-t border-transparent px-5 pb-5 pt-4" role="region">
        <form method="post" action="/api/admin/courses" class="space-y-4">
          <input type="hidden" name="action" value="create" />
          <input type="hidden" name="redirect_to" value="/admin/courses" />
          <div>
            <label for="course-title" class="block text-xs font-medium text-muted">Título</label>
            <input
              id="course-title"
              type="text"
              name="title"
              required
              class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="Ej: Introducción a Webflow"
            />
          </div>
          <div>
            <label for="course-description" class="block text-xs font-medium text-muted">Descripción</label>
            <textarea
              id="course-description"
              name="description"
              rows={3}
              class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="Breve descripción del curso"
            />
          </div>
          <div>
            <label for="course-cover" class="block text-xs font-medium text-muted">Imagen de portada</label>
            <input
              id="course-cover"
              type="text"
              name="cover_image"
              class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="URL de la imagen (sube en Webflow y pega el enlace)"
            />
          </div>
          <div>
            <label for="course-zoom-link" class="block text-xs font-medium text-muted">Enlace Zoom (por defecto del curso)</label>
            <input
              id="course-zoom-link"
              type="url"
              name="zoom_link"
              class="mt-1 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="https://zoom.us/j/..."
            />
            <p class="mt-1 text-[11px] text-muted">Se aplica a todas las clases. Puedes sobrescribirlo en cada clase si hace falta.</p>
          </div>
          <button type="submit" class="btn btn-primary">
            Crear curso
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="text-sm font-semibold text-white">Todos los cursos</h2>
      {courses.length > 0 ? (
        <ul class="space-y-4">
          {courses.map((course) => (
            <li class="rounded-xl border border-transparent bg-surface p-4">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
                <div class="h-20 w-32 shrink-0 overflow-hidden rounded-lg border border-transparent bg-surface-2">
                  {course.cover_image ? (
                    <img
                      src={course.cover_image.startsWith('http') ? course.cover_image : `/courses/${course.cover_image}`}
                      alt=""
                      class="h-full w-full object-cover"
                      width="128"
                      height="80"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center text-muted">
                      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="font-medium text-white">{course.title}</h3>
                  {course.description && (
                    <p class="mt-0.5 line-clamp-2 text-sm text-muted">{course.description}</p>
                  )}
                  <p class="mt-2 text-xs text-muted">
                    {course.lessonsCount} clases · {course.enrolledCount} inscritos
                  </p>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <a href={`/courses/${course.slug}`} class="btn btn-primary">
                    Ver curso
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                  <a href={`/admin/courses/${course.id}/lessons/new`} class="btn btn-secondary">
                    Agregar clase
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  </a>
                  <span class="inline-flex items-center gap-1" aria-label="Acciones">
                    <a href={`/admin/courses/${course.id}/edit`} class="btn btn-ghost btn-icon" title="Editar" aria-label="Editar">
                      <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>
                    <form method="post" action="/api/admin/courses" class="inline" id={`delete-course-form-${course.id}`}>
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="course_id" value={course.id} />
                      <input type="hidden" name="redirect_to" value="/admin/courses" />
                      <button
                        type="button"
                        data-delete-confirm
                        data-confirm-label={course.title}
                        data-delete-form-id={`delete-course-form-${course.id}`}
                        data-delete-description="Se borrarán clases, inscripciones, retos y entregas."
                        class="btn btn-danger btn-icon"
                        title="Eliminar"
                        aria-label="Eliminar"
                      >
                        <i class="bi bi-trash" aria-hidden="true"></i>
                      </button>
                    </form>
                  </span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="rounded-xl border border-dashed border-transparent bg-background p-6 text-center text-sm text-muted">
          Aún no hay cursos. Usa el formulario de arriba para crear el primero.
        </p>
      )}
    </div>
  </section>
</DashboardLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('toggle-create-course');
    const form = document.getElementById('create-course-form');
    const icon = document.getElementById('toggle-create-icon');
    if (!toggle || !form || !icon) return;
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      form.classList.toggle('hidden', open);
      icon.classList.toggle('rotate-180', !open);
      if (!open) {
        requestAnimationFrame(() => {
          document.dispatchEvent(new CustomEvent('custom-select-reinit', { detail: { container: form } }));
        });
      }
    });
  });
</script>
