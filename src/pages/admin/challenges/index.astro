---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { renderMarkdown } from '../../../lib/markdown';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { data: challengeRows } = await supabase
  .from('challenges')
  .select('id, title, description, deadline, points_reward, is_active, course_id, courses(title)')
  .order('created_at', { ascending: false });

type ChallengeWithMeta = {
  id: string;
  title: string;
  description: string | null;
  deadline: string | null;
  points_reward: number;
  is_active: boolean;
  course_id: string | null;
  courseTitle: string;
  submissionsCount: number;
  pendingCount: number;
};

const challengeIds = (challengeRows ?? []).map((c) => c.id);
const submissionsByChallenge = new Map<string, { total: number; pending: number }>();
if (challengeIds.length > 0) {
  const { data: submissionRows } = await supabase
    .from('submissions')
    .select('challenge_id, reviewed')
    .in('challenge_id', challengeIds);
  for (const row of submissionRows ?? []) {
    const key = row.challenge_id as string;
    const current = submissionsByChallenge.get(key) ?? { total: 0, pending: 0 };
    current.total += 1;
    if (!row.reviewed) current.pending += 1;
    submissionsByChallenge.set(key, current);
  }
}

const challenges: ChallengeWithMeta[] = (challengeRows ?? []).map((c) => {
  const course = c.courses as { title: string | null } | null;
  const counts = submissionsByChallenge.get(c.id) ?? { total: 0, pending: 0 };
  return {
    id: c.id,
    title: c.title ?? 'Sin título',
    description: (c.description as string | null) ?? null,
    deadline: c.deadline ?? null,
    points_reward: c.points_reward ?? 0,
    is_active: c.is_active ?? false,
    course_id: (c.course_id as string) ?? null,
    courseTitle: course?.title ?? '—',
    submissionsCount: counts.total,
    pendingCount: counts.pending,
  };
});

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));
const view = Astro.url.searchParams.get('view') ?? 'all';
const query = (Astro.url.searchParams.get('q') ?? '').trim().toLowerCase();
const courseFilter = Astro.url.searchParams.get('course') ?? '';

let filteredChallenges = challenges;
if (view === 'active') filteredChallenges = filteredChallenges.filter((c) => c.is_active);
if (view === 'inactive') filteredChallenges = filteredChallenges.filter((c) => !c.is_active);
if (courseFilter) filteredChallenges = filteredChallenges.filter((c) => (c.course_id ?? '') === courseFilter);
if (query) {
  filteredChallenges = filteredChallenges.filter((c) =>
    `${c.title} ${c.courseTitle} ${c.description ?? ''}`.toLowerCase().includes(query),
  );
}

const selectedCourse = courses.find((c) => c.id === courseFilter) ?? null;
const selectedCourseFilterLabel = selectedCourse?.title ?? '— Todos los cursos —';

const totalChallenges = challenges.length;
const activeChallenges = challenges.filter((c) => c.is_active).length;
const totalSubmissions = challenges.reduce((acc, c) => acc + c.submissionsCount, 0);
const pendingSubmissions = challenges.reduce((acc, c) => acc + c.pendingCount, 0);

function formatDeadline(iso: string | null): string {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleString('es', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}

function tabUrl(nextView: string): string {
  const u = new URL(Astro.url);
  u.searchParams.set('view', nextView);
  if (query) u.searchParams.set('q', query);
  if (courseFilter) u.searchParams.set('course', courseFilter);
  return `${u.pathname}${u.search}`;
}
---

<DashboardLayout>
  <Fragment slot="head">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js" defer></script>
  </Fragment>
  <section class="max-w-5xl space-y-8 xl:max-w-6xl">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Retos</h1>
      <p class="mt-1 text-sm text-muted">Crear y activar desafíos para el cohort.</p>
    </header>

    <div class="rounded-xl border border-transparent bg-surface">
      <button
        type="button"
        id="toggle-create-challenge"
        aria-expanded="false"
        aria-controls="create-challenge-form"
        class="flex w-full items-center justify-between px-5 py-4 text-left text-sm font-medium text-white transition hover:bg-surface-2/60"
      >
        <span>Crear nuevo reto</span>
        <svg id="toggle-create-challenge-icon" class="h-5 w-5 shrink-0 text-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id="create-challenge-form" class="hidden border-t border-transparent px-5 pb-6 pt-5" role="region">
        <form method="post" action="/api/admin/challenges" class="space-y-6">
          <input type="hidden" name="action" value="create" />
          <input type="hidden" name="redirect_to" value="/admin/challenges" />
          <div>
            <label for="challenge-title" class="block text-xs font-medium text-muted">Título</label>
            <input id="challenge-title" type="text" name="title" required class="mt-1.5 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" placeholder="Ej: Landing en Webflow" />
          </div>
          <div>
            <label for="challenge-description" class="block text-xs font-medium text-muted">Descripción</label>
            <textarea id="challenge-description" name="description" rows={4} class="mt-1.5 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" placeholder="Instrucciones del reto"></textarea>
            <p class="mt-1 text-[11px] text-muted/80">Puedes usar Markdown: <strong>**negrita**</strong>, <em>*cursiva*</em>, [texto del enlace](url)</p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="challenge-points" class="block text-xs font-medium text-muted">Puntos</label>
              <input id="challenge-points" type="number" name="points_reward" value="30" min="0" class="mt-1.5 w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
            </div>
            <div>
              <label for="challenge-deadline" class="block text-xs font-medium text-muted">Fecha límite</label>
              <div class="relative mt-1.5">
                <input id="challenge-deadline" type="text" name="deadline" readonly class="w-full cursor-pointer rounded-lg border border-transparent bg-surface-2 py-2.5 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" placeholder="Elegir fecha y hora" autocomplete="off" />
                <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
              </div>
            </div>
          </div>
          <div>
            <label for="challenge-course" class="block text-xs font-medium text-muted">Curso</label>
            <div class="custom-select custom-select--single relative mt-1" data-name="course_id">
              <input id="challenge-course" type="hidden" name="course_id" value="" />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
              >
                <span class="custom-select-label truncate">— Sin curso —</span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl">
                <button type="button" class="custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md bg-lime/10 px-2.5 py-2 text-left text-sm text-lime transition hover:bg-surface-2" data-value="" data-label="— Sin curso —">
                  <span class="flex h-4 w-4 items-center justify-center rounded-[4px] border border-lime bg-lime text-background">
                    <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                  </span>
                  <span class="truncate">— Sin curso —</span>
                </button>
                {courses.map((c) => (
                  <button
                    type="button"
                    class="custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm text-white transition hover:bg-surface-2"
                    data-value={c.id}
                    data-label={c.title}
                  >
                    <span class="flex h-4 w-4 items-center justify-center rounded-[4px] border border-transparent bg-surface-2 text-transparent transition">
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">{c.title}</span>
                  </button>
                ))}
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-start sm:gap-8">
            <label class="flex cursor-pointer items-center gap-2.5">
              <input type="checkbox" name="activate_now" value="on" class="peer sr-only" />
              <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border border-transparent bg-surface-2 text-transparent transition peer-checked:border-lime peer-checked:bg-lime peer-checked:text-background peer-checked:shadow-[0_0_0_1px_var(--color-lime)]">
                <i class="bi bi-check-lg text-[11px] leading-none" aria-hidden="true" />
              </span>
              <span class="text-sm text-white">Activar ahora</span>
            </label>
            <label class="flex cursor-pointer items-center gap-2.5">
              <input type="checkbox" name="available_for_on_demand" value="on" class="peer sr-only" />
              <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border border-transparent bg-surface-2 text-transparent transition peer-checked:border-lime peer-checked:bg-lime peer-checked:text-background peer-checked:shadow-[0_0_0_1px_var(--color-lime)]">
                <i class="bi bi-check-lg text-[11px] leading-none" aria-hidden="true" />
              </span>
              <span class="text-sm text-white">Disponible para on-demand</span>
            </label>
            <div id="scheduled-at-wrap" class="hidden min-w-[240px] flex-1">
              <label for="challenge-scheduled" class="block text-xs font-medium text-muted">Programar para</label>
              <div class="relative mt-1.5">
                <input id="challenge-scheduled" type="text" name="scheduled_at" readonly class="w-full cursor-pointer rounded-lg border border-transparent bg-surface-2 py-2.5 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" placeholder="Elegir fecha y hora" autocomplete="off" />
                <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
              </div>
            </div>
          </div>
          <div class="pt-2">
          <button type="submit" class="btn btn-primary">
            Crear reto
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </button>
          </div>
        </form>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-transparent bg-[#012EDC] p-4">
        <p class="font-manrope text-2xl font-semibold text-white/90">Total retos</p>
        <p class="mt-8 font-manrope text-2xl font-semibold text-white sm:text-4xl">{totalChallenges}</p>
      </div>
      <div class="rounded-xl border border-transparent bg-[#FFBE00] p-4">
        <p class="font-manrope text-2xl font-semibold text-background/80">Activos</p>
        <p class="mt-8 font-manrope text-2xl font-semibold text-background sm:text-4xl">{activeChallenges}</p>
      </div>
      <div class="rounded-xl border border-transparent bg-[#012EDC] p-4">
        <p class="font-manrope text-2xl font-semibold text-white/90">Entregas</p>
        <p class="mt-8 font-manrope text-2xl font-semibold text-white sm:text-4xl">{totalSubmissions}</p>
      </div>
      <div class="rounded-xl border border-transparent bg-[#FFBE00] p-4">
        <p class="font-manrope text-2xl font-semibold text-background/80">Pendientes</p>
        <p class="mt-8 font-manrope text-2xl font-semibold text-background sm:text-4xl">{pendingSubmissions}</p>
      </div>
    </div>

    <div class="space-y-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap items-center gap-2 rounded-xl border border-transparent bg-surface p-1">
          <a href={tabUrl('all')} class={`rounded-lg px-3 py-1.5 text-xs font-semibold transition ${view === 'all' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Todos</a>
          <a href={tabUrl('active')} class={`rounded-lg px-3 py-1.5 text-xs font-semibold transition ${view === 'active' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Activos</a>
          <a href={tabUrl('inactive')} class={`rounded-lg px-3 py-1.5 text-xs font-semibold transition ${view === 'inactive' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Inactivos</a>
        </div>
        <form method="get" action="/admin/challenges" class="flex w-full flex-wrap items-end gap-3">
          <input type="hidden" name="view" value={view} />
          <div class="min-w-[200px]">
            <label for="course-filter" class="block text-[11px] font-medium text-muted">Curso</label>
            <div class="custom-select custom-select--single relative mt-1" data-name="course">
              <input type="hidden" id="course-filter" name="course" value={courseFilter} />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-background px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
              >
                <span class="custom-select-label truncate">{selectedCourseFilterLabel}</span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl">
                <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!courseFilter ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Todos los cursos —">
                  <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!courseFilter ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                    <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                  </span>
                  <span class="truncate">— Todos los cursos —</span>
                </button>
                {courses.map((c) => {
                  const isSelected = courseFilter === c.id;
                  return (
                    <button
                      type="button"
                      class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                      data-value={c.id}
                      data-label={c.title}
                    >
                      <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                        <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                      </span>
                      <span class="truncate">{c.title}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          </div>
          <div class="min-w-[180px] flex-1">
            <label for="search-q" class="block text-[11px] font-medium text-muted">Buscar</label>
            <input
              id="search-q"
              type="search"
              name="q"
              value={query}
              placeholder="Título o descripción..."
              class="mt-1 w-full rounded-lg border border-transparent bg-surface px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            />
          </div>
<button type="submit" class="btn btn-secondary">
          Filtrar
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
        </button>
        </form>
      </div>

      {filteredChallenges.length > 0 ? (
        <div class="space-y-3">
          {filteredChallenges.map((ch) => (
            <article class="rounded-xl border border-transparent bg-surface p-4 shadow-[0_8px_24px_rgba(0,0,0,0.16)]">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0 space-y-2">
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="text-base font-semibold text-white">{ch.title}</h3>
                    <span class={`inline-flex items-center gap-1.5 text-[11px] font-medium ${ch.is_active ? 'text-lime' : 'text-muted'}`} aria-label={ch.is_active ? 'Activo' : 'Inactivo'}>
                      <span class={`h-1.5 w-1.5 shrink-0 rounded-full ${ch.is_active ? 'bg-lime' : 'bg-muted'}`} aria-hidden="true"></span>
                      {ch.is_active ? 'Activo' : 'Inactivo'}
                    </span>
                  </div>
                  {ch.description && (
                    <div class="line-clamp-2 max-w-2xl text-sm text-muted challenge-description" set:html={renderMarkdown(ch.description)} />
                  )}
                  <div class="flex flex-wrap items-center gap-2 text-xs">
                    <span class="rounded-md border border-transparent bg-surface-2 px-2 py-1 text-muted">
                      Curso: <span class="text-white">{ch.courseTitle}</span>
                    </span>
                    <span class="rounded-md border border-transparent bg-surface-2 px-2 py-1 text-muted">
                      Límite: <span class="text-white">{formatDeadline(ch.deadline)}</span>
                    </span>
                    <span class="rounded-md border border-lime/40 bg-lime/10 px-2 py-1 font-semibold text-lime">
                      {ch.points_reward} pts
                    </span>
                    <span class="rounded-md border border-transparent bg-surface-2 px-2 py-1 text-muted">
                      Entregas: <span class="text-white">{ch.submissionsCount}</span>
                    </span>
                    {ch.pendingCount > 0 && (
                      <span class="rounded-md border border-amber-400/40 bg-amber-500/10 px-2 py-1 font-semibold text-amber-300">
                        Pendientes: {ch.pendingCount}
                      </span>
                    )}
                  </div>
                </div>

                <div class="flex w-full flex-wrap items-center gap-2 lg:w-auto lg:justify-end">
                  <a href={`/admin/submissions?challenge=${ch.id}`} class="btn btn-secondary h-8 text-xs">Ver submissions</a>
                  <a href={`/admin/challenges/${ch.id}/edit`} class="btn btn-ghost btn-icon h-8 w-8" title="Editar" aria-label="Editar">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                  </a>
                  <form method="post" action="/api/admin/challenges" class="inline">
                    <input type="hidden" name="action" value="toggle" />
                    <input type="hidden" name="challenge_id" value={ch.id} />
                    <input type="hidden" name="redirect_to" value="/admin/challenges" />
                    <button type="submit" title={ch.is_active ? 'Desactivar' : 'Activar'} class="btn btn-ghost btn-icon h-8 w-8" aria-label={ch.is_active ? 'Desactivar' : 'Activar'}>
                      <i class={`bi ${ch.is_active ? 'bi-pause-circle' : 'bi-play-circle'}`} aria-hidden="true"></i>
                    </button>
                  </form>
                  <form method="post" action="/api/admin/challenges" class="inline" onsubmit="return confirm('¿Eliminar este reto?');">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="challenge_id" value={ch.id} />
                    <input type="hidden" name="redirect_to" value="/admin/challenges" />
                    <button type="submit" title="Eliminar" class="btn btn-danger btn-icon h-8 w-8" aria-label="Eliminar">
                      <i class="bi bi-trash" aria-hidden="true"></i>
                    </button>
                  </form>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="rounded-xl border border-dashed border-transparent bg-background p-6 text-center text-sm text-muted">
          {challenges.length === 0
            ? 'Aún no hay retos. Crea el primero con el formulario de arriba.'
            : 'No se encontraron retos con ese filtro.'}
        </p>
      )}
    </div>
  </section>
</DashboardLayout>

<script is:inline>
  (function() {
    function init() {
      var toggle = document.getElementById('toggle-create-challenge');
      var form = document.getElementById('create-challenge-form');
      var icon = document.getElementById('toggle-create-challenge-icon');
      if (toggle && form && icon) {
        toggle.addEventListener('click', function() {
          var open = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!open));
          form.classList.toggle('hidden', open);
          icon.classList.toggle('rotate-180', !open);
          if (!open) {
            form.style.overflow = 'visible';
            requestAnimationFrame(function() {
              document.dispatchEvent(new CustomEvent('custom-select-reinit', { detail: { container: form } }));
              document.dispatchEvent(new CustomEvent('create-form-shown'));
            });
          }
        });
      }
      var activateNow = document.querySelector('input[name="activate_now"]');
      var scheduledWrap = document.getElementById('scheduled-at-wrap');
      if (activateNow && scheduledWrap) {
        function update() { scheduledWrap.classList.toggle('hidden', activateNow.checked); }
        activateNow.addEventListener('change', update);
        update();
      }
    }
