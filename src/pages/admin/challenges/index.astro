---
import '../../../styles/global.css';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { data: challengeRows } = await supabase
  .from('challenges')
  .select('id, title, description, deadline, points_reward, is_active, course_id, courses(title)')
  .order('created_at', { ascending: false });

type ChallengeWithMeta = {
  id: string;
  title: string;
  description: string | null;
  deadline: string | null;
  points_reward: number;
  is_active: boolean;
  courseTitle: string;
  submissionsCount: number;
  pendingCount: number;
};

const challengeIds = (challengeRows ?? []).map((c) => c.id);
const submissionsByChallenge = new Map<string, { total: number; pending: number }>();
if (challengeIds.length > 0) {
  const { data: submissionRows } = await supabase
    .from('submissions')
    .select('challenge_id, reviewed')
    .in('challenge_id', challengeIds);
  for (const row of submissionRows ?? []) {
    const key = row.challenge_id as string;
    const current = submissionsByChallenge.get(key) ?? { total: 0, pending: 0 };
    current.total += 1;
    if (!row.reviewed) current.pending += 1;
    submissionsByChallenge.set(key, current);
  }
}

const challenges: ChallengeWithMeta[] = (challengeRows ?? []).map((c) => {
  const course = c.courses as { title: string | null } | null;
  const counts = submissionsByChallenge.get(c.id) ?? { total: 0, pending: 0 };
  return {
    id: c.id,
    title: c.title ?? 'Sin título',
    description: (c.description as string | null) ?? null,
    deadline: c.deadline ?? null,
    points_reward: c.points_reward ?? 0,
    is_active: c.is_active ?? false,
    courseTitle: course?.title ?? '—',
    submissionsCount: counts.total,
    pendingCount: counts.pending,
  };
});

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));
const view = Astro.url.searchParams.get('view') ?? 'all';
const query = (Astro.url.searchParams.get('q') ?? '').trim().toLowerCase();

let filteredChallenges = challenges;
if (view === 'active') filteredChallenges = filteredChallenges.filter((c) => c.is_active);
if (view === 'inactive') filteredChallenges = filteredChallenges.filter((c) => !c.is_active);
if (query) {
  filteredChallenges = filteredChallenges.filter((c) =>
    `${c.title} ${c.courseTitle} ${c.description ?? ''}`.toLowerCase().includes(query),
  );
}

const totalChallenges = challenges.length;
const activeChallenges = challenges.filter((c) => c.is_active).length;
const totalSubmissions = challenges.reduce((acc, c) => acc + c.submissionsCount, 0);
const pendingSubmissions = challenges.reduce((acc, c) => acc + c.pendingCount, 0);

function formatDeadline(iso: string | null): string {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleString('es', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}

function tabUrl(nextView: string): string {
  const u = new URL(Astro.url);
  u.searchParams.set('view', nextView);
  if (query) u.searchParams.set('q', query);
  return `${u.pathname}${u.search}`;
}
---

<AdminLayout>
  <section class="space-y-8">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Retos</h1>
      <p class="mt-1 text-sm text-muted">Crear y activar desafíos para el cohort.</p>
    </header>

    <div class="rounded-xl border border-border bg-surface">
      <button
        type="button"
        id="toggle-create-challenge"
        aria-expanded="false"
        aria-controls="create-challenge-form"
        class="flex w-full items-center justify-between px-5 py-4 text-left text-sm font-medium text-white transition hover:bg-surface-2/60"
      >
        <span>Crear nuevo reto</span>
        <svg id="toggle-create-challenge-icon" class="h-5 w-5 shrink-0 text-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id="create-challenge-form" class="hidden border-t border-border px-5 pb-5 pt-4" role="region">
        <form method="post" action="/api/admin/challenges" class="space-y-4">
          <input type="hidden" name="action" value="create" />
          <input type="hidden" name="redirect_to" value="/admin/challenges" />
          <div>
            <label for="challenge-title" class="block text-xs font-medium text-muted">Título</label>
            <input id="challenge-title" type="text" name="title" required class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" placeholder="Ej: Landing en Webflow" />
          </div>
          <div>
            <label for="challenge-description" class="block text-xs font-medium text-muted">Descripción</label>
            <textarea id="challenge-description" name="description" rows={3} class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" placeholder="Instrucciones del reto"></textarea>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="challenge-points" class="block text-xs font-medium text-muted">Puntos</label>
              <input id="challenge-points" type="number" name="points_reward" value="30" min="0" class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
            </div>
            <div>
              <label for="challenge-deadline" class="block text-xs font-medium text-muted">Fecha límite</label>
              <input id="challenge-deadline" type="datetime-local" name="deadline" class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
            </div>
          </div>
          <div>
            <label for="challenge-course" class="block text-xs font-medium text-muted">Curso</label>
            <select id="challenge-course" name="course_id" class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime">
              <option value="">— Sin curso —</option>
              {courses.map((c) => (
                <option value={c.id}>{c.title}</option>
              ))}
            </select>
          </div>
          <div class="flex flex-wrap items-center gap-4">
            <label class="flex items-center gap-2">
              <input type="checkbox" name="activate_now" value="on" class="rounded border-border bg-surface-2 text-lime focus:ring-lime" />
              <span class="text-sm text-white">Activar ahora</span>
            </label>
            <div id="scheduled-at-wrap" class="hidden">
              <label for="challenge-scheduled" class="block text-xs font-medium text-muted">Programar para</label>
              <input id="challenge-scheduled" type="datetime-local" name="scheduled_at" class="mt-1 rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
            </div>
          </div>
          <button type="submit" class="rounded-lg border border-lime bg-lime px-4 py-2 text-sm font-medium text-background transition hover:bg-lime/90">
            Crear reto
          </button>
        </form>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[11px] uppercase tracking-[0.14em] text-muted">Total retos</p>
        <p class="mt-1 text-2xl font-semibold text-white">{totalChallenges}</p>
      </div>
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[11px] uppercase tracking-[0.14em] text-muted">Activos</p>
        <p class="mt-1 text-2xl font-semibold text-lime">{activeChallenges}</p>
      </div>
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[11px] uppercase tracking-[0.14em] text-muted">Entregas</p>
        <p class="mt-1 text-2xl font-semibold text-white">{totalSubmissions}</p>
      </div>
      <div class="rounded-xl border border-border bg-surface p-4">
        <p class="text-[11px] uppercase tracking-[0.14em] text-muted">Pendientes</p>
        <p class="mt-1 text-2xl font-semibold text-amber-300">{pendingSubmissions}</p>
      </div>
    </div>

    <div class="space-y-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap items-center gap-2 rounded-xl border border-border bg-surface p-1">
          <a href={tabUrl('all')} class={`rounded-lg px-3 py-1.5 text-xs font-semibold transition ${view === 'all' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Todos</a>
          <a href={tabUrl('active')} class={`rounded-lg px-3 py-1.5 text-xs font-semibold transition ${view === 'active' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Activos</a>
          <a href={tabUrl('inactive')} class={`rounded-lg px-3 py-1.5 text-xs font-semibold transition ${view === 'inactive' ? 'bg-lime/15 text-lime' : 'text-muted hover:text-white'}`}>Inactivos</a>
        </div>
        <form method="get" action="/admin/challenges" class="flex w-full max-w-sm items-center gap-2">
          <input type="hidden" name="view" value={view} />
          <input
            type="search"
            name="q"
            value={query}
            placeholder="Buscar por título o curso..."
            class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
          />
          <button type="submit" class="rounded-lg border border-border bg-surface-2 px-3 py-2 text-xs font-medium text-white transition hover:border-lime/50 hover:bg-surface-2/80">Buscar</button>
        </form>
      </div>

      {filteredChallenges.length > 0 ? (
        <div class="space-y-3">
          {filteredChallenges.map((ch) => (
            <article class="rounded-xl border border-border bg-surface p-4 shadow-[0_8px_24px_rgba(0,0,0,0.16)]">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0 space-y-2">
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="text-base font-semibold text-white">{ch.title}</h3>
                    <span class={`inline-flex rounded-full px-2.5 py-1 text-[11px] font-semibold ${ch.is_active ? 'bg-lime/15 text-lime' : 'bg-surface-2 text-muted'}`}>
                      {ch.is_active ? 'Activo' : 'Inactivo'}
                    </span>
                  </div>
                  {ch.description && (
                    <p class="line-clamp-2 max-w-2xl text-sm text-muted">{ch.description}</p>
                  )}
                  <div class="flex flex-wrap items-center gap-2 text-xs">
                    <span class="rounded-md border border-border bg-surface-2 px-2 py-1 text-muted">
                      Curso: <span class="text-white">{ch.courseTitle}</span>
                    </span>
                    <span class="rounded-md border border-border bg-surface-2 px-2 py-1 text-muted">
                      Límite: <span class="text-white">{formatDeadline(ch.deadline)}</span>
                    </span>
                    <span class="rounded-md border border-lime/40 bg-lime/10 px-2 py-1 font-semibold text-lime">
                      {ch.points_reward} pts
                    </span>
                    <span class="rounded-md border border-border bg-surface-2 px-2 py-1 text-muted">
                      Entregas: <span class="text-white">{ch.submissionsCount}</span>
                    </span>
                    {ch.pendingCount > 0 && (
                      <span class="rounded-md border border-amber-400/40 bg-amber-500/10 px-2 py-1 font-semibold text-amber-300">
                        Pendientes: {ch.pendingCount}
                      </span>
                    )}
                  </div>
                </div>

                <div class="flex w-full flex-wrap gap-2 lg:w-auto lg:justify-end">
                  <a href={`/admin/submissions?challenge=${ch.id}`} class="inline-flex h-8 items-center rounded-lg border border-lime/40 bg-lime/10 px-3 text-xs font-medium text-lime transition hover:bg-lime/20">
                    Ver submissions
                  </a>
                  <a href={`/admin/challenges/${ch.id}/edit`} class="inline-flex h-8 items-center rounded-lg border border-border bg-surface-2 px-3 text-xs font-medium text-white transition hover:border-lime/50 hover:bg-surface-2/80">
                    Editar
                  </a>
                  <form method="post" action="/api/admin/challenges" class="inline">
                    <input type="hidden" name="action" value="toggle" />
                    <input type="hidden" name="challenge_id" value={ch.id} />
                    <input type="hidden" name="redirect_to" value="/admin/challenges" />
                    <button type="submit" class="inline-flex h-8 items-center rounded-lg border border-border bg-surface-2 px-3 text-xs font-medium text-white transition hover:border-lime/50 hover:bg-surface-2/80">
                      {ch.is_active ? 'Desactivar' : 'Activar'}
                    </button>
                  </form>
                  <form method="post" action="/api/admin/challenges" class="inline" onsubmit="return confirm('¿Eliminar este reto?');">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="challenge_id" value={ch.id} />
                    <input type="hidden" name="redirect_to" value="/admin/challenges" />
                    <button type="submit" class="inline-flex h-8 items-center rounded-lg border border-red-500/50 bg-red-500/10 px-3 text-xs font-medium text-red-400 transition hover:bg-red-500/20">
                      Eliminar
                    </button>
                  </form>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="rounded-xl border border-dashed border-border bg-surface-2/60 p-6 text-center text-sm text-muted">
          {challenges.length === 0
            ? 'Aún no hay retos. Crea el primero con el formulario de arriba.'
            : 'No se encontraron retos con ese filtro.'}
        </p>
      )}
    </div>
  </section>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('toggle-create-challenge');
    const form = document.getElementById('create-challenge-form');
    const icon = document.getElementById('toggle-create-challenge-icon');
    const activateNow = document.querySelector('input[name="activate_now"]');
    const scheduledWrap = document.getElementById('scheduled-at-wrap');
    if (toggle && form && icon) {
      toggle.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        form.classList.toggle('hidden', open);
        icon.classList.toggle('rotate-180', !open);
      });
    }
    if (activateNow && scheduledWrap) {
      const update = () => {
        scheduledWrap.classList.toggle('hidden', activateNow.checked);
      };
      activateNow.addEventListener('change', update);
      update();
    }
  });
</script>
