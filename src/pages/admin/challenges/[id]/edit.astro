---
import '../../../../styles/global.css';
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../../lib/supabase';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id: challengeId } = Astro.params as { id: string };
if (!challengeId) {
  return Astro.redirect('/admin/challenges');
}

const { data: challenge } = await supabase
  .from('challenges')
  .select('id, title, description, deadline, points_reward, course_id, is_active')
  .eq('id', challengeId)
  .maybeSingle();

if (!challenge) {
  return Astro.redirect('/admin/challenges');
}

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));

const deadlineLocal = challenge.deadline ? new Date(challenge.deadline as string).toISOString().slice(0, 16) : '';
---

<AdminLayout>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/admin/challenges" class="hover:text-white">Retos</a>
      <span class="mx-1">/</span>
      <span class="text-white">{challenge.title}</span>
      <span class="mx-1">/</span>
      <span class="text-white">Editar</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Editar reto</h1>
      <p class="mt-1 text-sm text-muted">{challenge.title}</p>
    </header>

    <form method="post" action="/api/admin/challenges" class="max-w-xl space-y-4 rounded-xl border border-border bg-surface p-5">
      <input type="hidden" name="action" value="update" />
      <input type="hidden" name="challenge_id" value={challengeId} />
      <input type="hidden" name="redirect_to" value="/admin/challenges" />

      <div>
        <label for="edit-title" class="block text-xs font-medium text-muted">Título</label>
        <input id="edit-title" type="text" name="title" required value={challenge.title ?? ''} class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
      </div>
      <div>
        <label for="edit-description" class="block text-xs font-medium text-muted">Descripción</label>
        <textarea id="edit-description" name="description" rows={4} class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime">{(challenge.description as string) ?? ''}</textarea>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="edit-deadline" class="block text-xs font-medium text-muted">Fecha límite</label>
          <input id="edit-deadline" type="datetime-local" name="deadline" value={deadlineLocal} class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
        </div>
        <div>
          <label for="edit-points" class="block text-xs font-medium text-muted">Puntos</label>
          <input id="edit-points" type="number" name="points_reward" min="0" value={challenge.points_reward ?? 30} class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime" />
        </div>
      </div>
      <div>
        <label for="edit-course" class="block text-xs font-medium text-muted">Curso</label>
        <select id="edit-course" name="course_id" class="mt-1 w-full rounded-lg border border-border bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime">
          <option value="" selected={!challenge.course_id}>— Sin curso —</option>
          {courses.map((c) => (
            <option value={c.id} selected={(challenge.course_id as string) === c.id}>{c.title}</option>
          ))}
        </select>
      </div>
      <label class="flex items-center gap-2">
        <input type="checkbox" name="is_active" value="on" class="rounded border-border bg-surface-2 text-lime focus:ring-lime" checked={challenge.is_active ?? false} />
        <span class="text-sm text-white">Activo</span>
      </label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="rounded-lg border border-lime bg-lime px-4 py-2 text-sm font-medium text-background transition hover:bg-lime/90">
          Guardar cambios
        </button>
        <a href="/admin/challenges" class="rounded-lg border border-border bg-surface-2 px-4 py-2 text-sm font-medium text-white transition hover:bg-surface-2/80">
          Cancelar
        </a>
      </div>
    </form>
  </section>
</AdminLayout>
