---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../../lib/supabase';
import { avatarImagePath } from '../../../lib/avatars';
import { formatDateTime } from '../../../lib/format-date';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
if ((userRow?.role as string) !== 'admin') {
  return Astro.redirect('/dashboard');
}

const selectedCourseId = Astro.url.searchParams.get('course') ?? '';
const selectedLessonId = Astro.url.searchParams.get('lesson') ?? '';

const { data: coursesRows } = await supabase.from('courses').select('id, title').order('title');
const courses = (coursesRows ?? []).map((c) => ({ id: c.id, title: c.title ?? 'Sin título' }));

const { data: lessonRows } = await supabase
  .from('lessons')
  .select('id, title, scheduled_at, order, course_id, courses(title)')
  .order('scheduled_at', { ascending: true, nullsFirst: false });

const allLessons = (lessonRows ?? []).map((l) => {
  const course = l.courses as { title: string | null } | null;
  return {
    id: l.id,
    title: l.title ?? 'Clase',
    scheduledAt: (l.scheduled_at as string | null) ?? null,
    order: (l.order as number | null) ?? 0,
    courseId: l.course_id as string,
    courseTitle: course?.title ?? 'Curso',
  };
});

const lessons = selectedCourseId ? allLessons.filter((l) => l.courseId === selectedCourseId) : [];
const selectedCourse = courses.find((c) => c.id === selectedCourseId) ?? null;
const selectedLesson = allLessons.find((l) => l.id === selectedLessonId) ?? null;

let students: { id: string; name: string; email: string | null; avatarId: string | null; alreadyPresent: boolean }[] = [];
if (selectedLesson) {
  const { data: enrollmentRows } = await supabase
    .from('enrollments')
    .select('user_id, access_type, users(id, display_name, email, avatar_id, role)')
    .eq('course_id', selectedLesson.courseId);

  const { data: attendanceRows } = await supabase
    .from('attendance')
    .select('user_id')
    .eq('lesson_id', selectedLesson.id);
  const presentSet = new Set((attendanceRows ?? []).map((r) => r.user_id as string));

  students = (enrollmentRows ?? [])
    .filter((row) => (row.access_type as string) !== 'on_demand')
    .map((row) => {
      const u = row.users as { id: string; display_name: string | null; email: string | null; avatar_id: string | null; role: string | null } | null;
      if (!u?.id || u.role !== 'student') return null;
      return {
        id: u.id,
        name: u.display_name ?? 'Estudiante',
        email: u.email ?? null,
        avatarId: u.avatar_id ?? null,
        alreadyPresent: presentSet.has(u.id),
      };
    })
    .filter((s): s is { id: string; name: string; email: string | null; avatarId: string | null; alreadyPresent: boolean } => Boolean(s));
}

---

<DashboardLayout>
  <section class="max-w-5xl space-y-6 xl:max-w-6xl">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Asistencia</h1>
      <p class="mt-1 text-sm text-muted">Marca asistencia por clase y suma puntos automáticamente.</p>
    </header>

    <div class="rounded-xl border border-transparent bg-surface p-5">
      <form method="get" action="/admin/attendance" class="flex flex-wrap items-end gap-3">
        <div class="min-w-[240px]">
          <label for="course-select" class="block text-xs font-medium text-muted">Curso</label>
          <div class="custom-select custom-select--single relative mt-1" data-name="course">
            <input type="hidden" id="course-select" name="course" value={selectedCourseId} />
            <button
              type="button"
              class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span class="custom-select-label truncate">{selectedCourse?.title ?? '— Elige un curso —'}</span>
              <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
              </svg>
            </button>
            <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
              <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!selectedCourseId ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Elige un curso —">
                <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!selectedCourseId ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                  <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                </span>
                <span class="truncate">— Elige un curso —</span>
              </button>
              {courses.map((c) => {
                const isSelected = selectedCourseId === c.id;
                return (
                  <button
                    type="button"
                    class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                    data-value={c.id}
                    data-label={c.title}
                  >
                    <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">{c.title}</span>
                  </button>
                );
              })}
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">
          Cargar clases
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </button>
      </form>

      {selectedCourseId && (
        <form method="get" action="/admin/attendance" class="mt-4 flex flex-wrap items-end gap-3">
          <input type="hidden" name="course" value={selectedCourseId} />
          <div class="min-w-[280px]">
            <label for="lesson-select" class="block text-xs font-medium text-muted">Clase</label>
            <div class="custom-select custom-select--single relative mt-1" data-name="lesson">
              <input type="hidden" id="lesson-select" name="lesson" value={selectedLessonId} />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-left text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
                aria-haspopup="listbox"
              >
                <span class="custom-select-label truncate">
                  {selectedLesson ? `${selectedLesson.title} · ${formatDateTime(selectedLesson.scheduledAt)}` : '— Elige una clase —'}
                </span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
                <button type="button" class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${!selectedLessonId ? 'bg-lime/10 text-lime' : 'text-white'}`} data-value="" data-label="— Elige una clase —">
                  <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${!selectedLessonId ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                    <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                  </span>
                  <span class="truncate">— Elige una clase —</span>
                </button>
                {lessons.map((l) => {
                  const optionLabel = `${l.title} · ${formatDateTime(l.scheduledAt)}`;
                  const isSelected = selectedLessonId === l.id;
                  return (
                    <button
                      type="button"
                      class={`custom-select-option mt-1 flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                      data-value={l.id}
                      data-label={optionLabel}
                    >
                      <span class={`flex h-4 w-4 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                        <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                      </span>
                      <span class="truncate">{optionLabel}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn-secondary">Cargar alumnos</button>
        </form>
      )}

      {selectedCourseId && lessons.length === 0 && (
        <div class="mt-4 rounded-xl border border-dashed border-transparent bg-background p-6 text-center">
          <p class="text-sm text-muted">No hay clases en este curso.</p>
        </div>
      )}
    </div>

    {selectedLesson ? (
      <div class="rounded-xl border border-transparent bg-surface p-5">
        <div class="mb-4">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{selectedLesson.courseTitle}</p>
          <h2 class="mt-1 text-lg font-semibold text-white">{selectedLesson.title}</h2>
          <p class="text-xs text-muted">{formatDateTime(selectedLesson.scheduledAt)}</p>
        </div>

        {students.length > 0 ? (
          <form method="post" action="/api/admin/attendance" id="attendance-form" class="space-y-4">
            <input type="hidden" name="lesson_id" value={selectedLesson.id} />
            <input type="hidden" name="redirect_to" value={`/admin/attendance?course=${selectedLesson.courseId}&lesson=${selectedLesson.id}`} />
            <p class="text-sm text-muted">Selecciona los alumnos que asistieron a esta clase.</p>
            <div class="flex flex-wrap items-center gap-2">
              <button type="button" id="select-all-attendance" class="rounded-lg border border-lime/50 bg-lime/10 px-3 py-1.5 text-xs font-medium text-lime transition hover:bg-lime/20">
                Marcar todos
              </button>
              <button type="button" id="deselect-all-attendance" class="rounded-lg border border-transparent bg-surface-2 px-3 py-1.5 text-xs font-medium text-muted transition hover:bg-surface-2/80 hover:text-white">
                Desmarcar todos
              </button>
              <span class="text-xs text-muted">· Shift+clic para seleccionar un bloque</span>
            </div>
            <ul class="space-y-2" id="attendance-student-list">
              {students.map((s, idx) => (
                <li class="rounded-lg border border-transparent bg-surface-2/60 px-3 py-2.5" data-index={idx}>
                  <label class="relative flex cursor-pointer items-center gap-3 attendance-row">
                    <input
                      type="checkbox"
                      name="user_ids"
                      value={s.id}
                      checked={s.alreadyPresent}
                      class="peer absolute inset-0 z-[1] h-full w-full cursor-pointer opacity-0"
                      aria-label={`Asistencia: ${s.name}`}
                    />
                    <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border border-transparent bg-surface text-transparent transition peer-checked:border-lime peer-checked:bg-lime peer-checked:text-background peer-checked:shadow-[0_0_0_1px_var(--color-lime)]">
                      <i class="bi bi-check-lg text-[11px] leading-none" aria-hidden="true" />
                    </span>
                    <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full border border-transparent bg-surface">
                      {avatarImagePath(s.avatarId) ? (
                        <img src={avatarImagePath(s.avatarId)!} alt="" class="h-full w-full object-cover" width="32" height="32" />
                      ) : (
                        <span class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted">{s.name.charAt(0).toUpperCase()}</span>
                      )}
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-sm font-medium text-white">{s.name}</p>
                      <p class="truncate text-xs text-muted">{s.email ?? '—'}</p>
                    </div>
                    {s.alreadyPresent && (
                      <span class="rounded-full bg-lime/15 px-2 py-0.5 text-[10px] font-semibold text-lime">Ya marcada</span>
                    )}
                  </label>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap items-center gap-3 pt-2">
              <button type="submit" class="btn btn-primary">
                Guardar asistencia
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </button>
              <span id="attendance-count" class="text-sm text-muted">0 seleccionados</span>
            </div>
          </form>

          <script>
            document.addEventListener('DOMContentLoaded', () => {
              const form = document.getElementById('attendance-form');
              const list = document.getElementById('attendance-student-list');
              const checkboxes = form?.querySelectorAll('input[name="user_ids"]');
              const rows = list?.querySelectorAll('.attendance-row');
              const selectAll = document.getElementById('select-all-attendance');
              const deselectAll = document.getElementById('deselect-all-attendance');
              const countEl = document.getElementById('attendance-count');
              const mainEl = document.querySelector('#main-content-panel main');

              let lastClickedIndex = -1;
              let savedMainScroll = 0;
              let restoreScrollAfterFocus = false;

              if (form && mainEl) {
                form.addEventListener(
                  'pointerdown',
                  (e) => {
                    const el = e.target;
                    if (!(el instanceof Element)) return;
                    if (!el.closest('.attendance-row')) return;
                    savedMainScroll = mainEl.scrollTop;
                    restoreScrollAfterFocus = true;
                  },
                  true,
                );
                form.addEventListener('focusin', (e) => {
                  const t = e.target;
                  if (!(t instanceof HTMLInputElement) || t.name !== 'user_ids' || !restoreScrollAfterFocus) return;
                  restoreScrollAfterFocus = false;
                  const y = savedMainScroll;
                  const restore = () => {
                    mainEl.scrollTop = y;
                  };
                  restore();
                  requestAnimationFrame(restore);
                  requestAnimationFrame(() => requestAnimationFrame(restore));
                });
              }

              const updateCount = () => {
                const checked = form?.querySelectorAll('input[name="user_ids"]:checked')?.length ?? 0;
                if (countEl) countEl.textContent = `${checked} seleccionado${checked !== 1 ? 's' : ''}`;
              };

              selectAll?.addEventListener('click', () => {
                checkboxes?.forEach((cb) => (cb.checked = true));
                updateCount();
              });
              deselectAll?.addEventListener('click', () => {
                checkboxes?.forEach((cb) => (cb.checked = false));
                updateCount();
              });

              rows?.forEach((row, idx) => {
                const cb = row.querySelector('input[name="user_ids"]');
                if (!cb) return;
                row.addEventListener('click', (e) => {
                  if (e.shiftKey) {
                    e.preventDefault();
                    restoreScrollAfterFocus = false;
                    if (lastClickedIndex === -1) {
                      (cb as HTMLInputElement).checked = true;
                      lastClickedIndex = idx;
                    } else {
                      const lo = Math.min(lastClickedIndex, idx);
                      const hi = Math.max(lastClickedIndex, idx);
                      checkboxes?.forEach((box, i) => {
                        if (i >= lo && i <= hi) (box as HTMLInputElement).checked = true;
                      });
                    }
                    updateCount();
                  } else {
                    lastClickedIndex = idx;
                  }
                });
                cb.addEventListener('change', updateCount);
              });

              updateCount();
            });
          </script>
        ) : (
          <p class="text-sm text-muted">No hay alumnos inscritos en este curso.</p>
        )}
      </div>
    ) : selectedCourseId ? (
      <div class="rounded-xl border border-dashed border-transparent bg-surface-2/60 p-6 text-sm text-muted">
        Elige una clase y haz clic en Cargar alumnos para ver la lista de estudiantes.
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-transparent bg-surface-2/60 p-6 text-sm text-muted">
        Elige un curso y haz clic en Cargar clases para ver la lista de clases.
      </div>
    )}

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const closeAllSelectPanels = () => {
          document.querySelectorAll('.custom-select-panel').forEach((p) => {
            p.classList.add('hidden');
            const el = p as HTMLElement;
            el.style.position = '';
            el.style.left = '';
            el.style.top = '';
            el.style.right = '';
            el.style.minWidth = '';
            el.style.width = '';
            el.style.maxHeight = '';
            el.style.overflowY = '';
            el.style.zIndex = '';
            el.style.display = '';
            el.style.visibility = '';
          });
        };
        closeAllSelectPanels();
        if (document.body.style.overflow === 'hidden') document.body.style.overflow = '';
        const form = document.getElementById('attendance-form');
        form?.addEventListener('submit', () => {
          closeAllSelectPanels();
        });
      });
    </script>
  </section>
</DashboardLayout>

