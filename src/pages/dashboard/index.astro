                            const lessonHref = `/courses/${lesson.courseSlug}/lessons/${lesson.id}`;
                            const isLatestRecording = monthIdx === 0 && idx === 0;
                            return (
                              <li
                                class={`rounded-xl bg-white px-3 py-2.5 shadow-sm ${isLatestRecording ? 'border-l-4 border-l-blue' : ''}`}
