---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { avatarImagePath } from '../../lib/avatars';
import BadgeIcon from '../../components/BadgeIcon.astro';
import BadgeOutline from '../../components/BadgeOutline.astro';
import { formatDayAndDate, formatTime, formatDateTime } from '../../lib/format-date';
import { isLessonCompleted } from '../../lib/lessons';
import { getPreviewContext, setPreviewCookie, clearPreviewCookie } from '../../lib/preview';
import { ON_DEMAND_BADGE_CONDITION_TYPES } from '../../lib/badges';
import { badgeDisplayDescription, badgeDisplayName } from '../../lib/badge-display';
import { getPointsBreakdownByCourse, type CoursePointsBreakdown } from '../../lib/points-breakdown';
import PointsBreakdownListItem from '../../components/PointsBreakdownListItem.astro';
import { getBadgeEarnGuideRows, type BadgeEarnRow } from '../../lib/badge-earn-guide';
import { APP_BIRTHDAY_TIMEZONE, daysUntilBirthdayAnniversary } from '../../lib/birthday';

const { isAuthenticated, userId, sessionClaims, redirectToSignIn } = Astro.locals.auth();

if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();

let { data: userRow } = await supabase
  .from('users')
  .select('id, email, display_name, avatar_id, points, role, timezone, birthday')
  .eq('id', userId)
  .maybeSingle();
if (!userRow) {
  await supabase.from('users').upsert({ id: userId }, { onConflict: 'id' });
  const refetch = await supabase
    .from('users')
    .select('id, email, display_name, avatar_id, points, role, timezone, birthday')
    .eq('id', userId)
    .maybeSingle();
  userRow = refetch.data ?? null;
}

if (userRow && (userRow.display_name == null || userRow.display_name === '')) {
  return Astro.redirect('/onboarding');
}

const role = (userRow?.role as 'admin' | 'student') ?? 'student';
let { preview, previewAs } = getPreviewContext(Astro);

// Salir de preview: limpiar cookie y redirigir
if (Astro.url.searchParams.get('exitPreview') === '1') {
  clearPreviewCookie(Astro);
  return Astro.redirect('/dashboard');
}

// Admin en preview: guardar cookie con el tipo elegido para persistir al navegar
if (role === 'admin' && preview) {
  setPreviewCookie(Astro, previewAs);
}

// ---------- Admin-only data (when role === 'admin' && !preview) ----------
type AdminCourseStats = { id: string; slug: string; title: string; studentsCount: number; totalLessons: number; avgPoints: number };
let totalStudents = 0;
let pendingSubmissionsCount = 0;
let cohortAvgPoints: number | null = null;
let activeChallengesCount = 0;
let cohortProgress: { id: string; name: string; avatarId: string | null; points: number }[] = [];
let recentSubmissions: { id: string; studentName: string; challengeTitle: string; submitted_at: string }[] = [];
let cohortMaxPoints = 1;
let adminCoursesWithStats: AdminCourseStats[] = [];
let adminBirthdaysToday: string[] = [];
let adminBirthdaysUpcoming: { name: string; daysUntil: number }[] = [];

if (role === 'admin' && !preview) {
  const [studentsCountRes, pendingCountRes, activeCountRes, cohortRowsRes, subRowsRes, pointsRowsRes, coursesRes, enrollmentsRes, lessonsCountRes, studentBirthdaysRes] = await Promise.all([
    supabase.from('users').select('*', { count: 'exact', head: true }).eq('role', 'student'),
    supabase.from('submissions').select('*', { count: 'exact', head: true }).eq('reviewed', false),
    supabase.from('challenges').select('*', { count: 'exact', head: true }).eq('is_active', true),
    supabase.from('users').select('id, display_name, avatar_id').eq('role', 'student'),
    supabase
      .from('submissions')
      .select('id, user_id, challenge_id, submitted_at, users(display_name), challenges(title)')
      .eq('reviewed', false)
      .order('submitted_at', { ascending: false })
      .limit(40),
    supabase.from('user_course_points').select('user_id, course_id, points'),
    supabase.from('courses').select('id, slug, title').order('title'),
    supabase.from('enrollments').select('course_id'),
    supabase.from('lessons').select('course_id'),
    supabase.from('users').select('display_name, birthday').eq('role', 'student').not('birthday', 'is', null),
  ]);
  totalStudents = studentsCountRes.count ?? 0;
  pendingSubmissionsCount = pendingCountRes.count ?? 0;
  activeChallengesCount = activeCountRes.count ?? 0;

  const pointsByUser = new Map<string, number>();
  const pointsByCourseUser = new Map<string, Map<string, number>>(); // courseId -> (userId -> points)
  for (const row of pointsRowsRes.data ?? []) {
    const uid = row.user_id as string;
    const cid = row.course_id as string;
    pointsByUser.set(uid, (pointsByUser.get(uid) ?? 0) + (row.points ?? 0));
    if (!pointsByCourseUser.has(cid)) pointsByCourseUser.set(cid, new Map());
    pointsByCourseUser.get(cid)!.set(uid, (pointsByCourseUser.get(cid)!.get(uid) ?? 0) + (row.points ?? 0));
  }
  const studentIds = (cohortRowsRes.data ?? []).map((u) => u.id);
  if (studentIds.length > 0) {
    const sum = studentIds.reduce((a, id) => a + (pointsByUser.get(id) ?? 0), 0);
    cohortAvgPoints = Math.round((sum / studentIds.length) * 10) / 10;
  }

  const cohortRows = cohortRowsRes.data;
  cohortProgress = (cohortRows ?? []).map((u) => ({
    id: u.id,
    name: u.display_name ?? 'Estudiante',
    avatarId: u.avatar_id ?? null,
    points: pointsByUser.get(u.id) ?? 0,
  })).sort((a, b) => b.points - a.points);
  cohortMaxPoints = Math.max(1, ...cohortProgress.map((u) => u.points));
  const subRows = subRowsRes.data ?? [];
  const seenPair = new Set<string>();
  recentSubmissions = [];
  for (const s of subRows) {
    const uid = s.user_id as string;
    const cid = s.challenge_id as string;
    const key = `${uid}:${cid}`;
    if (seenPair.has(key)) continue;
    seenPair.add(key);
    const u = s.users as { display_name: string | null } | null;
    const c = s.challenges as { title: string | null } | null;
    recentSubmissions.push({
      id: s.id,
      studentName: u?.display_name ?? 'Estudiante',
      challengeTitle: c?.title ?? 'Desafío',
      submitted_at: s.submitted_at as string,
    });
    if (recentSubmissions.length >= 5) break;
  }

  const courses = (coursesRes.data ?? []) as { id: string; slug: string | null; title: string | null }[];
  const enrollments = (enrollmentsRes.data ?? []) as { course_id: string }[];
  const lessonsByCourse = (lessonsCountRes.data ?? []).reduce((acc: Record<string, number>, r: { course_id: string }) => {
    const cid = r.course_id as string;
    acc[cid] = (acc[cid] ?? 0) + 1;
    return acc;
  }, {});
  const enrollmentsByCourse = enrollments.reduce((acc: Record<string, number>, r) => {
    acc[r.course_id] = (acc[r.course_id] ?? 0) + 1;
    return acc;
  }, {});

  adminCoursesWithStats = courses.map((course) => {
    const studentsCount = enrollmentsByCourse[course.id] ?? 0;
    const totalLessons = lessonsByCourse[course.id] ?? 0;
    const coursePoints = pointsByCourseUser.get(course.id);
    let avgPoints = 0;
    if (coursePoints && studentsCount > 0) {
      const sum = [...coursePoints.values()].reduce((a, p) => a + p, 0);
      avgPoints = Math.round((sum / studentsCount) * 10) / 10;
    }
    return {
      id: course.id,
      slug: typeof course.slug === 'string' && course.slug.trim() ? course.slug.trim() : course.id,
      title: course.title ?? 'Sin título',
      studentsCount,
      totalLessons,
      avgPoints,
    };
  });

  const tz = APP_BIRTHDAY_TIMEZONE;
  const todayNames: string[] = [];
  const upcoming: { name: string; daysUntil: number }[] = [];
  for (const row of studentBirthdaysRes.data ?? []) {
    const name = String((row as { display_name?: string | null }).display_name ?? '').trim() || 'Estudiante';
    const bd = (row as { birthday?: string | null }).birthday;
    const d = daysUntilBirthdayAnniversary(bd ?? null, tz);
    if (d === null) continue;
    if (d === 0) todayNames.push(name);
    else if (d >= 1 && d <= 3) upcoming.push({ name, daysUntil: d });
  }
  adminBirthdaysToday = todayNames.sort((a, b) => a.localeCompare(b));
  adminBirthdaysUpcoming = upcoming.sort((a, b) => a.daysUntil - b.daysUntil || a.name.localeCompare(b.name));
}

// ---------- Student view data (when student OR admin in preview) ----------
const iconMap: Record<string, string> = {
  first_submission: 'first_submission',
  on_time: 'on_time',
  early_bird: 'early_bird',
  streak_3: 'streak_3',
  attendance_streak_3: 'attendance_streak_3',
  first_attendance: 'first_attendance',
  module_complete: 'module_complete',
  night_owl: 'night_owl',
  course_complete: 'course_complete',
  manual: 'manual',
};

let points = 0;
let hasLiveEnrollment = false;
type DashboardBadge = { id: string; name: string; description: string | null; condition_type: string | null; earned: boolean; earned_at: string | null; earnedCount: number };
let dashboardBadges: DashboardBadge[] = [];
let studentTotalExpectedChallenges = 0;
let studentChallengesCompleted = 0;
let enrolledIds: string[] = [];
let enrolledCourses: { id: string; slug: string; title: string; cover_image: string | null; description: string | null; totalLessons: number; completedLessons: number }[] = [];
let leaderboard: { id: string; name: string; avatarId: string | null; points: number }[] = [];
let pointsBreakdownByCourse: CoursePointsBreakdown[] = [];
let badgeEarnGuideRows: BadgeEarnRow[] = [];
type UpcomingLesson = {
  id: string;
  title: string;
  scheduled_at: string;
  zoom_link: string | null;
  recording_url: string | null;
  recording_passcode: string | null;
  courseTitle: string;
  courseSlug: string;
};
let upcomingLessons: UpcomingLesson[] = [];
let upcomingByMonth: { monthLabel: string; lessons: UpcomingLesson[] }[] = [];
/** Solo cohort en vivo: lecciones pasadas con grabación (acceso rápido al lado del horario). */
let recordingByMonth: { monthLabel: string; lessons: UpcomingLesson[] }[] = [];

if (role !== 'admin' || preview) {
  try {
    const [badgeRowsRes, earnedRowsRes, enrollmentRowsRes] = await Promise.all([
      supabase.from('badges').select('id, name, description, condition_type').order('name'),
      supabase.from('user_badges').select('badge_id, earned_at').eq('user_id', userId),
      supabase
        .from('enrollments')
        .select('course_id, access_type, courses(id, slug, title, cover_image, description, expected_challenges_count)')
        .eq('user_id', userId),
    ]);
    const badgeRows = badgeRowsRes.data ?? null;
    const earnedRows = earnedRowsRes.data ?? null;
    const earnedSet = new Set((earnedRows ?? []).map((e) => e.badge_id));
    const earnedAtMap = new Map((earnedRows ?? []).map((e) => [e.badge_id, e.earned_at as string]));
    const earnedCountMap = new Map<string, number>();
    for (const row of earnedRows ?? []) {
      const id = row.badge_id as string;
      earnedCountMap.set(id, (earnedCountMap.get(id) ?? 0) + 1);
    }
    const allDashboardBadges = (badgeRows ?? []).map((b) => {
      const ct = (b.condition_type as string) ?? null;
      const rawName = (b.name as string) ?? null;
      const rawDesc = (b.description as string) ?? null;
      return {
      id: b.id,
      name: badgeDisplayName(ct, rawName),
      description: badgeDisplayDescription(ct, rawDesc, rawName),
      condition_type: ct,
      earned: earnedSet.has(b.id),
      earned_at: earnedAtMap.get(b.id) ?? null,
      earnedCount: earnedCountMap.get(b.id) ?? 0,
    };
    });
    const enrollmentRows = enrollmentRowsRes.data ?? null;
    const fromEnrollments = (enrollmentRows ?? []).some((r) => (r.access_type as string) !== 'on_demand');
    hasLiveEnrollment = role === 'admin' && preview ? previewAs === 'live' : fromEnrollments;
    dashboardBadges = hasLiveEnrollment
      ? allDashboardBadges
      : allDashboardBadges.filter((b) => b.condition_type && ON_DEMAND_BADGE_CONDITION_TYPES.includes(b.condition_type as 'first_submission' | 'early_bird' | 'module_complete' | 'course_complete'));

    const enrolledCourseIdsForPoints = [...new Set((enrollmentRows ?? []).map((r) => r.course_id as string).filter(Boolean))];
    if (enrolledCourseIdsForPoints.length > 0) {
      const { data: myPointsRows } = await supabase
        .from('user_course_points')
        .select('points')
        .eq('user_id', userId)
        .in('course_id', enrolledCourseIdsForPoints);
      points = (myPointsRows ?? []).reduce((a, r) => a + (r.points ?? 0), 0);
    }
    type EnrolledCourseRow = { id: string; slug: string | null; title: string; cover_image: string | null; description: string | null; expected_challenges_count?: number | null };
    let enrolledCourseRows = (enrollmentRows ?? [])
      .map((row) => (row as { courses: EnrolledCourseRow | null }).courses)
      .filter((course): course is EnrolledCourseRow => Boolean(course?.id));

    if (role === 'admin' && preview) {
      const { data: allCourses } = await supabase
        .from('courses')
        .select('id, slug, title, cover_image, description, expected_challenges_count')
        .order('title');
      enrolledCourseRows = (allCourses ?? []).filter(
        (c): c is EnrolledCourseRow => Boolean(c?.id),
      );
    }

    enrolledIds = enrolledCourseRows.map((course) => course.id);

    // Total retos previstos por curso inscrito (o todos en vista previa admin). null/omitido cuenta como 1 (Number(null) sería 0 y rompía el total).
    const uniqueCourseIds = [...new Set(enrolledIds.filter(Boolean))];
    if (uniqueCourseIds.length > 0) {
      const { data: courseTotals } = await supabase.from('courses').select('id, expected_challenges_count').in('id', uniqueCourseIds);
      const byId = new Map((courseTotals ?? []).map((r) => [r.id as string, (r as { expected_challenges_count?: unknown }).expected_challenges_count]));
      studentTotalExpectedChallenges = uniqueCourseIds.reduce((sum, cid) => {
        const raw = byId.get(cid);
        if (raw === null || raw === undefined || raw === '') return sum + 1;
        const n = Number(raw);
        return sum + (Number.isFinite(n) && n >= 0 ? n : 1);
      }, 0);
    } else {
      studentTotalExpectedChallenges = 0;
    }

    // Retos con al menos una entrega: del curso inscrito O retos globales (sin curso), como en /challenges
    if (enrolledIds.length > 0) {
      const [{ data: chByCourse }, { data: chGlobal }] = await Promise.all([
        supabase.from('challenges').select('id').in('course_id', enrolledIds),
        supabase.from('challenges').select('id').is('course_id', null).eq('is_active', true),
      ]);
      const enrolledChallengeIds = [
        ...new Set(
          [...(chByCourse ?? []), ...(chGlobal ?? [])].map((c) => c.id as string).filter(Boolean),
        ),
      ];
      if (enrolledChallengeIds.length > 0) {
        const { data: subRows } = await supabase.from('submissions').select('challenge_id').eq('user_id', userId).in('challenge_id', enrolledChallengeIds);
        studentChallengesCompleted = new Set((subRows ?? []).map((s) => s.challenge_id)).size;
      }
    }

    let leaderboardRowsRes: { data: { id: string; display_name: string | null; avatar_id: string | null }[] | null } = { data: [] };
    const leaderboardPointsByUser = new Map<string, number>();
    {
      const [{ data: allCoursePoints }, { data: allStudents }] = await Promise.all([
        supabase.from('user_course_points').select('user_id, points'),
        supabase.from('users').select('id, display_name, avatar_id').eq('role', 'student'),
      ]);
      for (const row of allCoursePoints ?? []) {
        const uid = row.user_id as string;
        const pts = (row as { points: number | null }).points ?? 0;
        leaderboardPointsByUser.set(uid, (leaderboardPointsByUser.get(uid) ?? 0) + pts);
      }
      leaderboardRowsRes = { data: allStudents ?? [] };
    }

    let lessonsByCourse = new Map<string, { total: number; completed: number }>();
    if (enrolledIds.length > 0) {
      const { data: lessonRows } = await supabase
        .from('lessons')
        .select('course_id, scheduled_at')
        .in('course_id', enrolledIds);

      const nowMs = Date.now();
      for (const lesson of lessonRows ?? []) {
        const courseId = lesson.course_id as string;
        const current = lessonsByCourse.get(courseId) ?? { total: 0, completed: 0 };
        current.total += 1;
        if (lesson.scheduled_at && isLessonCompleted(lesson.scheduled_at as string, nowMs)) {
          current.completed += 1;
        }
        lessonsByCourse.set(courseId, current);
      }
    }

    for (const course of enrolledCourseRows) {
      const stats = lessonsByCourse.get(course.id) ?? { total: 0, completed: 0 };
      enrolledCourses.push({
        id: course.id,
        slug: typeof course.slug === 'string' && course.slug.trim() ? course.slug.trim() : course.id,
        title: course.title ?? 'Curso',
        cover_image: course.cover_image ?? null,
        description: course.description ?? null,
        totalLessons: stats.total,
        completedLessons: stats.completed,
      });
    }

    if (enrolledIds.length > 0) {
      const now = new Date().toISOString();
      if (hasLiveEnrollment) {
        const { data: lessonRows } = await supabase
          .from('lessons')
          .select('id, title, scheduled_at, zoom_link, course_id, courses(title, slug, zoom_link)')
          .in('course_id', enrolledIds)
          .not('scheduled_at', 'is', null)
          .gt('scheduled_at', now)
          .order('scheduled_at', { ascending: true })
          .limit(6);
        upcomingLessons = (lessonRows ?? []).map((l) => {
          const course = l.courses as { title: string | null; slug: string | null; zoom_link?: string | null } | null;
          const zoomUrl = (l.zoom_link?.trim() || course?.zoom_link?.trim() || null) ?? null;
          return {
            id: l.id,
            title: l.title ?? 'Clase',
            scheduled_at: l.scheduled_at as string,
            zoom_link: zoomUrl,
            recording_url: null,
            recording_passcode: null,
            courseTitle: course?.title ?? 'Curso',
            courseSlug: (course?.slug ?? l.course_id) as string,
          };
        });
        const monthMapLive = new Map<string, UpcomingLesson[]>();
        for (const lesson of upcomingLessons) {
          const d = new Date(lesson.scheduled_at);
          const key = d.toLocaleDateString('es', { month: 'long', year: 'numeric' });
          const label = key.charAt(0).toUpperCase() + key.slice(1);
          if (!monthMapLive.has(label)) monthMapLive.set(label, []);
          monthMapLive.get(label)!.push(lesson);
        }
        upcomingByMonth = Array.from(monthMapLive.entries()).map(([monthLabel, lessons]) => ({ monthLabel, lessons }));

        const { data: recLessonRows } = await supabase
          .from('lessons')
          .select('id, title, scheduled_at, recording_url, recording_passcode, course_id, courses(title, slug)')
          .in('course_id', enrolledIds)
          .not('scheduled_at', 'is', null)
          .not('recording_url', 'is', null)
          .lt('scheduled_at', now)
          .order('scheduled_at', { ascending: false })
          .limit(24);
        const recordingLessons: UpcomingLesson[] = (recLessonRows ?? [])
          .map((l) => {
            const course = l.courses as { title: string | null; slug: string | null } | null;
            const recUrl = (l.recording_url && String(l.recording_url).trim()) || null;
            const recPass =
              l.recording_passcode && String(l.recording_passcode).trim()
                ? String(l.recording_passcode).trim()
                : null;
            return {
              id: l.id,
              title: l.title ?? 'Clase',
              scheduled_at: l.scheduled_at as string,
              zoom_link: null,
              recording_url: recUrl,
              recording_passcode: recPass,
              courseTitle: course?.title ?? 'Curso',
              courseSlug: (course?.slug ?? l.course_id) as string,
            };
          })
          .filter((l) => Boolean(l.recording_url));
        const recMonthMap = new Map<string, UpcomingLesson[]>();
        for (const lesson of recordingLessons) {
          const d = new Date(lesson.scheduled_at);
          const key = d.toLocaleDateString('es', { month: 'long', year: 'numeric' });
          const label = key.charAt(0).toUpperCase() + key.slice(1);
          if (!recMonthMap.has(label)) recMonthMap.set(label, []);
          recMonthMap.get(label)!.push(lesson);
        }
        recordingByMonth = Array.from(recMonthMap.entries()).map(([monthLabel, lessons]) => ({ monthLabel, lessons }));
      } else {
        const { data: lessonRows } = await supabase
          .from('lessons')
          .select('id, title, scheduled_at, recording_url, recording_passcode, course_id, courses(title, slug)')
          .in('course_id', enrolledIds)
          .not('scheduled_at', 'is', null)
          .not('recording_url', 'is', null)
          .lt('scheduled_at', now)
          .order('scheduled_at', { ascending: false })
          .limit(24);
        upcomingLessons = (lessonRows ?? [])
          .map((l) => {
            const course = l.courses as { title: string | null; slug: string | null } | null;
            const recUrl = (l.recording_url && String(l.recording_url).trim()) || null;
            const recPass =
              l.recording_passcode && String(l.recording_passcode).trim()
                ? String(l.recording_passcode).trim()
                : null;
            return {
              id: l.id,
              title: l.title ?? 'Clase',
              scheduled_at: l.scheduled_at as string,
              zoom_link: null,
              recording_url: recUrl,
              recording_passcode: recPass,
              courseTitle: course?.title ?? 'Curso',
              courseSlug: (course?.slug ?? l.course_id) as string,
            };
          })
          .filter((l) => Boolean(l.recording_url));
        const monthMapOd = new Map<string, UpcomingLesson[]>();
        for (const lesson of upcomingLessons) {
          const d = new Date(lesson.scheduled_at);
          const key = d.toLocaleDateString('es', { month: 'long', year: 'numeric' });
          const label = key.charAt(0).toUpperCase() + key.slice(1);
          if (!monthMapOd.has(label)) monthMapOd.set(label, []);
          monthMapOd.get(label)!.push(lesson);
        }
        upcomingByMonth = Array.from(monthMapOd.entries()).map(([monthLabel, lessons]) => ({ monthLabel, lessons }));
      }
    }

    const leaderboardRows = leaderboardRowsRes.data;
    const leaderboardSorted = (leaderboardRows ?? [])
      .map((u) => ({
        id: u.id,
        name: u.display_name ?? 'Estudiante',
        avatarId: u.avatar_id ?? null,
        points: leaderboardPointsByUser.get(u.id) ?? 0,
      }))
      .sort((a, b) => b.points - a.points);
    // Ranking general: suma de puntos en todos los cursos (plataforma); solo top 5 en UI.
    leaderboard = leaderboardSorted.filter((u) => u.points > 0).slice(0, 5);

    const { data: myPointsByCourseRows } = await supabase
      .from('user_course_points')
      .select('course_id, points')
      .eq('user_id', userId);
    const courseIdsWithPts = new Set((myPointsByCourseRows ?? []).map((r) => r.course_id as string));
    const breakdownCourseIds = [...new Set([...courseIdsWithPts, ...enrolledIds])];
    if (breakdownCourseIds.length > 0) {
      pointsBreakdownByCourse = await getPointsBreakdownByCourse(supabase, userId, breakdownCourseIds);
    }
    badgeEarnGuideRows = getBadgeEarnGuideRows(hasLiveEnrollment);
  } catch (err) {
    console.error('[dashboard] student data error', err);
    // Mantener valores por defecto (vacíos) para que la página cargue
  }
}

const displayName =
  userRow?.display_name ??
  (sessionClaims as any)?.first_name ??
  (sessionClaims as any)?.name ??
  (role === 'admin' ? 'Admin' : 'Estudiante');

const userTimezone = (userRow as { timezone?: string | null } | null)?.timezone ?? null;
const myBirthdayRaw = (userRow as { birthday?: string | null })?.birthday ?? null;
const daysUntilMyBirthday = daysUntilBirthdayAnniversary(myBirthdayRaw, APP_BIRTHDAY_TIMEZONE);
const showStudentBirthdayBanner = (role !== 'admin' || preview) && daysUntilMyBirthday === 0;
const recordingHasAny = recordingByMonth.some(({ lessons }) => lessons.length > 0);
const firstCourseHref = enrolledCourses[0] ? `/courses/${enrolledCourses[0].slug}` : '/courses';
---

{role === 'admin' && !preview ? (
  <DashboardLayout>
    <section class="max-w-5xl space-y-6 lg:space-y-8 xl:max-w-6xl">
      <header class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="font-manrope text-2xl font-semibold tracking-tight text-white">Dashboard de administración</h1>
          <p class="mt-1 text-sm text-muted">Resumen general del cohort, entregas y avance por curso.</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm text-muted">Ver como estudiante:</span>
          <a href="/dashboard?preview=true&as=live" class="btn btn-primary">
            En vivo
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a href="/dashboard?preview=true&as=on_demand" class="btn btn-secondary">
            On-demand
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </header>

      {(adminBirthdaysToday.length > 0 || adminBirthdaysUpcoming.length > 0) && (
        <div
          class="relative flex flex-wrap items-start gap-3 rounded-xl border border-lime/35 bg-lime/[0.08] px-4 py-3 md:items-center"
          role="status"
        >
          <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-lime/20 text-lg text-lime" aria-hidden="true">
            🎂
          </span>
          <div class="min-w-0 flex-1 space-y-1.5 text-sm">
            <p class="font-medium text-white">Cumpleaños del cohort</p>
            {adminBirthdaysToday.length > 0 && (
              <p class="text-muted">
                <span class="font-medium text-lime">Hoy:</span>{' '}
                {adminBirthdaysToday.join(', ')}
              </p>
            )}
            {adminBirthdaysUpcoming.length > 0 && (
              <p class="text-muted">
                <span class="font-medium text-white/90">Próximos (3 días):</span>{' '}
                {adminBirthdaysUpcoming
                  .map((u) => `${u.name} (${u.daysUntil === 1 ? 'mañana' : `en ${u.daysUntil} días`})`)
                  .join(' · ')}
              </p>
            )}
          </div>
          <button
            type="button"
            class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-muted transition hover:bg-white/10 hover:text-lime"
            title={`Fechas según cumpleaños en perfil. Aviso hasta 3 días antes de cada día (zona ${APP_BIRTHDAY_TIMEZONE.replace('_', ' ')}).`}
            aria-label="Información sobre avisos de cumpleaños"
          >
            <i class="bi bi-info-circle text-lg leading-none" aria-hidden="true"></i>
          </button>
        </div>
      )}

      <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
        <div class="min-w-0 space-y-6">
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-xl bg-[#012EDC] p-5">
              <p class="font-manrope text-2xl font-semibold text-white/90">Estudiantes totales</p>
              <p class="mt-8 font-manrope text-2xl font-semibold text-white sm:text-4xl">{totalStudents}</p>
            </div>
            <div class="rounded-xl bg-[#012EDC] p-5">
              <p class="font-manrope text-2xl font-semibold text-white/90">Entregas pendientes</p>
              <p class="mt-8 font-manrope text-2xl font-semibold text-white sm:text-4xl">{pendingSubmissionsCount}</p>
            </div>
            <div class="rounded-xl bg-[#FFBE00] p-5">
              <p class="font-manrope text-2xl font-semibold text-background/80">Promedio total (pts)</p>
              <p class="mt-8 font-manrope text-2xl font-semibold text-background sm:text-4xl">{cohortAvgPoints ?? 0}</p>
            </div>
            <div class="rounded-xl bg-[#FFBE00] p-5">
              <p class="font-manrope text-2xl font-semibold text-background/80">Desafíos activos</p>
              <p class="mt-8 font-manrope text-2xl font-semibold text-background sm:text-4xl">{activeChallengesCount}</p>
            </div>
          </div>

          <div class="rounded-xl bg-surface p-6">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div>
                <h2 class="font-manrope text-2xl font-semibold !text-white">Entregas recientes</h2>
                <p class="mt-1 text-sm text-muted">Pendientes de revisión (todas los cursos).</p>
              </div>
              <a href="/admin/submissions" class="btn btn-primary">
                Ver todas
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
            {recentSubmissions.length > 0 ? (
              <div class="-mx-2 mt-5 overflow-x-auto px-2 sm:mx-0 sm:px-0">
                <table class="w-full min-w-[400px] text-left text-sm">
                  <thead>
                    <tr class="border-b border-white/10 text-muted">
                      <th class="pb-3 pr-4 font-semibold">Estudiante</th>
                      <th class="pb-3 pr-4 font-semibold">Desafío</th>
                      <th class="pb-3 pr-4 font-semibold">Fecha</th>
                      <th class="pb-3 font-semibold text-right">Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    {recentSubmissions.map((sub) => (
                      <tr class="border-b border-white/5 last:border-0">
                        <td class="py-3 pr-4 font-medium text-white">{sub.studentName}</td>
                        <td class="py-3 pr-4 text-white">{sub.challengeTitle}</td>
                        <td class="py-3 pr-4 text-muted">{formatDateTime(sub.submitted_at, 'America/Lima')}</td>
                        <td class="py-3 text-right">
                          <a href={`/admin/submissions/${sub.id}?from=dashboard`} class="btn btn-primary text-sm">
                            Revisar
                            <i class="bi bi-eye h-4 w-4" aria-hidden="true"></i>
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="mt-5 text-sm text-muted">No hay entregas pendientes.</p>
            )}
          </div>

          <div class="rounded-xl p-6" style="background-color: #D6D6D6;">
            <h2 class="font-manrope text-2xl font-semibold text-[#1A1A1A]">Avance por curso</h2>
            <p class="mt-1 text-sm text-[#404040]">Estudiantes y promedio de puntos por curso.</p>
            {adminCoursesWithStats.length > 0 ? (
              <ul class="mt-5 space-y-4">
                {adminCoursesWithStats.map((course) => (
                  <li class="flex flex-col gap-2 rounded-lg bg-[#fff] p-4 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
                    <div class="min-w-0">
                      <h3 class="font-manrope text-lg font-semibold text-[#1A1A1A]">{course.title}</h3>
                      <p class="mt-0.5 text-sm text-[#404040]">
                        {course.studentsCount}{' '}{course.studentsCount === 1 ? 'estudiante' : 'estudiantes'} · {course.totalLessons} clases · Promedio {course.avgPoints} pts
                      </p>
                    </div>
                    <div class="flex shrink-0 gap-2">
                      <a href={`/admin/courses/${course.id}/edit`} class="btn btn-icon inline-flex items-center justify-center rounded-lg border border-transparent bg-transparent text-[#1A1A1A] transition hover:border-black/20 hover:bg-black/10 hover:!text-[#1A1A1A]" title="Editar curso" aria-label="Editar curso">
                        <i class="bi bi-pencil" aria-hidden="true"></i>
                      </a>
                      <a href={`/courses/${course.slug}`} class="btn text-sm border-2 border-[#1A1A1A] bg-transparent text-[#1A1A1A] hover:bg-[#1A1A1A] hover:text-white">
                        Ver curso
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    </div>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-5 text-sm text-[#404040]">Aún no hay cursos. Crea uno desde Cursos.</p>
            )}
          </div>
        </div>

        <aside class="lg:sticky lg:top-24 lg:self-start">
          <div class="rounded-xl bg-surface p-5">
            <h2 class="font-manrope text-2xl font-semibold text-white">Progreso general</h2>
            <p class="mt-0.5 text-[10px] text-muted">Puntos acumulados de todos los cursos.</p>
            {cohortProgress.length > 0 ? (
              <ul class="mt-3 max-h-[420px] space-y-1.5 overflow-y-auto pr-1">
                {cohortProgress.map((s, i) => (
                  <li class="flex items-center gap-2 rounded-lg bg-background px-2 py-1.5">
                    <span class={`w-5 shrink-0 text-[10px] font-semibold ${i < 5 ? 'text-lime' : 'text-muted'}`}>{i + 1}º</span>
                    <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full bg-surface-2">
                      <img src={avatarImagePath(s.avatarId) ?? '/avatars/avatar-01.png'} alt="" class="h-full w-full object-cover" width="32" height="32" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-[11px] font-medium text-white" title={s.name}>{s.name}</p>
                      <p class="text-[10px] font-semibold text-lime">{s.points} pts</p>
                    </div>
                  </li>
                ))}
              </ul>
            ) : (
              <div class="mt-4 rounded-xl border border-dashed border-transparent bg-background p-6 text-center">
                <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-full bg-surface-2 text-muted" aria-hidden="true">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
                  </svg>
                </div>
                <p class="mt-2 text-[11px] text-muted">Aún no hay estudiantes en el cohort.</p>
              </div>
            )}
          </div>
        </aside>
      </div>
    </section>
  </DashboardLayout>
) : (
  <DashboardLayout role={preview ? 'student' : role}>
    {role === 'admin' && preview && (
      <div class="-mx-4 -mt-6 mb-6 flex flex-wrap items-center justify-between gap-2 bg-background/95 px-4 py-3 md:-mx-6 md:mb-8 md:gap-4 md:px-6">
        <span class="flex items-center gap-2 text-sm font-medium text-lime">
          <span aria-hidden="true">👁</span>
          Vista previa: Estudiante {previewAs === 'on_demand' ? 'on-demand' : 'en vivo'}
        </span>
        <div class="flex flex-wrap items-center gap-2">
          <a
            href={previewAs === 'live' ? '#' : `${Astro.url.pathname}?preview=true&as=live`}
            class={`inline-flex items-center gap-1.5 rounded-[40px] border px-3 py-1.5 text-sm font-medium transition ${previewAs === 'live' ? 'border-lime bg-lime/15 text-lime' : 'border-white bg-transparent text-white hover:bg-white/10'}`}
          >
            En vivo
          </a>
          <a
            href={previewAs === 'on_demand' ? '#' : `${Astro.url.pathname}?preview=true&as=on_demand`}
            class={`inline-flex items-center gap-1.5 rounded-[40px] border px-3 py-1.5 text-sm font-medium transition ${previewAs === 'on_demand' ? 'border-lime bg-lime/15 text-lime' : 'border-white bg-transparent text-white hover:bg-white/10'}`}
          >
            On-demand
          </a>
          <a href="/dashboard?exitPreview=1" class="inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al dashboard de admin
          </a>
        </div>
      </div>
    )}
    {showStudentBirthdayBanner && (
      <div
        class="group relative mb-6 flex flex-wrap items-center gap-3 rounded-xl border border-lime/40 bg-gradient-to-r from-lime/15 via-lime/5 to-transparent px-4 py-3 md:mb-8"
        role="status"
        title="Te lo mostramos en tu cumple según la fecha de tu perfil (zona horaria Lima)."
      >
        <span class="text-2xl" aria-hidden="true">🎉</span>
        <div class="min-w-0 flex-1">
          <p class="text-base font-semibold text-white">¡Feliz cumpleaños, superHuman!</p>
          <p class="mt-0.5 text-sm text-muted">Que tengas un gran día.</p>
        </div>
        <span
          class="inline-flex h-8 w-8 shrink-0 cursor-help items-center justify-center rounded-full text-muted"
          aria-hidden="true"
        >
          <i class="bi bi-info-circle text-lg leading-none" aria-hidden="true"></i>
        </span>
      </div>
    )}
    <section class="max-w-5xl space-y-8 xl:max-w-6xl">
      <header class="space-y-2">
        <h1 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          {enrolledIds.length > 0 ? 'Tu viaje a ser un superhuman empieza aquí.' : 'Gracias por confiar en Superhuman'}
        </h1>
        <p class="text-sm text-muted">
          {enrolledIds.length > 0
            ? (hasLiveEnrollment
              ? 'Completa desafíos, asiste a sesiones en vivo y colecciona insignias mientras subes de nivel.'
              : 'Completa desafíos y avanza en las lecciones a tu ritmo.')
            : 'En breve serás asignado a un curso. Cuando esté listo, verás tus contenidos aquí.'}
        </p>
      </header>

      {enrolledIds.length === 0 ? (
        <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-white/20 bg-surface-2/40 px-8 py-16 text-center">
          <div class="flex h-20 w-20 items-center justify-center rounded-full bg-lime/20 text-lime" aria-hidden="true">
            <i class="bi bi-hourglass-split text-4xl" aria-hidden="true"></i>
          </div>
          <p class="mt-4 text-lg font-medium text-white">Estamos preparando todo para ti</p>
          <p class="mt-2 max-w-md text-sm text-muted">
            Gracias por unirte. En breve serás asignado a un curso. Cuando esté listo, verás tus contenidos aquí.
          </p>
          <button
            type="button"
            class="open-points-breakdown-trigger mt-6 inline-flex items-center gap-2 rounded-lg border border-transparent px-4 py-2 text-sm font-medium text-lime transition hover:bg-lime/10"
            aria-label="Ver cómo se suman los puntos"
          >
            <i class="bi bi-eye text-base" aria-hidden="true"></i>
            Cómo se suman los puntos
          </button>
        </div>
      ) : (
      <div class="flex flex-col gap-6 lg:flex-row">
        <section class="min-w-0 flex-1 space-y-4">
          {enrolledCourses.length > 0 && (
            <div class="space-y-3">
              <h2 class="text-sm font-semibold text-white">Mis cursos</h2>
              <ul class="grid gap-4 sm:grid-cols-2">
                {enrolledCourses.map((course) => (
                  <li>
                    <a
                      href={`/courses/${course.slug}`}
                      class="group block overflow-hidden rounded-xl bg-background transition-shadow hover:shadow-lg"
                    >
                      <div class="relative h-36 overflow-hidden bg-surface-2">
{course.cover_image ? (
                        <img
                          src={course.cover_image.startsWith('http') ? course.cover_image : `/courses/${course.cover_image}`}
                            alt=""
                            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                            width="400"
                            height="144"
                          />
                        ) : (
                          <div class="flex h-full w-full items-center justify-center text-muted">
                            <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                          </div>
                        )}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent" aria-hidden="true" />
                        <p class="absolute bottom-2 left-2 right-2 line-clamp-2 font-manrope text-base font-semibold leading-tight text-white drop-shadow sm:text-[20px]">
                          {course.title}
                        </p>
                      </div>
                      <div class="p-3">
                        <p class="text-xs text-muted">
                          {course.completedLessons} de {course.totalLessons} clases completadas
                        </p>
                        <div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-surface-2">
                          <div
                            class="h-full rounded-full bg-lime transition-all duration-300"
                            style={`width: ${course.totalLessons ? (course.completedLessons / course.totalLessons) * 100 : 0}%`}
                          />
                        </div>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="rounded-2xl bg-background p-5">
            <h2 class="text-sm font-semibold text-white">Progreso general</h2>
            <p class="mt-1 text-xs text-muted">
              Sigue tus puntos y cómo creces cada semana.
            </p>

            <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
              <div class="flex min-w-0 flex-col rounded-xl bg-[#012EDC] p-3 sm:p-5">
                <span class="font-manrope text-2xl font-semibold text-white">Desafíos</span>
                <div class="mt-8 flex items-baseline gap-0.5">
                  <span class="font-manrope text-2xl font-semibold leading-none text-white sm:text-[48px]">{studentChallengesCompleted}</span>
                  <span class="font-manrope text-2xl font-semibold leading-none text-[#436AFE] sm:text-[48px]">/{studentTotalExpectedChallenges > 0 ? studentTotalExpectedChallenges : 1}</span>
                </div>
              </div>
              <div class="flex min-w-0 flex-col rounded-xl bg-[#F5B800] p-3 sm:p-5">
                <div class="flex items-start justify-between gap-2">
                  <span class="font-manrope text-2xl font-semibold text-[#1A1A1A]">Puntos</span>
                  <button
                    type="button"
                    id="open-points-breakdown-modal"
                    class="open-points-breakdown-trigger -mr-1 -mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-[#1A1A1A]/55 transition hover:bg-black/10 hover:text-[#1A1A1A]"
                    aria-label="Ver desglose de puntos"
                    title="Ver desglose de puntos"
                    aria-haspopup="dialog"
                    aria-controls="points-breakdown-modal"
                  >
                    <i class="bi bi-eye text-[1.125rem] leading-none" aria-hidden="true"></i>
                  </button>
                </div>
                <div class="mt-8 font-manrope text-2xl font-semibold leading-none text-[#1A1A1A] sm:text-[48px]">{points}</div>
              </div>
            </div>
          </div>

          {hasLiveEnrollment ? (
            <div class="grid gap-4 lg:grid-cols-2 lg:items-start">
              <div class="rounded-2xl bg-background p-5">
                <h2 class="font-manrope text-2xl font-semibold text-white">Mi horario</h2>
                <p class="mt-0.5 text-xs text-muted">Próximas clases de tus cursos.</p>
                {upcomingLessons.length > 0 ? (
                  <div class="mt-3 max-h-[320px] overflow-y-auto space-y-4">
                    {upcomingByMonth.map(({ monthLabel, lessons }, monthIdx) => (
                      <div>
                        <p class="mb-2 text-[10px] font-semibold uppercase tracking-wider text-muted">{monthLabel}</p>
                        <ul class="space-y-2">
                          {lessons.map((lesson, idx) => {
                            const isNext =
                              monthIdx === 0 && idx === 0 && upcomingByMonth[0]?.lessons[0]?.id === lesson.id;
                            const joinUrl = lesson.zoom_link?.trim() || null;
                            return (
                              <li
                                class={`rounded-lg px-3 py-2.5 ${
                                  isNext ? 'border-l-4 border-l-lime bg-lime/10' : 'bg-background'
                                }`}
                              >
                                <div class="flex items-start justify-between gap-2">
                                  <div class="min-w-0 flex-1">
                                    <p class="text-[10px] text-muted">
                                      {formatDayAndDate(lesson.scheduled_at, userTimezone)} · {formatTime(lesson.scheduled_at, userTimezone)}
                                    </p>
                                    <p class="mt-0.5 font-work-sans text-[14px] font-medium leading-snug text-white">
                                      {lesson.title}
                                    </p>
                                    <p class="mt-0.5 text-[10px] text-muted">{lesson.courseTitle}</p>
                                  </div>
                                  {isNext && joinUrl && (
                                    <a
                                      href={joinUrl}
                                      target="_blank"
                                      rel="noopener noreferrer"
                                      class="shrink-0 rounded border border-lime bg-lime/15 px-2 py-1 text-[10px] font-medium text-lime transition hover:bg-lime/25"
                                    >
                                      Ver clase
                                    </a>
                                  )}
                                </div>
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="mt-3 rounded-xl border border-dashed border-transparent bg-background p-6 text-center">
                    <p class="text-sm text-muted">No hay clases programadas aún.</p>
                  </div>
                )}
              </div>

              <div class="rounded-2xl bg-[#D6D6D6] p-5">
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <h2 class="font-manrope text-2xl font-semibold text-[#1A1A1A]">Grabaciones</h2>
                    <p class="mt-0.5 text-xs text-[#404040]">Acceso rápido a clases pasadas.</p>
                  </div>
                  <a
