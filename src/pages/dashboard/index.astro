---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { avatarImagePath } from '../../lib/avatars';

const { isAuthenticated, userId, sessionClaims, redirectToSignIn } = Astro.locals.auth();

if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();

await supabase.from('users').upsert({ id: userId }, { onConflict: 'id' });

const { data: userRow } = await supabase
  .from('users')
  .select('id, email, display_name, avatar_id, points, role')
  .eq('id', userId)
  .maybeSingle();

if (userRow && (userRow.display_name == null || userRow.display_name === '')) {
  return Astro.redirect('/onboarding');
}

const role = (userRow?.role as 'admin' | 'student') ?? 'student';
const preview = Astro.url.searchParams.get('preview') === 'true';

// ---------- Admin-only data (when role === 'admin' && !preview) ----------
let totalStudents = 0;
let pendingSubmissionsCount = 0;
let cohortAvgPoints: number | null = null;
let activeChallengesCount = 0;
let cohortProgress: { id: string; name: string; avatarId: string | null; points: number }[] = [];
let recentSubmissions: { id: string; studentName: string; challengeTitle: string; submitted_at: string }[] = [];

if (role === 'admin' && !preview) {
  const { count: studentsCount } = await supabase
    .from('users')
    .select('*', { count: 'exact', head: true })
    .eq('role', 'student');
  totalStudents = studentsCount ?? 0;

  const { count: pendingCount } = await supabase
    .from('submissions')
    .select('*', { count: 'exact', head: true })
    .eq('reviewed', false);
  pendingSubmissionsCount = pendingCount ?? 0;

  const { data: studentPoints } = await supabase
    .from('users')
    .select('points')
    .eq('role', 'student');
  if (studentPoints?.length) {
    const sum = (studentPoints as { points: number | null }[]).reduce((a, r) => a + (r.points ?? 0), 0);
    cohortAvgPoints = Math.round((sum / studentPoints.length) * 10) / 10;
  }

  const { count: activeCount } = await supabase
    .from('challenges')
    .select('*', { count: 'exact', head: true })
    .eq('is_active', true);
  activeChallengesCount = activeCount ?? 0;

  const { data: cohortRows } = await supabase
    .from('users')
    .select('id, display_name, avatar_id, points')
    .eq('role', 'student')
    .order('points', { ascending: false });
  const maxPoints = Math.max(1, ...(cohortRows ?? []).map((r) => r.points ?? 0));
  cohortProgress = (cohortRows ?? []).map((u) => ({
    id: u.id,
    name: u.display_name ?? 'Estudiante',
    avatarId: u.avatar_id ?? null,
    points: u.points ?? 0,
  }));

  const { data: subRows } = await supabase
    .from('submissions')
    .select('id, submitted_at, users(display_name), challenges(title)')
    .eq('reviewed', false)
    .order('submitted_at', { ascending: false })
    .limit(5);
  recentSubmissions = (subRows ?? []).map((s) => {
    const u = s.users as { display_name: string | null } | null;
    const c = s.challenges as { title: string | null } | null;
    return {
      id: s.id,
      studentName: u?.display_name ?? 'Estudiante',
      challengeTitle: c?.title ?? 'Desafío',
      submitted_at: s.submitted_at as string,
    };
  });
}

// ---------- Student view data (when student OR admin in preview) ----------
const iconMap: Record<string, string> = {
  first_submission: 'bi-box-arrow-in-down',
  on_time: 'bi-clock-fill',
  early_bird: 'bi-lightning-fill',
  streak_3: 'bi-fire',
  attendance_streak_3: 'bi-calendar-check-fill',
  first_attendance: 'bi-geo-alt-fill',
  module_complete: 'bi-hammer',
  night_owl: 'bi-moon-fill',
  course_complete: 'bi-trophy-fill',
  manual: 'bi-star-fill',
};

let points = 0;
type DashboardBadge = { id: string; name: string; description: string | null; condition_type: string | null; earned: boolean; earned_at: string | null };
let dashboardBadges: DashboardBadge[] = [];
let studentActiveChallengesCount = 0;
let enrolledCourses: { id: string; slug: string; title: string; cover_image: string | null; description: string | null; totalLessons: number; completedLessons: number }[] = [];
let leaderboard: { id: string; name: string; avatarId: string | null; points: number }[] = [];
type UpcomingLesson = { id: string; title: string; scheduled_at: string; zoom_link: string | null; courseTitle: string };
let upcomingLessons: UpcomingLesson[] = [];
let upcomingByMonth: { monthLabel: string; lessons: UpcomingLesson[] }[] = [];

if (role !== 'admin' || preview) {
  points = userRow?.points ?? 0;
  const { data: badgeRows } = await supabase.from('badges').select('id, name, description, condition_type').order('name');
  const { data: earnedRows } = await supabase.from('user_badges').select('badge_id, earned_at').eq('user_id', userId);
  const earnedSet = new Set((earnedRows ?? []).map((e) => e.badge_id));
  const earnedAtMap = new Map((earnedRows ?? []).map((e) => [e.badge_id, e.earned_at as string]));
  dashboardBadges = (badgeRows ?? []).map((b) => ({
    id: b.id,
    name: b.name ?? 'Insignia',
    description: (b.description as string) ?? null,
    condition_type: (b.condition_type as string) ?? null,
    earned: earnedSet.has(b.id),
    earned_at: earnedAtMap.get(b.id) ?? null,
  }));

  const { count: sac } = await supabase
    .from('challenges')
    .select('*', { count: 'exact', head: true })
    .eq('is_active', true);
  studentActiveChallengesCount = sac ?? 0;

  const { data: enrollmentRows } = await supabase
    .from('enrollments')
    .select('course_id, courses(id, slug, title, cover_image, description)')
    .eq('user_id', userId);
  for (const row of enrollmentRows ?? []) {
    const course = (row as { courses: { id: string; slug: string | null; title: string; cover_image: string | null; description: string | null } | null }).courses;
    if (!course?.id) continue;
    const { data: lessonRows } = await supabase
      .from('lessons')
      .select('id, scheduled_at')
      .eq('course_id', course.id);
    const totalLessons = (lessonRows ?? []).length;
    const nowMs = Date.now();
    const completedLessons = (lessonRows ?? []).filter((l) => {
      if (!l.scheduled_at) return false;
      const t = new Date(l.scheduled_at as string).getTime();
      return Number.isFinite(t) && t < nowMs;
    }).length;
    enrolledCourses.push({
      id: course.id,
      slug: course.slug ?? course.id,
      title: course.title ?? 'Curso',
      cover_image: course.cover_image ?? null,
      description: course.description ?? null,
      totalLessons,
      completedLessons,
    });
  }

  const enrolledIds = enrolledCourses.map((c) => c.id);
  if (enrolledIds.length > 0) {
    const now = new Date().toISOString();
    const { data: lessonRows } = await supabase
      .from('lessons')
      .select('id, title, scheduled_at, zoom_link, course_id, courses(title)')
      .in('course_id', enrolledIds)
      .not('scheduled_at', 'is', null)
      .gt('scheduled_at', now)
      .order('scheduled_at', { ascending: true })
      .limit(6);
    upcomingLessons = (lessonRows ?? []).map((l) => {
      const course = l.courses as { title: string | null } | null;
      return {
        id: l.id,
        title: l.title ?? 'Clase',
        scheduled_at: l.scheduled_at as string,
        zoom_link: l.zoom_link ?? null,
        courseTitle: course?.title ?? 'Curso',
      };
    });
    const monthMap = new Map<string, UpcomingLesson[]>();
    for (const lesson of upcomingLessons) {
      const d = new Date(lesson.scheduled_at);
      const key = d.toLocaleDateString('es', { month: 'long', year: 'numeric' });
      const label = key.charAt(0).toUpperCase() + key.slice(1);
      if (!monthMap.has(label)) monthMap.set(label, []);
      monthMap.get(label)!.push(lesson);
    }
    upcomingByMonth = Array.from(monthMap.entries()).map(([monthLabel, lessons]) => ({ monthLabel, lessons }));
  }

  const { data: leaderboardRows } = await supabase
    .from('users')
    .select('id, display_name, avatar_id, points')
    .order('points', { ascending: false })
    .limit(10);
  leaderboard = (leaderboardRows ?? [])
    .map((u) => ({
      id: u.id,
      name: u.display_name ?? 'Estudiante',
      avatarId: u.avatar_id ?? null,
      points: u.points ?? 0,
    }))
    .filter((u) => u.points > 0)
    .slice(0, 5);
}

const displayName =
  userRow?.display_name ??
  (sessionClaims as any)?.first_name ??
  (sessionClaims as any)?.name ??
  (role === 'admin' ? 'Admin' : 'Estudiante');

function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleDateString('es', { day: '2-digit', month: 'short', year: 'numeric' });
  } catch {
    return iso;
  }
}

function formatDayAndDate(iso: string): string {
  try {
    const d = new Date(iso);
    const day = d.toLocaleDateString('es', { weekday: 'short' });
    const date = d.getDate();
    return `${day.charAt(0).toUpperCase() + day.slice(1)} ${date}`;
  } catch {
    return '';
  }
}

function formatTime(iso: string): string {
  try {
    return new Date(iso).toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit', hour12: true });
  } catch {
    return '';
  }
}
---

{role === 'admin' && !preview ? (
  <AdminLayout>
    <section class="space-y-8">
      <header class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl font-semibold tracking-tight text-white">Panel de administración</h1>
          <p class="mt-1 text-sm text-muted">Resumen del cohort y entregas pendientes.</p>
        </div>
        <a
          href="/dashboard?preview=true"
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface-2 px-4 py-2 text-sm font-medium text-white transition hover:border-lime/50 hover:bg-surface-2/80"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          Ver como estudiante
        </a>
      </header>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-border bg-surface p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Estudiantes</p>
          <p class="mt-1 text-2xl font-semibold text-white">{totalStudents}</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Entregas pendientes</p>
          <p class="mt-1 text-2xl font-semibold text-white">{pendingSubmissionsCount}</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Promedio cohort (pts)</p>
          <p class="mt-1 text-2xl font-semibold text-lime">{cohortAvgPoints ?? 0}</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Desafíos activos</p>
          <p class="mt-1 text-2xl font-semibold text-white">{activeChallengesCount}</p>
        </div>
      </div>

      <div class="rounded-xl border border-border bg-surface p-5">
        <h2 class="text-sm font-semibold text-white">Progreso del cohort</h2>
        <p class="mt-0.5 text-xs text-muted">Puntos por estudiante (ordenado por puntuación).</p>
        {cohortProgress.length > 0 ? (
          <ul class="mt-4 space-y-3">
            {cohortProgress.map((s) => {
              const maxPointsVal = Math.max(1, ...cohortProgress.map((x) => x.points));
              const pct = maxPointsVal ? (s.points / maxPointsVal) * 100 : 0;
              return (
                <li class="flex items-center gap-3">
                  <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full border border-border bg-surface-2">
                    <img
                      src={avatarImagePath(s.avatarId) ?? '/avatars/avatar-01.png'}
                      alt=""
                      class="h-full w-full object-cover"
                      width="32"
                      height="32"
                    />
                  </div>
                  <span class="min-w-[120px] truncate text-sm text-white" title={s.name}>{s.name}</span>
                  <div class="min-w-0 flex-1">
                    <div class="h-2 w-full overflow-hidden rounded-full bg-surface-2">
                      <div
                        class="h-full rounded-full bg-lime transition-all duration-300"
                        style={`width: ${pct}%`}
                      />
                    </div>
                  </div>
                  <span class="w-12 shrink-0 text-right text-sm font-medium text-lime">{s.points} pts</span>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="mt-4 text-sm text-muted">Aún no hay estudiantes en el cohort.</p>
        )}
      </div>

      <div class="rounded-xl border border-border bg-surface p-5">
        <div class="flex items-center justify-between gap-2">
          <div>
            <h2 class="text-sm font-semibold text-white">Entregas recientes</h2>
            <p class="mt-0.5 text-xs text-muted">Pendientes de revisión.</p>
          </div>
          <a
            href="/admin/submissions"
            class="text-xs font-medium text-lime hover:underline"
          >
            Ver todas →
          </a>
        </div>
        {recentSubmissions.length > 0 ? (
          <div class="mt-4 overflow-x-auto">
            <table class="w-full min-w-[400px] text-left text-sm">
              <thead>
                <tr class="border-b border-border text-muted">
                  <th class="pb-2 pr-4 font-medium">Estudiante</th>
                  <th class="pb-2 pr-4 font-medium">Desafío</th>
                  <th class="pb-2 pr-4 font-medium">Fecha</th>
                  <th class="pb-2 font-medium text-right">Acciones</th>
                </tr>
              </thead>
              <tbody>
                {recentSubmissions.map((sub) => (
                  <tr class="border-b border-border/60 last:border-0">
                    <td class="py-3 pr-4 text-white">{sub.studentName}</td>
                    <td class="py-3 pr-4 text-white">{sub.challengeTitle}</td>
                    <td class="py-3 pr-4 text-muted">{formatDate(sub.submitted_at)}</td>
                    <td class="py-3 text-right">
                      <form method="post" action="/api/submissions/review" class="inline-flex gap-2">
                        <input type="hidden" name="submission_id" value={sub.id} />
                        <input type="hidden" name="redirect_to" value="/dashboard" />
                        <button type="submit" name="action" value="approve" class="rounded-lg border border-lime bg-lime/15 px-3 py-1.5 text-xs font-medium text-lime transition hover:bg-lime/25">
                          Aprobar
                        </button>
                        <button type="submit" name="action" value="reject" class="rounded-lg border border-border bg-surface-2 px-3 py-1.5 text-xs font-medium text-muted transition hover:bg-red-500/15 hover:border-red-500/40 hover:text-red-400">
                          Rechazar
                        </button>
                      </form>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="mt-4 text-sm text-muted">No hay entregas pendientes.</p>
        )}
      </div>
    </section>
  </AdminLayout>
) : (
  <DashboardLayout role={preview ? 'student' : role}>
    {role === 'admin' && preview && (
      <div class="sticky top-0 z-40 -mx-4 -mt-8 mb-6 flex flex-wrap items-center justify-between gap-2 border-b border-border bg-surface/95 px-4 py-3 backdrop-blur sm:-mx-6 sm:gap-4 sm:px-6">
        <span class="flex items-center gap-2 text-sm font-medium text-lime">
          <span aria-hidden="true">👁</span>
          Modo vista previa
        </span>
        <a href="/dashboard" class="text-sm font-medium text-white underline hover:text-lime">
          Volver al panel admin
        </a>
      </div>
    )}
    <section class="space-y-8">
      <header class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-lime">
          Hola, {displayName}
        </p>
        <h1 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          Tu viaje a ser un superhuman empieza aquí.
        </h1>
        <p class="text-sm text-muted">
          Completa desafíos, asiste a sesiones en vivo y colecciona insignias mientras subes de nivel.
        </p>
      </header>

      <div class="grid gap-6 lg:grid-cols-3">
        <section class="lg:col-span-2 space-y-4">
          {enrolledCourses.length > 0 && (
            <div class="space-y-3">
              <h2 class="text-sm font-semibold text-white">Mis cursos</h2>
              <ul class="grid gap-4 sm:grid-cols-2">
                {enrolledCourses.map((course) => (
                  <li>
                    <a
                      href={`/courses/${course.slug}`}
                      class="group block overflow-hidden rounded-xl border border-border bg-surface transition-shadow hover:shadow-lg"
                    >
                      <div class="relative h-36 overflow-hidden bg-surface-2">
{course.cover_image ? (
                        <img
                          src={course.cover_image.startsWith('http') ? course.cover_image : `/courses/${course.cover_image}`}
                            alt=""
                            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                            width="400"
                            height="144"
                          />
                        ) : (
                          <div class="flex h-full w-full items-center justify-center text-muted">
                            <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                          </div>
                        )}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent" aria-hidden="true" />
                        <p class="absolute bottom-2 left-2 right-2 text-sm font-semibold text-white drop-shadow">
                          {course.title}
                        </p>
                      </div>
                      <div class="border-t border-border p-3">
                        <p class="text-xs text-muted">
                          {course.completedLessons} de {course.totalLessons} clases completadas
                        </p>
                        <div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-surface-2">
                          <div
                            class="h-full rounded-full bg-lime transition-all duration-300"
                            style={`width: ${course.totalLessons ? (course.completedLessons / course.totalLessons) * 100 : 0}%`}
                          />
                        </div>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          <div class="rounded-2xl border border-border bg-surface p-5">
            <h2 class="text-sm font-semibold text-white">Progreso</h2>
            <p class="mt-1 text-xs text-muted">
              Sigue tus puntos y cómo creces cada semana.
            </p>

            <dl class="mt-4 grid grid-cols-2 gap-4">
              <div class="space-y-1 rounded-xl border border-border bg-surface-2 p-3">
                <dt class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">
                  Puntos
                </dt>
                <dd class="text-2xl font-semibold text-lime">
                  {points}
                </dd>
              </div>
              <div class="space-y-1 rounded-xl border border-border bg-surface-2 p-3">
                <dt class="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">
                  Desafíos activos
                </dt>
                <dd class="text-2xl font-semibold text-white">
                  {studentActiveChallengesCount}
                </dd>
              </div>
            </dl>
          </div>

          <div class="rounded-2xl border border-border bg-surface p-5">
            <div>
              <h2 class="text-sm font-semibold text-white">Insignias</h2>
              <p class="text-xs text-muted">
                Las insignias aparecen aquí al completar lecciones y desafíos.
              </p>
            </div>

            <ul class="mt-4 grid gap-4 sm:grid-cols-2">
              {dashboardBadges.map((b) => (
                <li
                  class={`group rounded-xl border p-4 transition-colors ${
                    b.earned ? 'border-border bg-surface' : 'border-border bg-surface-2/60 opacity-50'
                  }`}
                >
                  <div class="flex items-start gap-4">
                    <div class={`flex h-14 w-14 shrink-0 items-center justify-center rounded-full p-1.5 ${b.earned ? 'bg-lime' : 'bg-surface-2'}`}>
                      <div class={`flex h-full w-full items-center justify-center rounded-full ring-1 ring-inset ${b.earned ? 'ring-black' : 'ring-border'}`}>
                        <i class={`bi ${iconMap[b.condition_type ?? ''] ?? 'bi-star-fill'} text-2xl transition-transform duration-200 group-hover:scale-110 ${b.earned ? 'text-background/75' : 'text-muted'}`} aria-hidden="true" />
                      </div>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-normal text-white/90">{b.name}</p>
                      {b.description && <p class="mt-0.5 text-[11px] text-muted/90">{b.description}</p>}
                      {b.earned && b.earned_at ? (
                        <p class="mt-2 text-[10px] tracking-wide text-lime/90">Obtenida {formatDate(b.earned_at)}</p>
                      ) : (
                        <p class="mt-2 text-[10px] tracking-wide text-muted/90">Bloqueado</p>
                      )}
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </section>

        <aside class="space-y-4 w-full lg:max-w-[300px]">
          <div class="rounded-xl border border-border bg-surface p-3">
            <h2 class="text-xs font-semibold text-white">Ranking</h2>
            <p class="mt-0.5 text-[10px] text-muted">Más puntos del cohort.</p>
            {leaderboard.length > 0 ? (
              <ul class="mt-3 space-y-1.5">
                {leaderboard.map((u, i) => (
                  <li class="flex items-center gap-2 rounded-lg border border-border bg-surface-2/60 px-2 py-1.5">
                    <span class={`w-5 shrink-0 text-[10px] font-semibold ${i === 0 ? 'text-lime' : 'text-muted'}`}>{i + 1}º</span>
                    <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full border border-border bg-surface-2">
                      <img src={avatarImagePath(u.avatarId) ?? '/avatars/avatar-01.png'} alt="" class="h-full w-full object-cover" width="32" height="32" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-[11px] font-medium text-white" title={u.name}>{u.name}</p>
                      <p class="text-[10px] font-semibold text-lime">{u.points} pts</p>
                    </div>
                  </li>
                ))}
              </ul>
            ) : (
              <div class="mt-4 flex flex-col items-center gap-2 text-center">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-surface-2 text-muted" aria-hidden="true">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
                  </svg>
                </div>
                <p class="text-[11px] text-muted">Sin puntos aún. Tú puedes lograrlo.</p>
              </div>
            )}
          </div>

          <div class="rounded-xl border border-border bg-surface p-4">
            <h2 class="text-sm font-semibold text-white">Próximas clases</h2>
            {upcomingLessons.length > 0 ? (
              <div class="mt-3 max-h-[320px] overflow-y-auto space-y-4">
                {upcomingByMonth.map(({ monthLabel, lessons }) => (
                  <div>
                    <p class="mb-2 text-[10px] font-semibold uppercase tracking-wider text-muted">{monthLabel}</p>
                    <ul class="space-y-2">
                      {lessons.map((lesson, idx) => {
                        const isNext = idx === 0 && upcomingByMonth[0]?.lessons[0]?.id === lesson.id;
                        const joinUrl = lesson.zoom_link?.trim() || null;
                        return (
                          <li
                            class={`rounded-lg border px-3 py-2.5 ${
                              isNext
                                ? 'border-l-4 border-l-lime bg-lime/10 border-border'
                                : 'border-border bg-surface-2/60'
                            }`}
                          >
                            <div class="flex items-start justify-between gap-2">
                              <div class="min-w-0 flex-1">
                                <p class="text-[10px] text-muted">
                                  {formatDayAndDate(lesson.scheduled_at)} · {formatTime(lesson.scheduled_at)}
                                </p>
                                <p class="mt-0.5 text-xs font-medium text-white">{lesson.title}</p>
                                <p class="mt-0.5 text-[10px] text-muted">{lesson.courseTitle}</p>
                              </div>
                              {joinUrl && (
                                <a
                                  href={joinUrl}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="shrink-0 rounded border border-lime bg-lime/15 px-2 py-1 text-[10px] font-medium text-lime transition hover:bg-lime/25"
                                >
                                  Unirse
                                </a>
                              )}
                            </div>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ))}
              </div>
            ) : (
              <p class="mt-3 text-sm text-muted">No hay clases programadas aún.</p>
            )}
          </div>
        </aside>
      </div>
    </section>
  </DashboardLayout>
)}