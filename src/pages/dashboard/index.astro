                                <div class="min-w-0 flex-1">
                                  <p class="text-[10px] text-[#737373]">
                                    {formatDayAndDate(lesson.scheduled_at, userTimezone)} · {formatTime(lesson.scheduled_at, userTimezone)}
                                  </p>
                                  <p class="mt-0.5 font-work-sans text-[14px] font-medium leading-snug text-[#1A1A1A]">
                                    {lesson.title}
                                  </p>
                                  <p class="mt-0.5 text-[10px] text-[#737373]">{lesson.courseTitle}</p>
                                </div>
                                <div class="flex shrink-0 flex-col items-end gap-1.5">
                                  {lesson.recording_passcode && (
                                    <div class="flex max-w-[10.5rem] items-center gap-1 rounded-md border border-[#d0d0d0] bg-[#F8F8F8] px-1.5 py-1">
