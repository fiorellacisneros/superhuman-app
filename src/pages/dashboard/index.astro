                  </svg>
                </div>
                <p class="text-[11px] text-muted">
                  {enrolledIds.length === 0 ? 'Inscríbete en un curso para ver el ranking de tu cohort.' : 'Sin puntos aún. Tú puedes lograrlo.'}
                </p>
              </div>
            )}
          </div>
          )}

          {(dashboardBadges.length > 0) && (
          <div class="rounded-[24px] bg-background p-5">
            <div class="mb-3 flex flex-wrap items-start justify-between gap-1">
              <div class="min-w-0 flex-1">
                <h2 class="font-manrope text-2xl font-semibold text-white">Insignias generales</h2>
                <p class="mt-0.5 text-xs text-muted">{hasLiveEnrollment ? 'Puedes ganar la misma insignia en distintos cursos.' : 'Insignias que puedes desbloquear (sin puntos ni sesiones en vivo).'}</p>
              </div>
              <button
                type="button"
                id="open-badge-guide-modal"
                class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-muted transition hover:bg-surface-2 hover:text-lime"
                aria-label="Cómo ganar insignias"
                title="Cómo ganar insignias"
                aria-haspopup="dialog"
                aria-controls="badge-guide-modal"
              >
                <i class="bi bi-info-circle text-[1.125rem] leading-none" aria-hidden="true"></i>
              </button>
            </div>
            <ul class="mt-4 grid grid-cols-3 gap-x-5 gap-y-6 sm:gap-x-6 sm:gap-y-6">
              {dashboardBadges.map((b) => (
                <li
                  class={`group flex min-w-0 flex-col items-center rounded-xl transition-colors ${
                    'bg-background'
                  }`}
                >
                  <BadgeOutline id={b.id} variant={b.earned ? 'earned' : 'unearned'} count={b.earnedCount > 0 ? b.earnedCount : undefined}>
                    <BadgeIcon
                      icon={iconMap[b.condition_type ?? ''] ?? 'manual'}
                      class={`transition-transform duration-200 group-hover:scale-110 ${b.earned ? 'text-[#012EDC]' : 'text-[#595959]'}`}
                    />
                  </BadgeOutline>
                  <p class="mt-2 min-w-0 max-w-full truncate text-center font-work-sans text-xs font-normal text-white" title={b.name}>{b.name}</p>
                </li>
              ))}
            </ul>
          </div>
          )}
        </aside>
      </div>
      )}

    <div
      id="points-breakdown-modal"
      class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="points-breakdown-modal-title"
    >
      <div id="points-breakdown-modal-backdrop" class="absolute inset-0" tabindex="-1" aria-hidden="true"></div>
      <div class="relative z-10 flex max-h-[min(85vh,620px)] w-full max-w-lg flex-col rounded-xl border border-transparent bg-surface shadow-xl">
        <div class="flex shrink-0 items-center justify-between border-b border-white/10 px-5 py-4">
          <h2 id="points-breakdown-modal-title" class="text-base font-semibold text-white">Desglose de puntos</h2>
          <button
            type="button"
            id="close-points-breakdown-modal"
            class="rounded-lg p-1.5 text-muted transition hover:bg-surface-2 hover:text-white"
            aria-label="Cerrar"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="min-h-0 flex-1 overflow-y-auto px-5 py-4">
          <p class="text-xs text-muted">
            ¡Sigue así!
          </p>
          {pointsBreakdownByCourse.length > 0 ? (
            <div class="mt-4 space-y-6">
              {pointsBreakdownByCourse.map((course) => {
                return (
                  <div class="rounded-lg border border-transparent bg-surface-2/40 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                      <h3 class="text-sm font-medium text-white">{course.courseTitle}</h3>
                      <span class="text-sm font-semibold text-lime">{course.totalStored} pts totales</span>
                    </div>
                    {course.items.length > 0 ? (
                      <ul class="mt-3 space-y-1.5">
                        {course.items.map((item) => (
                          <PointsBreakdownListItem label={item.label} detail={item.detail} pts={item.pts} />
                        ))}
                      </ul>
                    ) : (
                      <p class="mt-2 text-sm text-muted">
                        Aún no hay asistencias ni entregas registradas en este curso.
                      </p>
                    )}
                  </div>
                );
              })}
            </div>
          ) : (
            <p class="mt-3 text-sm text-muted">
              {enrolledIds.length === 0
                ? 'Cuando estés inscrito en un curso y empieces a sumar puntos, verás el detalle aquí.'
                : 'Aún no hay puntos registrados por curso. Asiste a clases, entrega retos o participa en Kahoot para sumar.'}
            </p>
          )}
        </div>
      </div>
    </div>

    <div
      id="badge-guide-modal"
      class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="badge-guide-modal-title"
    >
      <div id="badge-guide-modal-backdrop" class="absolute inset-0" tabindex="-1" aria-hidden="true"></div>
      <div
        class="relative z-10 flex max-h-[min(85vh,560px)] w-full max-w-lg flex-col rounded-xl border border-transparent bg-surface shadow-xl"
        id="badge-guide-modal-panel"
      >
        <div class="flex shrink-0 items-center justify-between border-b border-white/10 px-5 py-4">
          <h2 id="badge-guide-modal-title" class="text-base font-semibold text-white">Cómo ganar insignias</h2>
          <button
            type="button"
            id="close-badge-guide-modal"
            class="rounded-lg p-1.5 text-muted transition hover:bg-surface-2 hover:text-white"
            aria-label="Cerrar"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="min-h-0 flex-1 overflow-y-auto px-5 py-4">
          <p class="text-xs text-muted">
            {hasLiveEnrollment
              ? 'Estas reglas aplican a tus cursos y a los retos vinculados. Tus Jedis también pueden otorgar insignias manuales.'
              : 'En cursos on-demand solo aplican las insignias ligadas a entregas y progreso del curso (sin asistencia en vivo).'}
          </p>
          <ul class="mt-4 space-y-4">
            {badgeEarnGuideRows.map((row) => (
              <li class="rounded-lg bg-surface-2/50 px-3 py-2.5">
                <p class="text-sm font-medium text-white">{row.title}</p>
                <p class="mt-1 text-xs text-muted">{row.body}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        function syncBodyScroll() {
          const badge = document.getElementById('badge-guide-modal');
          const points = document.getElementById('points-breakdown-modal');
          const anyOpen = [badge, points].some((m) => m && !m.classList.contains('hidden'));
          document.body.style.overflow = anyOpen ? 'hidden' : '';
        }
        function wireModal(modalId, openSelector, closeBtnId, backdropId) {
          const modal = document.getElementById(modalId);
          const closeBtn = document.getElementById(closeBtnId);
          const backdrop = document.getElementById(backdropId);
          function openModal() {
            if (!modal) return;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            syncBodyScroll();
          }
          function closeModal() {
            if (!modal) return;
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            syncBodyScroll();
          }
          document.querySelectorAll(openSelector).forEach((el) => {
            el.addEventListener('click', openModal);
          });
          closeBtn?.addEventListener('click', closeModal);
          backdrop?.addEventListener('click', closeModal);
          return { closeModal, modal };
        }
        const badge = wireModal('badge-guide-modal', '#open-badge-guide-modal', 'close-badge-guide-modal', 'badge-guide-modal-backdrop');
        const points = wireModal('points-breakdown-modal', '.open-points-breakdown-trigger', 'close-points-breakdown-modal', 'points-breakdown-modal-backdrop');
        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          if (badge.modal && !badge.modal.classList.contains('hidden')) badge.closeModal();
          else if (points.modal && !points.modal.classList.contains('hidden')) points.closeModal();
        });

        document.addEventListener('click', (e) => {
          const t = e.target;
          if (!(t instanceof Element)) return;
          const btn = t.closest('.dashboard-copy-recording-code');
          if (!btn || btn.tagName !== 'BUTTON') return;
          const code = btn.getAttribute('data-code');
          if (!code) return;
          e.preventDefault();
          void navigator.clipboard.writeText(code).then(() => {
            const icon = btn.querySelector('i');
            if (icon) {
              icon.className = 'bi bi-check-lg text-sm leading-none';
              setTimeout(() => {
                icon.className = 'bi bi-clipboard text-sm leading-none';
              }, 1400);
            }
          });
        });
      });
    </script>
    </section>
  </DashboardLayout>
)}