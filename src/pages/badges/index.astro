---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const role = (userRow?.role as string) ?? 'student';

const iconMap: Record<string, string> = {
  first_submission: 'bi-box-arrow-in-down',
  on_time: 'bi-clock-fill',
  early_bird: 'bi-lightning-fill',
  streak_3: 'bi-fire',
  attendance_streak_3: 'bi-calendar-check-fill',
  first_attendance: 'bi-geo-alt-fill',
  module_complete: 'bi-hammer',
  night_owl: 'bi-moon-fill',
  course_complete: 'bi-trophy-fill',
  manual: 'bi-star-fill',
};

const { data: badgeRows } = await supabase.from('badges').select('id, name, description, image_url, condition_type').order('name');
const { data: earnedRows } = await supabase.from('user_badges').select('badge_id, earned_at').eq('user_id', userId);
const earnedSet = new Set((earnedRows ?? []).map((e) => e.badge_id));
const earnedAtMap = new Map((earnedRows ?? []).map((e) => [e.badge_id, e.earned_at as string]));

const badges = (badgeRows ?? []).map((b) => ({
  id: b.id,
  name: b.name ?? 'Insignia',
  description: (b.description as string) ?? null,
  image_url: (b.image_url as string) ?? null,
  condition_type: (b.condition_type as string) ?? null,
  earned: earnedSet.has(b.id),
  earned_at: earnedAtMap.get(b.id) ?? null,
}));

function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleDateString('es', { day: '2-digit', month: 'short', year: 'numeric' });
  } catch {
    return iso;
  }
}
---

<DashboardLayout role={role}>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Panel</a>
      <span class="mx-1">/</span>
      <span class="text-white">Insignias</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Insignias</h1>
      <p class="mt-1 text-sm text-muted">Colección de logros desbloqueados.</p>
    </header>

    {badges.length > 0 ? (
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {badges.map((b) => (
          <li
            class={`group rounded-xl border p-4 transition-colors ${
              b.earned ? 'border-border bg-surface' : 'border-border bg-surface-2/60 opacity-50'
            }`}
          >
            <div class="flex items-start gap-4">
              <div class={`flex h-14 w-14 shrink-0 items-center justify-center rounded-full p-1.5 ${b.earned ? 'bg-lime' : 'bg-surface-2'}`}>
                <div class={`flex h-full w-full items-center justify-center rounded-full ring-1 ring-inset ${b.earned ? 'ring-black' : 'ring-border'}`}>
                  <i class={`bi ${iconMap[b.condition_type ?? ''] ?? 'bi-star-fill'} text-2xl transition-transform duration-200 group-hover:scale-110 ${b.earned ? 'text-background/75' : 'text-muted'}`} aria-hidden="true" />
                </div>
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-normal text-white/90">{b.name}</p>
                {b.description && <p class="mt-0.5 text-[11px] text-muted/90">{b.description}</p>}
                {b.earned && b.earned_at ? (
                  <p class="mt-2 text-[10px] tracking-wide text-lime/90">Obtenida {formatDate(b.earned_at)}</p>
                ) : (
                  <p class="mt-2 text-[10px] tracking-wide text-muted/90">Bloqueado</p>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <div class="rounded-xl border border-dashed border-border bg-surface-2/60 p-8 text-center">
        <p class="text-sm font-medium text-white">Aún no hay insignias creadas.</p>
        <p class="mt-1 text-sm text-muted">Cuando existan insignias, aparecerán aquí para desbloquear.</p>
        <a href="/dashboard" class="mt-4 inline-block rounded-lg border border-lime bg-lime/15 px-4 py-2 text-sm font-medium text-lime transition hover:bg-lime/25">
          Volver al panel
        </a>
      </div>
    )}
  </section>
</DashboardLayout>
