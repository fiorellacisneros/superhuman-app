---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import BadgeIcon from '../../components/BadgeIcon.astro';
import { getPreviewContext } from '../../lib/preview';
import { isStudentVisibleBadgeCondition, ON_DEMAND_BADGE_CONDITION_TYPES } from '../../lib/badges';
import { badgeDisplayDescription, badgeDisplayName } from '../../lib/badge-display';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const role = (userRow?.role as string) ?? 'student';
const { preview, previewAs } = getPreviewContext(Astro);
const isPreviewMode = role === 'admin' && preview;

let hasLiveEnrollment = true;
if (role === 'student' && !isPreviewMode) {
  const { data: enrollments } = await supabase
    .from('enrollments')
    .select('access_type')
    .eq('user_id', userId);
  hasLiveEnrollment = (enrollments ?? []).some((e) => (e.access_type as string) !== 'on_demand');
  if (!hasLiveEnrollment) {
    return Astro.redirect('/dashboard');
  }
}
if (isPreviewMode && previewAs === 'on_demand') {
  return Astro.redirect('/dashboard');
}

const iconMap: Record<string, string> = {
  first_submission: 'first_submission',
  on_time: 'on_time',
  early_bird: 'early_bird',
  streak_3: 'streak_3',
  attendance_streak_3: 'attendance_streak_3',
  first_attendance: 'first_attendance',
  module_complete: 'module_complete',
  night_owl: 'night_owl',
  course_complete: 'course_complete',
  manual: 'manual',
};

const { data: badgeRows } = await supabase.from('badges').select('id, name, description, image_url, condition_type').order('name');
const { data: earnedRows } = await supabase.from('user_badges').select('badge_id, earned_at').eq('user_id', userId);
const earnedSet = new Set((earnedRows ?? []).map((e) => e.badge_id));
const earnedAtMap = new Map((earnedRows ?? []).map((e) => [e.badge_id, e.earned_at as string]));

const allBadges = (badgeRows ?? []).map((b) => {
  const ct = (b.condition_type as string) ?? null;
  const rawName = (b.name as string) ?? null;
  const rawDesc = (b.description as string) ?? null;
  return {
  id: b.id,
  name: badgeDisplayName(ct, rawName),
  description: badgeDisplayDescription(ct, rawDesc, rawName),
  image_url: (b.image_url as string) ?? null,
  condition_type: ct,
  earned: earnedSet.has(b.id),
  earned_at: earnedAtMap.get(b.id) ?? null,
};
});
const badges = hasLiveEnrollment
  ? allBadges.filter((b) => isStudentVisibleBadgeCondition(b.condition_type))
  : allBadges.filter((b) => b.condition_type && ON_DEMAND_BADGE_CONDITION_TYPES.includes(b.condition_type as 'first_submission' | 'early_bird' | 'module_complete' | 'course_complete' | 'manual'));

function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleDateString('es', { day: '2-digit', month: 'short', year: 'numeric' });
  } catch {
    return iso;
  }
}
---

<DashboardLayout role={isPreviewMode ? 'student' : role}>
  {isPreviewMode && (
    <div class="-mx-4 -mt-6 mb-6 flex flex-wrap items-center justify-between gap-2 bg-background/95 px-4 py-3 md:-mx-6 md:mb-8 md:gap-4 md:px-6">
      <span class="flex items-center gap-2 text-sm font-medium text-lime">
        <span aria-hidden="true">👁</span>
        Vista previa como estudiante
      </span>
      <a href="/dashboard?exitPreview=1" class="inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al dashboard de admin
      </a>
    </div>
  )}
  <section class="max-w-5xl space-y-6 xl:max-w-6xl">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <span class="text-white">Insignias</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Insignias</h1>
      <p class="mt-1 text-sm text-muted">{hasLiveEnrollment ? 'Colección de logros desbloqueados.' : 'Insignias que puedes desbloquear (sin puntos ni sesiones en vivo).'}</p>
    </header>

    {badges.length > 0 ? (
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {badges.map((b) => (
          <li
            class={`badge-tooltip-group group rounded-xl border p-4 transition-colors ${
              b.earned ? 'border-transparent bg-gray' : 'border-transparent bg-surface-2/60 opacity-50'
            }`}
          >
            <span class="badge-tooltip" role="tooltip">{b.description ?? b.name}</span>
            <div class="flex items-start gap-4">
              <div class={`flex h-14 w-14 shrink-0 items-center justify-center rounded-full p-1.5 ${b.earned ? 'bg-lime' : 'bg-surface-2'}`}>
                <div class={`flex h-full w-full items-center justify-center rounded-full ring-1 ring-inset ${b.earned ? 'ring-black' : 'ring-border'}`}>
                  <BadgeIcon
                    icon={iconMap[b.condition_type ?? ''] ?? 'manual'}
                    class={`h-6 w-6 transition-transform duration-200 group-hover:scale-110 ${b.earned ? 'text-background/75' : 'text-muted'}`}
                  />
                </div>
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-normal text-white/90">{b.name}</p>
                {b.description && <p class="mt-0.5 text-[11px] text-muted/90">{b.description}</p>}
                {b.earned && b.earned_at ? (
                  <p class="mt-2 text-[10px] tracking-wide text-lime/90">Obtenida {formatDate(b.earned_at)}</p>
                ) : (
                  <p class="mt-2 text-[10px] tracking-wide text-muted/90">Bloqueado</p>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <div class="rounded-xl border border-dashed border-transparent bg-background p-8 text-center">
        <p class="text-sm font-medium text-white">Aún no hay insignias creadas.</p>
        <p class="mt-1 text-sm text-muted">Cuando existan insignias, aparecerán aquí para desbloquear.</p>
        <a href="/dashboard" class="mt-4 inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al dashboard
        </a>
      </div>
    )}
  </section>
</DashboardLayout>
