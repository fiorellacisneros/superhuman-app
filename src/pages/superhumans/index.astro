---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { avatarImagePath } from '../../lib/avatars';
import { getPreviewContext } from '../../lib/preview';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const role = (userRow?.role as string) ?? 'student';
const { preview } = getPreviewContext(Astro);
const isPreviewMode = role === 'admin' && preview;

/** Solo `show_in_directory`; antes se filtraba `role = student` y los admins nunca aparecían. */
const { data: directoryRows } = await supabase
  .from('users')
  .select('id, display_name, self_declared_role, description, profile_photo_url, avatar_id, linkedin_url, instagram_url, portfolio_url')
  .eq('show_in_directory', true)
  .order('display_name', { ascending: true });

type DirectoryUser = {
  id: string;
  displayName: string;
  role: string;
  description: string;
  photoUrl: string;
  linkedinUrl: string | null;
  instagramUrl: string | null;
  portfolioUrl: string | null;
};

const users: DirectoryUser[] = (directoryRows ?? []).map((u) => {
  const photoUrl = (u.profile_photo_url as string)?.trim() || avatarImagePath(u.avatar_id as string) || '/avatars/avatar-01.png';
  return {
    id: u.id,
    displayName: (u.display_name as string) ?? 'Estudiante',
    role: (u.self_declared_role as string) ?? '',
    description: (u.description as string) ?? '',
    photoUrl,
    linkedinUrl: (u.linkedin_url as string)?.trim() || null,
    instagramUrl: (u.instagram_url as string)?.trim() || null,
    portfolioUrl: (u.portfolio_url as string)?.trim() || null,
  };
});

function hasLinks(u: DirectoryUser) {
  return Boolean(u.linkedinUrl || u.instagramUrl || u.portfolioUrl);
}

function hasDescription(u: DirectoryUser) {
  return Boolean(u.description?.trim());
}

/** Desplegable solo si hay descripción y/o enlaces (el cierre muestra nombre + puesto). */
function isExpandable(u: DirectoryUser) {
  return hasLinks(u) || hasDescription(u);
}

const glassPanel =
  'rounded-2xl border border-white/20 bg-black/35 p-4 text-left text-white shadow-[0_12px_40px_-8px_rgba(0,0,0,0.45)] backdrop-blur-xl backdrop-saturate-150 supports-[backdrop-filter]:bg-black/25';
---

<DashboardLayout role={isPreviewMode ? 'student' : (role === 'admin' ? 'admin' : 'student')}>
  {isPreviewMode && (
    <div class="-mx-4 -mt-6 mb-6 flex flex-wrap items-center justify-between gap-2 bg-background/95 px-4 py-3 md:-mx-6 md:mb-8 md:gap-4 md:px-6">
      <span class="flex items-center gap-2 text-sm font-medium text-lime">
        <span aria-hidden="true">👁</span>
        Vista previa como estudiante
      </span>
      <a href="/dashboard?exitPreview=1" class="inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al dashboard de admin
      </a>
    </div>
  )}
  <section class="max-w-6xl space-y-8 xl:max-w-7xl">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <span class="text-white">SuperHumans</span>
    </nav>

    <header class="max-w-xl">
      <h1 class="text-2xl font-semibold tracking-tight text-white md:text-3xl">SuperHumans</h1>
      <p class="mt-2 text-base leading-relaxed text-muted md:text-lg">Un espacio para conectar con compañeros de la comunidad.</p>
    </header>

    {users.length > 0 ? (
      <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
        {users.map((u) => {
          const expandable = isExpandable(u);
          const links = hasLinks(u);
          const desc = hasDescription(u);
          const showExpandedBody = desc || links;
          return (
            <article class="directory-portrait-card group/card overflow-hidden rounded-[1.75rem] border border-white/10 bg-surface shadow-[0_24px_60px_-20px_rgba(0,0,0,0.55)]">
              <div class="relative aspect-[4/5] min-h-[300px] w-full sm:min-h-[340px]">
                <img
                  src={u.photoUrl}
                  alt={u.displayName}
                  class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover/card:scale-[1.02]"
                  width="480"
                  height="600"
                  loading="lazy"
                  decoding="async"
                />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/50 via-black/5 to-transparent" aria-hidden="true" />

                <div class="absolute inset-x-3 bottom-3 z-10 sm:inset-x-4 sm:bottom-4">
                  {expandable ? (
                    <details class={`directory-card-details group ${glassPanel}`}>
                      <summary
                        class="flex cursor-pointer list-none items-start justify-between gap-3 outline-none [&::-webkit-details-marker]:hidden"
                        aria-label={desc && links ? 'Ver descripción y enlaces' : desc ? 'Ver descripción' : 'Ver enlaces'}
                      >
                        <div class="min-w-0 flex-1">
                          <h2 class="font-semibold leading-snug tracking-tight text-white">{u.displayName}</h2>
                          {u.role && <p class="mt-1 text-sm font-medium text-white/75">{u.role}</p>}
                        </div>
                        <span
                          class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#FFBE00] text-neutral-900 shadow-sm transition group-open:rotate-45"
                          aria-hidden="true"
                        >
                          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" d="M12 5v14M5 12h14" />
                          </svg>
                        </span>
                      </summary>

                      {showExpandedBody && (
                        <div class="mt-4 border-t border-white/20 pt-4">
                          {desc && <p class="text-sm leading-relaxed text-white/85">{u.description.trim()}</p>}
                          {links && (
                            <ul class={`flex flex-wrap gap-2 ${desc ? 'mt-4' : ''}`}>
                              {u.linkedinUrl && (
                                <li>
                                  <a
                                    href={u.linkedinUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/90 text-black shadow-sm transition hover:bg-white"
                                    aria-label="LinkedIn"
                                  >
                                    <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                    </svg>
                                  </a>
                                </li>
                              )}
                              {u.instagramUrl && (
                                <li>
                                  <a
                                    href={u.instagramUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/90 text-black shadow-sm transition hover:bg-white"
                                    aria-label="Instagram"
                                  >
                                    <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                                    </svg>
                                  </a>
                                </li>
                              )}
                              {u.portfolioUrl && (
                                <li>
                                  <a
                                    href={u.portfolioUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/90 text-black shadow-sm transition hover:bg-white"
                                    aria-label="Portafolio"
                                  >
                                    <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                                    </svg>
                                  </a>
                                </li>
                              )}
                            </ul>
                          )}
                        </div>
                      )}
                    </details>
                  ) : (
                    <div class={glassPanel}>
                      <h2 class="font-semibold leading-snug tracking-tight text-white">{u.displayName}</h2>
                      {u.role && <p class="mt-1 text-sm font-medium text-white/75">{u.role}</p>}
                    </div>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <div class={`rounded-2xl p-10 text-center ${glassPanel}`}>
        <p class="text-base font-medium text-white">Aún no hay perfiles para mostrar.</p>
        <p class="mt-2 text-sm text-white/65">Vuelve más adelante.</p>
        <a href="/profile" class="mt-6 inline-flex items-center gap-1.5 rounded-[40px] border border-white/40 bg-white/10 px-4 py-2 text-sm font-medium text-white backdrop-blur-sm transition hover:bg-white/20">
          Ir a mi perfil
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </section>
</DashboardLayout>
