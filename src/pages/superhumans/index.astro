---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { avatarImagePath } from '../../lib/avatars';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const role = (userRow?.role as string) ?? 'student';

const { data: directoryRows } = await supabase
  .from('users')
  .select('id, display_name, self_declared_role, description, profile_photo_url, avatar_id, linkedin_url, instagram_url, portfolio_url')
  .eq('show_in_directory', true)
  .eq('role', 'student')
  .order('display_name', { ascending: true });

type DirectoryUser = {
  id: string;
  displayName: string;
  role: string;
  description: string;
  photoUrl: string;
  linkedinUrl: string | null;
  instagramUrl: string | null;
  portfolioUrl: string | null;
};

const users: DirectoryUser[] = (directoryRows ?? []).map((u) => {
  const photoUrl = (u.profile_photo_url as string)?.trim() || avatarImagePath(u.avatar_id as string) || '/avatars/avatar-01.png';
  return {
    id: u.id,
    displayName: (u.display_name as string) ?? 'Estudiante',
    role: (u.self_declared_role as string) ?? '',
    description: (u.description as string) ?? '',
    photoUrl,
    linkedinUrl: (u.linkedin_url as string)?.trim() || null,
    instagramUrl: (u.instagram_url as string)?.trim() || null,
    portfolioUrl: (u.portfolio_url as string)?.trim() || null,
  };
});
---

<DashboardLayout role={role === 'admin' ? 'admin' : 'student'}>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <span class="text-white">SuperHumans</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">SuperHumans</h1>
      <p class="mt-1 text-sm text-muted">Conoce a la comunidad. Estudiantes que comparten su perfil.</p>
    </header>

    {users.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {users.map((u) => (
          <article class="rounded-xl border border-transparent bg-surface p-4 transition hover:border-lime/30">
            <div class="flex flex-col items-center text-center sm:flex-row sm:items-start sm:text-left sm:gap-4">
              <div class="shrink-0">
                <img
                  src={u.photoUrl}
                  alt=""
                  class="h-20 w-20 rounded-full border-2 border-lime/30 object-cover"
                  width="80"
                  height="80"
                  loading="lazy"
                />
              </div>
              <div class="mt-3 min-w-0 flex-1 sm:mt-0">
                <h2 class="font-semibold text-white">{u.displayName}</h2>
                {u.role && <p class="mt-0.5 text-xs font-medium uppercase tracking-wider text-lime">{u.role}</p>}
                {u.description && <p class="mt-1.5 line-clamp-2 text-sm text-muted">{u.description}</p>}
                <div class="mt-3 flex flex-wrap justify-center gap-2 sm:justify-start">
                  {u.linkedinUrl && (
                    <a
                      href={u.linkedinUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-transparent bg-surface-2 text-muted transition hover:border-lime/50 hover:text-lime"
                      aria-label="LinkedIn"
                    >
                      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                      </svg>
                    </a>
                  )}
                  {u.instagramUrl && (
                    <a
                      href={u.instagramUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-transparent bg-surface-2 text-muted transition hover:border-lime/50 hover:text-lime"
                      aria-label="Instagram"
                    >
                      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                      </svg>
                    </a>
                  )}
                  {u.portfolioUrl && (
                    <a
                      href={u.portfolioUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-transparent bg-surface-2 text-muted transition hover:border-lime/50 hover:text-lime"
                      aria-label="Portafolio"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="rounded-xl border border-transparent bg-surface p-8 text-center">
        <p class="text-muted">Aún nadie ha activado "Aparecer en el directorio".</p>
        <p class="mt-1 text-sm text-muted">Ve a tu perfil y activa la opción para que otros te encuentren.</p>
        <a href="/profile" class="mt-4 inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
          Ir a mi perfil
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </section>
</DashboardLayout>
