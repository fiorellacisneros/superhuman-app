---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { formatDayAndDate, formatTime } from '../../lib/format-date';
import { isLessonCompleted } from '../../lib/lessons';

const { isAuthenticated, userId, sessionClaims, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const { slug: courseSlug } = Astro.params as { slug: string };
if (!courseSlug) {
  return Astro.redirect('/dashboard');
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role, timezone').eq('id', userId).maybeSingle();
const roleFromClaims = (sessionClaims as { metadata?: { role?: string } } | null)?.metadata?.role;
const isAdmin = roleFromClaims === 'admin' || (userRow?.role as string) === 'admin';

let course: { id: string; slug: string | null; title: string; description: string | null; cover_image: string | null } | null = null;
const { data: bySlug } = await supabase
  .from('courses')
  .select('id, slug, title, description, cover_image')
  .eq('slug', courseSlug)
  .maybeSingle();
if (bySlug) {
  course = bySlug;
} else {
  const { data: byId } = await supabase
    .from('courses')
    .select('id, slug, title, description, cover_image')
    .eq('id', courseSlug)
    .maybeSingle();
  course = byId;
}
if (!course) {
  return Astro.redirect('/dashboard');
}
const resolvedCourseSlug = typeof course.slug === 'string' && course.slug.trim() ? course.slug.trim() : course.id;

let isOnDemand = false;
if (!isAdmin) {
  const { data: enrollment } = await supabase
    .from('enrollments')
    .select('course_id, access_type')
    .eq('user_id', userId)
    .eq('course_id', course.id)
    .maybeSingle();
  if (!enrollment) {
    return Astro.redirect('/dashboard');
  }
  isOnDemand = (enrollment.access_type as string) === 'on_demand';
}

const { data: lessons } = await supabase
  .from('lessons')
  .select('id, title, order, scheduled_at, recording_url, ppt_url')
  .eq('course_id', course.id)
  .order('order', { ascending: true });

const userTimezone = (userRow as { timezone?: string | null } | null)?.timezone ?? null;
const totalLessons = (lessons ?? []).length;
const now = Date.now();
const completedLessons = (lessons ?? []).filter((l) => {
  if (isOnDemand) {
    const hasContent = Boolean((l.recording_url && String(l.recording_url).trim()) || (l.ppt_url && String(l.ppt_url).trim()));
    return hasContent;
  }
  return isLessonCompleted(l.scheduled_at, now);
}).length;
const lessonItems = (lessons ?? []).map((lesson) => {
  const hasContent = Boolean((lesson.recording_url && String(lesson.recording_url).trim()) || (lesson.ppt_url && String(lesson.ppt_url).trim()));
  const completed = isOnDemand ? hasContent : isLessonCompleted(lesson.scheduled_at, now);
  const available = isOnDemand ? hasContent : true;
  return {
    ...lesson,
    completed,
    available,
    hasContent,
  };
});
---

<DashboardLayout>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Panel</a>
      <span class="mx-1">/</span>
      <span class="text-white">{course.title}</span>
    </nav>

    <div class="overflow-hidden rounded-xl border border-border">
      <div class="relative h-[180px] w-full overflow-hidden bg-surface-2 sm:h-[200px]">
        {course.cover_image ? (
          <img
            src={course.cover_image.startsWith('http') ? course.cover_image : `/courses/${course.cover_image}`}
            alt=""
            class="h-full w-full object-cover"
            width="1200"
            height="200"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-muted">
            <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent" aria-hidden="true" />
        <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5">
          <h1 class="text-xl font-semibold tracking-tight text-white drop-shadow sm:text-2xl">{course.title}</h1>
          {course.description && (
            <p class="mt-1 max-w-2xl text-sm text-white/90 drop-shadow">{course.description}</p>
          )}
        </div>
      </div>
      <div class="border-t border-border bg-surface px-4 py-3 sm:px-5">
        <p class="text-xs text-muted">{completedLessons} de {totalLessons} clases completadas</p>
        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-surface-2">
          <div
            class="h-full rounded-full bg-lime transition-all duration-300"
            style={`width: ${totalLessons ? (completedLessons / totalLessons) * 100 : 0}%`}
          />
        </div>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-surface p-4 sm:p-5">
      <h2 class="text-sm font-semibold text-white">Clases</h2>
      {lessons && lessons.length > 0 ? (
        <ul class="mt-4 space-y-2">
          {lessonItems.map((lesson) => {
            const completed = lesson.completed;
            const isUpcoming = !isOnDemand && lesson.scheduled_at ? new Date(lesson.scheduled_at).getTime() > now : false;
            const canOpen = isAdmin || lesson.available;
            const href = isAdmin ? `/admin/courses/${course.id}/lessons/${lesson.id}/edit` : (canOpen ? `/courses/${resolvedCourseSlug}/lessons/${lesson.id}` : '#');
            return (
              <li>
                {canOpen ? (
                  <a
                    href={href}
                    class={`flex items-center gap-3 rounded-lg border px-4 py-3 transition ${
                      completed
                        ? 'border-lime/40 bg-lime/10 hover:bg-lime/15'
                        : 'border-border bg-surface-2/60 hover:border-lime/40 hover:bg-surface-2'
                    }`}
                  >
                    <span class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-full border ${completed ? 'border-lime/40 bg-lime/15 text-lime' : 'border-border bg-surface text-muted'}`} aria-hidden="true">
                      {completed ? (
                        <svg class="h-4 w-4 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : isUpcoming ? (
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 7v5l3 2" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                      ) : (
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 6v12l9-6-9-6z" />
                        </svg>
                      )}
                    </span>
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-sm font-medium text-white">{lesson.title}</p>
                      {completed ? (
                        <p class="text-[11px] font-medium text-lime">Completada</p>
                      ) : (
                        <p class="text-[11px] text-muted">
                          {isUpcoming && lesson.scheduled_at
                            ? `${formatDayAndDate(lesson.scheduled_at, userTimezone)} · ${formatTime(lesson.scheduled_at, userTimezone)}`
                            : isOnDemand && !lesson.hasContent
                              ? 'Próximamente'
                              : 'Por completar'}
                        </p>
                      )}
                    </div>
                  </a>
                ) : (
                  <div class="flex items-center gap-3 rounded-lg border border-border bg-surface-2/40 px-4 py-3 opacity-75">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-border bg-surface text-muted" aria-hidden="true">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                      </svg>
                    </span>
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-sm font-medium text-muted">{lesson.title}</p>
                      <p class="text-[11px] text-muted">Próximamente (grabación o PPT)</p>
                    </div>
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="mt-4 text-sm text-muted">Aún no hay clases en este curso.</p>
      )}
    </div>
  </section>
</DashboardLayout>
