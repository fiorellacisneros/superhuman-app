---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { avatarImagePath } from '../../lib/avatars';
import BadgeIcon from '../../components/BadgeIcon.astro';
import BadgeOutline from '../../components/BadgeOutline.astro';
import { formatDayAndDate, formatTime } from '../../lib/format-date';
import { isLessonCompleted } from '../../lib/lessons';
import { getPreviewContext } from '../../lib/preview';
import { ON_DEMAND_BADGE_CONDITION_TYPES } from '../../lib/badges';
import { badgeDisplayDescription, badgeDisplayName } from '../../lib/badge-display';
import { getPointsBreakdownByCourse, type CoursePointsBreakdown } from '../../lib/points-breakdown';
import PointsBreakdownListItem from '../../components/PointsBreakdownListItem.astro';
import { getBadgeEarnGuideRows } from '../../lib/badge-earn-guide';

const iconMap: Record<string, string> = {
  first_submission: 'first_submission',
  on_time: 'on_time',
  early_bird: 'early_bird',
  streak_3: 'streak_3',
  attendance_streak_3: 'attendance_streak_3',
  first_attendance: 'first_attendance',
  module_complete: 'module_complete',
  night_owl: 'night_owl',
  course_complete: 'course_complete',
  manual: 'manual',
};

const { isAuthenticated, userId, sessionClaims, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const { slug: courseSlug } = Astro.params as { slug: string };
if (!courseSlug) {
  return Astro.redirect('/dashboard');
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role, timezone').eq('id', userId).maybeSingle();
const roleFromClaims = (sessionClaims as { metadata?: { role?: string } } | null)?.metadata?.role;
const isAdmin = roleFromClaims === 'admin' || (userRow?.role as string) === 'admin';

let course: {
  id: string;
  slug: string | null;
  title: string;
  description: string | null;
  cover_image: string | null;
  expected_challenges_count?: number | null;
} | null = null;
const { data: bySlug } = await supabase
  .from('courses')
  .select('id, slug, title, description, cover_image, expected_challenges_count')
  .eq('slug', courseSlug)
  .maybeSingle();
if (bySlug) {
  course = bySlug as typeof course;
} else {
  const { data: byId } = await supabase
    .from('courses')
    .select('id, slug, title, description, cover_image, expected_challenges_count')
    .eq('id', courseSlug)
    .maybeSingle();
  course = byId as typeof course;
}
if (!course) {
  return Astro.redirect('/dashboard');
}
const resolvedCourseSlug = typeof course.slug === 'string' && course.slug.trim() ? course.slug.trim() : course.id;

const { preview } = getPreviewContext(Astro);
const isPreviewingThisCourse = isAdmin && preview;

let isOnDemand = false;
if (!isAdmin && !isPreviewingThisCourse) {
  const { data: enrollment } = await supabase
    .from('enrollments')
    .select('course_id, access_type')
    .eq('user_id', userId)
    .eq('course_id', course.id)
    .maybeSingle();
  if (!enrollment) {
    return Astro.redirect('/dashboard');
  }
  isOnDemand = (enrollment.access_type as string) === 'on_demand';
} else if (isPreviewingThisCourse) {
  // Admin previsualizando: tratar como cohort (no on_demand) para ver contenido programado
  isOnDemand = false;
}

// En preview mostramos vista estudiante, no la de admin
const showAdminView = isAdmin && !isPreviewingThisCourse;
/** Misma guía que el dashboard: en vivo = todas las filas; on-demand = solo tipos permitidos. */
const badgeEarnGuideRows = getBadgeEarnGuideRows(!isOnDemand);

const [{ data: modulesData }, { data: lessons }] = await Promise.all([
  supabase
    .from('course_modules')
    .select('id, title, order')
    .eq('course_id', course.id)
    .order('order', { ascending: true }),
  supabase
    .from('lessons')
    .select('id, title, order, scheduled_at, recording_url, ppt_url, module_id')
    .eq('course_id', course.id)
    .order('order', { ascending: true }),
]);
const modules = (modulesData ?? []) as { id: string; title: string; order: number }[];

// Desafíos y puntos por curso (total = retos previstos del curso; completados = al menos una entrega, como en el dashboard)
let courseChallengesCompleted = 0;
let courseChallengesTotal = 1;
let coursePoints = 0;

const { data: courseChallenges } = await supabase.from('challenges').select('id').eq('course_id', course.id);
const challengeIds = (courseChallenges ?? []).map((c) => (c as { id: string }).id);
const rawExpected = course.expected_challenges_count;
const expectedN = Number(rawExpected);
if (rawExpected != null && rawExpected !== '' && Number.isFinite(expectedN) && expectedN >= 0) {
  courseChallengesTotal = expectedN < 1 ? Math.max(challengeIds.length, 1) : expectedN;
} else {
  courseChallengesTotal = Math.max(challengeIds.length, 1);
}

if (challengeIds.length > 0) {
  const { data: mySubs } = await supabase
    .from('submissions')
    .select('challenge_id')
    .eq('user_id', userId)
    .in('challenge_id', challengeIds);
  courseChallengesCompleted = new Set((mySubs ?? []).map((s) => (s as { challenge_id: string }).challenge_id)).size;
}

const { data: courseRetosRows } = await supabase
  .from('challenges')
  .select('id, title, points_reward, deadline')
  .eq('course_id', course.id)
  .eq('is_active', true)
  .order('deadline', { ascending: true });
const courseRetos = (courseRetosRows ?? []) as {
  id: string;
  title: string | null;
  points_reward: number | null;
  deadline: string | null;
}[];

// Puntos específicos de este curso para el usuario actual
const { data: myCoursePointsRows } = await supabase
  .from('user_course_points')
  .select('points')
  .eq('user_id', userId)
  .eq('course_id', course.id);
coursePoints = (myCoursePointsRows ?? []).reduce((acc, row) => acc + ((row as { points: number | null }).points ?? 0), 0);

let coursePointsBreakdown: CoursePointsBreakdown[] = [];
if (!showAdminView) {
  coursePointsBreakdown = await getPointsBreakdownByCourse(supabase, userId, [course.id]);
}

const userTimezone = (userRow as { timezone?: string | null } | null)?.timezone ?? null;
const totalLessons = (lessons ?? []).length;
const now = Date.now();
const completedLessons = (lessons ?? []).filter((l) => {
  if (isOnDemand) {
    const hasContent = Boolean((l.recording_url && String(l.recording_url).trim()) || (l.ppt_url && String(l.ppt_url).trim()));
    return hasContent;
  }
  return isLessonCompleted(l.scheduled_at, now);
}).length;
const lessonItems = (lessons ?? []).map((lesson) => {
  const hasContent = Boolean((lesson.recording_url && String(lesson.recording_url).trim()) || (lesson.ppt_url && String(lesson.ppt_url).trim()));
  const completed = isOnDemand ? hasContent : isLessonCompleted(lesson.scheduled_at, now);
  const available = isOnDemand ? hasContent : true;
  return {
    ...lesson,
    completed,
    available,
    hasContent,
  };
});

// Agrupar clases por módulo: primero cada módulo en orden, luego las sin módulo
type LessonItem = typeof lessonItems[number];
const moduleIds = new Set(modules.map((m) => m.id));
const lessonsByModule: { moduleTitle: string; moduleId: string | null; lessons: LessonItem[] }[] = [];
for (const mod of modules) {
  const inModule = lessonItems.filter((l) => (l as LessonItem & { module_id?: string | null }).module_id === mod.id);
  if (inModule.length > 0) {
    lessonsByModule.push({ moduleTitle: mod.title, moduleId: mod.id, lessons: inModule });
  }
}
const noModule = lessonItems.filter((l) => {
  const mid = (l as LessonItem & { module_id?: string | null }).module_id;
  return !mid || !moduleIds.has(mid);
});
if (noModule.length > 0) {
  lessonsByModule.push({ moduleTitle: 'Sin módulo', moduleId: null, lessons: noModule });
}

// Próximas sesiones para la card del dashboard (solo preview; el desglose completo está en /clases)
const upcomingSessionsPreview = (lessons ?? [])
  .filter((l) => l.scheduled_at && new Date(l.scheduled_at).getTime() >= now)
  .sort((a, b) => new Date(a.scheduled_at!).getTime() - new Date(b.scheduled_at!).getTime())
  .slice(0, 5)
  .map((l) => ({ id: l.id, title: l.title, scheduled_at: l.scheduled_at! }));
const nextMonthLabel =
  upcomingSessionsPreview.length > 0
    ? (() => {
        const d = new Date(upcomingSessionsPreview[0].scheduled_at);
        const months = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
        return `${months[d.getMonth()]} de ${d.getFullYear()}`;
      })()
    : '';

// Ranking del curso: solo inscritos live (excluir on-demand) con sus puntos en este curso
let courseLeaderboard: { id: string; name: string; avatarId: string | null; points: number }[] = [];
const { data: enrollmentsData } = await supabase.from('enrollments').select('user_id, access_type').eq('course_id', course.id);
const enrolledUserIds = [...new Set(
  (enrollmentsData ?? [])
    .filter((r) => (r as { access_type?: string }).access_type !== 'on_demand')
    .map((r) => (r as { user_id: string }).user_id)
    .filter(Boolean)
)];
if (enrolledUserIds.length > 0) {
  const [{ data: pointsData }, { data: usersData }] = await Promise.all([
    supabase.from('user_course_points').select('user_id, points').eq('course_id', course.id).in('user_id', enrolledUserIds),
    supabase.from('users').select('id, display_name, avatar_id').in('id', enrolledUserIds),
  ]);
  const pointsByUser = new Map<string, number>();
  for (const row of pointsData ?? []) {
    const uid = (row as { user_id: string; points: number }).user_id;
    const pts = (row as { user_id: string; points: number }).points ?? 0;
    pointsByUser.set(uid, (pointsByUser.get(uid) ?? 0) + pts);
  }
  const usersRows = (usersData ?? []) as { id: string; display_name: string | null; avatar_id: string | null }[];
  courseLeaderboard = usersRows
    .map((u) => ({ id: u.id, name: u.display_name ?? 'Sin nombre', avatarId: u.avatar_id, points: pointsByUser.get(u.id) ?? 0 }))
    .sort((a, b) => b.points - a.points);
}

/** Estudiantes: solo top 5 con puntos. Admin (vista de gestión del curso): ranking completo. */
const courseLeaderboardDisplay = showAdminView
  ? courseLeaderboard
  : courseLeaderboard.filter((u) => u.points > 0).slice(0, 5);

const totalEnrolled = enrolledUserIds.length;
const totalPointsAll = courseLeaderboard.reduce((acc, u) => acc + u.points, 0);
const averagePoints = totalEnrolled ? Math.round(totalPointsAll / totalEnrolled) : 0;
const maxPoints = courseLeaderboard[0]?.points ?? 0;

// Badges: mismas insignias que en el dashboard (globales), para mostrar en contexto del curso
type CourseBadge = { id: string; name: string; description: string | null; condition_type: string | null; earned: boolean; earned_at: string | null; earnedCount: number };
let courseBadges: CourseBadge[] = [];
const [{ data: badgeRows }, { data: earnedRows }] = await Promise.all([
  supabase.from('badges').select('id, name, description, condition_type').order('name'),
  supabase.from('user_badges').select('badge_id, earned_at').eq('user_id', userId),
]);
const earnedSet = new Set((earnedRows ?? []).map((e) => (e as { badge_id: string }).badge_id));
const earnedAtMap = new Map((earnedRows ?? []).map((e) => [(e as { badge_id: string }).badge_id, (e as { earned_at: string }).earned_at]));
const earnedCountMap = new Map<string, number>();
for (const row of earnedRows ?? []) {
  const id = (row as { badge_id: string }).badge_id;
  earnedCountMap.set(id, (earnedCountMap.get(id) ?? 0) + 1);
}
const allCourseBadges = (badgeRows ?? []).map((b) => {
  const row = b as { id: string; name: string | null; description: string | null; condition_type: string | null };
  const ct = row.condition_type ?? null;
  return {
  id: row.id,
  name: badgeDisplayName(ct, row.name),
  description: badgeDisplayDescription(ct, row.description, row.name),
  condition_type: ct,
  earned: earnedSet.has(row.id),
  earned_at: earnedAtMap.get(row.id) ?? null,
  earnedCount: earnedCountMap.get(row.id) ?? 0,
};
});
courseBadges = isOnDemand
  ? allCourseBadges.filter((b) => b.condition_type && ON_DEMAND_BADGE_CONDITION_TYPES.includes(b.condition_type as 'first_submission' | 'early_bird' | 'module_complete' | 'course_complete'))
  : allCourseBadges;
---

<DashboardLayout role={showAdminView ? 'admin' : 'student'}>
  {isPreviewingThisCourse && (
    <div class="-mx-4 -mt-6 mb-6 flex flex-wrap items-center justify-between gap-2 bg-background/95 px-4 py-3 md:-mx-6 md:mb-8 md:gap-4 md:px-6">
      <span class="flex items-center gap-2 text-sm font-medium text-lime">
        <span aria-hidden="true">👁</span>
        Vista previa como estudiante · {course.title}
      </span>
      <a href="/dashboard?exitPreview=1" class="inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al dashboard de admin
      </a>
    </div>
  )}
  <section class="max-w-5xl space-y-6 xl:max-w-6xl">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <a href="/courses" class="hover:text-white">Mis cursos</a>
      <span class="mx-1">/</span>
      <span class="text-white">{course.title}</span>
    </nav>

    <!-- Dos columnas: izquierda = progreso + Sesiones|Retos; derecha = ranking + Insignias -->
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_280px] lg:items-start">
      <div class="min-w-0 space-y-6">
        <div class="overflow-hidden rounded-xl">
          <div class="group relative h-[180px] w-full overflow-hidden bg-surface-2 sm:h-[200px]">
            {course.cover_image ? (
              <img
                src={course.cover_image.startsWith('http') ? course.cover_image : `/courses/${course.cover_image}`}
                alt=""
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                width="1200"
                height="200"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-muted">
                <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent" aria-hidden="true" />
            <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5">
              <h1 class="text-xl font-semibold tracking-tight text-white drop-shadow sm:text-2xl">{course.title}</h1>
              {course.description && (
                <p class="mt-1 max-w-2xl text-sm text-white/90 drop-shadow">{course.description}</p>
              )}
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-4 bg-surface px-4 py-3 sm:px-5">
            <div class="min-w-0 flex-1">
              <p class="text-xs text-muted">{completedLessons} de {totalLessons} clases completadas</p>
              <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-surface-2">
                <div
                  class="h-full rounded-full bg-lime transition-all duration-300"
                  style={`width: ${totalLessons ? (completedLessons / totalLessons) * 100 : 0}%`}
                />
              </div>
            </div>
            <a
              href={`/courses/${resolvedCourseSlug}/clases`}
              class="inline-flex shrink-0 items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10"
            >
              Ver curso
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
        {showAdminView ? (
          <div class="space-y-3">
            <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
            <div class="flex min-w-0 flex-col rounded-xl bg-[#012EDC] p-3 sm:p-5">
              <dt class="font-manrope text-2xl font-semibold text-white">Alumnos inscritos</dt>
              <dd class="mt-6 font-manrope text-3xl font-semibold leading-none text-white sm:text-[40px]">
                {totalEnrolled}
              </dd>
              <p class="mt-2 text-xs text-[#D0D4FF]">Incluye alumnos activos en este curso.</p>
            </div>
            <div class="flex min-w-0 flex-col rounded-xl bg-[#F5B800] p-3 sm:p-5">
              <dt class="font-manrope text-2xl font-semibold text-[#1A1A1A]">Puntos del curso</dt>
              <dd class="mt-4 space-y-1.5 font-manrope text-base font-semibold leading-none text-[#1A1A1A] sm:text-lg">
                <p>Promedio: {averagePoints}</p>
                <p>Máximo: {maxPoints}</p>
              </dd>
              <p class="mt-2 text-xs text-[#4A3B00]">Basado en el ranking actual de este curso.</p>
            </div>
          </dl>
          </div>
        ) : (
          <div class="space-y-3">
            <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
              <div class="flex min-w-0 flex-col rounded-xl bg-[#012EDC] p-3 sm:p-5">
                <dt class="font-manrope text-2xl font-semibold text-white">Desafíos</dt>
                <dd class="mt-8 flex items-baseline gap-0.5">
                  <span class="font-manrope text-2xl font-semibold leading-none text-white sm:text-[48px]">{courseChallengesCompleted}</span>
                  <span class="font-manrope text-2xl font-semibold leading-none text-[#436AFE] sm:text-[48px]">/{courseChallengesTotal}</span>
                </dd>
              </div>
              <div class="flex min-w-0 flex-col rounded-xl bg-[#F5B800] p-3 sm:p-5">
                <div class="flex items-start justify-between gap-2">
                  <dt class="font-manrope text-2xl font-semibold text-[#1A1A1A]">Puntos</dt>
                  <button
                    type="button"
                    class="open-course-points-breakdown-trigger -mr-1 -mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-[#1A1A1A]/55 transition hover:bg-black/10 hover:text-[#1A1A1A]"
                    aria-label="Ver desglose de puntos"
                    title="Ver desglose de puntos"
                    aria-haspopup="dialog"
                    aria-controls="course-points-breakdown-modal"
                  >
                    <i class="bi bi-eye text-[1.125rem] leading-none" aria-hidden="true"></i>
                  </button>
                </div>
                <dd class="mt-8 font-manrope text-2xl font-semibold leading-none text-[#1A1A1A] sm:text-[48px]">{coursePoints}</dd>
              </div>
            </dl>
          </div>
        )}

        {!showAdminView ? (
          <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:items-start">
            <div class="flex h-[350px] min-w-0 flex-col overflow-hidden rounded-xl p-4 sm:p-5" style="background-color: #D6D6D6;">
              <div class="flex shrink-0 items-start justify-between gap-2">
                <div>
                  <h2 class="font-manrope text-xl font-semibold text-[#1A1A1A] sm:text-2xl">Sesiones</h2>
                  {nextMonthLabel && <p class="mt-0.5 text-xs text-[#404040]">{nextMonthLabel}</p>}
                </div>
                <a
                  href={`/courses/${resolvedCourseSlug}/clases`}
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-[#012EDC] transition hover:bg-[#012EDC]/15"
                  title="Ver todas las clases"
                  aria-label="Ver todas las clases"
                >
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
              {upcomingSessionsPreview.length > 0 ? (
                <ul class="mt-3 h-[260px] shrink-0 space-y-2 overflow-y-auto pt-1 pb-4 pr-1" style="scrollbar-color: #404040 transparent;">
                  {upcomingSessionsPreview.map((s, idx) => {
                    const isNext = idx === 0;
                    return (
                    <li>
                      <a
                        href={`/courses/${resolvedCourseSlug}/lessons/${s.id}`}
                        class={`block rounded-lg px-3 py-2.5 transition hover:opacity-90 ${isNext ? 'border-l-4 border-l-[#012EDC]' : ''}`}
                        style="background-color: #FFFFFF;"
                      >
                        <p class="text-[11px] font-medium text-[#404040]">
                          {formatDayAndDate(s.scheduled_at, userTimezone)} {formatTime(s.scheduled_at, userTimezone)}
                        </p>
                        <p class="mt-0.5 text-sm font-medium text-[#1A1A1A]">{s.title}</p>
                        <p class="mt-0.5 text-xs text-[#737373]">{course.title}</p>
                      </a>
                    </li>
                    );
                  })}
                </ul>
              ) : (
                <p class="mt-3 text-sm text-[#404040]">No hay sesiones próximas.</p>
              )}
            </div>

            <div class="flex h-[350px] min-w-0 flex-col overflow-hidden rounded-xl bg-background p-4 sm:p-5">
              <div class="flex shrink-0 items-start justify-between gap-2">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-1">
                    <h2 class="font-manrope text-xl font-semibold text-white sm:text-2xl">Retos</h2>
                    <button
                      type="button"
                      class="open-course-retos-info-trigger inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-muted transition hover:bg-white/10 hover:text-white"
                      aria-label="Qué son los retos"
                      title="Qué son los retos"
                      aria-haspopup="dialog"
                      aria-controls="course-retos-info-modal"
                    >
                      <i class="bi bi-info-circle text-base leading-none" aria-hidden="true"></i>
                    </button>
                  </div>
                  <p class="mt-0.5 text-xs text-muted">Desafíos activos de este curso.</p>
                </div>
                <a
                  href="/challenges"
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-lime transition hover:bg-white/10"
                  title="Ver todos los retos"
                  aria-label="Ver todos los retos"
                >
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
              {courseRetos.length > 0 ? (
                <ul class="mt-3 h-[260px] shrink-0 space-y-2 overflow-y-auto pt-1 pb-4 pr-1" style="scrollbar-color: #404040 transparent;">
                  {courseRetos.map((r) => (
                    <li>
                      <a
                        href="/challenges"
                        class="block rounded-lg border border-border bg-surface-2 px-3 py-2.5 transition hover:bg-white/5"
                      >
                        <p class="line-clamp-2 text-sm font-medium text-white">{r.title ?? 'Reto'}</p>
                        <p class="mt-0.5 text-[11px] font-medium text-muted">
                          {(r.points_reward ?? 0) > 0 ? `${r.points_reward} pts` : 'Sin puntos'}
                        </p>
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="mt-3 text-sm text-muted">No hay retos activos en este curso.</p>
              )}
            </div>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:items-start">
            <div class="flex h-[350px] min-w-0 flex-col overflow-hidden rounded-xl p-4 sm:p-5" style="background-color: #D6D6D6;">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <h2 class="font-manrope text-xl font-semibold text-[#1A1A1A] sm:text-2xl">Sesiones</h2>
                  {nextMonthLabel && <p class="mt-0.5 text-xs text-[#404040]">{nextMonthLabel}</p>}
                </div>
                <a
                  href={`/courses/${resolvedCourseSlug}/clases`}
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-[#012EDC] transition hover:bg-[#012EDC]/15"
                  title="Ver todas las clases"
                  aria-label="Ver todas las clases"
                >
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
              {upcomingSessionsPreview.length > 0 ? (
                <ul class="mt-3 h-[260px] space-y-2 overflow-y-auto pt-1 pb-4 pr-1" style="scrollbar-color: #404040 transparent;">
                  {upcomingSessionsPreview.map((s, idx) => {
                    const isNext = idx === 0;
                    return (
                    <li>
                      <a
                        href={`/courses/${resolvedCourseSlug}/lessons/${s.id}`}
                        class={`block rounded-lg px-3 py-2.5 transition hover:opacity-90 ${isNext ? 'border-l-4 border-l-[#012EDC]' : ''}`}
                        style="background-color: #FFFFFF;"
                      >
                        <p class="text-[11px] font-medium text-[#404040]">
                          {formatDayAndDate(s.scheduled_at, userTimezone)} {formatTime(s.scheduled_at, userTimezone)}
                        </p>
                        <p class="mt-0.5 text-sm font-medium text-[#1A1A1A]">{s.title}</p>
                        <p class="mt-0.5 text-xs text-[#737373]">{course.title}</p>
                      </a>
                    </li>
                    );
                  })}
                </ul>
              ) : (
                <p class="mt-3 text-sm text-[#404040]">No hay sesiones próximas.</p>
              )}
            </div>

            <div class="flex h-[350px] min-w-0 flex-col overflow-hidden rounded-xl bg-background p-4 sm:p-5">
              <div class="flex shrink-0 items-start justify-between gap-2">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-1">
                    <h2 class="font-manrope text-xl font-semibold text-white sm:text-2xl">Retos</h2>
                    <button
                      type="button"
                      class="open-course-retos-info-trigger inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-muted transition hover:bg-white/10 hover:text-white"
                      aria-label="Qué son los retos"
                      title="Qué son los retos"
                      aria-haspopup="dialog"
                      aria-controls="course-retos-info-modal"
                    >
                      <i class="bi bi-info-circle text-base leading-none" aria-hidden="true"></i>
                    </button>
                  </div>
                  <p class="mt-0.5 text-xs text-muted">Desafíos activos de este curso.</p>
                </div>
                <a
                  href="/admin/challenges"
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-lime transition hover:bg-white/10"
                  title="Gestionar retos"
                  aria-label="Gestionar retos"
                >
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
              {courseRetos.length > 0 ? (
                <ul class="mt-3 h-[260px] shrink-0 space-y-2 overflow-y-auto pt-1 pb-4 pr-1" style="scrollbar-color: #404040 transparent;">
                  {courseRetos.map((r) => (
                    <li>
                      <a
                        href={`/admin/challenges/${r.id}/edit`}
                        class="block rounded-lg border border-border bg-surface-2 px-3 py-2.5 transition hover:bg-white/5"
                      >
                        <p class="line-clamp-2 text-sm font-medium text-white">{r.title ?? 'Reto'}</p>
                        <p class="mt-0.5 text-[11px] font-medium text-muted">
                          {(r.points_reward ?? 0) > 0 ? `${r.points_reward} pts` : 'Sin puntos'}
                        </p>
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="mt-3 text-sm text-muted">No hay retos activos en este curso.</p>
              )}
            </div>
          </div>
        )}
      </div>

      <aside class="flex min-w-0 flex-col gap-6">
        <div class="rounded-xl bg-surface p-4">
          <h2 class="font-manrope text-xl font-semibold text-white sm:text-2xl">Ranking {course.title}</h2>
          <p class="mt-0.5 text-[10px] text-muted">Puntos de este curso.</p>
          {courseLeaderboardDisplay.length > 0 ? (
            <ul
              class={`mt-3 space-y-1.5 ${showAdminView ? 'max-h-[min(70vh,520px)] overflow-y-auto pr-1' : ''}`}
              style={showAdminView ? 'scrollbar-color: #404040 transparent;' : undefined}
            >
              {courseLeaderboardDisplay.map((u, i) => (
                <li class="flex items-center gap-2 rounded-lg bg-background px-2 py-1.5">
                  <span class={`w-5 shrink-0 text-[10px] font-semibold ${i < 5 ? 'text-lime' : 'text-muted'}`}>{i + 1}º</span>
                  <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full bg-surface-2">
                    <img src={avatarImagePath(u.avatarId) ?? '/avatars/avatar-01.png'} alt="" class="h-full w-full object-cover" width="32" height="32" />
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-[11px] font-medium text-white" title={u.name}>{u.name}</p>
                    <p class="text-[10px] font-semibold text-lime">{u.points} pts</p>
                  </div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-3 text-xs text-muted">Sin puntos aún en este curso.</p>
          )}
        </div>

        {!showAdminView && courseBadges.length > 0 && (
          <div class="relative flex max-h-[min(70vh,520px)] min-h-0 w-full min-w-0 flex-col rounded-[24px] bg-background p-4 sm:p-5">
            <div class="mb-3 flex flex-wrap items-start justify-between gap-1">
              <div class="min-w-0 flex-1">
                <h2 class="font-manrope text-xl font-semibold text-white sm:text-2xl">Insignias</h2>
                <p class="mt-0.5 text-xs text-muted">{isOnDemand ? 'Insignias que puedes desbloquear (sin puntos).' : 'Completa lecciones y desafíos.'}</p>
              </div>
              <button
                type="button"
                class="open-course-insignias-info-trigger inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-transparent text-muted transition hover:bg-surface-2 hover:text-lime"
                aria-label="Cómo ganar insignias"
                title="Cómo ganar insignias"
                aria-haspopup="dialog"
                aria-controls="course-insignias-info-modal"
              >
                <i class="bi bi-info-circle text-[1.125rem] leading-none" aria-hidden="true"></i>
              </button>
            </div>
            <ul class="mt-4 grid min-h-0 flex-1 grid-cols-3 gap-x-2 gap-y-4 overflow-y-auto py-2 pr-1" style="scrollbar-color: #404040 transparent;">
              {courseBadges.map((b) => (
                <li class="group flex min-w-0 flex-col items-center rounded-xl transition-colors">
                  <BadgeOutline id={b.id} variant={b.earned ? 'earned' : 'unearned'} count={b.earnedCount > 0 ? b.earnedCount : undefined}>
                    <BadgeIcon
                      icon={iconMap[b.condition_type ?? ''] ?? 'manual'}
                      class={`transition-transform duration-200 group-hover:scale-110 ${b.earned ? 'text-[#012EDC]' : 'text-[#595959]'}`}
                    />
                  </BadgeOutline>
                  <p class="mt-2 min-w-0 max-w-full truncate text-center font-work-sans text-[10px] font-normal leading-tight text-white sm:text-xs" title={b.name}>{b.name}</p>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>

    {!showAdminView && (
        <div
          id="course-points-breakdown-modal"
          class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
          role="dialog"
          aria-modal="true"
          aria-labelledby="course-points-breakdown-modal-title"
        >
          <div id="course-points-breakdown-modal-backdrop" class="absolute inset-0" tabindex="-1" aria-hidden="true"></div>
          <div class="relative z-10 flex max-h-[min(85vh,620px)] w-full max-w-lg flex-col rounded-xl border border-transparent bg-surface shadow-xl">
            <div class="flex shrink-0 items-center justify-between border-b border-white/10 px-5 py-4">
              <h2 id="course-points-breakdown-modal-title" class="text-base font-semibold text-white">
                Desglose de puntos · {course.title}
              </h2>
              <button
                type="button"
                id="close-course-points-breakdown-modal"
                class="rounded-lg p-1.5 text-muted transition hover:bg-surface-2 hover:text-white"
                aria-label="Cerrar"
              >
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <div class="min-h-0 flex-1 overflow-y-auto px-5 py-4">
              <p class="text-xs text-muted">Cómo suman tus puntos en este curso.</p>
              {coursePointsBreakdown.length > 0 ? (
                <div class="mt-4 space-y-6">
                  {coursePointsBreakdown.map((c) => {
                    const sumFromItems = c.items.reduce((a, i) => a + i.pts, 0);
                    return (
                      <div class="rounded-lg border border-transparent bg-surface-2/40 p-4">
                        <div class="flex justify-end">
                          <span class="text-sm font-semibold text-lime">{c.totalStored} pts totales</span>
                        </div>
                        {c.items.length > 0 ? (
                          <ul class="mt-3 space-y-1.5">
                            {c.items.map((item) => (
                              <PointsBreakdownListItem
                                label={item.label}
                                detail={item.detail}
                                pts={item.pts}
                                infoOnly={item.infoOnly}
                              />
                            ))}
                            {sumFromItems !== c.totalStored && (
                              <li class="mt-2 border-t border-transparent pt-2 text-xs text-amber-400">
                                Suma del desglose: {sumFromItems} pts (en BD: {c.totalStored})
                              </li>
                            )}
                          </ul>
                        ) : (
                          <p class="mt-2 text-sm text-muted">
                            Aún no hay asistencias ni entregas registradas en este curso.
                          </p>
                        )}
                      </div>
                    );
                  })}
                </div>
              ) : (
                <p class="mt-3 text-sm text-muted">
                  Aún no hay puntos registrados. Asiste a clases, entrega retos o participa en Kahoot para sumar.
                </p>
              )}
            </div>
          </div>
        </div>
    )}

        <div
          id="course-retos-info-modal"
          class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
          role="dialog"
          aria-modal="true"
          aria-labelledby="course-retos-info-modal-title"
        >
          <div id="course-retos-info-modal-backdrop" class="absolute inset-0" tabindex="-1" aria-hidden="true"></div>
          <div class="relative z-10 flex max-h-[min(85vh,520px)] w-full max-w-lg flex-col rounded-xl border border-transparent bg-surface shadow-xl">
            <div class="flex shrink-0 items-center justify-between border-b border-white/10 px-5 py-4">
              <h2 id="course-retos-info-modal-title" class="text-base font-semibold text-white">Sobre los retos</h2>
              <button
                type="button"
                id="close-course-retos-info-modal"
                class="rounded-lg p-1.5 text-muted transition hover:bg-surface-2 hover:text-white"
                aria-label="Cerrar"
              >
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-5 py-4 text-sm text-muted">
              <p>
                Los <strong class="font-medium text-white">retos</strong> son desafíos prácticos de este curso: entregas con enlace o archivo que revisa el equipo. Al aprobar una entrega sumas puntos según la rúbrica del reto (y a tiempo o fuera de plazo).
              </p>
              <p>
                Desde la lista puedes ir a <a href="/challenges" class="font-medium text-lime underline-offset-2 hover:underline">Retos</a> para ver el detalle, plazos y enviar o actualizar tu entrega.
              </p>
              <p class="text-xs">
                La tarjeta <strong class="text-white/90">Desafíos</strong> arriba muestra cuántos retos llevas completados respecto al total previsto del curso.
              </p>
            </div>
          </div>
        </div>

        <div
          id="course-insignias-info-modal"
          class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
          role="dialog"
          aria-modal="true"
          aria-labelledby="course-insignias-info-modal-title"
        >
          <div id="course-insignias-info-modal-backdrop" class="absolute inset-0" tabindex="-1" aria-hidden="true"></div>
          <div class="relative z-10 flex max-h-[min(85vh,560px)] w-full max-w-lg flex-col rounded-xl border border-transparent bg-surface shadow-xl">
            <div class="flex shrink-0 items-center justify-between border-b border-white/10 px-5 py-4">
              <h2 id="course-insignias-info-modal-title" class="text-base font-semibold text-white">Cómo ganar insignias</h2>
              <button
                type="button"
                id="close-course-insignias-info-modal"
                class="rounded-lg p-1.5 text-muted transition hover:bg-surface-2 hover:text-white"
                aria-label="Cerrar"
              >
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <div class="min-h-0 flex-1 overflow-y-auto px-5 py-4">
              <p class="text-xs text-muted">
                {!isOnDemand
                  ? 'Estas reglas aplican a tus cursos y a los retos vinculados. Tus Jedis también pueden otorgar insignias manuales.'
                  : 'En cursos on-demand solo aplican las insignias ligadas a entregas y progreso del curso (sin asistencia en vivo).'}
              </p>
              <ul class="mt-4 space-y-4">
                {badgeEarnGuideRows.map((row) => (
                  <li class="rounded-lg bg-surface-2/50 px-3 py-2.5">
                    <p class="text-sm font-medium text-white">{row.title}</p>
                    <p class="mt-1 text-xs text-muted">{row.body}</p>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <script is:inline>
          document.addEventListener('DOMContentLoaded', () => {
            function syncBodyScroll() {
              const a = document.getElementById('course-points-breakdown-modal');
              const b = document.getElementById('course-retos-info-modal');
              const c = document.getElementById('course-insignias-info-modal');
              const anyOpen = [a, b, c].some((m) => m && !m.classList.contains('hidden'));
              document.body.style.overflow = anyOpen ? 'hidden' : '';
            }
            function wireModal(modalId, openSelector, closeBtnId, backdropId) {
              const modal = document.getElementById(modalId);
              const closeBtn = document.getElementById(closeBtnId);
              const backdrop = document.getElementById(backdropId);
              function openModal() {
                if (!modal) return;
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                syncBodyScroll();
              }
              function closeModal() {
                if (!modal) return;
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                syncBodyScroll();
              }
              document.querySelectorAll(openSelector).forEach((el) => {
                el.addEventListener('click', openModal);
              });
              closeBtn?.addEventListener('click', closeModal);
              backdrop?.addEventListener('click', closeModal);
              return { closeModal, modal };
            }
            const pts = wireModal(
              'course-points-breakdown-modal',
              '.open-course-points-breakdown-trigger',
              'close-course-points-breakdown-modal',
              'course-points-breakdown-modal-backdrop',
            );
            const retos = wireModal(
              'course-retos-info-modal',
              '.open-course-retos-info-trigger',
              'close-course-retos-info-modal',
              'course-retos-info-modal-backdrop',
            );
            const insignias = wireModal(
              'course-insignias-info-modal',
              '.open-course-insignias-info-trigger',
              'close-course-insignias-info-modal',
              'course-insignias-info-modal-backdrop',
            );
            document.addEventListener('keydown', (e) => {
              if (e.key !== 'Escape') return;
              if (pts.modal && !pts.modal.classList.contains('hidden')) pts.closeModal();
              else if (retos.modal && !retos.modal.classList.contains('hidden')) retos.closeModal();
              else if (insignias.modal && !insignias.modal.classList.contains('hidden')) insignias.closeModal();
            });
          });
        </script>
  </section>
</DashboardLayout>
