---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import { avatarImagePath } from '../../lib/avatars';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const role = (userRow?.role as string) ?? 'student';

// Cursos inscritos (para selector y validación)
const { data: enrollmentRows } = await supabase
  .from('enrollments')
  .select('course_id, courses(id, title)')
  .eq('user_id', userId);
const enrolledCourses = (enrollmentRows ?? [])
  .map((r) => {
    const c = (r as { courses?: { id: string; title: string | null } | null }).courses;
    return c?.id ? { id: c.id, title: c.title ?? 'Curso' } : null;
  })
  .filter((c): c is { id: string; title: string } => Boolean(c));
const enrolledCourseIds = enrolledCourses.map((c) => c.id);

// Curso seleccionado: query param o el primero si solo hay uno
const courseParam = Astro.url.searchParams.get('course');
const selectedCourseId =
  courseParam && enrolledCourseIds.includes(courseParam)
    ? courseParam
    : enrolledCourses[0]?.id ?? null;
const selectedCourse = enrolledCourses.find((c) => c.id === selectedCourseId);

// Ranking por curso: solo estudiantes del curso seleccionado, puntos de ese curso
let studentRows: { id: string; display_name: string | null; avatar_id: string | null }[] | null = [];
let pointsByUser = new Map<string, number>();
if (selectedCourseId) {
  const { data: cohortUserIds } = await supabase
    .from('enrollments')
    .select('user_id')
    .eq('course_id', selectedCourseId);
  const uniqueIds = [...new Set((cohortUserIds ?? []).map((r) => r.user_id as string))];
  if (uniqueIds.length > 0) {
    const [userDataRes, pointsRes] = await Promise.all([
      supabase.from('users').select('id, display_name, avatar_id').in('id', uniqueIds).eq('role', 'student'),
      supabase.from('user_course_points').select('user_id, points').eq('course_id', selectedCourseId).in('user_id', uniqueIds),
    ]);
    studentRows = userDataRes.data;
    for (const row of pointsRes.data ?? []) {
      pointsByUser.set(row.user_id as string, row.points ?? 0);
    }
  }
}

type LeaderboardRow = { id: string; display_name: string; avatar_id: string | null; points: number; badgesCount: number };
const studentIds = (studentRows ?? []).map((u) => u.id);
const badgeCountByUser = new Map<string, number>();
if (studentIds.length > 0) {
  const { data: badgeRows } = await supabase
    .from('user_badges')
    .select('user_id')
    .in('user_id', studentIds);
  for (const row of badgeRows ?? []) {
    const id = row.user_id as string;
    badgeCountByUser.set(id, (badgeCountByUser.get(id) ?? 0) + 1);
  }
}

const rows: LeaderboardRow[] = (studentRows ?? [])
  .map((u) => ({
    id: u.id,
    display_name: u.display_name ?? 'Estudiante',
    avatar_id: u.avatar_id ?? null,
    points: pointsByUser.get(u.id) ?? 0,
    badgesCount: badgeCountByUser.get(u.id) ?? 0,
  }))
  .sort((a, b) => b.points - a.points);

const topScore = Math.max(1, ...rows.map((r) => r.points));
---

<DashboardLayout role={role === 'admin' ? 'admin' : 'student'}>
  <section class="space-y-6">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <span class="text-white">Ranking</span>
    </nav>

    <header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight text-white">Ranking</h1>
        <p class="mt-1 text-sm text-muted">
          {selectedCourse
            ? `Puntos del cohort "${selectedCourse.title}" ordenados de mayor a menor.`
            : 'Puntos del cohort ordenados de mayor a menor.'}
        </p>
      </div>
      {enrolledCourses.length > 1 && (
        <form method="get" action="/leaderboard" class="relative w-full sm:w-56">
          <select
            name="course"
            class="w-full cursor-pointer appearance-none rounded-lg border border-transparent bg-surface-2 py-2.5 pl-3 pr-10 text-sm text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            onchange="this.form.submit()"
          >
            {enrolledCourses.map((c) => (
              <option value={c.id} selected={c.id === selectedCourseId}>
                {c.title}
              </option>
            ))}
          </select>
          <i class="bi bi-chevron-down pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
        </form>
      )}
    </header>

    {rows.length > 0 ? (
      <div class="overflow-hidden rounded-xl border border-transparent bg-background">
        <ul class="divide-y divide-white/5">
          {rows.map((r, i) => {
            const pct = topScore ? (r.points / topScore) * 100 : 0;
            const isCurrentUser = r.id === userId;
            return (
              <li class={`flex items-center gap-4 px-4 py-3 ${isCurrentUser ? 'border-l-4 border-l-yellow bg-yellow/10' : 'bg-background'}`}>
                <span class="w-8 shrink-0 text-sm font-semibold text-muted">{i + 1}</span>
                <div class="h-10 w-10 shrink-0 overflow-hidden rounded-full border border-transparent bg-surface-2">
                  {avatarImagePath(r.avatar_id) ? (
                    <img src={avatarImagePath(r.avatar_id)!} alt="" class="h-full w-full object-cover" width="40" height="40" />
                  ) : (
                    <span class="flex h-full w-full items-center justify-center text-sm font-semibold text-muted">{(r.display_name || 'E').charAt(0).toUpperCase()}</span>
                  )}
                </div>
                <div class="min-w-0 flex-1">
                  <p class="font-medium text-white">{r.display_name}</p>
                  <p class="text-xs text-muted">{r.badgesCount} insignias</p>
                </div>
                <div class="w-24 shrink-0 text-right">
                  <span class={`font-semibold ${isCurrentUser ? 'text-yellow' : 'text-white'}`}>{r.points} pts</span>
                </div>
                <div class="hidden w-32 shrink-0 sm:block">
                  <div class="h-2 w-full overflow-hidden rounded-full bg-white/10">
                    <div
                      class={`h-full rounded-full transition-all ${isCurrentUser ? 'bg-yellow' : 'bg-white/25'}`}
                      style={`width: ${pct}%`}
                    />
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-transparent bg-background p-8 text-center">
        <p class="text-sm font-medium text-white">
          {enrolledCourseIds.length === 0
            ? 'No estás inscrito en ningún curso.'
            : 'Aún no hay estudiantes en el ranking.'}
        </p>
        <p class="mt-1 text-sm text-muted">
          {enrolledCourseIds.length === 0
            ? 'El ranking muestra a los estudiantes de tus cursos. Inscríbete en un curso para verlo.'
            : 'Los puntos aparecerán cuando alguien complete retos o asista a clases.'}
        </p>
        <a href="/dashboard" class="mt-4 inline-flex items-center gap-1.5 rounded-[40px] border border-white bg-transparent px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al dashboard
        </a>
      </div>
    )}
  </section>
</DashboardLayout>
