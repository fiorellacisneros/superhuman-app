---
import '../../styles/global.css';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseServiceRoleClient } from '../../lib/supabase';
import {
  getPreviewContext,
  setPreviewCookie,
  withPreviewParams,
} from '../../lib/preview';

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase.from('users').select('role').eq('id', userId).maybeSingle();
const dbRole = (userRow?.role as string) ?? 'student';
const { preview, previewAs } = getPreviewContext(Astro);

if (dbRole === 'admin' && preview) {
  setPreviewCookie(Astro, previewAs);
}

/** Panel de gestión (admin real). Si eres admin con vista previa de estudiante, ves la misma UI que un alumno. */
const isAdminView = dbRole === 'admin' && !preview;

if (dbRole === 'admin' && preview && previewAs === 'on_demand') {
  return Astro.redirect(withPreviewParams('/sesion-grupal', true, 'on_demand'));
}

if (!isAdminView) {
  const { data: enrollments } = await supabase
    .from('enrollments')
    .select('access_type')
    .eq('user_id', userId);
  const hasOnlyOnDemand = (enrollments ?? []).length > 0 && (enrollments ?? []).every((e) => (e.access_type as string) === 'on_demand');
  if (hasOnlyOnDemand) {
    return Astro.redirect(withPreviewParams('/sesion-grupal', dbRole === 'admin' && preview, previewAs));
  }
}

type Course1to1 = {
  id: string;
  title: string;
  slug: string;
  ends_at: string | null;
  calendly_link_1to1: string | null;
  bookingCount: number;
  bookings: { id: string; scheduled_at: string; status: string; display_name?: string | null }[];
  liveStudents?: { id: string; display_name: string }[];
};

const courses1to1: Course1to1[] = [];
let onDemandStudents: { id: string; display_name: string; asistenciasCount: number }[] = [];
type SesionGrupalItem = { id: number; title: string | null; link_url: string; fecha_label: string | null; order_index: number };
let sesionesGrupalesList: SesionGrupalItem[] = [];

if (isAdminView) {
  const { data: allCourses } = await supabase
    .from('courses')
    .select('id, title, slug, ends_at, calendly_link_1to1')
    .not('calendly_link_1to1', 'is', null);
  const today = new Date().toISOString().slice(0, 10);
  for (const c of allCourses ?? []) {
    const endsAt = c.ends_at ? String(c.ends_at).slice(0, 10) : null;
    if (endsAt && endsAt < today) continue;
    const { count } = await supabase
      .from('one_on_one_bookings')
      .select('*', { count: 'exact', head: true })
      .eq('course_id', c.id)
      .in('status', ['scheduled', 'completed']);
    const { data: bookings } = await supabase
      .from('one_on_one_bookings')
      .select('id, scheduled_at, status, users(display_name)')
      .eq('course_id', c.id)
      .order('scheduled_at', { ascending: false })
      .limit(10);
    const { data: liveEnrollments } = await supabase
      .from('enrollments')
      .select('user_id, users(id, display_name)')
      .eq('course_id', c.id)
      // NULL o distinto de on_demand = cohort/live (neq solo no incluye NULL en SQL)
      .or('access_type.is.null,access_type.neq.on_demand');
    const liveStudents = (liveEnrollments ?? []).map((e) => {
      const u = (e as { users?: { id: string; display_name: string | null } | null }).users;
      return { id: u?.id ?? (e as { user_id: string }).user_id, display_name: u?.display_name ?? 'Sin nombre' };
    });
    courses1to1.push({
      id: c.id,
      title: (c.title as string) ?? 'Curso',
      slug: (c.slug as string) ?? c.id,
      ends_at: c.ends_at as string | null,
      calendly_link_1to1: c.calendly_link_1to1 as string | null,
      bookingCount: count ?? 0,
      bookings: (bookings ?? []).map((b) => {
        const u = (b as { users?: { display_name?: string | null } | null }).users;
        return { id: b.id, scheduled_at: b.scheduled_at as string, status: b.status as string, display_name: u?.display_name ?? null };
      }),
      liveStudents,
    });
  }

  const { data: allEnrollments } = await supabase.from('enrollments').select('user_id, access_type');
  const userIdsWithLive = new Set((allEnrollments ?? []).filter((e) => (e.access_type as string) !== 'on_demand').map((e) => e.user_id as string));
  const onDemandOnlyUserIds = [...new Set((allEnrollments ?? []).map((e) => e.user_id as string).filter(Boolean))].filter((id) => !userIdsWithLive.has(id));
  if (onDemandOnlyUserIds.length > 0) {
    const { data: studentRows } = await supabase.from('users').select('id, display_name').in('id', onDemandOnlyUserIds).eq('role', 'student');
    const countByUser = new Map<string, number>();
    try {
      const { data: asistenciasRows } = await supabase.from('sesion_grupal_asistencias').select('user_id').in('user_id', onDemandOnlyUserIds);
      for (const r of asistenciasRows ?? []) {
        const uid = r.user_id as string;
        countByUser.set(uid, (countByUser.get(uid) ?? 0) + 1);
      }
    } catch {
      // Tabla puede no existir si no se corrió la migración
    }
    onDemandStudents = (studentRows ?? []).map((u) => ({
      id: u.id,
      display_name: (u.display_name as string) ?? 'Sin nombre',
      asistenciasCount: countByUser.get(u.id) ?? 0,
    }));
  }
  try {
    const { data: sesionesRows } = await supabase
      .from('sesion_grupal_sesiones')
      .select('id, title, link_url, fecha_label, order_index')
      .order('order_index', { ascending: true });
    sesionesGrupalesList = (sesionesRows ?? []).map((s) => ({
      id: s.id as number,
      title: (s.title as string | null) ?? null,
      link_url: (s.link_url as string) ?? '',
      fecha_label: (s.fecha_label as string | null) ?? null,
      order_index: (s.order_index as number) ?? 0,
    }));
  } catch {
    // Tabla sesion_grupal_sesiones puede no existir
  }
} else {
  onDemandStudents = [];
  const { data: enrollments } = await supabase
    .from('enrollments')
    .select('course_id')
    .eq('user_id', userId)
    .or('access_type.is.null,access_type.neq.on_demand');
  const liveCourseIds = (enrollments ?? []).map((r) => (r as { course_id: string }).course_id).filter(Boolean);
  if (liveCourseIds.length > 0) {
    const { data: courseRows } = await supabase
      .from('courses')
      .select('id, title, slug, ends_at, calendly_link_1to1')
      .in('id', liveCourseIds);
    for (const c of courseRows ?? []) {
      const { count } = await supabase
        .from('one_on_one_bookings')
        .select('*', { count: 'exact', head: true })
        .eq('user_id', userId)
        .eq('course_id', c.id)
        .in('status', ['scheduled', 'completed']);
      const { data: bookings } = await supabase
        .from('one_on_one_bookings')
        .select('id, scheduled_at, status')
        .eq('user_id', userId)
        .eq('course_id', c.id)
        .order('scheduled_at', { ascending: false })
        .limit(10);
      courses1to1.push({
        id: c.id,
        title: (c.title as string) ?? 'Curso',
        slug: (c.slug as string) ?? c.id,
        ends_at: c.ends_at as string | null,
        calendly_link_1to1: c.calendly_link_1to1 as string | null,
        bookingCount: count ?? 0,
        bookings: (bookings ?? []).map((b) => ({ id: b.id, scheduled_at: b.scheduled_at as string, status: b.status as string, display_name: null })),
      });
    }
  }
}

const todayYmd = new Date().toISOString().slice(0, 10);

/** Misma regla que el botón “Reservar”: aún puede agendar en este curso. */
function studentCanBook1to1(course: Course1to1, ymd: string): boolean {
  const endDay = course.ends_at ? String(course.ends_at).slice(0, 10) : null;
  const ended = endDay ? endDay < ymd : false;
  const link = typeof course.calendly_link_1to1 === 'string' ? course.calendly_link_1to1.trim() : '';
  return !ended && course.bookingCount < 2 && link.length > 0;
}

/** Tiene cursos listados pero ya no puede reservar en ninguno (cuota agotada, curso terminado o sin Calendly aún). */
const showStudent1to1SettledBanner =
  !isAdminView && courses1to1.length > 0 && courses1to1.every((c) => !studentCanBook1to1(c, todayYmd));

function formatBookingDate(iso: string) {
  try {
    return new Date(iso).toLocaleString('es', { dateStyle: 'medium', timeStyle: 'short' });
  } catch {
    return iso;
  }
}

/** Valor para input datetime-local (hora local del navegador al editar). */
function toDatetimeLocalValue(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  const pad = (n: number) => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

---
<DashboardLayout role={isAdminView ? 'admin' : 'student'}>
  {courses1to1.some((c) => c.calendly_link_1to1) && !isAdminView && (
    <Fragment slot="head">
      <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    </Fragment>
  )}
  <section class="max-w-5xl space-y-6 xl:max-w-6xl">
    <nav class="text-sm text-muted">
      <a href="/dashboard" class="hover:text-white">Dashboard</a>
      <span class="mx-1">/</span>
      <span class="text-white">Sesiones 1:1</span>
    </nav>

    <header>
      <h1 class="text-2xl font-semibold tracking-tight text-white">Sesiones 1:1</h1>
      <p class="mt-1 text-sm text-muted">
        {isAdminView
          ? 'Cursos con Calendly configurado. Los alumnos en vivo pueden reservar hasta 2 sesiones por curso mientras esté activo.'
          : 'Tienes hasta 2 sesiones 1:1 por curso (en vivo). Reserva desde el enlace de Calendly antes de que termine el curso.'}
      </p>
    </header>

    {showStudent1to1SettledBanner && (
      <div
        class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white/90"
        role="status"
      >
        <p class="font-medium text-white">Por ahora no puedes reservar más sesiones 1:1</p>
        <p class="mt-1.5 text-muted">
          Ya usaste tu cuota, el curso terminó o aún no hay enlace de reserva activo. Abajo sigues viendo el detalle por curso y tu historial.
        </p>
        <p class="mt-2 text-muted">
          Si más adelante te inscribes a <span class="text-white/80">otro curso en vivo</span> con este beneficio, volverá a aparecer aquí tu nueva cuota (hasta 2 sesiones por curso).
        </p>
      </div>
    )}

    {courses1to1.length === 0 ? (
      <div class="rounded-xl border border-transparent bg-surface p-6">
        <p class="text-sm text-muted">
          {isAdminView
            ? 'No hay cursos con link de Calendly 1:1. Edita un curso y añade el enlace + fecha fin.'
            : 'No tienes inscripciones en cohort en vivo por ahora. Cuando te inscriban a un curso en vivo con sesiones 1:1, aparecerán aquí. Si crees que falta algo, escríbenos.'}
        </p>
        {isAdminView && (
          <p class="mt-3">
            <a href="/admin/courses" class="btn btn-primary">
              Ir a Cursos para editar
            </a>
          </p>
        )}
      </div>
    ) : (
      <ul class="space-y-4">
        {courses1to1.map((course) => {
          const today = new Date().toISOString().slice(0, 10);
          const ended = course.ends_at ? course.ends_at < today : false;
          const canBook = !ended && course.bookingCount < 2 && course.calendly_link_1to1;
          return (
            <li class="rounded-xl border border-transparent bg-surface p-5">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <h2 class="font-semibold text-white">{course.title}</h2>
                  {course.ends_at && (
                    <p class="mt-0.5 text-xs text-muted">
                      Curso hasta: {new Date(course.ends_at).toLocaleDateString('es', { dateStyle: 'long' })}
                      {ended && <span class="ml-1 text-amber-400">(finalizado)</span>}
                    </p>
                  )}
                  {!isAdminView && (
                    <p class="mt-1 text-sm text-white/80">
                      Sesiones usadas: <span class="font-medium text-lime">{course.bookingCount}/2</span>
                    </p>
                  )}
                </div>
                {canBook && !isAdminView && (
                  <button
                    type="button"
                    class="btn btn-primary shrink-0 calendly-open"
                    data-calendly-url={course.calendly_link_1to1!}
                    aria-label="Abrir Calendly para reservar sesión 1:1"
                  >
                    Reservar sesión 1:1
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </button>
                )}
                {!ended && !isAdminView && !course.calendly_link_1to1 && course.bookingCount < 2 && (
                  <p class="max-w-sm shrink-0 text-xs text-muted">
                    El enlace de reserva (Calendly) aún no está publicado para este curso. Vuelve más tarde o pregunta al equipo.
                  </p>
                )}
                {ended && !isAdminView && (
                  <p class="text-xs text-muted shrink-0">Ya no puedes agendar; el curso terminó.</p>
                )}
                {!ended && !isAdminView && course.bookingCount >= 2 && (
                  <div class="shrink-0 rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-left">
                    <p class="text-sm font-medium text-amber-200">Ya usaste tus 2 sesiones 1:1 para este curso.</p>
                    <p class="mt-1 text-xs text-muted">Si necesitas más ayuda, contáctanos directamente.</p>
                  </div>
                )}
              </div>
              {course.bookings.length > 0 && (
                <div class="mt-4 border-t border-white/10 pt-4">
                  <h3 class="text-xs font-medium text-muted">
                    {isAdminView ? 'Últimas reservas del curso' : 'Tus reservas'}
                  </h3>
                  <ul class="mt-2 space-y-1.5">
                    {course.bookings.map((b) => {
                      const deleteConfirmLabel = `${formatBookingDate(b.scheduled_at)}${b.display_name ? ` · ${b.display_name}` : ''}`;
                      return (
                      <li class="rounded-lg bg-background/60 px-3 py-2 text-sm" data-booking-row>
                        <div class="flex flex-wrap items-center gap-2" data-booking-view>
                          <div class="min-w-0 flex-1">
                            <span class="text-white">{formatBookingDate(b.scheduled_at)}</span>
                            {isAdminView && b.display_name && <span class="ml-2 text-muted">· {b.display_name}</span>}
                          </div>
                          <span
                            class={`shrink-0 rounded px-1.5 py-0.5 text-[10px] font-medium ${
                              b.status === 'scheduled' ? 'bg-lime/15 text-lime' : b.status === 'completed' ? 'bg-white/10 text-muted' : 'bg-red-500/15 text-red-400'
                            }`}
                          >
                            {b.status === 'scheduled' ? 'Programada' : b.status === 'completed' ? 'Realizada' : 'Cancelada'}
                          </span>
                          {isAdminView && (
                            <div class="flex shrink-0 items-center gap-1">
                              <button
                                type="button"
                                class="btn btn-ghost btn-icon h-8 w-8"
                                title="Editar"
                                aria-label="Editar reserva"
                                data-booking-edit-open
                              >
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                              </button>
                              <button
                                type="button"
                                class="btn btn-danger btn-icon h-8 w-8"
                                title="Eliminar"
                                aria-label="Eliminar reserva"
                                data-delete-confirm
                                data-confirm-label={deleteConfirmLabel}
                                data-delete-form-id={`booking-del-${b.id}`}
                              >
                                <i class="bi bi-trash" aria-hidden="true"></i>
                              </button>
                            </div>
                          )}
                        </div>
                        {isAdminView && (
                          <>
                            <form
                              id={`booking-del-${b.id}`}
                              method="post"
                              action="/api/admin/one-on-one-bookings"
                              class="hidden"
                              aria-hidden="true"
                            >
                              <input type="hidden" name="_action" value="delete" />
                              <input type="hidden" name="booking_id" value={b.id} />
                              <input type="hidden" name="course_id" value={course.id} />
                              <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
                            </form>
                            <form
                              method="post"
                              action="/api/admin/one-on-one-bookings"
                              class="hidden mt-3 flex flex-wrap items-end gap-3 border-t border-white/5 pt-3"
                              data-booking-edit
                            >
                              <input type="hidden" name="_action" value="update" />
                              <input type="hidden" name="booking_id" value={b.id} />
                              <input type="hidden" name="course_id" value={course.id} />
                              <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
                              <div>
                                <label for={`edit-date-${b.id}`} class="block text-[11px] text-muted">Fecha y hora</label>
                                <input
                                  id={`edit-date-${b.id}`}
                                  type="datetime-local"
                                  name="scheduled_at"
                                  required
                                  value={toDatetimeLocalValue(b.scheduled_at)}
                                  class="mt-0.5 min-w-[200px] rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                                />
                              </div>
                              <div>
                                <label for={`edit-status-${b.id}`} class="block text-[11px] text-muted">Estado</label>
                                <select
                                  id={`edit-status-${b.id}`}
                                  name="status"
                                  required
                                  class="mt-0.5 min-w-[140px] rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                                >
                                  <option value="scheduled" selected={b.status === 'scheduled'}>Programada</option>
                                  <option value="completed" selected={b.status === 'completed'}>Realizada</option>
                                  <option value="cancelled" selected={b.status === 'cancelled'}>Cancelada</option>
                                </select>
                              </div>
                              <button type="submit" class="btn btn-primary btn-icon h-9 w-9 shrink-0" title="Guardar" aria-label="Guardar cambios">
                                <i class="bi bi-check-lg" aria-hidden="true"></i>
                              </button>
                              <button
                                type="button"
                                class="btn btn-secondary btn-icon h-9 w-9 shrink-0"
                                title="Cancelar"
                                aria-label="Cancelar edición"
                                data-booking-edit-cancel
                              >
                                <i class="bi bi-x-lg" aria-hidden="true"></i>
                              </button>
                            </form>
                          </>
                        )}
                      </li>
                    );
                    })}
                  </ul>
                </div>
              )}
              {isAdminView && course.liveStudents && course.liveStudents.length > 0 && (
                <form method="post" action="/api/admin/one-on-one-bookings" class="mt-4 border-t border-white/10 pt-4">
                  <input type="hidden" name="course_id" value={course.id} />
                  <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
                  <h3 class="text-xs font-medium text-muted">Registrar reserva manual</h3>
                  <p class="mt-0.5 text-[11px] text-muted">Cuando un alumno reserve en Calendly, anótala aquí para que cuente en su cuota.</p>
                  <div class="mt-3 flex flex-wrap items-end gap-3">
                    <div>
                      <label for={`student-${course.id}`} class="block text-[11px] text-muted">Alumno</label>
                      <select
                        id={`student-${course.id}`}
                        name="user_id"
                        required
                        class="mt-0.5 min-w-[180px] rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                      >
                        <option value="">Elegir…</option>
                        {course.liveStudents.map((s) => (
                          <option value={s.id}>{s.display_name}</option>
                        ))}
                      </select>
                    </div>
                    <div>
                      <label for={`date-${course.id}`} class="block text-[11px] text-muted">Fecha y hora</label>
                      <div class="relative mt-0.5">
                        <input
                          id={`date-${course.id}`}
                          type="text"
                          name="scheduled_at"
                          required
                          readonly
                          autocomplete="off"
                          class="flatpickr-scheduled w-full cursor-pointer rounded-lg border border-transparent bg-surface-2 py-2 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                          placeholder="Elegir fecha y hora"
                        />
                        <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
                      </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                      Guardar reserva
                    </button>
                  </div>
                </form>
              )}
            </li>
          );
        })}
      </ul>
    )}

    {isAdminView && (
      <div class="mt-10 rounded-xl border border-transparent bg-surface p-5">
        <h2 class="text-lg font-semibold text-white">Sesión grupal (on-demand)</h2>
        <p class="mt-0.5 text-sm text-muted">
          Una vez al mes. Agrega aquí el link y la fecha de cada sesión; los alumnos on-demand verán el listado. Registra manualmente cuando asistan (máx. 2 por alumno).
        </p>

        <div class="mt-6">
          <h3 class="text-sm font-medium text-white">Sesiones programadas</h3>
          {sesionesGrupalesList.length > 0 ? (
            <ul class="mt-2 space-y-2">
              {sesionesGrupalesList.map((s) => {
                const sgDeleteLabel = (s.title ?? '').trim() || (s.fecha_label ?? '').trim() || 'Sesión grupal';
                return (
                <li class="rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm" data-sg-row>
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1" data-sg-view>
                    <span class="font-medium text-white">{s.title ?? 'Sesión grupal'}</span>
                    {s.fecha_label && <span class="text-muted">· {s.fecha_label}</span>}
                    <a href={s.link_url} target="_blank" rel="noopener noreferrer" class="text-lime hover:underline sm:ml-1">
                      Ver enlace
                    </a>
                    <div class="ml-auto flex shrink-0 items-center gap-1">
                      <button
                        type="button"
                        class="btn btn-ghost btn-icon h-8 w-8"
                        title="Editar"
                        aria-label="Editar sesión grupal"
                        data-sg-edit-open
                      >
                        <i class="bi bi-pencil" aria-hidden="true"></i>
                      </button>
                      <button
                        type="button"
                        class="btn btn-danger btn-icon h-8 w-8"
                        title="Eliminar"
                        aria-label="Eliminar sesión grupal"
                        data-delete-confirm
                        data-confirm-label={sgDeleteLabel}
                        data-delete-form-id={`sg-del-${s.id}`}
                      >
                        <i class="bi bi-trash" aria-hidden="true"></i>
                      </button>
                    </div>
                  </div>
                  <form
                    id={`sg-del-${s.id}`}
                    method="post"
                    action="/api/admin/sesion-grupal-sesiones"
                    class="hidden"
                    aria-hidden="true"
                  >
                    <input type="hidden" name="sg_action" value="delete" />
                    <input type="hidden" name="session_id" value={s.id} />
                    <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
                  </form>
                  <form
                    method="post"
                    action="/api/admin/sesion-grupal-sesiones"
                    class="mt-3 hidden flex flex-wrap items-end gap-3 border-t border-white/10 pt-3"
                    data-sg-edit
                  >
                    <input type="hidden" name="sg_action" value="update" />
                    <input type="hidden" name="session_id" value={s.id} />
                    <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
                    <div>
                      <label for={`sg-edit-title-${s.id}`} class="block text-[11px] text-muted">Título (opcional)</label>
                      <input
                        id={`sg-edit-title-${s.id}`}
                        type="text"
                        name="title"
                        value={s.title ?? ''}
                        class="mt-0.5 min-w-[160px] rounded-lg border border-transparent bg-background px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                      />
                    </div>
                    <div>
                      <label for={`sg-edit-link-${s.id}`} class="block text-[11px] text-muted">Enlace</label>
                      <input
                        id={`sg-edit-link-${s.id}`}
                        type="url"
                        name="link_url"
                        required
                        value={s.link_url}
                        class="mt-0.5 min-w-[200px] rounded-lg border border-transparent bg-background px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                      />
                    </div>
                    <div>
                      <label for={`sg-edit-fecha-${s.id}`} class="block text-[11px] text-muted">Fecha y hora (texto)</label>
                      <input
                        id={`sg-edit-fecha-${s.id}`}
                        type="text"
                        name="fecha_label"
                        value={s.fecha_label ?? ''}
                        class="mt-0.5 min-w-[200px] rounded-lg border border-transparent bg-background px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                      />
                    </div>
                    <button type="submit" class="btn btn-primary btn-icon h-9 w-9 shrink-0" title="Guardar" aria-label="Guardar cambios">
                      <i class="bi bi-check-lg" aria-hidden="true"></i>
                    </button>
                    <button
                      type="button"
                      class="btn btn-secondary btn-icon h-9 w-9 shrink-0"
                      title="Cancelar"
                      aria-label="Cancelar edición"
                      data-sg-edit-cancel
                    >
                      <i class="bi bi-x-lg" aria-hidden="true"></i>
                    </button>
                  </form>
                </li>
              );
              })}
            </ul>
          ) : (
            <p class="mt-2 text-sm text-muted">Aún no hay sesiones. Agrega la primera abajo.</p>
          )}
        </div>

        <form method="post" action="/api/admin/sesion-grupal-sesiones" class="mt-6 flex flex-wrap items-end gap-3 rounded-lg border border-transparent bg-surface-2 p-4">
          <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
          <div>
            <label for="sg-title" class="block text-[11px] text-muted">Título (opcional)</label>
            <input
              id="sg-title"
              type="text"
              name="title"
              placeholder="Ej. Webflow Camp - Marzo"
              class="mt-0.5 min-w-[180px] rounded-lg border border-transparent bg-background px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            />
          </div>
          <div>
            <label for="sg-link" class="block text-[11px] text-muted">Enlace de la sesión</label>
            <input
              id="sg-link"
              type="url"
              name="link_url"
              required
              placeholder="https://meet.google.com/..."
              class="mt-0.5 min-w-[220px] rounded-lg border border-transparent bg-background px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            />
          </div>
          <div>
            <label for="sg-fecha" class="block text-[11px] text-muted">Fecha y hora</label>
            <div class="relative mt-0.5">
              <input
                id="sg-fecha"
                type="text"
                name="fecha_label"
                required
                autocomplete="off"
                class="flatpickr-sg-sesion min-w-[240px] w-full rounded-lg border border-transparent bg-background py-2 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                placeholder="Calendario o escribe la fecha"
              />
              <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
            </div>
          </div>
          <button type="submit" class="btn btn-primary">Agregar sesión</button>
        </form>

        {onDemandStudents.length > 0 ? (
          <form method="post" action="/api/admin/sesion-grupal-asistencia" class="mt-6 flex flex-wrap items-end gap-3">
            <input type="hidden" name="redirect_to" value="/sesiones-1-1" />
            <h3 class="w-full text-sm font-medium text-white">Registrar asistencia</h3>
            <div>
              <label for="sesion-grupal-user" class="block text-[11px] text-muted">Alumno on-demand</label>
              <select
                id="sesion-grupal-user"
                name="user_id"
                required
                class="mt-0.5 min-w-[200px] rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              >
                <option value="">Elegir…</option>
                {onDemandStudents.map((s) => (
                  <option value={s.id}>
                    {s.display_name} ({s.asistenciasCount}/2)
                  </option>
                ))}
              </select>
            </div>
            <div>
              <label for="sesion-grupal-date" class="block text-[11px] text-muted">Fecha de la sesión</label>
              <div class="relative mt-0.5">
                <input
                  id="sesion-grupal-date"
                  type="text"
                  name="attended_at"
                  readonly
                  autocomplete="off"
                  class="flatpickr-sesion-grupal w-full cursor-pointer rounded-lg border border-transparent bg-surface-2 py-2 pl-3 pr-10 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                  placeholder="Opcional: elegir fecha"
                />
                <i class="bi bi-calendar3 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-muted" aria-hidden="true"></i>
              </div>
            </div>
            <button type="submit" class="btn btn-primary">
              Registrar asistencia
            </button>
          </form>
        ) : (
          <p class="mt-4 text-sm text-muted">No hay alumnos solo on-demand. Cuando asignes cursos on-demand, podrás registrar aquí su asistencia (máx. 2 por alumno).</p>
        )}
      </div>
    )}
  </section>

  {courses1to1.some((c) => c.calendly_link_1to1) && !isAdminView && (
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  )}
  {courses1to1.some((c) => c.calendly_link_1to1) && !isAdminView && (
    <script is:inline>
      (function () {
        function openCalendly(url) {
          if (typeof window.Calendly !== 'undefined') {
            window.Calendly.initPopupWidget({ url: url });
            return;
          }
          var s = document.createElement('script');
          s.src = 'https://assets.calendly.com/assets/external/widget.js';
          s.async = true;
          s.onload = function () {
            window.Calendly.initPopupWidget({ url: url });
          };
          document.head.appendChild(s);
        }
        document.querySelectorAll('.calendly-open').forEach(function (btn) {
          var url = btn.getAttribute('data-calendly-url');
          if (url) btn.addEventListener('click', function () { openCalendly(url); });
        });
      })();
    </script>
  )}
  {isAdminView && (
    <script>
      import flatpickr from 'flatpickr';
      import { Spanish } from 'flatpickr/dist/l10n/es.js';
      const pickerOptsBase = {
        enableTime: true,
        dateFormat: 'Y-m-d H:i',
        locale: Spanish,
        time_24hr: true,
      };
      const init = () => {
        document.querySelectorAll('.flatpickr-scheduled, .flatpickr-sesion-grupal, .flatpickr-sg-sesion').forEach((el) => {
          const input = el as HTMLInputElement;
          if (input.dataset.flatpickrInit) return;
          input.dataset.flatpickrInit = '1';
          const allowInput = input.classList.contains('flatpickr-sg-sesion');
          flatpickr(el, { ...pickerOptsBase, allowInput, appendTo: document.body });
        });
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        function wire(openSel, cancelSel, viewSel, editSel, rowSel) {
          document.querySelectorAll(openSel).forEach(function (btn) {
            btn.addEventListener('click', function () {
              var li = btn.closest(rowSel);
              if (!li) return;
              var v = li.querySelector(viewSel);
              var e = li.querySelector(editSel);
              if (v) v.classList.add('hidden');
              if (e) e.classList.remove('hidden');
            });
          });
          document.querySelectorAll(cancelSel).forEach(function (btn) {
            btn.addEventListener('click', function () {
              var li = btn.closest(rowSel);
              if (!li) return;
              var v = li.querySelector(viewSel);
              var e = li.querySelector(editSel);
              if (v) v.classList.remove('hidden');
              if (e) e.classList.add('hidden');
            });
          });
        }
        wire('[data-sg-edit-open]', '[data-sg-edit-cancel]', '[data-sg-view]', '[data-sg-edit]', '[data-sg-row]');
        wire('[data-booking-edit-open]', '[data-booking-edit-cancel]', '[data-booking-view]', '[data-booking-edit]', '[data-booking-row]');
      });
    </script>
  )}
</DashboardLayout>
