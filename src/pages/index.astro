---
import '../styles/global.css';
import { SignIn } from '@clerk/astro/components';

const auth = Astro.locals.auth?.();
if (auth?.isAuthenticated) {
  return Astro.redirect('/dashboard');
}

const signInAppearance = {
  variables: {
    colorPrimary: '#C6F135',
    colorBackground: '#141414',
    colorInputBackground: '#1A1A1A',
    colorInputText: '#FFFFFF',
    colorText: '#FFFFFF',
    colorTextSecondary: '#A3A3A3',
    colorNeutral: '#262626',
    borderRadius: '0.75rem',
  },
  elements: {
    rootBox: 'w-full',
    card: 'w-full max-w-full border border-border bg-surface shadow-none',
    formButtonPrimary: 'bg-lime text-background hover:bg-lime/90',
    footerActionLink: 'text-lime hover:text-lime/90',
    socialButtonsBlockButton: 'border-border bg-surface-2 text-white hover:bg-surface',
    formFieldInput: 'border-border bg-surface-2 text-white',
  },
} as const;
---

<html lang="es" class="h-full">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Superhuman School</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-background text-white antialiased">
    <main class="flex min-h-screen items-center justify-center px-4 py-6 sm:py-8">
      <div class="mx-auto flex w-full max-w-4xl flex-col gap-10 md:flex-row md:items-center">
        <section class="flex-1 space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-lime">
            Superhuman School
          </p>
          <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">
            Potencia tus superpoderes de diseño.
          </h1>
          <p class="max-w-md text-sm text-muted md:text-base">
            Únete a tu cohort privado, completa desafíos de Webflow y producto, gana insignias y
            sube en el ranking con tus compañeros.
          </p>
        </section>

        <section class="w-full flex-1 md:max-w-[430px]">
          <div id="login-card" class="relative rounded-2xl border border-border bg-surface p-6 shadow-xl shadow-black/40 backdrop-blur min-h-[320px]">
            <div id="login-loading" class="absolute inset-0 z-10 hidden flex-col items-center justify-center gap-3 rounded-2xl bg-surface text-white" aria-live="polite">
              <span class="inline-block h-6 w-6 animate-spin rounded-full border-2 border-lime border-t-transparent" aria-hidden="true" />
              <p class="text-sm font-medium text-muted">Cargando…</p>
            </div>
            <SignIn redirectUrl="/dashboard" appearance={signInAppearance} />
          </div>
        </section>
      </div>
    </main>
    <script>
      (function () {
        const loading = document.getElementById('login-loading');
        if (!loading) return;
        function showLoading() {
          loading.classList.remove('hidden');
          loading.classList.add('flex');
        }
        // Show loader only when the browser is actually navigating away.
        window.addEventListener('beforeunload', showLoading);
      })();
    </script>
    <style>
      /* Keep Clerk container responsive on small screens. */
      :global(.cl-rootBox),
      :global(.cl-signIn-root),
      :global(.cl-card),
      :global(.cl-main) {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
      }

      :global(.cl-card) {
        width: 100%;
      }
    </style>
  </body>
</html>
