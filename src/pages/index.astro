---
import '../styles/global.css';
import { SignIn } from '@clerk/astro/components';
import { dark } from '@clerk/ui/themes';

const auth = Astro.locals.auth?.();
if (auth?.isAuthenticated) {
  return Astro.redirect('/dashboard');
}
---

<html lang="es" class="h-full">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Superhuman School</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-background text-white antialiased">
    <main class="flex min-h-screen items-center justify-center px-4 py-6 sm:py-8">
      <div class="mx-auto flex w-full max-w-5xl flex-col gap-10 md:flex-row md:items-center md:gap-14">
        <section class="flex-1 space-y-5">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1 text-xs text-muted">
            <span class="h-6 w-6 rounded-full bg-gradient-to-tr from-yellow-400 via-lime to-cyan-400" />
            <span class="font-medium text-white">Ranking, badges y sesiones 1:1</span>
          </div>
          <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl">
            Potencia tus superpoderes de diseño.
          </h1>
          <p class="max-w-md text-sm text-muted md:text-base">
            Únete a tu cohort privado, completa desafíos de Webflow y producto, gana insignias y
            sube en el ranking con tus compañeros.
          </p>
        </section>

        <section class="w-full flex-1 md:max-w-[430px]">
          <div class="flex justify-center md:justify-end">
            <SignIn
              redirectUrl="/dashboard"
              appearance={{
                theme: dark,
              }}
            />
          </div>
        </section>
      </div>
    </main>
    <script>
      // No JS extra por ahora; dejamos solo el widget de Clerk.
    </script>
    <style>
      /* Solo hacemos que el contenedor de Clerk sea responsivo; el resto queda por defecto. */
      :global(.cl-rootBox),
      :global(.cl-signIn-root),
      :global(.cl-main) {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
      }

      /* Ocultar subtítulo por defecto "para continuar a..." */
      :global(.cl-headerSubtitle) {
        display: none;
      }
    </style>
  </body>
</html>
