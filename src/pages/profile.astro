---
import '../styles/global.css';
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { SignOutButton } from '@clerk/astro/components';
import { getSupabaseServiceRoleClient } from '../lib/supabase';
import { avatarImagePath } from '../lib/avatars';
import { TIMEZONE_OPTIONS } from '../lib/timezones';

const { isAuthenticated, userId, redirectToSignIn, sessionClaims } = Astro.locals.auth();
if (!isAuthenticated || !userId) {
  return redirectToSignIn();
}

// Datos de inscripción (Clerk + Supabase): email y nombre con el que se registraron
let email = '';
let signupFirstName = '';
let signupLastName = '';
let signupFullName = '';
const supabase = getSupabaseServiceRoleClient();
const { data: userRow } = await supabase
  .from('users')
  .select('display_name, avatar_id, created_at, role, email')
  .eq('id', userId)
  .maybeSingle();

// Nombre/email de inscripción desde Clerk (currentUser o sessionClaims)
try {
  const currentUser = await (Astro.locals as any).currentUser?.();
  if (currentUser) {
    if (currentUser.emailAddresses?.[0]?.emailAddress) email = String(currentUser.emailAddresses[0].emailAddress);
    signupFirstName = String(currentUser.firstName ?? '');
    signupLastName = String(currentUser.lastName ?? '');
    signupFullName = String(currentUser.fullName ?? ([currentUser.firstName, currentUser.lastName].filter(Boolean).join(' ') || ''));
  }
} catch {
  // ignore
}
if (!email || (!signupFullName && !signupFirstName)) {
  const claims = sessionClaims as Record<string, unknown> | undefined;
  if (!email) {
    email = (claims?.primary_email ?? claims?.email ?? claims?.email_address ?? '') as string;
    if (!email && Array.isArray((claims as any)?.email_addresses)?.[0]) {
      email = String((claims as any).email_addresses[0].email_address ?? '');
    }
  }
  if (!signupFirstName && (claims as any)?.first_name) signupFirstName = String((claims as any).first_name);
  if (!signupLastName && (claims as any)?.last_name) signupLastName = String((claims as any).last_name);
  if (!signupFullName && (claims as any)?.name) signupFullName = String((claims as any).name);
  if (!signupFullName && (signupFirstName || signupLastName)) {
    signupFullName = [signupFirstName, signupLastName].filter(Boolean).join(' ').trim();
  }
}

// Optional profile fields (run docs/supabase-profile-fields.sql, supabase-profile-social.sql, supabase-timezone-migration.sql if missing)
let description = '';
let selfDeclaredRole = '';
let showInDirectory = false;
let timezone = 'America/Lima';
let linkedinUrl = '';
let instagramUrl = '';
let portfolioUrl = '';
let profilePhotoUrl = '';
let birthday = '';
const { data: profileRow, error: _profileErr } = await supabase
  .from('users')
  .select('description, self_declared_role, show_in_directory, timezone, linkedin_url, instagram_url, portfolio_url, profile_photo_url, birthday')
  .eq('id', userId)
  .maybeSingle();
if (!_profileErr && profileRow) {
  description = (profileRow as any)?.description ?? '';
  selfDeclaredRole = (profileRow as any)?.self_declared_role ?? '';
  showInDirectory = Boolean((profileRow as any)?.show_in_directory);
  const tz = (profileRow as any)?.timezone;
  timezone = typeof tz === 'string' && tz.trim() ? tz : 'America/Lima';
  linkedinUrl = (profileRow as any)?.linkedin_url ?? '';
  instagramUrl = (profileRow as any)?.instagram_url ?? '';
  portfolioUrl = (profileRow as any)?.portfolio_url ?? '';
  profilePhotoUrl = (profileRow as any)?.profile_photo_url ?? '';
  const bd = (profileRow as any)?.birthday;
  birthday = typeof bd === 'string' && bd ? bd.slice(0, 10) : '';
}

if (userRow?.email) email = String(userRow.email);

const displayName = userRow?.display_name ?? 'Estudiante';
const avatarId = userRow?.avatar_id ?? 'avatar-01';
const avatarSrc = profilePhotoUrl?.trim() || avatarImagePath(avatarId) || '/avatars/avatar-01.png';
let points = 0;
const { data: pointsRows } = await supabase.from('user_course_points').select('points').eq('user_id', userId);
points = (pointsRows ?? []).reduce((a, r) => a + (r.points ?? 0), 0);
const createdAt = userRow?.created_at ?? null;
const role = userRow?.role ?? 'student';

const memberSinceFormatted = createdAt
  ? (() => {
      const d = new Date(createdAt);
      const month = d.toLocaleDateString('es-ES', { month: 'long' });
      const year = d.getFullYear();
      return `${month.charAt(0).toUpperCase() + month.slice(1)} ${year}`;
    })()
  : '—';

const roleLabel = role === 'admin' ? 'Admin' : 'Estudiante';

// Enrolled courses (enrollments + courses) — safe if table/relation missing
let courseTitles: string[] = [];
try {
  const { data: enrollments } = await supabase
    .from('enrollments')
    .select('course_id, courses(title)')
    .eq('user_id', userId);
  courseTitles = (enrollments ?? [])
    .map((e: { courses?: { title?: string } | null }) => e?.courses?.title)
    .filter(Boolean) as string[];
} catch {
  // enrollments or courses relation may not exist yet
}

// Earned badges (user_badges + badges) — safe if table/relation missing
let earnedBadges: { name: string; image_url: string | null }[] = [];
try {
  const { data: userBadges } = await supabase
    .from('user_badges')
    .select('badge_id, badges(name, image_url)')
    .eq('user_id', userId);
  earnedBadges = (userBadges ?? [])
    .map((ub: { badges?: { name?: string; image_url?: string | null } | null }) => ub?.badges)
    .filter((b): b is { name: string; image_url: string | null } => Boolean(b?.name)) as { name: string; image_url: string | null }[];
} catch {
  // user_badges or badges relation may not exist yet
}

// Cumpleaños: día + mes (año opcional). Año 4 = sentinel para "sin año".
const birthdayLabel = birthday ? (() => {
  try {
    const d = new Date(birthday + 'T12:00:00');
    const year = d.getFullYear();
    if (year === 4) {
      return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'long' });
    }
    return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch {
    return birthday;
  }
})() : '—';

const MONTH_NAMES = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const MONTH_OPTIONS = MONTH_NAMES.map((name, i) => ({ value: String(i + 1), label: name }));

// Parsear birthday para pre-seleccionar mes y día
let birthdayMonth = '';
let birthdayDay = '';
if (birthday) {
  const m = parseInt(birthday.slice(5, 7), 10);
  const d = parseInt(birthday.slice(8, 10), 10);
  if (m >= 1 && m <= 12) birthdayMonth = String(m);
  if (d >= 1 && d <= 31) birthdayDay = String(d);
}

const avatarCount = 25;
const avatarOptions = Array.from({ length: avatarCount }, (_, i) => {
  const num = String(i + 1).padStart(2, '0');
  return { id: `avatar-${num}`, src: `/avatars/avatar-${num}.png` };
});
---

<DashboardLayout>
  <section class="mx-auto max-w-2xl space-y-5 sm:space-y-4">
    <nav aria-label="Navegación" class="mb-4">
      <ol class="flex items-center gap-1.5 text-sm text-muted">
        <li>
          <a href="/dashboard" class="transition hover:text-lime">Dashboard</a>
        </li>
        <li aria-hidden="true" class="text-muted/60">/</li>
        <li class="font-medium text-white" aria-current="page">Perfil</li>
      </ol>
    </nav>
    <header class="mb-6 sm:mb-6">
      <h1 class="text-2xl font-semibold tracking-tight text-white sm:text-2xl">Tu cuenta</h1>
    </header>

    <!-- Top card: avatar + info -->
    <div class="rounded-xl border border-transparent bg-surface p-5 sm:p-6">
      <div class="flex flex-col gap-6 sm:flex-row sm:gap-6">
        <div class="flex flex-col items-center sm:items-start sm:shrink-0">
          <div class="h-24 w-24 overflow-hidden rounded-full border border-transparent bg-surface-2 ring-2 ring-lime/30 sm:h-20 sm:w-20">
            <img src={avatarSrc} alt="" class="h-full w-full object-cover" width="96" height="96" />
          </div>
          <button
            type="button"
            id="toggle-avatar-modal"
            aria-haspopup="dialog"
            aria-controls="avatar-modal"
            class="btn btn-secondary mt-3 w-full sm:mt-2 sm:w-auto"
          >
            Cambiar avatar
          </button>
        </div>
        <div class="min-w-0 flex-1 space-y-3">
          <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-2">
            <p id="display-name-text" class="text-xl font-semibold text-white">{displayName}</p>
            <div class="flex flex-wrap items-center gap-2">
              <button
                type="button"
                id="display-name-edit-btn"
                class="btn btn-ghost px-3 py-2 sm:px-2.5 sm:py-1"
              >
                Editar
              </button>
              <span class="rounded-full bg-lime/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-lime">
                {roleLabel}
              </span>
            </div>
          </div>
          <div id="display-name-form-wrap" class="hidden">
            <form method="post" action="/api/onboarding" class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-2">
              <input type="hidden" name="intent" value="display_name" />
              <input type="hidden" name="redirect_to" value="/profile" />
              <input
                type="text"
                id="profile-display-name"
                name="display_name"
                value={displayName}
                required
                class="w-full rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-base text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime sm:min-w-[180px] sm:py-1.5"
                placeholder="Nombre para mostrar"
              />
              <div class="flex gap-2">
                <button type="submit" class="btn btn-primary flex-1 sm:flex-none sm:px-3 sm:py-1.5">
                  Guardar
                </button>
                <button type="button" id="display-name-cancel-btn" class="btn btn-ghost flex-1 sm:flex-none sm:px-3 sm:py-1.5">
                  Cancelar
                </button>
              </div>
            </form>
          </div>
          <p class="truncate text-sm text-muted">{email || '—'}</p>
          <div class="flex flex-col gap-2 text-sm text-muted sm:flex-row sm:flex-wrap sm:gap-x-4 sm:gap-y-0.5">
            <span><span class="font-semibold uppercase tracking-wider text-muted/80">Puntos</span> <span class="font-medium text-lime">{points}</span></span>
            <span><span class="font-semibold uppercase tracking-wider text-muted/80">Miembro desde</span> <span class="font-medium text-white">{memberSinceFormatted}</span></span>
            <span><span class="font-semibold uppercase tracking-wider text-muted/80">Rol</span> <span class="font-medium text-white">{roleLabel}</span></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Datos de inscripción + Información en dos columnas -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="rounded-xl border border-transparent bg-surface p-5 sm:p-4">
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-muted">Datos de inscripción</h2>
        <dl class="space-y-3 text-sm">
          <div class="flex flex-col gap-0.5">
            <dt class="font-semibold uppercase tracking-wider text-muted/80">Correo</dt>
            <dd class="truncate text-white">{email || '—'}</dd>
          </div>
          <div class="flex flex-col gap-0.5">
            <dt class="font-semibold uppercase tracking-wider text-muted/80">Nombre completo</dt>
            <dd class="text-white">{signupFullName || [signupFirstName, signupLastName].filter(Boolean).join(' ').trim() || '—'}</dd>
          </div>
          <div class="flex flex-col gap-0.5">
            <dt class="font-semibold uppercase tracking-wider text-muted/80">Fecha de registro</dt>
            <dd class="text-white">{memberSinceFormatted}</dd>
          </div>
        </dl>
      </div>
      <div class="rounded-xl border border-transparent bg-surface p-5 sm:p-4">
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-muted">Información</h2>
        <dl class="space-y-3 text-sm">
          <div class="flex flex-col gap-0.5">
            <dt class="font-semibold uppercase tracking-wider text-muted/80">Cumpleaños</dt>
            <dd class="text-white">{birthdayLabel}</dd>
          </div>
          <div class="flex flex-col gap-0.5">
            <dt class="font-semibold uppercase tracking-wider text-muted/80">Cursos inscritos</dt>
            <dd class="text-white">
              {courseTitles.length > 0 ? courseTitles.join(', ') : 'Ninguno aún'}
            </dd>
          </div>
          <div class="flex flex-col gap-0.5">
            <dt class="font-semibold uppercase tracking-wider text-muted/80">Insignias</dt>
            <dd class="flex flex-wrap items-center gap-2">
              {earnedBadges.length > 0 ? (
                <>
                  <span class="text-white">{earnedBadges.length} ganada{earnedBadges.length !== 1 ? 's' : ''}</span>
                  <span class="flex flex-wrap gap-1.5">
                    {earnedBadges.map((b) => (
                      <span class="rounded-full bg-lime/10 px-2.5 py-1 text-xs font-medium text-lime" key={b.name}>{b.name}</span>
                    ))}
                  </span>
                </>
              ) : (
                <span class="text-muted">Aún no has ganado insignias</span>
              )}
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Visibilidad en directorio: rol, descripción, aparecer en directorio -->
    <div class="rounded-xl border border-transparent bg-surface p-5 sm:p-4">
      <h2 class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-muted">Visibilidad en el directorio</h2>
      <p class="mb-4 text-sm text-muted">Estos datos pueden mostrarse en el directorio de estudiantes si lo activas.</p>
      <form method="post" action="/api/onboarding" class="space-y-5">
        <input type="hidden" name="intent" value="profile" />
        <input type="hidden" name="redirect_to" value="/profile" />
        <div class="flex flex-col gap-2">
          <label class="text-sm font-medium text-muted">Cumpleaños (día y mes)</label>
          <input type="hidden" id="profile-birthday" name="birthday" value={birthday} />
          <div class="flex gap-3">
            <div class="custom-select custom-select--single relative flex-1" data-name="birthday_month">
              <input type="hidden" data-birthday-part="month" value={birthdayMonth} />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-left text-base text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
              >
                <span class="custom-select-label truncate">{birthdayMonth ? MONTH_OPTIONS.find((o) => o.value === birthdayMonth)?.label ?? 'Mes' : 'Mes'}</span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
                {MONTH_OPTIONS.map((opt, idx) => (
                  <button
                    type="button"
                    class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${idx > 0 ? 'mt-1' : ''} ${opt.value === birthdayMonth ? 'bg-lime/10 text-lime' : 'text-white'}`}
                    data-value={opt.value}
                    data-label={opt.label}
                  >
                    <span class={`flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border transition ${opt.value === birthdayMonth ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">{opt.label}</span>
                  </button>
                ))}
              </div>
            </div>
            <div class="custom-select custom-select--single relative flex-1" data-name="birthday_day">
              <input type="hidden" data-birthday-part="day" value={birthdayDay} />
              <button
                type="button"
                class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-left text-base text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
                aria-expanded="false"
              >
                <span class="custom-select-label truncate">{birthdayDay || 'Día'}</span>
                <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
                </svg>
              </button>
              <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
                {Array.from({ length: 31 }, (_, i) => {
                  const d = String(i + 1);
                  const isSelected = d === birthdayDay;
                  return (
                    <button
                      type="button"
                      class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${i > 0 ? 'mt-1' : ''} ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                      data-value={d}
                      data-label={d}
                    >
                      <span class={`flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                        <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                      </span>
                      <span class="truncate">{d}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <label for="profile-timezone" class="text-sm font-medium text-muted">Zona horaria / país</label>
          <div class="custom-select custom-select--single relative" data-name="timezone">
            <input id="profile-timezone" type="hidden" name="timezone" value={timezone} />
            <button
              type="button"
              class="custom-select-trigger flex w-full cursor-pointer items-center justify-between rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-left text-base text-white transition hover:border-lime/50 focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              aria-expanded="false"
            >
              <span class="custom-select-label truncate">{TIMEZONE_OPTIONS.find(([, tz]) => tz === timezone)?.[0] ?? 'Perú (Lima)'}</span>
              <svg class="h-4 w-4 shrink-0 text-muted transition" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 8l4 4 4-4" />
              </svg>
            </button>
            <div class="custom-select-panel absolute left-0 right-0 z-40 mt-2 hidden max-h-64 overflow-y-auto rounded-xl border border-transparent bg-surface p-2 shadow-2xl" role="listbox">
              {TIMEZONE_OPTIONS.map(([label, tz], idx) => {
                const isSelected = tz === timezone;
                return (
                  <button
                    type="button"
                    class={`custom-select-option flex w-full cursor-pointer items-center gap-2 rounded-md px-2.5 py-2 text-left text-sm transition hover:bg-surface-2 ${idx > 0 ? 'mt-1' : ''} ${isSelected ? 'bg-lime/10 text-lime' : 'text-white'}`}
                    data-value={tz}
                    data-label={label}
                  >
                    <span class={`flex h-4 w-4 shrink-0 items-center justify-center rounded-[4px] border transition ${isSelected ? 'border-lime bg-lime text-background' : 'border-transparent bg-surface-2 text-transparent'}`}>
                      <i class="bi bi-check2 text-[12px] leading-none" aria-hidden="true" />
                    </span>
                    <span class="truncate">{label}</span>
                  </button>
                );
              })}
            </div>
          </div>
          <p class="text-xs text-muted">Las horas de las clases se mostrarán en tu zona local.</p>
        </div>
        <div class="flex flex-col gap-2">
          <label for="profile-role" class="text-sm font-medium text-muted">Tu rol</label>
          <input
            type="text"
            id="profile-role"
            name="self_declared_role"
            value={selfDeclaredRole}
            class="rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-base text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
            placeholder="Ej. Diseñador UX, Frontend Developer"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label for="profile-description" class="text-sm font-medium text-muted">Descripción</label>
          <textarea
            id="profile-description"
            name="description"
            rows={3}
            class="rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-base text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime resize-y min-h-[72px]"
            placeholder="Una frase sobre ti o qué te trae al curso."
          >{description}</textarea>
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-sm font-medium text-muted">Foto de perfil</label>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:gap-4">
            <form id="profile-photo-form" method="post" action="/api/profile/photo" enctype="multipart/form-data" class="flex flex-1 flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
              <input type="hidden" name="redirect_to" value="/profile" />
              <input
                type="file"
                id="profile-photo-file"
                name="photo"
                accept="image/jpeg,image/png,image/webp"
                class="block w-full text-sm text-muted file:mr-3 file:rounded-lg file:border-0 file:bg-lime/20 file:px-4 file:py-2 file:text-sm file:font-medium file:text-lime hover:file:bg-lime/30"
              />
              <button type="submit" class="btn btn-secondary shrink-0">
                Subir foto
              </button>
            </form>
          </div>
          <p id="profile-photo-size-warning" class="hidden text-xs font-medium text-amber-400">
            La foto pesa demasiado (máx. 500KB). Comprímela o elige otra.
          </p>
          <p class="text-xs text-muted">JPEG, PNG o WebP. Máx. 500KB para no consumir mucho ancho de banda.</p>
          <div class="flex flex-col gap-2 pt-3">
            <label for="profile-photo-url" class="text-xs font-medium text-muted">O pega un enlace</label>
            <input
              type="url"
              id="profile-photo-url"
              name="profile_photo_url"
              value={profilePhotoUrl}
              class="rounded-lg border border-transparent bg-surface-2 px-3 py-2 text-sm text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="https://..."
            />
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4 pt-4 sm:grid-cols-3 sm:gap-6">
          <div class="flex flex-col gap-2">
            <label for="profile-linkedin" class="text-sm font-medium text-muted">LinkedIn</label>
            <input
              type="url"
              id="profile-linkedin"
              name="linkedin_url"
              value={linkedinUrl}
              class="rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-base text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="https://linkedin.com/in/..."
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="profile-instagram" class="text-sm font-medium text-muted">Instagram</label>
            <input
              type="url"
              id="profile-instagram"
              name="instagram_url"
              value={instagramUrl}
              class="rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-base text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="https://instagram.com/..."
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="profile-portfolio" class="text-sm font-medium text-muted">Portafolio</label>
            <input
              type="url"
              id="profile-portfolio"
              name="portfolio_url"
              value={portfolioUrl}
              class="rounded-lg border border-transparent bg-surface-2 px-3 py-2.5 text-base text-white placeholder:text-muted focus:border-lime focus:outline-none focus:ring-1 focus:ring-lime"
              placeholder="https://..."
            />
          </div>
        </div>
        <div class="flex flex-col gap-3 rounded-lg border border-transparent bg-surface-2/50 px-5 py-4 mt-5 sm:flex-row sm:items-center sm:justify-between sm:gap-6 sm:px-5 sm:py-4">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-white">Aparecer en el directorio</p>
            <p class="mt-1 text-sm text-muted">Tu perfil será visible para otros estudiantes en el directorio.</p>
          </div>
          <label class="relative inline-flex cursor-pointer items-center shrink-0 self-start sm:self-center">
            <input
              type="checkbox"
              name="show_in_directory"
              value="on"
              class="peer sr-only"
              checked={showInDirectory}
            />
            <span class="relative h-6 w-11 rounded-full border border-transparent bg-surface-2 transition-colors peer-checked:border-lime peer-checked:bg-lime after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:border after:border-transparent after:bg-white after:transition-transform after:content-[''] peer-checked:after:translate-x-5 peer-checked:after:border-lime" />
          </label>
        </div>
        <div class="flex justify-end pt-5">
          <button type="submit" class="btn btn-primary w-full sm:w-auto sm:py-2.5">
            Guardar cambios
          </button>
        </div>
      </form>
    </div>

    <!-- Cerrar sesión -->
    <div class="pt-2">
      <SignOutButton
        redirectUrl="/"
        class="btn btn-ghost"
      >
        Cerrar sesión
      </SignOutButton>
    </div>

    <!-- Modal: elegir avatar -->
    <div
      id="avatar-modal"
      class="fixed inset-0 z-50 flex hidden items-center justify-center p-4 bg-black/60 sm:p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="avatar-modal-title"
    >
      <div
        id="avatar-modal-backdrop"
        class="absolute inset-0"
        tabindex="-1"
      />
      <div
        class="relative w-full max-w-lg max-h-[85vh] flex flex-col rounded-xl border border-transparent bg-surface shadow-xl"
        id="avatar-modal-panel"
      >
        <div class="flex shrink-0 items-center justify-between border-b border-transparent px-5 py-4 sm:px-4 sm:py-3">
          <h2 id="avatar-modal-title" class="text-sm font-semibold text-white">Elegir avatar</h2>
          <button
            type="button"
            id="avatar-modal-close"
            class="rounded-lg p-1.5 text-muted transition hover:bg-surface-2 hover:text-white"
            aria-label="Cerrar"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <form method="post" action="/api/onboarding" class="flex min-h-0 flex-1 flex-col overflow-hidden">
          <input type="hidden" name="intent" value="avatar" />
          <input type="hidden" name="redirect_to" value="/profile" />
          <div class="overflow-y-auto p-5 sm:p-4">
            <div class="grid grid-cols-5 gap-3 sm:grid-cols-6 sm:gap-2">
              {avatarOptions.map((avatar) => {
                const isSelected = avatar.id === avatarId;
                return (
                  <button
                    type="submit"
                    name="avatar_id"
                    value={avatar.id}
                    class={[
                      'flex aspect-square flex-col items-center justify-center rounded-lg border transition',
                      isSelected
                        ? 'border-lime bg-lime/10 shadow-[0_0_0_1px_var(--color-lime)]'
                        : 'border-transparent bg-surface-2 hover:border-lime/50',
                    ]
                      .filter(Boolean)
                      .join(' ')}
                  >
                    <div class="flex h-10 w-10 shrink-0 overflow-hidden rounded-full bg-surface ring-1 ring-border">
                      <img src={avatar.src} alt="Avatar" class="h-full w-full object-cover" width="40" height="40" />
                    </div>
                    {isSelected && <span class="mt-1 text-xs font-semibold text-lime">Actual</span>}
                  </button>
                );
              })}
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const birthdayInput = document.getElementById('profile-birthday') as HTMLInputElement | null;
      const monthSelect = document.querySelector('.custom-select[data-name="birthday_month"]');
      const daySelect = document.querySelector('.custom-select[data-name="birthday_day"]');
      const maxDayForMonth = (month: number) => {
        if ([4, 6, 9, 11].includes(month)) return 30;
        if (month === 2) return 29; // año 4 es bisiesto
        return 31;
      };
      const syncBirthday = () => {
        if (!birthdayInput || !monthSelect || !daySelect) return;
        const monthHidden = monthSelect.querySelector('input[type="hidden"]') as HTMLInputElement | null;
        const dayHidden = daySelect.querySelector('input[type="hidden"]') as HTMLInputElement | null;
        const m = monthHidden?.value?.trim();
        const d = dayHidden?.value?.trim();
        if (m && d) {
          const monthNum = parseInt(m, 10);
          let dayNum = parseInt(d, 10);
          dayNum = Math.min(dayNum, maxDayForMonth(monthNum));
          dayNum = Math.max(1, dayNum);
          const mm = String(monthNum).padStart(2, '0');
          const dd = String(dayNum).padStart(2, '0');
          birthdayInput.value = `0004-${mm}-${dd}`;
        } else {
          birthdayInput.value = '';
        }
      };
      monthSelect?.addEventListener('custom-select-change', syncBirthday);
      daySelect?.addEventListener('custom-select-change', syncBirthday);
      syncBirthday();
      const avatarBtn = document.getElementById('toggle-avatar-modal');
      const avatarModal = document.getElementById('avatar-modal');
      const avatarBackdrop = document.getElementById('avatar-modal-backdrop');
      const avatarClose = document.getElementById('avatar-modal-close');
      function openAvatarModal() {
        if (avatarModal) {
          avatarModal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      }
      function closeAvatarModal() {
        if (avatarModal) {
          avatarModal.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }
      if (avatarBtn) avatarBtn.addEventListener('click', openAvatarModal);
      if (avatarBackdrop) avatarBackdrop.addEventListener('click', closeAvatarModal);
      if (avatarClose) avatarClose.addEventListener('click', closeAvatarModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && avatarModal && !avatarModal.classList.contains('hidden')) {
          closeAvatarModal();
        }
      });

      const editBtn = document.getElementById('display-name-edit-btn');
      const formWrap = document.getElementById('display-name-form-wrap');
      const nameText = document.getElementById('display-name-text');
      const cancelBtn = document.getElementById('display-name-cancel-btn');
      if (editBtn && formWrap && nameText && cancelBtn) {
        editBtn.addEventListener('click', () => {
          nameText.classList.add('hidden');
          editBtn.classList.add('hidden');
          formWrap.classList.remove('hidden');
          formWrap.querySelector('input')?.focus();
        });
        cancelBtn.addEventListener('click', () => {
          formWrap.classList.add('hidden');
          nameText.classList.remove('hidden');
          editBtn.classList.remove('hidden');
        });
      }

      const photoForm = document.getElementById('profile-photo-form');
      const photoFile = document.getElementById('profile-photo-file');
      const photoWarning = document.getElementById('profile-photo-size-warning');
      const MAX_PHOTO_BYTES = 500 * 1024;
      function checkPhotoSize() {
        if (!photoFile || !photoWarning) return;
        const file = (photoFile as HTMLInputElement).files?.[0];
        if (!file) {
          photoWarning.classList.add('hidden');
          return;
        }
        if (file.size > MAX_PHOTO_BYTES) {
          photoWarning.classList.remove('hidden');
        } else {
          photoWarning.classList.add('hidden');
        }
      }
      photoFile?.addEventListener('change', checkPhotoSize);
      photoForm?.addEventListener('submit', (e) => {
        const file = (photoFile as HTMLInputElement)?.files?.[0];
        if (file && file.size > MAX_PHOTO_BYTES) {
          e.preventDefault();
          photoWarning?.classList.remove('hidden');
        }
      });
    });
  </script>
</DashboardLayout>
